---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getToolIcon } from '../data/icons';

const posts = (await getCollection('blog', ({ data }) => {
  return !data.draft && data.lang === 'en';
})).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);

const tools = [
  {
    href: '/tools/json-formatter',
    slug: 'json-formatter',
    name: 'JSON Formatter',
    description: 'Prettify, minify, and validate JSON instantly in your browser.',
  },
  {
    href: '/tools/base64',
    slug: 'base64',
    name: 'Base64 Encode / Decode',
    description: 'Encode text to Base64 or decode Base64 back to plain text.',
  },
  {
    href: '/tools/uuid-generator',
    slug: 'uuid-generator',
    name: 'UUID Generator',
    description: 'Generate v4 UUIDs instantly — single or batch.',
  },
  {
    href: '/tools/url-encode',
    slug: 'url-encode',
    name: 'URL Encode / Decode',
    description: 'Encode or decode URL components and query strings.',
  },
  {
    href: '/tools/text-case',
    slug: 'text-case',
    name: 'Text Case Converter',
    description: 'Convert text to UPPER, lower, Title, camelCase, snake_case, and more.',
  },
  {
    href: '/tools/markdown-preview',
    slug: 'markdown-preview',
    name: 'Markdown Preview',
    description: 'Live Markdown editor with real-time HTML preview. Supports GFM tables, task lists, and code blocks.',
  },
  {
    href: '/tools/color-converter',
    slug: 'color-converter',
    name: 'Color Converter',
    description: 'Convert colors between HEX, RGB, and HSL formats with a live color preview.',
  },
  {
    href: '/tools/regex-tester',
    slug: 'regex-tester',
    name: 'Regex Tester',
    description: 'Test regular expressions in real time with match highlighting and capture group details.',
  },
  {
    href: '/tools/hash-generator',
    slug: 'hash-generator',
    name: 'Hash Generator',
    description: 'Generate MD5, SHA-1, SHA-256, SHA-384, and SHA-512 hashes from any text.',
  },
  {
    href: '/tools/timestamp-converter',
    slug: 'timestamp-converter',
    name: 'Timestamp Converter',
    description: 'Convert Unix timestamps to human-readable dates and vice versa. Auto-detects seconds vs milliseconds.',
  },
  {
    href: '/tools/jwt-decoder',
    slug: 'jwt-decoder',
    name: 'JWT Decoder',
    description: 'Decode and inspect JWT header, payload, and signature. Highlights expiry status and timestamp claims.',
  },
  {
    href: '/tools/diff-checker',
    slug: 'diff-checker',
    name: 'Diff Checker',
    description: 'Compare two texts line by line and highlight additions and deletions. Powered by LCS algorithm.',
  },
  {
    href: '/tools/password-generator',
    slug: 'password-generator',
    name: 'Password Generator',
    description: 'Generate cryptographically secure passwords. Customize length and character sets with entropy meter.',
  },
  {
    href: '/tools/qr-code-generator',
    slug: 'qr-code-generator',
    name: 'QR Code Generator',
    description: 'Generate QR codes from URLs, text, Wi-Fi credentials, and more. Download as PNG.',
  },
  {
    href: '/tools/cron-parser',
    slug: 'cron-parser',
    name: 'Cron Expression Parser',
    description: 'Parse and explain cron expressions in plain English. Preview next 10 scheduled run times.',
  },
  {
    href: '/tools/lorem-ipsum',
    slug: 'lorem-ipsum',
    name: 'Lorem Ipsum Generator',
    description: 'Generate Lorem Ipsum placeholder text instantly. Choose paragraph count and copy to clipboard.',
  },
  {
    href: '/tools/word-counter',
    slug: 'word-counter',
    name: 'Word & Character Counter',
    description: 'Count words, characters, sentences, and paragraphs. Estimate reading and speaking time.',
  },
  {
    href: '/tools/chmod-calculator',
    slug: 'chmod-calculator',
    name: 'Chmod Calculator',
    description: 'Calculate Linux file permissions interactively. Convert between numeric and symbolic notation.',
  },
  {
    href: '/tools/csv-json',
    slug: 'csv-json',
    name: 'CSV to JSON Converter',
    description: 'Convert CSV to JSON and JSON to CSV instantly. Handles quoted fields, auto-detects headers.',
  },
  {
    href: '/tools/html-entity',
    slug: 'html-entity',
    name: 'HTML Entity Encoder / Decoder',
    description: 'Encode and decode HTML entities. Supports named, decimal, and hex entities.',
  },
];
---

<BaseLayout
  title="ZeroTool — Free Online Developer Tools"
  description="Free, fast, browser-based developer tools. JSON formatter, Base64, UUID generator, URL encoder, text case converter. No sign-up required."
  lang="en"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'ZeroTool',
      url: 'https://zerotool.dev',
      description: 'Free, fast, browser-based developer tools. No sign-up required.',
    })} />
  </Fragment>
  <div class="home">
    <section class="hero">
      <h1>Free Online Developer Tools</h1>
      <p class="hero-sub">
        Fast, private, browser-based. No sign-up required. Works offline.
      </p>
    </section>

    <section class="tools-grid">
      {tools.map(tool => (
        <a href={tool.href} class="tool-card">
          <span class="tool-icon" set:html={getToolIcon(tool.slug)} />
          <div class="tool-info">
            <h2>{tool.name}</h2>
            <p>{tool.description}</p>
          </div>
        </a>
      ))}
    </section>

    <section class="why-section">
      <h2>Why ZeroTool?</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3>Privacy First</h3>
          <p>All computation runs in your browser. Zero server requests. Your data never leaves your device.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3>Lightning Fast</h3>
          <p>Zero JavaScript framework overhead. Static pages served from Cloudflare's global CDN edge network.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3>Bilingual Native</h3>
          <p>Built from the ground up in English and Chinese. Not translated — natively written for both audiences.</p>
        </div>
      </div>
    </section>

    {posts.length > 0 && (
      <section class="blog-section">
        <h2>Latest Articles</h2>
        <ul class="posts-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}`} class="post-link">
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric', month: 'long', day: 'numeric',
                  })}
                </time>
              </a>
            </li>
          ))}
        </ul>
        <a href="/blog" class="view-all">View all articles →</a>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .home {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1rem 4rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .hero-sub {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    margin: 0;
  }

  /* ── Tool Grid: responsive CSS Grid ── */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 860px) {
    .tools-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .tools-grid { grid-template-columns: 1fr; }
    .tool-card {
      flex-direction: row;
      align-items: center;
      padding: 0.85rem 1rem;
      gap: 0.75rem;
    }
    .tool-icon {
      width: 36px;
      height: 36px;
    }
    .tool-icon :global(svg) {
      width: 18px;
      height: 18px;
    }
  }

  /* ── Tool Card ── */
  .tool-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: inherit;
    background: var(--color-bg);
    box-shadow: var(--shadow-card);
    transition: border-color var(--transition-fast), box-shadow var(--transition-med), transform var(--transition-med);
  }

  .tool-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .tool-icon {
    width: 44px;
    height: 44px;
    background: var(--color-bg-icon);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .tool-icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .tool-info h2 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
  }

  .tool-info p {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Why Section ── */
  .why-section {
    margin-top: 4rem;
  }

  .why-section h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    text-align: center;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 700px) {
    .why-grid { grid-template-columns: 1fr; }
  }

  .why-card {
    text-align: center;
    padding: 1.5rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-card);
  }

  .why-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-icon);
    border-radius: var(--radius-sm);
    color: var(--color-primary);
  }

  .why-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .why-card p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Blog Section ── */
  .blog-section {
    margin-top: 4rem;
  }

  .blog-section h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-link {
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: inherit;
    box-shadow: var(--shadow-card);
    transition: border-color var(--transition-fast), box-shadow var(--transition-med);
  }

  .post-link:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
    text-decoration: none;
  }

  .post-link h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.35rem;
  }

  .post-link p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin: 0 0 0.5rem;
  }

  .post-link time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .view-all {
    font-size: 0.9rem;
  }
</style>
