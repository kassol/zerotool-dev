---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolDirectory from '../components/ToolDirectory.astro';
import { allTools } from '../data/tools';

const toolCount = allTools.length;
---

<BaseLayout
  title="ZeroTool — Free Online Developer Tools"
  description={`${toolCount} free, fast, browser-based developer tools for JSON, Base64, UUIDs, URLs, text, security, images, and APIs.`}
  lang="en"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'ZeroTool',
      url: 'https://zerotool.dev',
      description: 'Free, fast, browser-based developer tools.',
    })} />
  </Fragment>
  <ToolDirectory lang="en" mode="home" />
</BaseLayout>
