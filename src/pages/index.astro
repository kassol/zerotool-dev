---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => {
  return !data.draft && data.lang === 'en';
})).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);

const tools = [
  {
    href: '/tools/json-formatter',
    name: 'JSON Formatter',
    description: 'Prettify, minify, and validate JSON instantly in your browser.',
    icon: '{ }',
  },
  {
    href: '/tools/base64',
    name: 'Base64 Encode / Decode',
    description: 'Encode text to Base64 or decode Base64 back to plain text.',
    icon: '64',
  },
  {
    href: '/tools/uuid-generator',
    name: 'UUID Generator',
    description: 'Generate v4 UUIDs instantly — single or batch.',
    icon: '#',
  },
  {
    href: '/tools/url-encode',
    name: 'URL Encode / Decode',
    description: 'Encode or decode URL components and query strings.',
    icon: '%',
  },
  {
    href: '/tools/text-case',
    name: 'Text Case Converter',
    description: 'Convert text to UPPER, lower, Title, camelCase, snake_case, and more.',
    icon: 'Aa',
  },
  {
    href: '/tools/markdown-preview',
    name: 'Markdown Preview',
    description: 'Live Markdown editor with real-time HTML preview. Supports GFM tables, task lists, and code blocks.',
    icon: 'MD',
  },
  {
    href: '/tools/color-converter',
    name: 'Color Converter',
    description: 'Convert colors between HEX, RGB, and HSL formats with a live color preview.',
    icon: '#',
  },
  {
    href: '/tools/regex-tester',
    name: 'Regex Tester',
    description: 'Test regular expressions in real time with match highlighting and capture group details.',
    icon: '.*',
  },
  {
    href: '/tools/hash-generator',
    name: 'Hash Generator',
    description: 'Generate MD5, SHA-1, SHA-256, SHA-384, and SHA-512 hashes from any text.',
    icon: '#!',
  },
  {
    href: '/tools/timestamp-converter',
    name: 'Timestamp Converter',
    description: 'Convert Unix timestamps to human-readable dates and vice versa. Auto-detects seconds vs milliseconds.',
    icon: 'ts',
  },
  {
    href: '/tools/jwt-decoder',
    name: 'JWT Decoder',
    description: 'Decode and inspect JWT header, payload, and signature. Highlights expiry status and timestamp claims.',
    icon: 'JWT',
  },
  {
    href: '/tools/diff-checker',
    name: 'Diff Checker',
    description: 'Compare two texts line by line and highlight additions and deletions. Powered by LCS algorithm.',
    icon: '+-',
  },
  {
    href: '/tools/password-generator',
    name: 'Password Generator',
    description: 'Generate cryptographically secure passwords. Customize length and character sets with entropy meter.',
    icon: '***',
  },
  {
    href: '/tools/qr-code-generator',
    name: 'QR Code Generator',
    description: 'Generate QR codes from URLs, text, Wi-Fi credentials, and more. Download as PNG.',
    icon: 'QR',
  },
  {
    href: '/tools/cron-parser',
    name: 'Cron Expression Parser',
    description: 'Parse and explain cron expressions in plain English. Preview next 10 scheduled run times.',
    icon: '⏰',
  },
];
---

<BaseLayout
  title="ZeroTool — Free Online Developer Tools"
  description="Free, fast, browser-based developer tools. JSON formatter, Base64, UUID generator, URL encoder, text case converter. No sign-up required."
  lang="en"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'ZeroTool',
      url: 'https://zerotool.dev',
      description: 'Free, fast, browser-based developer tools. No sign-up required.',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://zerotool.dev/?q={search_term_string}',
        'query-input': 'required name=search_term_string',
      },
    })} />
  </Fragment>
  <div class="home">
    <section class="hero">
      <h1>Free Online Developer Tools</h1>
      <p class="hero-sub">
        Fast, private, browser-based. No sign-up required. Works offline.
      </p>
    </section>

    <section class="tools-grid">
      {tools.map(tool => (
        <a href={tool.href} class="tool-card">
          <span class="tool-icon">{tool.icon}</span>
          <div class="tool-info">
            <h2>{tool.name}</h2>
            <p>{tool.description}</p>
          </div>
        </a>
      ))}
    </section>

    {posts.length > 0 && (
      <section class="blog-section">
        <h2>Latest Articles</h2>
        <ul class="posts-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}`} class="post-link">
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric', month: 'long', day: 'numeric',
                  })}
                </time>
              </a>
            </li>
          ))}
        </ul>
        <a href="/blog" class="view-all">View all articles →</a>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .home {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 1rem 4rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .hero-sub {
    color: #666;
    font-size: 1.05rem;
    margin: 0;
  }

  .tools-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tool-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .tool-card:hover {
    border-color: #0070f3;
    box-shadow: 0 0 0 3px rgba(0,112,243,0.08);
    text-decoration: none;
  }

  .tool-icon {
    width: 48px;
    height: 48px;
    background: #f0f4ff;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    color: #0070f3;
    flex-shrink: 0;
    font-family: monospace;
  }

  .tool-info h2 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
  }

  .tool-info p {
    font-size: 0.9rem;
    color: #666;
    margin: 0;
  }

  .blog-section {
    margin-top: 4rem;
  }

  .blog-section h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-link {
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .post-link:hover {
    border-color: #0070f3;
    box-shadow: 0 0 0 3px rgba(0,112,243,0.08);
    text-decoration: none;
  }

  .post-link h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.35rem;
  }

  .post-link p {
    font-size: 0.9rem;
    color: #666;
    margin: 0 0 0.5rem;
  }

  .post-link time {
    font-size: 0.8rem;
    color: #999;
  }

  .view-all {
    font-size: 0.9rem;
    color: #0070f3;
  }
</style>
