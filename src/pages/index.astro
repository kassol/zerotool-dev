---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  {
    href: '/tools/json-formatter',
    name: 'JSON Formatter',
    description: 'Prettify, minify, and validate JSON instantly in your browser.',
    icon: '{ }',
  },
  {
    href: '/tools/base64',
    name: 'Base64 Encode / Decode',
    description: 'Encode text to Base64 or decode Base64 back to plain text.',
    icon: '64',
  },
  {
    href: '/tools/uuid-generator',
    name: 'UUID Generator',
    description: 'Generate v4 UUIDs instantly — single or batch.',
    icon: '#',
  },
  {
    href: '/tools/url-encode',
    name: 'URL Encode / Decode',
    description: 'Encode or decode URL components and query strings.',
    icon: '%',
  },
  {
    href: '/tools/text-case',
    name: 'Text Case Converter',
    description: 'Convert text to UPPER, lower, Title, camelCase, snake_case, and more.',
    icon: 'Aa',
  },
];
---

<BaseLayout
  title="ZeroTool — Free Online Developer Tools"
  description="Free, fast, browser-based developer tools. JSON formatter, Base64, UUID generator, URL encoder, text case converter. No sign-up required."
  lang="en"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'ZeroTool',
      url: 'https://zerotool.dev',
      description: 'Free, fast, browser-based developer tools. No sign-up required.',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://zerotool.dev/?q={search_term_string}',
        'query-input': 'required name=search_term_string',
      },
    })} />
  </Fragment>
  <div class="home">
    <section class="hero">
      <h1>Free Online Developer Tools</h1>
      <p class="hero-sub">
        Fast, private, browser-based. No sign-up required. Works offline.
      </p>
    </section>

    <section class="tools-grid">
      {tools.map(tool => (
        <a href={tool.href} class="tool-card">
          <span class="tool-icon">{tool.icon}</span>
          <div class="tool-info">
            <h2>{tool.name}</h2>
            <p>{tool.description}</p>
          </div>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .home {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 1rem 4rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .hero-sub {
    color: #666;
    font-size: 1.05rem;
    margin: 0;
  }

  .tools-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tool-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .tool-card:hover {
    border-color: #0070f3;
    box-shadow: 0 0 0 3px rgba(0,112,243,0.08);
    text-decoration: none;
  }

  .tool-icon {
    width: 48px;
    height: 48px;
    background: #f0f4ff;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    color: #0070f3;
    flex-shrink: 0;
    font-family: monospace;
  }

  .tool-info h2 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
  }

  .tool-info p {
    font-size: 0.9rem;
    color: #666;
    margin: 0;
  }
</style>
