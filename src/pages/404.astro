---
import BaseLayout from '../layouts/BaseLayout.astro';

const isZh = Astro.url.pathname.startsWith('/zh');
const lang = isZh ? 'zh' : 'en';
const homeHref = isZh ? '/zh' : '/';
---

<BaseLayout
  title={isZh ? '404 — 页面未找到' : '404 — Page Not Found'}
  description={isZh ? '您访问的页面不存在。' : 'The page you are looking for does not exist.'}
  lang={lang}
  noindex={true}
>
  <div class="not-found">
    <h1>404</h1>
    <p>{isZh ? '页面未找到' : 'Page Not Found'}</p>
    <a href={homeHref}>{isZh ? '返回首页' : 'Back to Home'}</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    padding: 2rem 1rem;
  }

  .not-found h1 {
    font-size: 5rem;
    font-weight: 700;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem;
    line-height: 1;
  }

  .not-found p {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    margin: 0 0 1.5rem;
  }

  .not-found a {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: var(--color-primary);
    color: #fff;
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    transition: background var(--transition-fast);
  }

  .not-found a:hover {
    background: var(--color-primary-hover);
    text-decoration: none;
  }
</style>
