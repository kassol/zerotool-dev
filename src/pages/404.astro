---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n/utils';

const isZh = Astro.url.pathname.startsWith('/zh');
const lang = isZh ? 'zh' : 'en';
const homeHref = isZh ? '/zh' : '/';
---

<BaseLayout
  title={t(lang, 'error.title')}
  description={t(lang, 'error.description')}
  lang={lang}
  noindex={true}
>
  <div class="not-found">
    <h1>404</h1>
    <p>{t(lang, 'error.heading')}</p>
    <a href={homeHref}>{t(lang, 'error.backHome')}</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    padding: 2rem 1rem;
  }

  .not-found h1 {
    font-size: 5rem;
    font-weight: 700;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem;
    line-height: 1;
  }

  .not-found p {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    margin: 0 0 1.5rem;
  }

  .not-found a {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: var(--color-primary);
    color: #fff;
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    transition: background var(--transition-fast);
  }

  .not-found a:hover {
    background: var(--color-primary-hover);
    text-decoration: none;
  }
</style>
