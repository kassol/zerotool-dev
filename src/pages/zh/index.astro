---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolDirectory from '../../components/ToolDirectory.astro';
import { allTools } from '../../data/tools';

const toolCount = allTools.length;
---

<BaseLayout
  title="ZeroTool — 免费在线开发者工具"
  description={`${toolCount} 款免费、快速、纯浏览器端开发者工具，覆盖 JSON、Base64、UUID、URL、文本、安全、图像和 API。`}
  lang="zh"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'ZeroTool',
      url: 'https://zerotool.dev/zh/',
      description: '免费、快速、纯浏览器端开发者工具集。',
    })} />
  </Fragment>
  <ToolDirectory lang="zh" mode="home" />
</BaseLayout>
