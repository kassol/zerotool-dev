---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getToolIcon } from '../../data/icons';
import { allTools } from '../../data/tools';

const posts = (await getCollection('blog', ({ data }) => {
  return !data.draft && data.lang === 'zh';
})).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tools = allTools.map(t => ({
  href: `/zh/tools/${t.slug}`,
  slug: t.slug,
  name: t.nameZh,
  description: t.descriptionZh,
}));
---

<BaseLayout
  title="ZeroTool — 免费在线开发者工具"
  description="免费、快速、纯浏览器端开发者工具集。JSON 格式化、Base64 编码、UUID 生成、URL 编码、文本大小写转换。无需注册，支持离线使用。"
  lang="zh"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'ZeroTool',
      url: 'https://zerotool.dev/zh',
      description: '免费、快速、纯浏览器端开发者工具集。无需注册。',
    })} />
  </Fragment>
  <div class="home">
    <section class="hero">
      <h1>免费在线开发者工具</h1>
      <p class="hero-sub">快速、私密、纯浏览器端运行。无需注册，支持离线使用。</p>
    </section>

    <section class="tools-grid">
      {tools.map(tool => (
        <a href={tool.href} class="tool-card">
          <span class="tool-icon" set:html={getToolIcon(tool.slug)} />
          <div class="tool-info">
            <h2>{tool.name}</h2>
            <p>{tool.description}</p>
          </div>
        </a>
      ))}
    </section>

    <section class="why-section">
      <h2>为什么选择 ZeroTool？</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3>隐私优先</h3>
          <p>所有计算在浏览器中完成，零服务器请求。你的数据永远不会离开你的设备。</p>
        </div>
        <div class="why-card">
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3>极速加载</h3>
          <p>零 JavaScript 框架开销，静态页面通过 Cloudflare 全球 CDN 边缘网络分发。</p>
        </div>
        <div class="why-card">
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3>原生双语</h3>
          <p>中英双语从零构建，非机器翻译——为两个语种的用户原生打造。</p>
        </div>
      </div>
    </section>

    {posts.length > 0 && (
      <section class="blog-section">
        <h2>最新文章</h2>
        <ul class="posts-list">
          {posts.slice(0, 3).map((post) => (
            <li>
              <a href={`/zh/blog/${post.slug}`} class="post-link">
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-CN', {
                    year: 'numeric', month: 'long', day: 'numeric',
                  })}
                </time>
              </a>
            </li>
          ))}
        </ul>
        <a href="/zh/blog" class="view-all">查看所有文章 →</a>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .home {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1rem 4rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .hero-sub {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    margin: 0;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 860px) {
    .tools-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .tools-grid { grid-template-columns: 1fr; }
    .tool-card {
      flex-direction: row;
      align-items: center;
      padding: 0.85rem 1rem;
      gap: 0.75rem;
    }
    .tool-icon {
      width: 36px;
      height: 36px;
    }
    .tool-icon :global(svg) {
      width: 18px;
      height: 18px;
    }
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: inherit;
    background: var(--color-bg);
    box-shadow: var(--shadow-card);
    transition: border-color var(--transition-fast), box-shadow var(--transition-med), transform var(--transition-med);
  }

  .tool-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .tool-icon {
    width: 44px;
    height: 44px;
    background: var(--color-bg-icon);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .tool-icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .tool-info h2 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
  }

  .tool-info p {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Why Section ── */
  .why-section {
    margin-top: 4rem;
  }

  .why-section h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    text-align: center;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 700px) {
    .why-grid { grid-template-columns: 1fr; }
  }

  .why-card {
    text-align: center;
    padding: 1.5rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-card);
  }

  .why-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-icon);
    border-radius: var(--radius-sm);
    color: var(--color-primary);
  }

  .why-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .why-card p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .blog-section {
    margin-top: 4rem;
  }

  .blog-section h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-link {
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: inherit;
    box-shadow: var(--shadow-card);
    transition: border-color var(--transition-fast), box-shadow var(--transition-med);
  }

  .post-link:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
    text-decoration: none;
  }

  .post-link h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.35rem;
  }

  .post-link p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin: 0 0 0.5rem;
  }

  .post-link time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .view-all {
    font-size: 0.9rem;
  }
</style>
