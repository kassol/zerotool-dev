---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => {
  return !data.draft && data.lang === 'zh';
})).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tools = [
  {
    href: '/tools/json-formatter',
    name: 'JSON 格式化',
    description: '在浏览器中即时美化、压缩和验证 JSON，实时高亮语法错误。',
    icon: '{ }',
  },
  {
    href: '/tools/base64',
    name: 'Base64 编码 / 解码',
    description: '将文本编码为 Base64，或将 Base64 解码为纯文本。',
    icon: '64',
  },
  {
    href: '/tools/uuid-generator',
    name: 'UUID 生成器',
    description: '即时生成 v4 UUID，支持单个或批量生成。',
    icon: '#',
  },
  {
    href: '/tools/url-encode',
    name: 'URL 编码 / 解码',
    description: '编码或解码 URL 组件和查询字符串。',
    icon: '%',
  },
  {
    href: '/tools/text-case',
    name: '文本大小写转换',
    description: '将文本转换为全大写、全小写、标题格式、驼峰命名、下划线命名等。',
    icon: 'Aa',
  },
  {
    href: '/tools/markdown-preview',
    name: 'Markdown 预览',
    description: '实时 Markdown 编辑器，带 HTML 预览。支持 GFM 表格、任务列表和代码块。',
    icon: 'MD',
  },
  {
    href: '/tools/color-converter',
    name: '颜色转换器',
    description: '在 HEX、RGB 和 HSL 格式之间转换颜色，带实时颜色预览。',
    icon: '#',
  },
  {
    href: '/tools/regex-tester',
    name: '正则表达式测试器',
    description: '实时测试正则表达式，高亮匹配结果并显示捕获组详情。',
    icon: '.*',
  },
  {
    href: '/tools/hash-generator',
    name: '哈希生成器',
    description: '从任意文本生成 MD5、SHA-1、SHA-256、SHA-384 和 SHA-512 哈希值。',
    icon: '#!',
  },
  {
    href: '/tools/timestamp-converter',
    name: '时间戳转换器',
    description: '将 Unix 时间戳转换为可读日期，或反向转换。自动检测秒/毫秒。',
    icon: 'ts',
  },
  {
    href: '/tools/jwt-decoder',
    name: 'JWT 解码器',
    description: '解码并查看 JWT 的 Header、Payload 和 Signature，高亮过期状态。',
    icon: 'JWT',
  },
  {
    href: '/tools/diff-checker',
    name: '文本对比',
    description: '逐行比较两段文本，高亮新增和删除内容，基于 LCS 算法。',
    icon: '+-',
  },
  {
    href: '/tools/password-generator',
    name: '密码生成器',
    description: '生成加密安全的密码，可自定义长度和字符集，附熵值计量。',
    icon: '***',
  },
  {
    href: '/tools/qr-code-generator',
    name: '二维码生成器',
    description: '从 URL、文本、Wi-Fi 凭证等生成二维码，可下载为 PNG。',
    icon: 'QR',
  },
  {
    href: '/tools/cron-parser',
    name: 'Cron 表达式解析器',
    description: '用自然语言解释 Cron 表达式，预览最近 10 次执行时间。',
    icon: '⏰',
  },
];
---

<BaseLayout
  title="ZeroTool — 免费在线开发者工具"
  description="免费、快速、纯浏览器端开发者工具集。JSON 格式化、Base64 编码、UUID 生成、URL 编码、文本大小写转换。无需注册，支持离线使用。"
  lang="zh"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'ZeroTool',
      url: 'https://zerotool.dev/zh',
      description: '免费、快速、纯浏览器端开发者工具集。无需注册。',
    })} />
  </Fragment>
  <div class="home">
    <section class="hero">
      <h1>免费在线开发者工具</h1>
      <p class="hero-sub">快速、私密、纯浏览器端运行。无需注册，支持离线使用。</p>
    </section>

    <section class="tools-grid">
      {tools.map(tool => (
        <a href={tool.href} class="tool-card">
          <span class="tool-icon">{tool.icon}</span>
          <div class="tool-info">
            <h2>{tool.name}</h2>
            <p>{tool.description}</p>
          </div>
        </a>
      ))}
    </section>

    {posts.length > 0 && (
      <section class="blog-section">
        <h2>最新文章</h2>
        <ul class="posts-list">
          {posts.slice(0, 3).map((post) => (
            <li>
              <a href={`/zh/blog/${post.slug}`} class="post-link">
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-CN', {
                    year: 'numeric', month: 'long', day: 'numeric',
                  })}
                </time>
              </a>
            </li>
          ))}
        </ul>
        <a href="/zh/blog" class="view-all">查看所有文章 →</a>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .home {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 1rem 4rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .hero-sub {
    color: #666;
    font-size: 1.05rem;
    margin: 0;
  }

  .tools-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tool-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .tool-card:hover {
    border-color: #0070f3;
    box-shadow: 0 0 0 3px rgba(0,112,243,0.08);
    text-decoration: none;
  }

  .tool-icon {
    width: 48px;
    height: 48px;
    background: #f0f4ff;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    color: #0070f3;
    flex-shrink: 0;
    font-family: monospace;
  }

  .tool-info h2 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
  }

  .tool-info p {
    font-size: 0.9rem;
    color: #666;
    margin: 0;
  }

  .blog-section {
    margin-top: 4rem;
  }

  .blog-section h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-link {
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .post-link:hover {
    border-color: #0070f3;
    box-shadow: 0 0 0 3px rgba(0,112,243,0.08);
    text-decoration: none;
  }

  .post-link h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.35rem;
  }

  .post-link p {
    font-size: 0.9rem;
    color: #666;
    margin: 0 0 0.5rem;
  }

  .post-link time {
    font-size: 0.8rem;
    color: #999;
  }

  .view-all {
    font-size: 0.9rem;
    color: #0070f3;
  }
</style>
