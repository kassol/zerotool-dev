---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import DiffCheckerTool from '../../../components/tools/DiffCheckerTool.astro';
---

<ToolLayout
  toolName="文本对比"
  title="文本对比工具 — 在线逐行比较 | ZeroTool"
  description="逐行比较两段文本，高亮显示新增和删除内容。免费在线 Diff 工具，基于 LCS 算法。"
  lang="zh"
  faqItems={[
    {
      question: "我的文本会发送到服务器吗？",
      answer: "不会。所有差异计算完全在浏览器中进行，文本不会离开您的设备。",
    },
    {
      question: "使用什么差异算法？",
      answer: "此工具使用行级最长公共子序列（LCS）算法——与 Unix diff 使用的原理相同。",
    },
    {
      question: "可以比较代码文件吗？",
      answer: "可以。粘贴任何纯文本——源代码、配置文件、文章——此工具都会显示新增和删除的行。",
    },
    {
      question: "仅空白字符不同的行会显示吗？",
      answer: "会。默认显示所有差异，包括仅空白字符不同的行。",
    },
  ]}
>
  <DiffCheckerTool slot="tool" />

  <h2>使用方法</h2>
  <ol>
    <li>将原始文本粘贴到 <strong>Original</strong> 面板。</li>
    <li>将修改后的文本粘贴到 <strong>Modified</strong> 面板。</li>
    <li>点击 <strong>Compare</strong> 查看差异。</li>
    <li><span style="color:#c0392b">红色</span>高亮的行表示被删除；<span style="color:#057a55">绿色</span>高亮的行表示被新增。</li>
    <li>使用 <strong>Swap</strong> 可交换比较方向。</li>
  </ol>

  <h2>关于此工具</h2>
  <p>
    此文本对比工具使用最长公共子序列（LCS）算法进行逐行比较——与 <code>git diff</code> 和
    Unix <code>diff</code> 使用的原理相同。非常适合比较代码、配置文件、日志输出或任何需要行级差异的文本。
  </p>
</ToolLayout>
