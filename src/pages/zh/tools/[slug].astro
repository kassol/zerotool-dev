---
import { getEntry } from 'astro:content';
import ToolLayout from '../../../layouts/ToolLayout.astro';
import { allTools, getToolName } from '../../../data/tools';

import AsciiConverterTool from '../../../components/tools/AsciiConverterTool.astro';
import AspectRatioTool from '../../../components/tools/AspectRatioTool.astro';
import Base64Tool from '../../../components/tools/Base64Tool.astro';
import ChmodCalculatorTool from '../../../components/tools/ChmodCalculatorTool.astro';
import ColorConverterTool from '../../../components/tools/ColorConverterTool.astro';
import CronParserTool from '../../../components/tools/CronParserTool.astro';
import CssToTailwindTool from '../../../components/tools/CssToTailwindTool.astro';
import CsvJsonTool from '../../../components/tools/CsvJsonTool.astro';
import DiffCheckerTool from '../../../components/tools/DiffCheckerTool.astro';
import HashGeneratorTool from '../../../components/tools/HashGeneratorTool.astro';
import HtmlEntityTool from '../../../components/tools/HtmlEntityTool.astro';
import ImageToBase64Tool from '../../../components/tools/ImageToBase64Tool.astro';
import JsonFormatterTool from '../../../components/tools/JsonFormatterTool.astro';
import JwtDecoderTool from '../../../components/tools/JwtDecoderTool.astro';
import LineToolsTool from '../../../components/tools/LineToolsTool.astro';
import LoremIpsumTool from '../../../components/tools/LoremIpsumTool.astro';
import MarkdownPreviewTool from '../../../components/tools/MarkdownPreviewTool.astro';
import MarkdownTableGeneratorTool from '../../../components/tools/MarkdownTableGeneratorTool.astro';
import NumberBaseTool from '../../../components/tools/NumberBaseTool.astro';
import PasswordGeneratorTool from '../../../components/tools/PasswordGeneratorTool.astro';
import QrCodeGeneratorTool from '../../../components/tools/QrCodeGeneratorTool.astro';
import RegexTesterTool from '../../../components/tools/RegexTesterTool.astro';
import SqlFormatterTool from '../../../components/tools/SqlFormatterTool.astro';
import TextCaseTool from '../../../components/tools/TextCaseTool.astro';
import TimestampConverterTool from '../../../components/tools/TimestampConverterTool.astro';
import TomlJsonTool from '../../../components/tools/TomlJsonTool.astro';
import UrlEncodeTool from '../../../components/tools/UrlEncodeTool.astro';
import UuidGeneratorTool from '../../../components/tools/UuidGeneratorTool.astro';
import WordCounterTool from '../../../components/tools/WordCounterTool.astro';
import XmlFormatterTool from '../../../components/tools/XmlFormatterTool.astro';
import YamlJsonTool from '../../../components/tools/YamlJsonTool.astro';

const toolComponentMap: Record<string, (_props: Record<string, never>) => any> = {
  'ascii-converter': AsciiConverterTool,
  'aspect-ratio': AspectRatioTool,
  'base64': Base64Tool,
  'chmod-calculator': ChmodCalculatorTool,
  'color-converter': ColorConverterTool,
  'cron-parser': CronParserTool,
  'css-to-tailwind': CssToTailwindTool,
  'csv-json': CsvJsonTool,
  'diff-checker': DiffCheckerTool,
  'hash-generator': HashGeneratorTool,
  'html-entity': HtmlEntityTool,
  'image-to-base64': ImageToBase64Tool,
  'json-formatter': JsonFormatterTool,
  'jwt-decoder': JwtDecoderTool,
  'line-tools': LineToolsTool,
  'lorem-ipsum': LoremIpsumTool,
  'markdown-preview': MarkdownPreviewTool,
  'markdown-table-generator': MarkdownTableGeneratorTool,
  'number-base': NumberBaseTool,
  'password-generator': PasswordGeneratorTool,
  'qr-code-generator': QrCodeGeneratorTool,
  'regex-tester': RegexTesterTool,
  'sql-formatter': SqlFormatterTool,
  'text-case': TextCaseTool,
  'timestamp-converter': TimestampConverterTool,
  'toml-json': TomlJsonTool,
  'url-encode': UrlEncodeTool,
  'uuid-generator': UuidGeneratorTool,
  'word-counter': WordCounterTool,
  'xml-formatter': XmlFormatterTool,
  'yaml-json': YamlJsonTool,
};

export async function getStaticPaths() {
  return allTools.map((tool) => ({ params: { slug: tool.slug } }));
}

const { slug } = Astro.params;
const tool = allTools.find((t) => t.slug === slug)!;
const entry = await getEntry('tools', `${slug}/zh`);
if (!entry) throw new Error(`Missing content entry: tools/${slug}/zh`);
const { Content } = await entry.render();
const { seoTitle, seoDescription, faqItems } = entry.data;

const ToolComponent = toolComponentMap[slug!];
---

<ToolLayout
  toolName={getToolName(tool, 'zh')}
  title={seoTitle}
  description={seoDescription}
  lang="zh"
  faqItems={faqItems}
>
  <ToolComponent slot="tool" />
  <Content />
</ToolLayout>
