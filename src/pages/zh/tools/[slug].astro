---
import { getEntry } from 'astro:content';
import ToolLayout from '../../../layouts/ToolLayout.astro';
import { allTools, getToolName } from '../../../data/tools';

import { toolComponentMap } from "../../../components/tools/registry";


export async function getStaticPaths() {
  return allTools.map((tool) => ({ params: { slug: tool.slug } }));
}

const { slug } = Astro.params;
const tool = allTools.find((t) => t.slug === slug)!;
const entry = await getEntry('tools', `${slug}/zh`);
if (!entry) throw new Error(`Missing content entry: tools/${slug}/zh`);
const { Content } = await entry.render();
const { seoTitle, seoDescription, faqItems } = entry.data;

const ToolComponent = toolComponentMap[slug!];
---

<ToolLayout
  toolName={getToolName(tool, 'zh')}
  title={seoTitle}
  description={seoDescription}
  lang="zh"
  faqItems={faqItems}
>
  <ToolComponent slot="tool" lang="zh" />
  <Content />
</ToolLayout>
