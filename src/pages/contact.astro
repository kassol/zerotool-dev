---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — ZeroTool"
  description="Get in touch with the ZeroTool team. Email us at hello@zerotool.dev."
  lang="en"
>
  <div class="prose-container">
    <article class="prose">
      <h1>Contact</h1>
      <p>
        Have a tool request, found a bug, or just want to say hello? We'd love to hear from you.
      </p>
      <p>
        We're a small independent team and we read every message. Expect a reply within a few
        business days.
      </p>
      <p>
        <a class="prose-contact-email" href="mailto:hello@zerotool.dev">hello@zerotool.dev</a>
      </p>
    </article>
  </div>
</BaseLayout>
