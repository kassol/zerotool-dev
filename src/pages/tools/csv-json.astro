---
import ToolLayout from '../../layouts/ToolLayout.astro';
import CsvJsonTool from '../../components/tools/CsvJsonTool.astro';
---

<ToolLayout
  toolName="CSV to JSON Converter"
  title="CSV to JSON Converter Online — Free Data Format Tool | ZeroTool"
  description="Convert CSV to JSON and JSON to CSV instantly. Handles quoted fields, auto-detects headers. Free, browser-based, no server required."
  lang="en"
  faqItems={[
    {
      question: "What CSV format is supported?",
      answer: "Standard RFC 4180 CSV: comma-separated values with optional double-quote escaping. Quoted fields may contain commas, newlines, and escaped quotes (\"\").",
    },
    {
      question: "How are headers handled?",
      answer: "The first row of your CSV is always treated as headers. Each subsequent row becomes a JSON object whose keys are the header values.",
    },
    {
      question: "Is there a maximum file size?",
      answer: "There is no hard limit — processing happens entirely in your browser. Practically, files up to a few MB convert instantly; very large files may slow down depending on your device.",
    },
    {
      question: "Is my data sent anywhere?",
      answer: "No. All conversion runs 100% in your browser using JavaScript. Your data never leaves your machine.",
    },
  ]}
>
  <CsvJsonTool slot="tool" />

  <h2>How to Use</h2>
  <ol>
    <li>To convert <strong>CSV → JSON</strong>: paste your CSV data (with a header row) into the left panel and click <strong>CSV → JSON</strong>.</li>
    <li>To convert <strong>JSON → CSV</strong>: paste an array of JSON objects into the right panel and click <strong>JSON → CSV</strong>.</li>
    <li>Click the <strong>Copy</strong> button on either panel to copy the result to your clipboard.</li>
    <li>The status line below the buttons shows the row count or any parsing errors.</li>
  </ol>

  <h2>Worked Examples</h2>

  <h3>Simple table</h3>
  <p>Input CSV:</p>
  <pre><code>name,age,city
Alice,30,London
Bob,25,Paris</code></pre>
  <p>Output JSON:</p>
  <pre><code set:html={`[\n  { "name": "Alice", "age": "30", "city": "London" },\n  { "name": "Bob", "age": "25", "city": "Paris" }\n]`} /></pre>

  <h3>Quoted fields with commas</h3>
  <p>Input CSV:</p>
  <pre><code>product,description,price
Widget,"Small, round widget",9.99
Gadget,"Includes ""turbo"" mode",24.50</code></pre>
  <p>The <code>description</code> field contains a comma and escaped quotes — both are handled correctly.</p>

  <h3>JSON back to CSV</h3>
  <p>Paste the JSON output back into the right panel and click <strong>JSON → CSV</strong> to round-trip your data.</p>

  <h2>Supported CSV Format</h2>
  <p>
    This tool follows the <strong>RFC 4180</strong> standard. Fields are separated by commas.
    If a field contains a comma, newline, or double-quote, it must be enclosed in double quotes.
    A literal double-quote inside a quoted field is escaped as two consecutive double-quotes (<code>""</code>).
    The first row is always interpreted as column headers.
  </p>
</ToolLayout>
