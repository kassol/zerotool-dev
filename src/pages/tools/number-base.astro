---
import ToolLayout from '../../layouts/ToolLayout.astro';
import NumberBaseTool from '../../components/tools/NumberBaseTool.astro';
---

<ToolLayout
  toolName="Number Base Converter"
  title="Number Base Converter — Binary, Octal, Decimal, Hex | ZeroTool"
  description="Convert numbers between binary, octal, decimal, and hexadecimal instantly. Free online base converter, runs in your browser."
  lang="en"
  faqItems={[
    {
      question: "What number bases are supported?",
      answer: "Binary (base 2), Octal (base 8), Decimal (base 10), and Hexadecimal (base 16).",
    },
    {
      question: "Can it handle large numbers?",
      answer: "Yes. The converter uses BigInt internally, so it can handle arbitrarily large integers without precision loss.",
    },
    {
      question: "Is my data sent anywhere?",
      answer: "No. All conversion runs 100% in your browser using JavaScript. Your data never leaves your machine.",
    },
  ]}
>
  <NumberBaseTool slot="tool" />

  <h2>How to Use</h2>
  <ol>
    <li>Select the input base from the dropdown (Binary, Octal, Decimal, or Hex).</li>
    <li>Enter your number in the input field.</li>
    <li>All conversions update instantly in the results below.</li>
    <li>Click <strong>Copy</strong> on any result to copy it to your clipboard.</li>
  </ol>

  <h2>Worked Examples</h2>
  <h3>Decimal 255</h3>
  <p>Enter <code>255</code> with Decimal selected:</p>
  <ul>
    <li>Binary: <code>11111111</code></li>
    <li>Octal: <code>377</code></li>
    <li>Hex: <code>FF</code></li>
  </ul>

  <h3>Hex FF</h3>
  <p>Enter <code>FF</code> with Hex selected — same results as above.</p>

  <h2>Common Conversions</h2>
  <p>Number base conversion is essential in programming, networking, and digital electronics. Binary is the native language of computers, hex is used for memory addresses and color codes, and octal appears in Unix file permissions.</p>
</ToolLayout>
