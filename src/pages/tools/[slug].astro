export async function getStaticPaths() {
  return allTools.map((tool) => ({ params: { slug: tool.slug } }));
}

const { slug } = Astro.params;
const tool = allTools.find((t) => t.slug === slug)!;
const entry = await getEntry('tools', `${slug}/en`);
if (!entry) throw new Error(`Missing content entry: tools/${slug}/en`);
const { Content } = await entry.render();
const { seoTitle, seoDescription, faqItems } = entry.data;

const ToolComponent = toolComponentMap[slug!];
---

<ToolLayout
  toolName={getToolName(tool, 'en')}
  title={seoTitle}
  description={seoDescription}
  lang="en"
  faqItems={faqItems}
>
  <ToolComponent slot="tool" />
  <Content />
</ToolLayout>
