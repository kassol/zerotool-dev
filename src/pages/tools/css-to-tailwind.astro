---
import ToolLayout from '../../layouts/ToolLayout.astro';
import CssToTailwindTool from '../../components/tools/CssToTailwindTool.astro';
---

<ToolLayout
  toolName="CSS to Tailwind Converter"
  title="CSS to Tailwind CSS Converter Online — Free Dev Tool | ZeroTool"
  description="Convert CSS properties to equivalent Tailwind CSS utility classes. Covers display, spacing, typography, flexbox, grid, and more. Free, browser-based, instant conversion."
  lang="en"
  faqItems={[
    {
      question: "What CSS properties are supported?",
      answer: "The tool covers the most common CSS properties: display, position, overflow, flexbox, grid, alignment, spacing (margin/padding/gap), sizing (width/height), typography (font-size, font-weight, text-align), borders, border-radius, opacity, z-index, cursor, and transitions.",
    },
    {
      question: "What happens to properties that can't be mapped?",
      answer: "Unmapped properties appear as /* keep: property: value */ comments in the output. This way you know exactly which styles need manual attention without losing any information.",
    },
    {
      question: "Can I paste a full CSS rule with a selector?",
      answer: "Yes. You can paste one or more CSS rule blocks (e.g. .card { ... }). The converter outputs each selector's classes in a comment-labeled group. You can also paste bare declarations without a selector.",
    },
    {
      question: "Does it support Tailwind v4?",
      answer: "The output uses standard Tailwind utility class names that are compatible with both Tailwind v3 and v4. Arbitrary value syntax (e.g. p-[13px]) is not generated — you can add those manually for values not in the Tailwind scale.",
    },
  ]}
>
  <CssToTailwindTool slot="tool" />

  <h2>How to Use</h2>
  <ol>
    <li>Paste your CSS into the left panel — either bare declarations or full rule blocks with selectors.</li>
    <li>Click <strong>Convert to Tailwind</strong> (or press <strong>Ctrl+Enter</strong> / <strong>Cmd+Enter</strong>).</li>
    <li>Review the Tailwind classes in the right panel. Comments mark unmapped properties.</li>
    <li>Click <strong>Copy</strong> to copy the output to your clipboard.</li>
  </ol>

  <h2>Worked Examples</h2>

  <h3>Flexbox card</h3>
  <p>Input CSS:</p>
  <pre><code>.card {"{"}
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  padding: 1.5rem;
  border-radius: 0.5rem;
{"}"}</code></pre>
  <p>Output Tailwind:</p>
  <pre><code>/* .card */
flex flex-col items-center gap-4 p-6 rounded-lg</code></pre>

  <h3>Typography</h3>
  <p>Input CSS:</p>
  <pre><code>font-size: 1.125rem;
font-weight: 600;
text-align: center;
text-transform: uppercase;
letter-spacing: 0.05em;</code></pre>
  <p>Output Tailwind:</p>
  <pre><code>text-lg font-semibold text-center uppercase tracking-wider</code></pre>

  <h2>Limitations</h2>
  <p>
    This tool uses a built-in mapping table rather than a full CSS parser.
    It covers roughly 80% of typical utility-class use cases.
    Complex values such as custom colors, multi-value transitions, CSS variables, and calc() expressions are left as <code>/* keep: ... */</code> comments for you to handle manually or convert using Tailwind's arbitrary value syntax (<code>p-[13px]</code>, <code>text-[#ff6600]</code>).
  </p>
</ToolLayout>
