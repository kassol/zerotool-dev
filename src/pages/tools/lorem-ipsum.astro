---
import ToolLayout from '../../layouts/ToolLayout.astro';
import LoremIpsumTool from '../../components/tools/LoremIpsumTool.astro';
---

<ToolLayout
  toolName="Lorem Ipsum Generator"
  title="Lorem Ipsum Generator Online — Free Dummy Text Tool | ZeroTool"
  description="Generate Lorem Ipsum placeholder text instantly. Choose paragraph count, copy to clipboard. Free, browser-based, no server required."
  lang="en"
  faqItems={[
    {
      question: "What is Lorem Ipsum?",
      answer: "Lorem Ipsum is dummy placeholder text used in the printing and typesetting industry since the 1500s. It mimics the look of natural language without carrying meaningful content, allowing designers to focus on visual layout.",
    },
    {
      question: "Why use Lorem Ipsum instead of real text?",
      answer: "Real content can distract reviewers from evaluating design, typography, and layout. Lorem Ipsum provides realistic text density and rhythm without the distraction of readable content.",
    },
    {
      question: "Where does Lorem Ipsum come from?",
      answer: "It originates from sections 1.10.32 and 1.10.33 of 'De Finibus Bonorum et Malorum' by Cicero, written in 45 BC. The standard Lorem Ipsum passage has been used since the 1500s.",
    },
    {
      question: "Is my data sent to any server?",
      answer: "No. All text is generated entirely in your browser using JavaScript. Nothing is transmitted over the network.",
    },
  ]}
>
  <LoremIpsumTool slot="tool" />

  <h2>How to Use</h2>
  <ol>
    <li>Set the number of paragraphs you need (1–20).</li>
    <li>Optionally check "Start with Lorem ipsum dolor sit amet..." for the classic opening.</li>
    <li>Click <strong>Generate</strong>, then <strong>Copy All</strong> to copy the text to your clipboard.</li>
  </ol>

  <h2>Worked Examples</h2>
  <h3>Card Mockup</h3>
  <p>
    Designing a product card? Set paragraphs to <strong>1</strong> to get a short block of text
    that simulates a product description. Paste it into your Figma frame or HTML prototype.
  </p>
  <h3>Blog Layout</h3>
  <p>
    Testing a blog post template? Generate <strong>5 paragraphs</strong> with the classic opening
    to simulate a realistic article. This helps verify heading spacing, line height, and readability
    at typical content lengths.
  </p>
  <h3>Email Template</h3>
  <p>
    Building an HTML email? Use <strong>2–3 paragraphs</strong> to fill the body section.
    This reveals how your layout handles varying text lengths across email clients.
  </p>

  <h2>What is Lorem Ipsum?</h2>
  <p>
    Lorem Ipsum is the standard dummy text of the printing and typesetting industry. It has
    been the industry's standard placeholder since the 1500s, when an unknown printer scrambled
    a section of Cicero's philosophical work <em>De Finibus Bonorum et Malorum</em> to create
    a type specimen book.
  </p>
  <p>
    Despite being nonsensical Latin, Lorem Ipsum has a natural distribution of letters and word
    lengths that closely resembles real text, making it ideal for previewing fonts, layouts, and
    designs without the distraction of meaningful content.
  </p>
</ToolLayout>
