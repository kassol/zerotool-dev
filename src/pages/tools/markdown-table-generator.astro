---
import ToolLayout from '../../layouts/ToolLayout.astro';
import MarkdownTableGeneratorTool from '../../components/tools/MarkdownTableGeneratorTool.astro';
---

<ToolLayout
  toolName="Markdown Table Generator"
  title="Markdown Table Generator Online — Visual Editor with CSV & JSON Import | ZeroTool"
  description="Build Markdown tables visually with a live editor. Add rows and columns, set column alignment, paste CSV or JSON data, and copy GFM-formatted tables instantly."
  lang="en"
  faqItems={[
    {
      question: "What is Markdown table syntax?",
      answer: "GitHub Flavored Markdown (GFM) tables use pipe characters to separate columns. The first row is the header, the second row is the separator (e.g. |---|---|), and subsequent rows are data. Example: | Name | Age |\\n|---|---|\\n| Alice | 30 |",
    },
    {
      question: "How do I align columns in a Markdown table?",
      answer: "Column alignment is set in the separator row using colons: :--- for left-align (default), :---: for center, and ---: for right-align. Use the ⇤ ⇔ ⇥ buttons in the header row to change alignment.",
    },
    {
      question: "Can I paste CSV data?",
      answer: "Yes. Switch to the CSV Paste tab and paste your CSV. The tool auto-detects the delimiter (comma, tab, or semicolon) and populates the visual editor and Markdown output instantly.",
    },
    {
      question: "What JSON format is supported?",
      answer: "Paste a JSON array of objects — each object's keys become column headers and each object becomes a row. Example: [{\"name\":\"Alice\",\"age\":30},{\"name\":\"Bob\",\"age\":25}]",
    },
    {
      question: "Are pipe characters in cell content handled?",
      answer: "Yes. Any pipe character (|) inside a cell is automatically escaped as \\| so the Markdown table remains valid.",
    },
  ]}
>
  <MarkdownTableGeneratorTool slot="tool" />

  <h2>How to Use</h2>

  <h3>Manual Editor</h3>
  <ol>
    <li>Click any cell to edit it inline. The Markdown output updates in real time.</li>
    <li>Use <strong>+ Row</strong> / <strong>+ Column</strong> to add rows or columns, and <strong>− Row</strong> / <strong>− Column</strong> to remove them.</li>
    <li>In the header row, use the <strong>⇤ ⇔ ⇥</strong> buttons to set column alignment (left / center / right).</li>
    <li>Click <strong>Copy</strong> to copy the Markdown table to your clipboard.</li>
  </ol>

  <h3>CSV Paste</h3>
  <ol>
    <li>Switch to the <strong>CSV Paste</strong> tab.</li>
    <li>Paste your CSV data — the first row is treated as headers.</li>
    <li>The tool auto-detects commas, tabs, or semicolons as delimiters and populates the table immediately.</li>
  </ol>

  <h3>JSON Paste</h3>
  <ol>
    <li>Switch to the <strong>JSON Paste</strong> tab.</li>
    <li>Paste a JSON array of objects. Keys become column headers; each object becomes a data row.</li>
    <li>The table and Markdown output update instantly as you type.</li>
  </ol>

  <h2>Supported Formats</h2>
  <p>
    This tool generates <strong>GitHub Flavored Markdown (GFM)</strong> tables, compatible with GitHub,
    GitLab, Notion, Obsidian, VS Code, and most modern Markdown renderers.
    Pipe characters (<code>|</code>) in cell content are automatically escaped.
  </p>

  <h2>Worked Examples</h2>

  <h3>Basic table</h3>
  <p>Manual editor with 3 columns and 2 data rows:</p>
  <pre><code>| Name  | Age | City   |
|-------|-----|--------|
| Alice | 30  | London |
| Bob   | 25  | Paris  |</code></pre>

  <h3>Center-aligned column</h3>
  <p>Click ⇔ on the "Score" header to center-align:</p>
  <pre><code>| Player | Score | Level |
|--------|:-----:|-------|
| Alice  |  100  | 5     |
| Bob    |   80  | 3     |</code></pre>

  <h3>From JSON</h3>
  <p>Paste this JSON into the JSON Paste tab:</p>
  <pre><code set:html={`[{"product":"Widget","price":9.99},{"product":"Gadget","price":24.50}]`} /></pre>
  <p>Result:</p>
  <pre><code>| product | price |
|---------|-------|
| Widget  | 9.99  |
| Gadget  | 24.5  |</code></pre>
</ToolLayout>
