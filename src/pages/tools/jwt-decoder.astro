---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  toolName="JWT Decoder"
  title="JWT Decoder Online — Decode & Verify JWT Tokens | ZeroTool"
  description="Decode and inspect JWT (JSON Web Token) header, payload, and signature instantly. Free, browser-based, no token sent to servers."
  lang="en"
  faqItems={[
    {
      question: "Is my JWT token sent to any server?",
      answer: "No. Decoding happens entirely in your browser using JavaScript. Your token never leaves your machine.",
    },
    {
      question: "Can this tool verify the JWT signature?",
      answer: "Signature verification requires the secret key or public key. This tool decodes and displays the payload without verifying the signature — use it to inspect claims only.",
    },
    {
      question: "What are the three parts of a JWT?",
      answer: "A JWT is three Base64URL-encoded parts separated by dots: Header (algorithm and token type), Payload (claims/data), and Signature (used to verify integrity).",
    },
    {
      question: "What does 'exp' mean in the payload?",
      answer: "'exp' is the expiration time claim — a Unix timestamp indicating when the token expires. This tool shows a human-readable date next to the raw value.",
    },
  ]}
>
  <div slot="tool">
    <div class="jwt-wrap">
      <div class="jwt-input-section">
        <label for="jwt-input">Paste JWT Token</label>
        <textarea
          id="jwt-input"
          placeholder="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c"
          spellcheck="false"
          autocomplete="off"
        ></textarea>
        <div class="jwt-actions">
          <button id="jwt-decode" class="btn-primary">Decode</button>
          <button id="jwt-clear" class="btn-ghost">Clear</button>
        </div>
      </div>

      <div id="jwt-status" class="jwt-status" aria-live="polite"></div>

      <div id="jwt-results" class="jwt-results"></div>
    </div>

    <script is:inline>
      (function () {
        function b64urlDecode(str) {
          // Pad to multiple of 4
          str = str.replace(/-/g, '+').replace(/_/g, '/');
          while (str.length % 4) str += '=';
          try {
            return atob(str);
          } catch (e) {
            return null;
          }
        }

        function parseJSON(str) {
          try { return JSON.parse(str); } catch (e) { return null; }
        }

        function syntaxHighlight(obj) {
          var json = JSON.stringify(obj, null, 2);
          return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+-]?\d+)?)/g, function (match) {
            var cls = 'jv-num';
            if (/^"/.test(match)) {
              if (/:$/.test(match)) {
                cls = 'jv-key';
              } else {
                cls = 'jv-str';
              }
            } else if (/true|false/.test(match)) {
              cls = 'jv-bool';
            } else if (/null/.test(match)) {
              cls = 'jv-null';
            }
            return '<span class="' + cls + '">' + match + '</span>';
          });
        }

        function formatTimeClaim(key, val) {
          if (['exp', 'iat', 'nbf'].indexOf(key) !== -1 && typeof val === 'number') {
            var d = new Date(val * 1000);
            var now = Date.now();
            var extra = ' <span class="jwt-time-hint">(' + d.toUTCString();
            if (key === 'exp') {
              extra += val * 1000 < now ? ' — <span class="jwt-expired">EXPIRED</span>' : ' — <span class="jwt-valid">valid</span>';
            }
            extra += ')</span>';
            return extra;
          }
          return '';
        }

        function buildSection(label, color, obj) {
          var div = document.createElement('div');
          div.className = 'jwt-section';

          var header = document.createElement('div');
          header.className = 'jwt-section-header';
          header.innerHTML = '<span class="jwt-section-dot" style="background:' + color + '"></span><strong>' + label + '</strong>';
          div.appendChild(header);

          var pre = document.createElement('pre');
          pre.className = 'jwt-json';
          // For payload, annotate time claims
          if (label === 'Payload' && obj) {
            var json = JSON.stringify(obj, null, 2);
            // highlight then add time hints
            var highlighted = syntaxHighlight(obj);
            // Add time annotations inline
            highlighted = highlighted.replace(/"(exp|iat|nbf)": (<span[^>]*>(\d+)<\/span>)/g, function(match, key, spanHtml, val) {
              return '"' + key + '": ' + spanHtml + formatTimeClaim(key, parseInt(val));
            });
            pre.innerHTML = highlighted;
          } else if (obj) {
            pre.innerHTML = syntaxHighlight(obj);
          } else {
            pre.textContent = '(unable to parse)';
          }
          div.appendChild(pre);

          // Copy button
          var copyBtn = document.createElement('button');
          copyBtn.className = 'btn-copy';
          copyBtn.textContent = 'Copy';
          copyBtn.addEventListener('click', function () {
            navigator.clipboard.writeText(JSON.stringify(obj, null, 2)).then(function () {
              copyBtn.textContent = 'Copied!';
              setTimeout(function () { copyBtn.textContent = 'Copy'; }, 1500);
            });
          });
          div.appendChild(copyBtn);

          return div;
        }

        function buildSigSection(sigRaw) {
          var div = document.createElement('div');
          div.className = 'jwt-section';
          var header = document.createElement('div');
          header.className = 'jwt-section-header';
          header.innerHTML = '<span class="jwt-section-dot" style="background:#f59e0b"></span><strong>Signature</strong> <span class="jwt-sig-note">(raw Base64URL — not verified)</span>';
          div.appendChild(header);
          var code = document.createElement('code');
          code.className = 'jwt-sig';
          code.textContent = sigRaw;
          div.appendChild(code);
          return div;
        }

        function decode() {
          var raw = document.getElementById('jwt-input').value.trim();
          var statusEl = document.getElementById('jwt-status');
          var resultsEl = document.getElementById('jwt-results');
          resultsEl.innerHTML = '';

          if (!raw) {
            statusEl.textContent = 'Please paste a JWT token.';
            statusEl.className = 'jwt-status error';
            return;
          }

          var parts = raw.split('.');
          if (parts.length !== 3) {
            statusEl.textContent = 'Invalid JWT: expected 3 dot-separated parts, got ' + parts.length + '.';
            statusEl.className = 'jwt-status error';
            return;
          }

          var headerStr = b64urlDecode(parts[0]);
          var payloadStr = b64urlDecode(parts[1]);

          if (!headerStr || !payloadStr) {
            statusEl.textContent = 'Failed to Base64URL-decode token parts.';
            statusEl.className = 'jwt-status error';
            return;
          }

          var header = parseJSON(headerStr);
          var payload = parseJSON(payloadStr);

          resultsEl.appendChild(buildSection('Header', '#6366f1', header));
          resultsEl.appendChild(buildSection('Payload', '#10b981', payload));
          resultsEl.appendChild(buildSigSection(parts[2]));

          statusEl.textContent = 'Decoded successfully.';
          statusEl.className = 'jwt-status success';
          window.trackTool && window.trackTool('jwt_decoder', 'decode');
        }

        document.getElementById('jwt-decode').addEventListener('click', decode);

        document.getElementById('jwt-input').addEventListener('keydown', function (e) {
          if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) decode();
        });

        document.getElementById('jwt-clear').addEventListener('click', function () {
          document.getElementById('jwt-input').value = '';
          document.getElementById('jwt-results').innerHTML = '';
          document.getElementById('jwt-status').textContent = '';
          document.getElementById('jwt-status').className = 'jwt-status';
        });
      })();
    </script>
  </div>

  <h2>How to Use</h2>
  <ol>
    <li>Paste your JWT token into the input box.</li>
    <li>Click <strong>Decode</strong> (or press Ctrl+Enter / Cmd+Enter).</li>
    <li>The Header, Payload, and Signature are displayed with syntax highlighting.</li>
    <li>Timestamp claims (<code>exp</code>, <code>iat</code>, <code>nbf</code>) show a human-readable date and expiry status.</li>
    <li>Click <strong>Copy</strong> in any section to copy that JSON to clipboard.</li>
  </ol>

  <h2>What is a JWT?</h2>
  <p>
    A JSON Web Token (JWT) is a compact, URL-safe token format used for authentication and
    information exchange. It consists of three Base64URL-encoded parts separated by dots:
  </p>
  <ul>
    <li><strong>Header:</strong> Specifies the signing algorithm (e.g., HS256, RS256) and token type.</li>
    <li><strong>Payload:</strong> Contains claims — statements about an entity (typically the user) and additional metadata.</li>
    <li><strong>Signature:</strong> Ensures the token has not been tampered with. Requires the secret or public key to verify.</li>
  </ul>
  <p>
    Common claims include <code>sub</code> (subject), <code>iss</code> (issuer), <code>exp</code> (expiration),
    <code>iat</code> (issued at), and <code>aud</code> (audience).
  </p>
</ToolLayout>

<style>
  .jwt-wrap { display: flex; flex-direction: column; gap: 1rem; }

  .jwt-input-section { display: flex; flex-direction: column; gap: 0.4rem; }

  .jwt-input-section label {
    font-size: 0.82rem;
    font-weight: 600;
    color: #555;
  }

  .jwt-input-section textarea {
    width: 100%;
    min-height: 90px;
    font-family: 'Fira Code', monospace;
    font-size: 0.82rem;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    resize: vertical;
    background: #fafafa;
    word-break: break-all;
  }
  .jwt-input-section textarea:focus { outline: none; border-color: #6366f1; background: #fff; }

  .jwt-actions { display: flex; gap: 0.5rem; margin-top: 0.25rem; }

  .jwt-status { font-size: 0.85rem; min-height: 1.2rem; }
  .jwt-status.success { color: #057a55; }
  .jwt-status.error { color: #c0392b; }

  .jwt-results { display: flex; flex-direction: column; gap: 1rem; }

  .jwt-section {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    overflow: hidden;
  }

  .jwt-section-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: #f8f9fa;
    border-bottom: 1px solid #e5e7eb;
    font-size: 0.88rem;
  }

  .jwt-section-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .jwt-sig-note {
    font-size: 0.78rem;
    color: #888;
    font-weight: 400;
  }

  .jwt-json {
    margin: 0;
    padding: 0.75rem 1rem;
    font-family: 'Fira Code', monospace;
    font-size: 0.82rem;
    line-height: 1.55;
    overflow-x: auto;
    background: #fff;
    white-space: pre;
  }

  .jwt-sig {
    display: block;
    padding: 0.75rem 1rem;
    font-family: 'Fira Code', monospace;
    font-size: 0.82rem;
    color: #555;
    word-break: break-all;
    background: #fff;
  }

  .btn-copy {
    margin: 0.5rem 0.75rem 0.75rem;
    padding: 0.2rem 0.8rem;
    font-size: 0.78rem;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 4px;
    cursor: pointer;
    color: #555;
    display: block;
  }
  .btn-copy:hover { border-color: #6366f1; color: #6366f1; }

  .jv-key { color: #0070f3; }
  .jv-str { color: #e67e22; }
  .jv-num { color: #27ae60; }
  .jv-bool { color: #8e44ad; }
  .jv-null { color: #95a5a6; }

  .jwt-time-hint { font-size: 0.78rem; color: #888; }
  .jwt-expired { color: #e00; font-weight: 700; }
  .jwt-valid { color: #057a55; font-weight: 700; }

  .btn-primary {
    padding: 0.45rem 1.25rem;
    background: #6366f1;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .btn-primary:hover { background: #4f46e5; }

  .btn-ghost {
    padding: 0.45rem 1rem;
    background: none;
    color: #888;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .btn-ghost:hover { color: #e00; }
</style>
