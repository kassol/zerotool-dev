---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolSearchBar from '../../components/ToolSearchBar.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import { getToolIcon } from '../../data/icons';
import { allTools, getToolName, getToolDescription } from '../../data/tools';

const tools = allTools.map(tool => ({
  href: `/tools/${tool.slug}`,
  slug: tool.slug,
  name: getToolName(tool, 'en'),
  description: getToolDescription(tool, 'en'),
  category: tool.category,
}));
---

<BaseLayout
  title="All Tools — ZeroTool"
  description="Browse all free online developer tools: JSON formatter, Base64, UUID generator, URL encoder, regex tester, and more. No sign-up required."
  lang="en"
>
  <div class="tools-page">
    <section class="hero">
      <h1>All Developer Tools</h1>
      <p class="hero-sub">Free, private, browser-based. No sign-up required.</p>
    </section>

    <ToolSearchBar lang="en" />
    <CategoryFilter lang="en" />

    <section class="tools-grid">
      {tools.map(tool => (
        <a href={tool.href} class="tool-card" data-keywords={`${tool.slug} ${tool.name.toLowerCase()} ${tool.description.toLowerCase()}`} data-category={tool.category} data-slug={tool.slug}>
          <span class="tool-icon" set:html={getToolIcon(tool.slug)} />
          <div class="tool-info">
            <h2>{tool.name}</h2>
            <p>{tool.description}</p>
          </div>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .tools-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1rem 4rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .hero-sub {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    margin: 0;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 860px) {
    .tools-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .tools-grid { grid-template-columns: 1fr; }
    .tool-card {
      flex-direction: row;
      align-items: center;
      padding: 0.85rem 1rem;
      gap: 0.75rem;
    }
    .tool-icon {
      width: 36px;
      height: 36px;
    }
    .tool-icon :global(svg) {
      width: 18px;
      height: 18px;
    }
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: inherit;
    background: var(--color-bg);
    box-shadow: var(--shadow-card);
    transition: border-color var(--transition-fast), box-shadow var(--transition-med), transform var(--transition-med);
  }

  .tool-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .tool-icon {
    width: 44px;
    height: 44px;
    background: var(--color-bg-icon);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .tool-icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .tool-info h2 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
  }

  .tool-info p {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }
</style>
