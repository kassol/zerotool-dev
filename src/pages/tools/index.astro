---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolDirectory from '../../components/ToolDirectory.astro';
import { allTools } from '../../data/tools';

const toolCount = allTools.length;
---

<BaseLayout
  title="All Tools — ZeroTool"
  description={`Browse ${toolCount} free online developer tools: JSON formatter, Base64, UUID generator, URL encoder, regex tester, and more.`}
  lang="en"
>
  <ToolDirectory lang="en" mode="tools" />
</BaseLayout>
