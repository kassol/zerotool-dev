---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  toolName="Diff Checker"
  title="Diff Checker Online — Compare Text Side by Side | ZeroTool"
  description="Compare two pieces of text and see the differences highlighted line by line. Free, browser-based text diff tool. No data sent to servers."
  lang="en"
  faqItems={[
    {
      question: "Is my text sent to any server?",
      answer: "No. All diff computation runs entirely in your browser. Your text never leaves your machine.",
    },
    {
      question: "What diffing algorithm does this use?",
      answer: "This tool uses a line-level Longest Common Subsequence (LCS) algorithm — the same principle used by Unix diff.",
    },
    {
      question: "Can I compare code files?",
      answer: "Yes. Paste any plain text — source code, config files, prose — and this tool will show added and removed lines.",
    },
    {
      question: "Are whitespace-only differences shown?",
      answer: "Yes. By default all differences are shown, including lines that differ only in whitespace.",
    },
  ]}
>
  <div slot="tool">
    <div class="diff-wrap">
      <div class="diff-inputs">
        <div class="diff-panel">
          <label for="diff-original">Original</label>
          <textarea id="diff-original" placeholder="Paste original text here..." spellcheck="false"></textarea>
        </div>
        <div class="diff-panel">
          <label for="diff-modified">Modified</label>
          <textarea id="diff-modified" placeholder="Paste modified text here..." spellcheck="false"></textarea>
        </div>
      </div>

      <div class="diff-actions">
        <button id="diff-compare" class="btn-primary">Compare</button>
        <button id="diff-swap" class="btn-secondary">Swap</button>
        <button id="diff-clear" class="btn-ghost">Clear</button>
      </div>

      <div id="diff-status" class="diff-status" aria-live="polite"></div>

      <div id="diff-output" class="diff-output"></div>
    </div>

    <script is:inline>
      (function () {
        // LCS-based line diff
        function lcs(a, b) {
          var m = a.length, n = b.length;
          var dp = [];
          for (var i = 0; i <= m; i++) { dp[i] = []; for (var j = 0; j <= n; j++) dp[i][j] = 0; }
          for (var i = 1; i <= m; i++) {
            for (var j = 1; j <= n; j++) {
              dp[i][j] = a[i-1] === b[j-1] ? dp[i-1][j-1] + 1 : Math.max(dp[i-1][j], dp[i][j-1]);
            }
          }
          // Backtrack
          var result = [];
          var i = m, j = n;
          while (i > 0 || j > 0) {
            if (i > 0 && j > 0 && a[i-1] === b[j-1]) {
              result.unshift({ type: 'equal', val: a[i-1] });
              i--; j--;
            } else if (j > 0 && (i === 0 || dp[i][j-1] >= dp[i-1][j])) {
              result.unshift({ type: 'add', val: b[j-1] });
              j--;
            } else {
              result.unshift({ type: 'del', val: a[i-1] });
              i--;
            }
          }
          return result;
        }

        function esc(s) {
          return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        function compare() {
          var origLines = document.getElementById('diff-original').value.split('\n');
          var modLines = document.getElementById('diff-modified').value.split('\n');
          var statusEl = document.getElementById('diff-status');
          var outputEl = document.getElementById('diff-output');
          outputEl.innerHTML = '';

          if (!document.getElementById('diff-original').value && !document.getElementById('diff-modified').value) {
            statusEl.textContent = 'Please enter text in at least one panel.';
            statusEl.className = 'diff-status error';
            return;
          }

          var diff = lcs(origLines, modLines);
          var addCount = 0, delCount = 0;
          var html = '';
          var lineNum = 0;

          diff.forEach(function (op) {
            if (op.type === 'equal') {
              lineNum++;
              html += '<div class="diff-line diff-equal"><span class="diff-ln">' + lineNum + '</span><span class="diff-marker"> </span><span class="diff-text">' + esc(op.val) + '</span></div>';
            } else if (op.type === 'del') {
              html += '<div class="diff-line diff-del"><span class="diff-ln">-</span><span class="diff-marker">-</span><span class="diff-text">' + esc(op.val) + '</span></div>';
              delCount++;
            } else {
              html += '<div class="diff-line diff-add"><span class="diff-ln">+</span><span class="diff-marker">+</span><span class="diff-text">' + esc(op.val) + '</span></div>';
              addCount++;
            }
          });

          outputEl.innerHTML = html || '<div class="diff-empty">No differences found.</div>';

          if (addCount === 0 && delCount === 0) {
            statusEl.textContent = 'Files are identical.';
            statusEl.className = 'diff-status success';
          } else {
            statusEl.textContent = '+' + addCount + ' additions, -' + delCount + ' deletions.';
            statusEl.className = 'diff-status info';
          }
          window.trackTool && window.trackTool('diff_checker', 'compare');
        }

        document.getElementById('diff-compare').addEventListener('click', compare);

        document.getElementById('diff-swap').addEventListener('click', function () {
          var orig = document.getElementById('diff-original');
          var mod = document.getElementById('diff-modified');
          var tmp = orig.value;
          orig.value = mod.value;
          mod.value = tmp;
          document.getElementById('diff-output').innerHTML = '';
          document.getElementById('diff-status').textContent = 'Swapped.';
          document.getElementById('diff-status').className = 'diff-status';
        });

        document.getElementById('diff-clear').addEventListener('click', function () {
          document.getElementById('diff-original').value = '';
          document.getElementById('diff-modified').value = '';
          document.getElementById('diff-output').innerHTML = '';
          document.getElementById('diff-status').textContent = '';
          document.getElementById('diff-status').className = 'diff-status';
        });
      })();
    </script>
  </div>

  <h2>How to Use</h2>
  <ol>
    <li>Paste your original text into the <strong>Original</strong> panel.</li>
    <li>Paste your modified text into the <strong>Modified</strong> panel.</li>
    <li>Click <strong>Compare</strong> to see the diff.</li>
    <li>Lines highlighted in <span style="color:#c0392b">red</span> were removed; lines in <span style="color:#057a55">green</span> were added.</li>
    <li>Use <strong>Swap</strong> to reverse the comparison direction.</li>
  </ol>

  <h2>About This Tool</h2>
  <p>
    This diff checker performs line-by-line comparison using the Longest Common Subsequence (LCS) algorithm —
    the same principle used by <code>git diff</code> and Unix <code>diff</code>. It's ideal for comparing
    code, configuration files, log output, or any text where line-level changes matter.
  </p>
</ToolLayout>

<style>
  .diff-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .diff-inputs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  @media (max-width: 600px) {
    .diff-inputs { grid-template-columns: 1fr; }
  }

  .diff-panel { display: flex; flex-direction: column; gap: 0.3rem; }

  .diff-panel label {
    font-size: 0.82rem;
    font-weight: 600;
    color: #555;
  }

  .diff-panel textarea {
    width: 100%;
    min-height: 160px;
    font-family: 'Fira Code', monospace;
    font-size: 0.82rem;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    resize: vertical;
    background: #fafafa;
  }
  .diff-panel textarea:focus { outline: none; border-color: #0070f3; background: #fff; }

  .diff-actions { display: flex; gap: 0.5rem; }

  .diff-status { font-size: 0.85rem; min-height: 1.2rem; }
  .diff-status.success { color: #057a55; }
  .diff-status.error { color: #c0392b; }
  .diff-status.info { color: #0070f3; }

  .diff-output {
    font-family: 'Fira Code', monospace;
    font-size: 0.82rem;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    overflow-x: auto;
    background: #fff;
  }

  .diff-line {
    display: flex;
    align-items: flex-start;
    min-height: 1.6rem;
    padding: 0.15rem 0;
  }

  .diff-line:not(:last-child) { border-bottom: 1px solid #f3f4f6; }

  .diff-equal { background: #fff; }
  .diff-del { background: #fff0f0; }
  .diff-add { background: #f0fff4; }

  .diff-ln {
    min-width: 38px;
    text-align: right;
    padding: 0 0.5rem;
    color: #aaa;
    font-size: 0.78rem;
    user-select: none;
    flex-shrink: 0;
    line-height: 1.6rem;
    border-right: 1px solid #eee;
  }

  .diff-marker {
    width: 20px;
    text-align: center;
    flex-shrink: 0;
    font-weight: 700;
    line-height: 1.6rem;
  }
  .diff-del .diff-marker { color: #c0392b; }
  .diff-add .diff-marker { color: #057a55; }

  .diff-text {
    flex: 1;
    padding: 0 0.5rem;
    white-space: pre;
    line-height: 1.6rem;
  }
  .diff-del .diff-text { color: #c0392b; }
  .diff-add .diff-text { color: #057a55; }

  .diff-empty { padding: 1.5rem; text-align: center; color: #888; }

  .btn-primary {
    padding: 0.45rem 1.25rem;
    background: #0070f3;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .btn-primary:hover { background: #005bd3; }

  .btn-secondary {
    padding: 0.45rem 1.25rem;
    background: #fff;
    color: #333;
    border: 1px solid #ddd;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .btn-secondary:hover { border-color: #0070f3; color: #0070f3; }

  .btn-ghost {
    padding: 0.45rem 1rem;
    background: none;
    color: #888;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .btn-ghost:hover { color: #e00; }
</style>
