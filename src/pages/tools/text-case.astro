---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  toolName="Text Case Converter"
  title="Text Case Converter Online — Free Tool | ZeroTool"
  description="Convert text to UPPER CASE, lower case, Title Case, camelCase, PascalCase, kebab-case, and snake_case instantly. Free online tool."
  lang="en"
  faqItems={[
    {
      question: "What is camelCase?",
      answer: "camelCase joins words with no separator, capitalizing each word after the first. Example: 'hello world' → 'helloWorld'. Used widely in JavaScript variable names.",
    },
    {
      question: "What is snake_case?",
      answer: "snake_case replaces spaces with underscores and lowercases everything. Example: 'Hello World' → 'hello_world'. Common in Python and database column names.",
    },
    {
      question: "What is kebab-case?",
      answer: "kebab-case replaces spaces with hyphens and lowercases everything. Example: 'Hello World' → 'hello-world'. Standard for CSS class names and URL slugs.",
    },
    {
      question: "Is my text sent anywhere?",
      answer: "No. All conversions run entirely in your browser with JavaScript. Nothing is sent to any server.",
    },
  ]}
>
  <div slot="tool">
    <div class="tc-wrap">
      <div class="tc-row">
        <label for="tc-input">Input Text</label>
        <textarea
          id="tc-input"
          placeholder="Enter your text here..."
          rows="4"
          spellcheck="false"
        ></textarea>
      </div>

      <div class="tc-cases" id="tc-cases">
        <!-- Populated by JS -->
      </div>
    </div>

    <script is:inline>
      (function () {
        var inputEl = document.getElementById('tc-input');
        var casesEl = document.getElementById('tc-cases');

        var converters = [
          {
            id: 'upper',
            label: 'UPPER CASE',
            fn: function (s) { return s.toUpperCase(); },
          },
          {
            id: 'lower',
            label: 'lower case',
            fn: function (s) { return s.toLowerCase(); },
          },
          {
            id: 'title',
            label: 'Title Case',
            fn: function (s) {
              return s.replace(/\w\S*/g, function (w) {
                return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
              });
            },
          },
          {
            id: 'sentence',
            label: 'Sentence case',
            fn: function (s) {
              return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase();
            },
          },
          {
            id: 'camel',
            label: 'camelCase',
            fn: function (s) {
              return s
                .toLowerCase()
                .replace(/[^a-z0-9]+(.)/g, function (_, c) { return c.toUpperCase(); });
            },
          },
          {
            id: 'pascal',
            label: 'PascalCase',
            fn: function (s) {
              return s
                .toLowerCase()
                .replace(/(^|[^a-z0-9]+)(.)/g, function (_, __, c) { return c.toUpperCase(); });
            },
          },
          {
            id: 'kebab',
            label: 'kebab-case',
            fn: function (s) {
              return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
            },
          },
          {
            id: 'snake',
            label: 'snake_case',
            fn: function (s) {
              return s.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
            },
          },
          {
            id: 'constant',
            label: 'CONSTANT_CASE',
            fn: function (s) {
              return s.toUpperCase().replace(/[^A-Z0-9]+/g, '_').replace(/^_|_$/g, '');
            },
          },
        ];

        // Build output rows
        converters.forEach(function (c) {
          var row = document.createElement('div');
          row.className = 'tc-output-row';

          var lbl = document.createElement('span');
          lbl.className = 'tc-case-label';
          lbl.textContent = c.label;

          var out = document.createElement('input');
          out.type = 'text';
          out.id = 'tc-out-' + c.id;
          out.readOnly = true;
          out.className = 'tc-case-output';
          out.placeholder = c.fn('hello world');

          var btn = document.createElement('button');
          btn.className = 'btn-copy';
          btn.textContent = 'Copy';
          btn.addEventListener('click', function () {
            if (!out.value) return;
            navigator.clipboard.writeText(out.value).then(function () {
              btn.textContent = 'Copied!';
              setTimeout(function () { btn.textContent = 'Copy'; }, 1500);
            });
            window.trackTool && window.trackTool('text_case', 'copy_' + c.id);
          });

          row.appendChild(lbl);
          row.appendChild(out);
          row.appendChild(btn);
          casesEl.appendChild(row);
        });

        function convert(text) {
          converters.forEach(function (c) {
            document.getElementById('tc-out-' + c.id).value = text ? c.fn(text) : '';
          });
        }

        inputEl.addEventListener('input', function () {
          convert(inputEl.value);
        });
      })();
    </script>
  </div>

  <h2>How to Use</h2>
  <ol>
    <li>Type or paste text into the input box.</li>
    <li>All case variants update instantly as you type.</li>
    <li>Click <strong>Copy</strong> next to any variant to copy it.</li>
  </ol>

  <h2>Case Formats Reference</h2>
  <table>
    <thead>
      <tr><th>Name</th><th>Example</th><th>Common Use</th></tr>
    </thead>
    <tbody>
      <tr><td>UPPER CASE</td><td>HELLO WORLD</td><td>Headings, constants (informal)</td></tr>
      <tr><td>lower case</td><td>hello world</td><td>General text normalization</td></tr>
      <tr><td>Title Case</td><td>Hello World</td><td>Titles, proper nouns</td></tr>
      <tr><td>Sentence case</td><td>Hello world</td><td>Normal prose</td></tr>
      <tr><td>camelCase</td><td>helloWorld</td><td>JS variables, JSON keys</td></tr>
      <tr><td>PascalCase</td><td>HelloWorld</td><td>Classes, components</td></tr>
      <tr><td>kebab-case</td><td>hello-world</td><td>CSS classes, URL slugs</td></tr>
      <tr><td>snake_case</td><td>hello_world</td><td>Python, SQL columns</td></tr>
      <tr><td>CONSTANT_CASE</td><td>HELLO_WORLD</td><td>Env vars, constants</td></tr>
    </tbody>
  </table>
</ToolLayout>

<style>
  .tc-wrap { display: flex; flex-direction: column; gap: 1rem; }

  .tc-row { display: flex; flex-direction: column; gap: 0.4rem; }

  .tc-row label { font-size: 0.85rem; font-weight: 600; color: #555; }

  .tc-row textarea {
    width: 100%;
    font-family: inherit;
    font-size: 0.95rem;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    resize: vertical;
    background: #fafafa;
  }

  .tc-row textarea:focus { outline: none; border-color: #0070f3; background: #fff; }

  .tc-cases { display: flex; flex-direction: column; gap: 0.5rem; }

  .tc-output-row {
    display: grid;
    grid-template-columns: 130px 1fr auto;
    gap: 0.5rem;
    align-items: center;
  }

  .tc-case-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #555;
    font-family: monospace;
    white-space: nowrap;
  }

  .tc-case-output {
    font-family: 'Fira Code', monospace;
    font-size: 0.88rem;
    padding: 0.4rem 0.6rem;
    border: 1px solid #ddd;
    border-radius: 5px;
    background: #fafafa;
    min-width: 0;
  }

  .btn-copy {
    padding: 0.2rem 0.7rem;
    font-size: 0.78rem;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 4px;
    cursor: pointer;
    color: #555;
    white-space: nowrap;
  }
  .btn-copy:hover { border-color: #0070f3; color: #0070f3; }

  table { width: 100%; border-collapse: collapse; font-size: 0.9rem; margin-top: 0.5rem; }
  th, td { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid #eee; }
  th { font-weight: 600; background: #f8f9fa; }
  td:nth-child(2) { font-family: monospace; }

  @media (max-width: 500px) {
    .tc-output-row { grid-template-columns: 110px 1fr auto; }
  }
</style>
