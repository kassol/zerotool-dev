---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  toolName="Regex Tester"
  title="Regex Tester & Debugger — Free Online | ZeroTool"
  description="Test and debug regular expressions in real time. See all matches highlighted, capture groups listed, and get instant match counts. Free, browser-based."
  lang="en"
  faqItems={[
    {
      question: "Which regex flavor does this tool use?",
      answer: "JavaScript (ECMAScript) regex via the browser's built-in RegExp engine.",
    },
    {
      question: "What flags are supported?",
      answer: "g (global), i (case-insensitive), m (multiline), and s (dotAll — dot matches newline). You can combine them.",
    },
    {
      question: "Why does 'g' flag matter?",
      answer: "Without 'g', only the first match is returned. With 'g', all matches are found.",
    },
    {
      question: "Are capture groups shown?",
      answer: "Yes. When matches have capture groups they are listed below each match.",
    },
  ]}
>
  <div slot="tool">
    <div class="rt-wrap">
      <div class="rt-pattern-row">
        <span class="rt-slash">/</span>
        <input id="rt-pattern" type="text" placeholder="(\\w+)@(\\w+\\.\\w+)" spellcheck="false" autocomplete="off" />
        <span class="rt-slash">/</span>
        <div class="rt-flags">
          <label title="global"><input type="checkbox" value="g" checked /> g</label>
          <label title="case-insensitive"><input type="checkbox" value="i" /> i</label>
          <label title="multiline"><input type="checkbox" value="m" /> m</label>
          <label title="dotAll"><input type="checkbox" value="s" /> s</label>
        </div>
      </div>

      <div class="rt-field">
        <label for="rt-test">Test String</label>
        <textarea
          id="rt-test"
          placeholder="Paste your text here..."
          spellcheck="false"
        ></textarea>
      </div>

      <div id="rt-status" class="rt-status" aria-live="polite"></div>

      <div class="rt-field">
        <label>Highlighted Matches</label>
        <div id="rt-highlight" class="rt-highlight"></div>
      </div>

      <div id="rt-matches" class="rt-matches"></div>
    </div>

    <script is:inline>
      (function () {
        var patternEl = document.getElementById('rt-pattern');
        var testEl = document.getElementById('rt-test');
        var statusEl = document.getElementById('rt-status');
        var highlightEl = document.getElementById('rt-highlight');
        var matchesEl = document.getElementById('rt-matches');
        var flagCheckboxes = document.querySelectorAll('.rt-flags input[type="checkbox"]');

        function getFlags() {
          var f = '';
          flagCheckboxes.forEach(function (cb) { if (cb.checked) f += cb.value; });
          return f;
        }

        function escapeHtml(str) {
          return str
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
        }

        function run() {
          var pattern = patternEl.value;
          var text = testEl.value;
          highlightEl.innerHTML = '';
          matchesEl.innerHTML = '';

          if (!pattern) {
            highlightEl.textContent = text;
            statusEl.textContent = '';
            statusEl.className = 'rt-status';
            return;
          }

          var flags = getFlags();
          var re;
          try {
            re = new RegExp(pattern, flags.includes('g') ? flags : flags + 'g');
          } catch (e) {
            statusEl.textContent = 'Invalid regex: ' + e.message;
            statusEl.className = 'rt-status error';
            highlightEl.textContent = text;
            return;
          }

          var allMatches = [];
          var m;
          re.lastIndex = 0;
          while ((m = re.exec(text)) !== null) {
            allMatches.push({ index: m.index, end: m.index + m[0].length, match: m[0], groups: Array.from(m).slice(1) });
            if (m[0].length === 0) re.lastIndex++; // avoid infinite loop on zero-length match
            if (!flags.includes('g')) break;
          }

          var count = allMatches.length;
          statusEl.textContent = count === 0 ? 'No matches.' : count + ' match' + (count > 1 ? 'es' : '') + ' found.';
          statusEl.className = 'rt-status ' + (count > 0 ? 'success' : 'none');

          // Build highlighted HTML
          var html = '';
          var cursor = 0;
          allMatches.forEach(function (match) {
            html += escapeHtml(text.slice(cursor, match.index));
            html += '<mark>' + escapeHtml(match.match) + '</mark>';
            cursor = match.end;
          });
          html += escapeHtml(text.slice(cursor));
          highlightEl.innerHTML = html;

          // List matches
          if (count > 0) {
            var ul = document.createElement('ul');
            ul.className = 'rt-match-list';
            allMatches.slice(0, 100).forEach(function (match, i) {
              var li = document.createElement('li');
              var header = '<strong>Match ' + (i + 1) + ':</strong> <code>' + escapeHtml(match.match) + '</code> <span class="rt-pos">(index ' + match.index + ')</span>';
              if (match.groups.length > 0 && match.groups.some(function(g){ return g !== undefined; })) {
                header += '<ul class="rt-groups">' + match.groups.map(function(g, j) {
                  return '<li>Group ' + (j+1) + ': <code>' + (g !== undefined ? escapeHtml(g) : '<em>undefined</em>') + '</code></li>';
                }).join('') + '</ul>';
              }
              li.innerHTML = header;
              ul.appendChild(li);
            });
            if (count > 100) {
              var more = document.createElement('li');
              more.textContent = '... and ' + (count - 100) + ' more matches.';
              ul.appendChild(more);
            }
            matchesEl.appendChild(ul);
          }
        }

        patternEl.addEventListener('input', run);
        testEl.addEventListener('input', run);
        flagCheckboxes.forEach(function (cb) { cb.addEventListener('change', run); });
      })();
    </script>
  </div>

  <h2>How to Use</h2>
  <ol>
    <li>Enter your regular expression in the pattern field (without slashes).</li>
    <li>Paste or type the text you want to test in the <strong>Test String</strong> area.</li>
    <li>Toggle flags: <code>g</code> (all matches), <code>i</code> (case-insensitive), <code>m</code> (multiline), <code>s</code> (dotAll).</li>
    <li>Matches are highlighted in real time. Capture groups are listed below.</li>
  </ol>

  <h2>Common Regex Patterns</h2>
  <ul>
    <li><code>\d+</code> — one or more digits</li>
    <li><code>\w+</code> — one or more word characters (letters, digits, underscore)</li>
    <li><code>[a-zA-Z]+</code> — letters only</li>
    <li><code>^\s+|\s+$</code> — leading or trailing whitespace</li>
    <li><code>(\w+)@(\w+\.\w+)</code> — simple email capture</li>
    <li><code>https?://\S+</code> — URLs</li>
  </ul>
</ToolLayout>

<style>
  .rt-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .rt-pattern-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .rt-slash {
    font-size: 1.4rem;
    color: #0070f3;
    font-weight: 700;
    font-family: monospace;
    line-height: 1;
    user-select: none;
  }

  .rt-pattern-row input {
    flex: 1;
    min-width: 120px;
    padding: 0.5rem 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-family: monospace;
    font-size: 0.95rem;
    background: #fafafa;
  }

  .rt-pattern-row input:focus { outline: none; border-color: #0070f3; background: #fff; }

  .rt-flags {
    display: flex;
    gap: 0.75rem;
    font-size: 0.9rem;
    font-family: monospace;
  }

  .rt-flags label {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    cursor: pointer;
    color: #555;
  }

  .rt-field { display: flex; flex-direction: column; gap: 0.3rem; }

  .rt-field > label {
    font-size: 0.82rem;
    font-weight: 600;
    color: #555;
  }

  .rt-field textarea {
    width: 100%;
    min-height: 100px;
    font-family: monospace;
    font-size: 0.88rem;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    resize: vertical;
    background: #fafafa;
  }

  .rt-field textarea:focus { outline: none; border-color: #0070f3; background: #fff; }

  .rt-highlight {
    min-height: 60px;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    background: #fafafa;
    font-family: monospace;
    font-size: 0.88rem;
    white-space: pre-wrap;
    word-break: break-all;
    line-height: 1.6;
  }

  .rt-highlight mark {
    background: #ffe082;
    color: #111;
    border-radius: 2px;
    padding: 0 1px;
  }

  .rt-status { font-size: 0.85rem; min-height: 1.2rem; }
  .rt-status.success { color: #057a55; }
  .rt-status.error { color: #c0392b; }
  .rt-status.none { color: #888; }

  .rt-match-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .rt-match-list > li {
    padding: 0.5rem 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    font-size: 0.88rem;
    background: #fafafa;
  }

  .rt-match-list code {
    background: #f0f4ff;
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
    font-family: monospace;
  }

  .rt-pos { color: #888; font-size: 0.82rem; }

  .rt-groups {
    list-style: none;
    padding: 0.3rem 0 0 1rem;
    margin: 0;
    color: #555;
    font-size: 0.84rem;
  }
</style>
