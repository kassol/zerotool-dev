---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  toolName="Base64 Encode / Decode"
  title="Base64 Encode & Decode Online — Free Tool | ZeroTool"
  description="Encode text to Base64 or decode Base64 strings back to plain text instantly. Free, browser-based, no data sent to servers."
  lang="en"
  faqItems={[
    {
      question: "What is Base64?",
      answer: "Base64 is an encoding scheme that converts binary data to ASCII text using 64 printable characters. It's commonly used in data URIs, email attachments, and API tokens.",
    },
    {
      question: "Is my data sent to any server?",
      answer: "No. Everything runs in your browser using built-in JavaScript APIs (btoa/atob). Nothing leaves your machine.",
    },
    {
      question: "Can I encode binary files?",
      answer: "This tool handles text (UTF-8). For binary files, you need a file-based encoder — coming soon.",
    },
    {
      question: "Why does decoding fail?",
      answer: "Base64 strings must have valid characters and correct padding. If your string looks truncated, try adding '=' at the end.",
    },
  ]}
>
  <div slot="tool">
    <div class="b64-wrap">
      <div class="b64-mode">
        <label>
          <input type="radio" name="b64mode" value="encode" checked /> Encode
        </label>
        <label>
          <input type="radio" name="b64mode" value="decode" /> Decode
        </label>
      </div>

      <div class="b64-row">
        <label for="b64-input" id="b64-input-label"><span>Plain Text</span></label>
        <textarea
          id="b64-input"
          placeholder="Enter text to encode..."
          spellcheck="false"
        ></textarea>
      </div>

      <div class="b64-actions">
        <button id="b64-run" class="btn-primary">Encode</button>
        <button id="b64-swap" class="btn-secondary">Swap</button>
        <button id="b64-clear" class="btn-ghost">Clear</button>
      </div>

      <div id="b64-status" class="b64-status" aria-live="polite"></div>

      <div class="b64-row">
        <label for="b64-output" id="b64-output-label">
          <span>Base64</span>
          <button id="b64-copy" class="btn-copy" type="button">Copy</button>
        </label>
        <textarea
          id="b64-output"
          placeholder="Result appears here..."
          readonly
          spellcheck="false"
        ></textarea>
      </div>
    </div>

    <script is:inline>
      (function () {
        var inputEl = document.getElementById('b64-input');
        var outputEl = document.getElementById('b64-output');
        var statusEl = document.getElementById('b64-status');
        var runBtn = document.getElementById('b64-run');
        var copyBtn = document.getElementById('b64-copy');
        var inputLabel = document.getElementById('b64-input-label');
        var outputLabel = document.getElementById('b64-output-label');
        var mode = 'encode';

        function setStatus(msg, isError) {
          statusEl.textContent = msg;
          statusEl.className = 'b64-status ' + (isError ? 'error' : 'success');
        }

        function clearStatus() {
          statusEl.textContent = '';
          statusEl.className = 'b64-status';
        }

        function updateLabels() {
          if (mode === 'encode') {
            inputLabel.querySelector('span').textContent = 'Plain Text';
            outputLabel.querySelector('span').textContent = 'Base64';
            inputEl.placeholder = 'Enter text to encode...';
            outputEl.placeholder = 'Base64 output appears here...';
            runBtn.textContent = 'Encode';
          } else {
            inputLabel.querySelector('span').textContent = 'Base64';
            outputLabel.querySelector('span').textContent = 'Plain Text';
            inputEl.placeholder = 'Enter Base64 string to decode...';
            outputEl.placeholder = 'Decoded text appears here...';
            runBtn.textContent = 'Decode';
          }
        }

        document.querySelectorAll('input[name="b64mode"]').forEach(function (radio) {
          radio.addEventListener('change', function () {
            mode = this.value;
            updateLabels();
            clearStatus();
            outputEl.value = '';
          });
        });

        runBtn.addEventListener('click', function () {
          var val = inputEl.value;
          if (!val) { clearStatus(); outputEl.value = ''; return; }
          try {
            if (mode === 'encode') {
              outputEl.value = btoa(unescape(encodeURIComponent(val)));
              setStatus('Encoded.', false);
            } else {
              outputEl.value = decodeURIComponent(escape(atob(val.trim())));
              setStatus('Decoded.', false);
            }
          } catch (e) {
            outputEl.value = '';
            setStatus('Error: ' + e.message, true);
          }
        });

        document.getElementById('b64-swap').addEventListener('click', function () {
          var tmp = inputEl.value;
          inputEl.value = outputEl.value;
          outputEl.value = tmp;
          clearStatus();
        });

        document.getElementById('b64-clear').addEventListener('click', function () {
          inputEl.value = '';
          outputEl.value = '';
          clearStatus();
        });

        copyBtn.addEventListener('click', function () {
          if (!outputEl.value) return;
          navigator.clipboard.writeText(outputEl.value).then(function () {
            copyBtn.textContent = 'Copied!';
            setTimeout(function () { copyBtn.textContent = 'Copy'; }, 1500);
          });
        });
      })();
    </script>
  </div>

  <h2>How to Use</h2>
  <ol>
    <li>Select <strong>Encode</strong> or <strong>Decode</strong> mode.</li>
    <li>Paste your text or Base64 string into the input box.</li>
    <li>Click the action button.</li>
    <li>Copy the result with the <strong>Copy</strong> button.</li>
    <li>Use <strong>Swap</strong> to move the output back to input for chained operations.</li>
  </ol>

  <h2>Common Use Cases</h2>
  <ul>
    <li><strong>API authentication:</strong> Basic Auth headers use Base64-encoded credentials.</li>
    <li><strong>Data URIs:</strong> Inline images and fonts in CSS/HTML are Base64-encoded.</li>
    <li><strong>JWT tokens:</strong> The header and payload sections are Base64url-encoded.</li>
    <li><strong>Email:</strong> MIME attachments are Base64-encoded.</li>
  </ul>
</ToolLayout>

<style>
  .b64-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .b64-mode { display: flex; gap: 1.5rem; font-size: 0.95rem; }
  .b64-mode label { display: flex; align-items: center; gap: 0.4rem; cursor: pointer; }

  .b64-row { display: flex; flex-direction: column; gap: 0.4rem; }

  .b64-row label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #555;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .b64-row textarea {
    width: 100%;
    min-height: 140px;
    font-family: 'Fira Code', monospace;
    font-size: 0.88rem;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    resize: vertical;
    background: #fafafa;
  }

  .b64-row textarea:focus { outline: none; border-color: #0070f3; background: #fff; }

  .b64-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .btn-primary {
    padding: 0.45rem 1.25rem;
    background: #0070f3;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .btn-primary:hover { background: #005bd3; }

  .btn-secondary {
    padding: 0.45rem 1.25rem;
    background: #fff;
    color: #333;
    border: 1px solid #ddd;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .btn-secondary:hover { border-color: #0070f3; color: #0070f3; }

  .btn-ghost {
    padding: 0.45rem 1rem;
    background: none;
    color: #888;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .btn-ghost:hover { color: #e00; }

  .btn-copy {
    padding: 0.2rem 0.7rem;
    font-size: 0.78rem;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 4px;
    cursor: pointer;
    color: #555;
  }
  .btn-copy:hover { border-color: #0070f3; color: #0070f3; }

  .b64-status { font-size: 0.85rem; min-height: 1.2rem; }
  .b64-status.success { color: #057a55; }
  .b64-status.error { color: #c0392b; }
</style>
