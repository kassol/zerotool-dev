---
import ToolLayout from '../../layouts/ToolLayout.astro';
import AspectRatioTool from '../../components/tools/AspectRatioTool.astro';
---

<ToolLayout
  toolName="Aspect Ratio Calculator"
  title="Aspect Ratio Calculator — Resize & Scale Dimensions | ZeroTool"
  description="Calculate aspect ratios, resize dimensions proportionally, and explore common presets like 16:9 and 4:3. Free online tool."
  lang="en"
  faqItems={[
    {
      question: "What is an aspect ratio?",
      answer: "An aspect ratio is the proportional relationship between width and height. For example, 16:9 means for every 16 units of width, there are 9 units of height.",
    },
    {
      question: "How does the resize feature work?",
      answer: "Enter your current width and height to establish the ratio. Then change either dimension — the other will automatically adjust to maintain the same aspect ratio.",
    },
    {
      question: "What are common aspect ratios?",
      answer: "16:9 (widescreen monitors, YouTube), 4:3 (classic TV, iPad), 21:9 (ultrawide monitors), 1:1 (Instagram square), 9:16 (mobile stories), 3:2 (DSLR photos).",
    },
    {
      question: "Is my data sent anywhere?",
      answer: "No. All calculations run 100% in your browser. Nothing is sent to any server.",
    },
  ]}
>
  <AspectRatioTool slot="tool" />

  <h2>How to Use</h2>
  <ol>
    <li>Enter a <strong>Width</strong> and <strong>Height</strong> to see the simplified aspect ratio.</li>
    <li>Click a <strong>preset</strong> button (16:9, 4:3, etc.) to quickly set common ratios.</li>
    <li>Use the <strong>Lock Ratio</strong> toggle to maintain the ratio when changing dimensions.</li>
    <li>The visual preview shows the shape of your aspect ratio.</li>
  </ol>

  <h2>Common Aspect Ratios</h2>
  <table>
    <thead><tr><th>Ratio</th><th>Use Case</th></tr></thead>
    <tbody>
      <tr><td>16:9</td><td>Widescreen monitors, YouTube, HDTV</td></tr>
      <tr><td>4:3</td><td>Classic TV, iPad, presentations</td></tr>
      <tr><td>21:9</td><td>Ultrawide monitors, cinema</td></tr>
      <tr><td>1:1</td><td>Instagram square posts</td></tr>
      <tr><td>9:16</td><td>Mobile stories, TikTok, Reels</td></tr>
      <tr><td>3:2</td><td>DSLR photography, MacBook displays</td></tr>
    </tbody>
  </table>

  <h2>Aspect Ratio in Web Design</h2>
  <p>Understanding aspect ratios is crucial for responsive design, video embeds, image cropping, and CSS <code>aspect-ratio</code> property. This calculator helps designers and developers quickly find the right dimensions for any target ratio.</p>
</ToolLayout>
