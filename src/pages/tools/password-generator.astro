---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  toolName="Password Generator"
  title="Password Generator — Strong Random Passwords Online | ZeroTool"
  description="Generate strong, random passwords instantly. Customize length and character sets. Cryptographically secure. Free, browser-based, no password stored or transmitted."
  lang="en"
  faqItems={[
    {
      question: "Are generated passwords stored anywhere?",
      answer: "No. Passwords are generated in your browser using the Web Crypto API and are never sent to any server. Close the tab and they're gone.",
    },
    {
      question: "Is this cryptographically secure?",
      answer: "Yes. This tool uses window.crypto.getRandomValues() — the same source of randomness used for TLS keys and other cryptographic operations in browsers.",
    },
    {
      question: "What password length should I use?",
      answer: "For most accounts, 16+ characters is sufficient. For highly sensitive accounts (banking, email, work systems), use 24+ characters.",
    },
    {
      question: "Should I include special characters?",
      answer: "Yes when allowed. Special characters increase entropy significantly. However, some sites restrict allowed characters — use the checkboxes to match site requirements.",
    },
  ]}
>
  <div slot="tool">
    <div class="pg-wrap">
      <div class="pg-output-row">
        <div id="pg-output" class="pg-output">Click Generate</div>
        <button id="pg-copy" class="btn-icon" title="Copy to clipboard" aria-label="Copy">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        </button>
      </div>

      <div class="pg-strength-bar">
        <div id="pg-strength-fill" class="pg-strength-fill"></div>
      </div>
      <div id="pg-strength-label" class="pg-strength-label"></div>

      <div class="pg-controls">
        <div class="pg-length-row">
          <label for="pg-length-input">Length:</label>
          <input type="range" id="pg-length" min="4" max="128" value="20" />
          <input type="number" id="pg-length-input" min="4" max="128" value="20" />
        </div>

        <div class="pg-checkboxes">
          <label><input type="checkbox" id="pg-upper" checked /> Uppercase (A–Z)</label>
          <label><input type="checkbox" id="pg-lower" checked /> Lowercase (a–z)</label>
          <label><input type="checkbox" id="pg-digits" checked /> Digits (0–9)</label>
          <label><input type="checkbox" id="pg-symbols" checked /> Symbols (!@#$…)</label>
          <label><input type="checkbox" id="pg-ambiguous" /> Exclude ambiguous (0Ol1I)</label>
        </div>
      </div>

      <div class="pg-actions">
        <button id="pg-generate" class="btn-primary">Generate</button>
        <button id="pg-batch-generate" class="btn-secondary">Generate 10</button>
      </div>

      <textarea id="pg-batch-output" class="pg-batch" readonly placeholder="Batch passwords appear here..." spellcheck="false"></textarea>
    </div>

    <script is:inline>
      (function () {
        var UPPER = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
        var LOWER = 'abcdefghijklmnopqrstuvwxyz';
        var DIGITS = '0123456789';
        var SYMBOLS = '!@#$%^&*()-_=+[]{}|;:,.<>?';
        var AMBIGUOUS = /[0Ol1I]/g;

        function buildCharset() {
          var s = '';
          if (document.getElementById('pg-upper').checked) s += UPPER;
          if (document.getElementById('pg-lower').checked) s += LOWER;
          if (document.getElementById('pg-digits').checked) s += DIGITS;
          if (document.getElementById('pg-symbols').checked) s += SYMBOLS;
          if (document.getElementById('pg-ambiguous').checked) s = s.replace(AMBIGUOUS, '');
          return s;
        }

        function genPassword(len, charset) {
          if (!charset) return '';
          var arr = new Uint32Array(len);
          crypto.getRandomValues(arr);
          var result = '';
          for (var i = 0; i < len; i++) {
            result += charset[arr[i] % charset.length];
          }
          return result;
        }

        function entropy(len, charsetSize) {
          return len * Math.log2(charsetSize);
        }

        function strengthInfo(bits) {
          if (bits < 40) return { label: 'Very Weak', color: '#e00', width: 15 };
          if (bits < 60) return { label: 'Weak', color: '#e67e22', width: 35 };
          if (bits < 80) return { label: 'Fair', color: '#f39c12', width: 55 };
          if (bits < 100) return { label: 'Strong', color: '#27ae60', width: 75 };
          return { label: 'Very Strong', color: '#057a55', width: 100 };
        }

        function updateStrength(pwd, charsetSize) {
          var bits = pwd.length * Math.log2(Math.max(charsetSize, 1));
          var info = strengthInfo(bits);
          var fill = document.getElementById('pg-strength-fill');
          var label = document.getElementById('pg-strength-label');
          fill.style.width = info.width + '%';
          fill.style.background = info.color;
          label.textContent = info.label + ' (' + Math.round(bits) + ' bits)';
          label.style.color = info.color;
        }

        function generate() {
          var len = Math.min(128, Math.max(4, parseInt(document.getElementById('pg-length').value) || 20));
          var charset = buildCharset();
          if (!charset) {
            document.getElementById('pg-output').textContent = 'Select at least one character set.';
            return;
          }
          var pwd = genPassword(len, charset);
          var out = document.getElementById('pg-output');
          out.textContent = pwd;
          out.classList.add('has-value');
          updateStrength(pwd, charset.length);
          window.trackTool && window.trackTool('password_generator', 'generate');
          return pwd;
        }

        function syncLengthInputs(source) {
          var val = Math.min(128, Math.max(4, parseInt(source.value) || 20));
          document.getElementById('pg-length').value = val;
          document.getElementById('pg-length-input').value = val;
        }

        document.getElementById('pg-length').addEventListener('input', function () {
          syncLengthInputs(this);
          generate();
        });
        document.getElementById('pg-length-input').addEventListener('input', function () {
          syncLengthInputs(this);
          generate();
        });

        ['pg-upper', 'pg-lower', 'pg-digits', 'pg-symbols', 'pg-ambiguous'].forEach(function (id) {
          document.getElementById(id).addEventListener('change', generate);
        });

        document.getElementById('pg-generate').addEventListener('click', generate);

        document.getElementById('pg-copy').addEventListener('click', function () {
          var val = document.getElementById('pg-output').textContent;
          if (val === 'Click Generate' || val === 'Select at least one character set.') return;
          navigator.clipboard.writeText(val).then(function () {
            var btn = document.getElementById('pg-copy');
            btn.style.color = '#057a55';
            setTimeout(function () { btn.style.color = ''; }, 1500);
          });
        });

        document.getElementById('pg-batch-generate').addEventListener('click', function () {
          var len = Math.min(128, Math.max(4, parseInt(document.getElementById('pg-length').value) || 20));
          var charset = buildCharset();
          if (!charset) return;
          var passwords = [];
          for (var i = 0; i < 10; i++) passwords.push(genPassword(len, charset));
          document.getElementById('pg-batch-output').value = passwords.join('\n');
          window.trackTool && window.trackTool('password_generator', 'generate_batch');
        });

        // Auto-generate on load
        generate();
      })();
    </script>
  </div>

  <h2>How to Use</h2>
  <ol>
    <li>Adjust the <strong>Length</strong> slider (4–128 characters).</li>
    <li>Select which character sets to include.</li>
    <li>A password is generated automatically — click <strong>Generate</strong> for a new one.</li>
    <li>The strength meter shows entropy in bits. Aim for <strong>80+ bits</strong> for strong security.</li>
    <li>Click the copy icon to copy to clipboard, or use <strong>Generate 10</strong> for a batch.</li>
  </ol>

  <h2>Password Security Tips</h2>
  <ul>
    <li>Use a unique password for every account. A password manager makes this practical.</li>
    <li>Longer passwords are exponentially stronger — prefer length over complexity alone.</li>
    <li>Enable two-factor authentication wherever possible, regardless of password strength.</li>
    <li>Never use personal information (birthdays, names) in passwords — even partially.</li>
  </ul>
</ToolLayout>

<style>
  .pg-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .pg-output-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
  }

  .pg-output {
    flex: 1;
    font-family: 'Fira Code', monospace;
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    color: #999;
    user-select: all;
    word-break: break-all;
  }
  .pg-output.has-value { color: #1a1a1a; }

  .btn-icon {
    background: none;
    border: none;
    cursor: pointer;
    color: #888;
    padding: 0.25rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .btn-icon:hover { color: #0070f3; background: #e8f0fe; }

  .pg-strength-bar {
    height: 6px;
    background: #e5e7eb;
    border-radius: 3px;
    overflow: hidden;
  }

  .pg-strength-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.2s, background 0.2s;
    width: 0;
  }

  .pg-strength-label { font-size: 0.78rem; font-weight: 600; }

  .pg-controls { display: flex; flex-direction: column; gap: 0.75rem; }

  .pg-length-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: #555;
  }

  .pg-length-row input[type=range] { flex: 1; accent-color: #0070f3; }

  .pg-length-row input[type=number] {
    width: 60px;
    padding: 0.25rem 0.4rem;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-size: 0.88rem;
    text-align: center;
  }

  .pg-checkboxes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.25rem;
    font-size: 0.88rem;
    color: #444;
  }

  .pg-checkboxes label { display: flex; align-items: center; gap: 0.35rem; cursor: pointer; }
  .pg-checkboxes input[type=checkbox] { accent-color: #0070f3; }

  .pg-actions { display: flex; gap: 0.5rem; }

  .pg-batch {
    width: 100%;
    min-height: 140px;
    font-family: 'Fira Code', monospace;
    font-size: 0.85rem;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    background: #fafafa;
    resize: vertical;
  }

  .btn-primary {
    padding: 0.45rem 1.25rem;
    background: #0070f3;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .btn-primary:hover { background: #005bd3; }

  .btn-secondary {
    padding: 0.45rem 1.25rem;
    background: #fff;
    color: #333;
    border: 1px solid #ddd;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .btn-secondary:hover { border-color: #0070f3; color: #0070f3; }
</style>
