---
import ToolLayout from '../../layouts/ToolLayout.astro';
import QrCodeGeneratorTool from '../../components/tools/QrCodeGeneratorTool.astro';
---

<ToolLayout
  toolName="QR Code Generator"
  title="QR Code Generator Online — Free, Instant, No Sign-up | ZeroTool"
  description="Generate QR codes from any URL, text, email, or phone number. Download as PNG. Free, browser-based, no data sent to servers."
  lang="en"
  faqItems={[
    {
      question: "Is my data sent to a server?",
      answer: "No. QR codes are generated entirely in your browser using the qrcode.js library. Your data never leaves your machine.",
    },
    {
      question: "What can I encode in a QR code?",
      answer: "Any text up to ~2953 bytes: URLs, plain text, contact cards (vCard), Wi-Fi credentials, email addresses, phone numbers, and more.",
    },
    {
      question: "What does the error correction level do?",
      answer: "Higher error correction allows the QR code to be read even if part of it is obscured or damaged. Use High (H) for printed QR codes that may get dirty or partially covered.",
    },
    {
      question: "What size should I choose?",
      answer: "For digital display, 256px is sufficient. For print, choose 512px or higher to ensure sharp output at larger physical sizes.",
    },
  ]}
>
  <QrCodeGeneratorTool slot="tool" />

  <h2>How to Use</h2>
  <ol>
    <li>Enter any URL, text, phone number, or other content in the input box.</li>
    <li>Optionally adjust size, error correction level, and colors.</li>
    <li>Click <strong>Generate QR Code</strong>.</li>
    <li>Scan the QR code with any smartphone camera to verify it.</li>
    <li>Click <strong>Download PNG</strong> to save the image.</li>
  </ol>

  <h2>Common QR Code Use Cases</h2>
  <ul>
    <li><strong>URLs:</strong> Just paste the full URL including <code>https://</code>.</li>
    <li><strong>Wi-Fi:</strong> Use the format <code>WIFI:T:WPA;S:NetworkName;P:Password;;</code></li>
    <li><strong>Email:</strong> <code>mailto:user@example.com?subject=Hello</code></li>
    <li><strong>Phone:</strong> <code>tel:+15551234567</code></li>
    <li><strong>SMS:</strong> <code>smsto:+15551234567:Your message here</code></li>
  </ul>
</ToolLayout>
