---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  toolName="QR Code Generator"
  title="QR Code Generator Online — Free, Instant, No Sign-up | ZeroTool"
  description="Generate QR codes from any URL, text, email, or phone number. Download as PNG. Free, browser-based, no data sent to servers."
  lang="en"
  faqItems={[
    {
      question: "Is my data sent to a server?",
      answer: "No. QR codes are generated entirely in your browser using the qrcode.js library. Your data never leaves your machine.",
    },
    {
      question: "What can I encode in a QR code?",
      answer: "Any text up to ~2953 bytes: URLs, plain text, contact cards (vCard), Wi-Fi credentials, email addresses, phone numbers, and more.",
    },
    {
      question: "What does the error correction level do?",
      answer: "Higher error correction allows the QR code to be read even if part of it is obscured or damaged. Use High (H) for printed QR codes that may get dirty or partially covered.",
    },
    {
      question: "What size should I choose?",
      answer: "For digital display, 256px is sufficient. For print, choose 512px or higher to ensure sharp output at larger physical sizes.",
    },
  ]}
>
  <div slot="tool">
    <div class="qr-wrap">
      <div class="qr-left">
        <div class="qr-field">
          <label for="qr-input">Content</label>
          <textarea
            id="qr-input"
            placeholder="https://example.com"
            spellcheck="false"
            rows="4"
          ></textarea>
        </div>

        <div class="qr-options">
          <div class="qr-opt-row">
            <label for="qr-size">Size:</label>
            <select id="qr-size">
              <option value="128">128 px</option>
              <option value="192">192 px</option>
              <option value="256" selected>256 px</option>
              <option value="384">384 px</option>
              <option value="512">512 px</option>
            </select>
          </div>

          <div class="qr-opt-row">
            <label for="qr-ecl">Error Correction:</label>
            <select id="qr-ecl">
              <option value="L">Low (L — 7%)</option>
              <option value="M" selected>Medium (M — 15%)</option>
              <option value="Q">Quartile (Q — 25%)</option>
              <option value="H">High (H — 30%)</option>
            </select>
          </div>

          <div class="qr-opt-row">
            <label for="qr-color">Foreground:</label>
            <input type="color" id="qr-color" value="#000000" />
          </div>

          <div class="qr-opt-row">
            <label for="qr-bg">Background:</label>
            <input type="color" id="qr-bg" value="#ffffff" />
          </div>
        </div>

        <div class="qr-actions">
          <button id="qr-generate" class="btn-primary">Generate QR Code</button>
        </div>

        <div id="qr-status" class="qr-status" aria-live="polite"></div>
      </div>

      <div class="qr-right">
        <div id="qr-preview" class="qr-preview">
          <span class="qr-placeholder">QR code appears here</span>
        </div>
        <button id="qr-download" class="btn-secondary" style="display:none">Download PNG</button>
      </div>
    </div>

    <!-- qrcode.js via CDN -->
    <script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.4/build/qrcode.min.js" is:inline></script>

    <script is:inline>
      (function () {
        var canvas = null;

        function generate() {
          var text = document.getElementById('qr-input').value.trim();
          var statusEl = document.getElementById('qr-status');
          var preview = document.getElementById('qr-preview');
          var dlBtn = document.getElementById('qr-download');

          if (!text) {
            statusEl.textContent = 'Please enter some content.';
            statusEl.className = 'qr-status error';
            return;
          }

          if (typeof QRCode === 'undefined') {
            statusEl.textContent = 'QR library not loaded. Please check your network connection.';
            statusEl.className = 'qr-status error';
            return;
          }

          var size = parseInt(document.getElementById('qr-size').value) || 256;
          var ecl = document.getElementById('qr-ecl').value;
          var color = document.getElementById('qr-color').value;
          var bg = document.getElementById('qr-bg').value;

          // Remove placeholder
          preview.innerHTML = '';
          canvas = document.createElement('canvas');
          preview.appendChild(canvas);

          QRCode.toCanvas(canvas, text, {
            width: size,
            margin: 2,
            color: { dark: color, light: bg },
            errorCorrectionLevel: ecl,
          }, function (err) {
            if (err) {
              statusEl.textContent = 'Error: ' + err.message;
              statusEl.className = 'qr-status error';
              preview.innerHTML = '<span class="qr-placeholder">Generation failed</span>';
              dlBtn.style.display = 'none';
              canvas = null;
              return;
            }
            statusEl.textContent = 'Generated.';
            statusEl.className = 'qr-status success';
            dlBtn.style.display = 'block';
            window.trackTool && window.trackTool('qr_code_generator', 'generate');
          });
        }

        document.getElementById('qr-generate').addEventListener('click', generate);

        document.getElementById('qr-input').addEventListener('keydown', function (e) {
          if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) generate();
        });

        document.getElementById('qr-download').addEventListener('click', function () {
          if (!canvas) return;
          var link = document.createElement('a');
          link.download = 'qrcode.png';
          link.href = canvas.toDataURL('image/png');
          link.click();
        });

        // Auto-generate on load with example URL
        document.getElementById('qr-input').value = 'https://zerotool.dev';
        generate();
      })();
    </script>
  </div>

  <h2>How to Use</h2>
  <ol>
    <li>Enter any URL, text, phone number, or other content in the input box.</li>
    <li>Optionally adjust size, error correction level, and colors.</li>
    <li>Click <strong>Generate QR Code</strong>.</li>
    <li>Scan the QR code with any smartphone camera to verify it.</li>
    <li>Click <strong>Download PNG</strong> to save the image.</li>
  </ol>

  <h2>Common QR Code Use Cases</h2>
  <ul>
    <li><strong>URLs:</strong> Just paste the full URL including <code>https://</code>.</li>
    <li><strong>Wi-Fi:</strong> Use the format <code>WIFI:T:WPA;S:NetworkName;P:Password;;</code></li>
    <li><strong>Email:</strong> <code>mailto:user@example.com?subject=Hello</code></li>
    <li><strong>Phone:</strong> <code>tel:+15551234567</code></li>
    <li><strong>SMS:</strong> <code>smsto:+15551234567:Your message here</code></li>
  </ul>
</ToolLayout>

<style>
  .qr-wrap {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem;
    align-items: start;
  }

  @media (max-width: 600px) {
    .qr-wrap { grid-template-columns: 1fr; }
    .qr-right { display: flex; flex-direction: column; align-items: center; }
  }

  .qr-left { display: flex; flex-direction: column; gap: 0.75rem; }

  .qr-field { display: flex; flex-direction: column; gap: 0.3rem; }

  .qr-field label {
    font-size: 0.82rem;
    font-weight: 600;
    color: #555;
  }

  .qr-field textarea {
    width: 100%;
    font-family: inherit;
    font-size: 0.9rem;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    resize: vertical;
    background: #fafafa;
  }
  .qr-field textarea:focus { outline: none; border-color: #0070f3; background: #fff; }

  .qr-options { display: flex; flex-direction: column; gap: 0.4rem; }

  .qr-opt-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
  }

  .qr-opt-row label {
    font-weight: 600;
    color: #555;
    min-width: 130px;
  }

  .qr-opt-row select {
    padding: 0.25rem 0.5rem;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-size: 0.88rem;
    background: #fff;
  }

  .qr-opt-row input[type=color] {
    width: 40px;
    height: 28px;
    border: 1px solid #ddd;
    border-radius: 4px;
    cursor: pointer;
    padding: 1px;
  }

  .qr-actions { display: flex; gap: 0.5rem; }

  .qr-status { font-size: 0.85rem; min-height: 1.2rem; }
  .qr-status.success { color: #057a55; }
  .qr-status.error { color: #c0392b; }

  .qr-right { display: flex; flex-direction: column; gap: 0.5rem; align-items: center; }

  .qr-preview {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 0.75rem;
    background: #fff;
    min-width: 160px;
    min-height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .qr-preview canvas { display: block; max-width: 100%; height: auto; }

  .qr-placeholder { font-size: 0.82rem; color: #aaa; text-align: center; }

  .btn-primary {
    padding: 0.45rem 1.25rem;
    background: #0070f3;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .btn-primary:hover { background: #005bd3; }

  .btn-secondary {
    padding: 0.4rem 1rem;
    background: #fff;
    color: #333;
    border: 1px solid #ddd;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.85rem;
    width: 100%;
  }
  .btn-secondary:hover { border-color: #0070f3; color: #0070f3; }
</style>
