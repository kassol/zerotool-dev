---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  toolName="URL Encode / Decode"
  title="URL Encode & Decode Online — Free Tool | ZeroTool"
  description="Encode or decode URL components and query strings online. Handles percent-encoding instantly in your browser. Free, no sign-up."
  lang="en"
  faqItems={[
    {
      question: "What is URL encoding?",
      answer: "URL encoding (percent-encoding) converts characters that are not allowed in URLs into a '%' followed by two hex digits. For example, a space becomes %20 and '&' becomes %26.",
    },
    {
      question: "What is the difference between encodeURI and encodeURIComponent?",
      answer: "encodeURI encodes an entire URL and skips characters like '/', '?', and '#'. encodeURIComponent encodes a single component (like a query value) and encodes those characters too. This tool uses encodeURIComponent.",
    },
    {
      question: "Is my data sent to any server?",
      answer: "No. All processing runs in your browser using JavaScript's built-in encodeURIComponent/decodeURIComponent functions.",
    },
    {
      question: "When do I need URL encoding?",
      answer: "When you pass special characters in query strings, form data, or path segments — spaces, ampersands, equals signs, and non-ASCII characters all need encoding.",
    },
  ]}
>
  <div slot="tool">
    <div class="url-wrap">
      <div class="url-mode">
        <label>
          <input type="radio" name="urlmode" value="encode" checked /> Encode
        </label>
        <label>
          <input type="radio" name="urlmode" value="decode" /> Decode
        </label>
      </div>

      <div class="url-row">
        <label for="url-input" id="url-input-label">Plain Text / URL</label>
        <textarea
          id="url-input"
          placeholder="Enter text or URL to encode..."
          spellcheck="false"
        ></textarea>
      </div>

      <div class="url-actions">
        <button id="url-run" class="btn-primary">Encode</button>
        <button id="url-swap" class="btn-secondary">Swap</button>
        <button id="url-clear" class="btn-ghost">Clear</button>
      </div>

      <div id="url-status" class="url-status" aria-live="polite"></div>

      <div class="url-row">
        <label for="url-output" id="url-output-label">
          Encoded URL
          <button id="url-copy" class="btn-copy" type="button">Copy</button>
        </label>
        <textarea
          id="url-output"
          placeholder="Result appears here..."
          readonly
          spellcheck="false"
        ></textarea>
      </div>
    </div>

    <script is:inline>
      (function () {
        var inputEl = document.getElementById('url-input');
        var outputEl = document.getElementById('url-output');
        var statusEl = document.getElementById('url-status');
        var runBtn = document.getElementById('url-run');
        var copyBtn = document.getElementById('url-copy');
        var mode = 'encode';

        function setStatus(msg, isError) {
          statusEl.textContent = msg;
          statusEl.className = 'url-status ' + (isError ? 'error' : 'success');
        }

        function clearStatus() {
          statusEl.textContent = '';
          statusEl.className = 'url-status';
        }

        function updateUI() {
          if (mode === 'encode') {
            document.getElementById('url-input-label').textContent = 'Plain Text / URL';
            runBtn.textContent = 'Encode';
            inputEl.placeholder = 'Enter text or URL to encode...';
            outputEl.placeholder = 'Percent-encoded output appears here...';
          } else {
            document.getElementById('url-input-label').textContent = 'Encoded URL';
            runBtn.textContent = 'Decode';
            inputEl.placeholder = 'Enter percent-encoded URL to decode...';
            outputEl.placeholder = 'Decoded text appears here...';
          }
        }

        document.querySelectorAll('input[name="urlmode"]').forEach(function (r) {
          r.addEventListener('change', function () {
            mode = this.value;
            updateUI();
            clearStatus();
            outputEl.value = '';
          });
        });

        runBtn.addEventListener('click', function () {
          var val = inputEl.value;
          if (!val) { clearStatus(); outputEl.value = ''; return; }
          try {
            outputEl.value = mode === 'encode'
              ? encodeURIComponent(val)
              : decodeURIComponent(val);
            setStatus(mode === 'encode' ? 'Encoded.' : 'Decoded.', false);
            window.trackTool && window.trackTool('url_encode', mode);
          } catch (e) {
            outputEl.value = '';
            setStatus('Error: ' + e.message, true);
          }
        });

        document.getElementById('url-swap').addEventListener('click', function () {
          var tmp = inputEl.value;
          inputEl.value = outputEl.value;
          outputEl.value = tmp;
          clearStatus();
        });

        document.getElementById('url-clear').addEventListener('click', function () {
          inputEl.value = '';
          outputEl.value = '';
          clearStatus();
        });

        copyBtn.addEventListener('click', function () {
          if (!outputEl.value) return;
          navigator.clipboard.writeText(outputEl.value).then(function () {
            copyBtn.textContent = 'Copied!';
            setTimeout(function () { copyBtn.textContent = 'Copy'; }, 1500);
          });
        });
      })();
    </script>
  </div>

  <h2>How to Use</h2>
  <ol>
    <li>Select <strong>Encode</strong> or <strong>Decode</strong> mode.</li>
    <li>Paste your text or URL into the input box.</li>
    <li>Click the action button.</li>
    <li>Use <strong>Copy</strong> to copy the result, or <strong>Swap</strong> to reverse the operation.</li>
  </ol>

  <h2>When to Use URL Encoding</h2>
  <p>
    Browsers and servers communicate via URLs, which only allow a specific set of characters.
    Anything outside that set — spaces, Unicode characters, operators like <code>&amp;</code> and <code>=</code> —
    must be percent-encoded before being included in a URL.
  </p>
  <p>
    Common scenarios: passing query parameters with special characters, constructing redirect URLs,
    encoding form data, building REST API calls with dynamic values.
  </p>
</ToolLayout>

<style>
  .url-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .url-mode { display: flex; gap: 1.5rem; font-size: 0.95rem; }
  .url-mode label { display: flex; align-items: center; gap: 0.4rem; cursor: pointer; }

  .url-row { display: flex; flex-direction: column; gap: 0.4rem; }

  .url-row label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #555;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .url-row textarea {
    width: 100%;
    min-height: 120px;
    font-family: 'Fira Code', monospace;
    font-size: 0.88rem;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    resize: vertical;
    background: #fafafa;
  }

  .url-row textarea:focus { outline: none; border-color: #0070f3; background: #fff; }

  .url-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .btn-primary {
    padding: 0.45rem 1.25rem;
    background: #0070f3;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .btn-primary:hover { background: #005bd3; }

  .btn-secondary {
    padding: 0.45rem 1.25rem;
    background: #fff;
    color: #333;
    border: 1px solid #ddd;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .btn-secondary:hover { border-color: #0070f3; color: #0070f3; }

  .btn-ghost {
    padding: 0.45rem 1rem;
    background: none;
    color: #888;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .btn-ghost:hover { color: #e00; }

  .btn-copy {
    padding: 0.2rem 0.7rem;
    font-size: 0.78rem;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 4px;
    cursor: pointer;
    color: #555;
  }
  .btn-copy:hover { border-color: #0070f3; color: #0070f3; }

  .url-status { font-size: 0.85rem; min-height: 1.2rem; }
  .url-status.success { color: #057a55; }
  .url-status.error { color: #c0392b; }
</style>
