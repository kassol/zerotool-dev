---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  toolName="UUID Generator"
  title="UUID Generator Online — Free v4 UUID Tool | ZeroTool"
  description="Generate random v4 UUIDs instantly. Single or batch generation, copy to clipboard. Free, browser-based, no server required."
  lang="en"
  faqItems={[
    {
      question: "What is a UUID?",
      answer: "UUID (Universally Unique Identifier) is a 128-bit label used to uniquely identify objects. A v4 UUID is randomly generated, making collisions astronomically unlikely.",
    },
    {
      question: "Are these UUIDs truly random?",
      answer: "Yes. This tool uses the Web Crypto API (crypto.randomUUID) which is cryptographically secure and built into all modern browsers.",
    },
    {
      question: "What is the format of a UUID?",
      answer: "A UUID follows the format xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx, where x is a random hex digit and y is constrained to 8, 9, a, or b.",
    },
    {
      question: "How many UUIDs can I generate at once?",
      answer: "Up to 100 at a time using the batch generator.",
    },
  ]}
>
  <div slot="tool">
    <div class="uuid-wrap">
      <div class="uuid-single">
        <div class="uuid-display" id="uuid-output">Click Generate</div>
        <div class="uuid-actions">
          <button id="uuid-generate" class="btn-primary">Generate</button>
          <button id="uuid-copy-single" class="btn-secondary">Copy</button>
        </div>
      </div>

      <hr class="uuid-divider" />

      <div class="uuid-batch-section">
        <label class="batch-label">
          Batch:
          <input type="number" id="uuid-count" value="5" min="1" max="100" />
          UUIDs
        </label>
        <div class="uuid-actions">
          <button id="uuid-batch-gen" class="btn-primary">Generate Batch</button>
          <button id="uuid-batch-copy" class="btn-secondary">Copy All</button>
          <button id="uuid-batch-clear" class="btn-ghost">Clear</button>
        </div>
        <textarea id="uuid-batch-output" readonly placeholder="Batch UUIDs appear here..." spellcheck="false"></textarea>
      </div>
    </div>

    <script is:inline>
      (function () {
        var singleOut = document.getElementById('uuid-output');
        var batchOut = document.getElementById('uuid-batch-output');
        var countInput = document.getElementById('uuid-count');

        function genUUID() {
          return crypto.randomUUID();
        }

        document.getElementById('uuid-generate').addEventListener('click', function () {
          singleOut.textContent = genUUID();
          singleOut.classList.add('has-value');
          window.trackTool && window.trackTool('uuid_generator', 'generate');
        });

        document.getElementById('uuid-copy-single').addEventListener('click', function () {
          var val = singleOut.textContent;
          if (val === 'Click Generate') return;
          navigator.clipboard.writeText(val).then(function () {
            var btn = document.getElementById('uuid-copy-single');
            btn.textContent = 'Copied!';
            setTimeout(function () { btn.textContent = 'Copy'; }, 1500);
          });
        });

        document.getElementById('uuid-batch-gen').addEventListener('click', function () {
          var count = Math.min(100, Math.max(1, parseInt(countInput.value) || 5));
          var uuids = [];
          for (var i = 0; i < count; i++) uuids.push(genUUID());
          batchOut.value = uuids.join('\n');
          window.trackTool && window.trackTool('uuid_generator', 'generate_batch');
        });

        document.getElementById('uuid-batch-copy').addEventListener('click', function () {
          if (!batchOut.value) return;
          navigator.clipboard.writeText(batchOut.value).then(function () {
            var btn = document.getElementById('uuid-batch-copy');
            btn.textContent = 'Copied!';
            setTimeout(function () { btn.textContent = 'Copy All'; }, 1500);
          });
        });

        document.getElementById('uuid-batch-clear').addEventListener('click', function () {
          batchOut.value = '';
        });

        // Auto-generate one on load
        singleOut.textContent = genUUID();
        singleOut.classList.add('has-value');
      })();
    </script>
  </div>

  <h2>How to Use</h2>
  <ol>
    <li>Click <strong>Generate</strong> to create a single UUID.</li>
    <li>Click <strong>Copy</strong> to copy it to clipboard.</li>
    <li>For multiple UUIDs, set the count (1–100) and click <strong>Generate Batch</strong>.</li>
    <li>Click <strong>Copy All</strong> to copy the entire list.</li>
  </ol>

  <h2>What is UUID v4?</h2>
  <p>
    Version 4 UUIDs are generated using random numbers. With 122 bits of randomness,
    the probability of a collision is negligible — you'd need to generate over a billion
    UUIDs per second for thousands of years to have a 50% chance of a single collision.
  </p>
  <p>
    UUIDs are used as primary keys in databases, identifiers in distributed systems,
    file names, session IDs, and anywhere a globally unique label is needed.
  </p>
</ToolLayout>

<style>
  .uuid-wrap { display: flex; flex-direction: column; gap: 1.25rem; }

  .uuid-single { display: flex; flex-direction: column; gap: 0.75rem; align-items: flex-start; }

  .uuid-display {
    font-family: 'Fira Code', 'Cascadia Code', monospace;
    font-size: 1.1rem;
    letter-spacing: 0.02em;
    padding: 0.75rem 1rem;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    width: 100%;
    color: #999;
    user-select: all;
  }

  .uuid-display.has-value { color: #1a1a1a; }

  .uuid-divider {
    border: none;
    border-top: 1px solid #eee;
    margin: 0;
  }

  .uuid-batch-section { display: flex; flex-direction: column; gap: 0.75rem; }

  .batch-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: #555;
  }

  .batch-label input {
    width: 70px;
    padding: 0.3rem 0.5rem;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-size: 0.9rem;
    text-align: center;
  }

  .uuid-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  #uuid-batch-output {
    width: 100%;
    min-height: 140px;
    font-family: 'Fira Code', monospace;
    font-size: 0.85rem;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    background: #fafafa;
    resize: vertical;
  }

  .btn-primary {
    padding: 0.45rem 1.25rem;
    background: #0070f3;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .btn-primary:hover { background: #005bd3; }

  .btn-secondary {
    padding: 0.45rem 1.25rem;
    background: #fff;
    color: #333;
    border: 1px solid #ddd;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .btn-secondary:hover { border-color: #0070f3; color: #0070f3; }

  .btn-ghost {
    padding: 0.45rem 1rem;
    background: none;
    color: #888;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .btn-ghost:hover { color: #e00; }
</style>
