---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  toolName="Markdown Preview"
  title="Markdown Preview & Editor — Free Online | ZeroTool"
  description="Live Markdown editor with real-time HTML preview. Supports headings, bold, italic, code blocks, lists, links, and tables. Free, browser-based."
  lang="en"
  faqItems={[
    {
      question: "Is my content sent to a server?",
      answer: "No. The Markdown is parsed and rendered entirely in your browser using JavaScript. Nothing leaves your machine.",
    },
    {
      question: "Which Markdown features are supported?",
      answer: "Headings (H1–H6), bold, italic, inline code, fenced code blocks, unordered and ordered lists, blockquotes, links, images, horizontal rules, and GFM-style tables.",
    },
    {
      question: "Can I copy the rendered HTML?",
      answer: "Yes. Click the Copy HTML button above the preview pane to copy the rendered HTML to clipboard.",
    },
    {
      question: "Does it support GitHub Flavored Markdown (GFM)?",
      answer: "Yes — tables, strikethrough, and task lists are supported.",
    },
  ]}
>
  <div slot="tool">
    <div class="mp-wrap">
      <div class="mp-toolbar">
        <button id="mp-copy-html" class="btn-secondary">Copy HTML</button>
        <button id="mp-clear" class="btn-ghost">Clear</button>
        <span id="mp-word-count" class="mp-word-count"></span>
      </div>
      <div class="mp-panes">
        <div class="mp-pane mp-editor-pane">
          <div class="mp-pane-label">Markdown</div>
          <textarea
            id="mp-editor"
            spellcheck="false"
            placeholder="# Hello, World!&#10;&#10;Type your **Markdown** here..."
          ></textarea>
        </div>
        <div class="mp-pane mp-preview-pane">
          <div class="mp-pane-label">Preview</div>
          <div id="mp-preview" class="mp-preview prose"></div>
        </div>
      </div>
      <div id="mp-status" class="mp-status" aria-live="polite"></div>
    </div>

    <script is:inline>
      (function () {
        // Lightweight Markdown parser (GFM subset)
        function parseMarkdown(src) {
          // Escape HTML entities
          function esc(s) {
            return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
          }

          // inline: bold, italic, strikethrough, code, link, image
          function inline(s) {
            return s
              .replace(/!\[([^\]]*)\]\(([^)]+)\)/g, function(_,alt,src){ return '<img src="'+esc(src)+'" alt="'+esc(alt)+'" style="max-width:100%">'; })
              .replace(/\[([^\]]+)\]\(([^)]+)\)/g, function(_,text,href){ return '<a href="'+esc(href)+'" target="_blank" rel="noopener">'+esc(text)+'</a>'; })
              .replace(/~~([^~]+)~~/g, function(_,t){ return '<del>'+esc(t)+'</del>'; })
              .replace(/`([^`]+)`/g, function(_,t){ return '<code>'+esc(t)+'</code>'; })
              .replace(/\*\*\*([^*]+)\*\*\*/g, function(_,t){ return '<strong><em>'+esc(t)+'</em></strong>'; })
              .replace(/\*\*([^*]+)\*\*/g, function(_,t){ return '<strong>'+esc(t)+'</strong>'; })
              .replace(/__([^_]+)__/g, function(_,t){ return '<strong>'+esc(t)+'</strong>'; })
              .replace(/\*([^*]+)\*/g, function(_,t){ return '<em>'+esc(t)+'</em>'; })
              .replace(/_([^_]+)_/g, function(_,t){ return '<em>'+esc(t)+'</em>'; });
          }

          var lines = src.split('\n');
          var html = '';
          var i = 0;

          function peek(offset) { return lines[i + (offset||0)] || ''; }

          while (i < lines.length) {
            var line = lines[i];

            // Fenced code block
            if (/^```/.test(line)) {
              var lang = line.slice(3).trim();
              var code = '';
              i++;
              while (i < lines.length && !/^```/.test(lines[i])) {
                code += esc(lines[i]) + '\n';
                i++;
              }
              html += '<pre><code' + (lang ? ' class="language-'+esc(lang)+'"' : '') + '>' + code + '</code></pre>';
              i++;
              continue;
            }

            // Horizontal rule
            if (/^[-*_]{3,}\s*$/.test(line)) {
              html += '<hr>';
              i++;
              continue;
            }

            // Headings
            var hm = line.match(/^(#{1,6})\s+(.+)/);
            if (hm) {
              var lvl = hm[1].length;
              html += '<h' + lvl + '>' + inline(esc(hm[2])) + '</h' + lvl + '>';
              i++;
              continue;
            }

            // Blockquote
            if (/^>/.test(line)) {
              var bqLines = [];
              while (i < lines.length && /^>/.test(lines[i])) {
                bqLines.push(lines[i].replace(/^>\s?/, ''));
                i++;
              }
              html += '<blockquote>' + parseMarkdown(bqLines.join('\n')) + '</blockquote>';
              continue;
            }

            // Unordered list
            if (/^[-*+]\s/.test(line)) {
              html += '<ul>';
              while (i < lines.length && /^[-*+]\s/.test(lines[i])) {
                var itemText = lines[i].replace(/^[-*+]\s/, '');
                // task list
                var tm = itemText.match(/^\[([ x])\]\s+(.*)/);
                if (tm) {
                  html += '<li><input type="checkbox" disabled' + (tm[1]==='x'?' checked':'') + '> ' + inline(esc(tm[2])) + '</li>';
                } else {
                  html += '<li>' + inline(esc(itemText)) + '</li>';
                }
                i++;
              }
              html += '</ul>';
              continue;
            }

            // Ordered list
            if (/^\d+\.\s/.test(line)) {
              html += '<ol>';
              while (i < lines.length && /^\d+\.\s/.test(lines[i])) {
                html += '<li>' + inline(esc(lines[i].replace(/^\d+\.\s/, ''))) + '</li>';
                i++;
              }
              html += '</ol>';
              continue;
            }

            // GFM table
            if (i + 1 < lines.length && /^\|/.test(line) && /^[\s|:-]+$/.test(lines[i+1])) {
              var headers = line.split('|').filter(function(c,j,a){ return j>0&&j<a.length-1; }).map(function(c){ return '<th>'+inline(esc(c.trim()))+'</th>'; }).join('');
              i += 2; // skip separator
              var rows = '';
              while (i < lines.length && /^\|/.test(lines[i])) {
                var cells = lines[i].split('|').filter(function(c,j,a){ return j>0&&j<a.length-1; }).map(function(c){ return '<td>'+inline(esc(c.trim()))+'</td>'; }).join('');
                rows += '<tr>' + cells + '</tr>';
                i++;
              }
              html += '<table><thead><tr>'+headers+'</tr></thead><tbody>'+rows+'</tbody></table>';
              continue;
            }

            // Blank line
            if (/^\s*$/.test(line)) {
              i++;
              continue;
            }

            // Paragraph — collect consecutive non-blank, non-special lines
            var pLines = [];
            while (i < lines.length && !/^\s*$/.test(lines[i]) && !/^#{1,6}\s/.test(lines[i]) && !/^[-*+]\s/.test(lines[i]) && !/^\d+\.\s/.test(lines[i]) && !/^>/.test(lines[i]) && !/^```/.test(lines[i]) && !/^[-*_]{3,}\s*$/.test(lines[i])) {
              pLines.push(lines[i]);
              i++;
            }
            if (pLines.length > 0) {
              html += '<p>' + inline(esc(pLines.join(' '))) + '</p>';
            }
          }

          return html;
        }

        var editor = document.getElementById('mp-editor');
        var preview = document.getElementById('mp-preview');
        var wordCount = document.getElementById('mp-word-count');

        function update() {
          var src = editor.value;
          preview.innerHTML = parseMarkdown(src);
          var words = src.trim() ? src.trim().split(/\s+/).length : 0;
          var chars = src.length;
          wordCount.textContent = words + ' words · ' + chars + ' chars';
        }

        editor.addEventListener('input', update);

        document.getElementById('mp-copy-html').addEventListener('click', function () {
          var html = preview.innerHTML;
          if (!html) return;
          navigator.clipboard.writeText(html).then(function () {
            var btn = document.getElementById('mp-copy-html');
            var prev = btn.textContent;
            btn.textContent = 'Copied!';
            setTimeout(function () { btn.textContent = prev; }, 1500);
          });
        });

        document.getElementById('mp-clear').addEventListener('click', function () {
          editor.value = '';
          preview.innerHTML = '';
          wordCount.textContent = '';
        });

        // Default content
        editor.value = [
          '# Welcome to Markdown Preview',
          '',
          'This is a **live** Markdown editor. Changes render _instantly_ to the right.',
          '',
          '## Features',
          '',
          '- Headings H1–H6',
          '- **Bold**, _italic_, ~~strikethrough~~',
          '- `inline code` and fenced code blocks',
          '- [Links](https://zerotool.dev) and images',
          '- Tables (GFM)',
          '- Task lists',
          '',
          '## Code Example',
          '',
          '```js',
          'const greet = name => `Hello, ${name}!`;',
          'console.log(greet("ZeroTool"));',
          '```',
          '',
          '## Table',
          '',
          '| Name | Role |',
          '|------|------|',
          '| Alice | Engineer |',
          '| Bob | Designer |',
          '',
          '## Task List',
          '',
          '- [x] Build 5 tools',
          '- [ ] Deploy to production',
        ].join('\n');
        update();
      })();
    </script>
  </div>

  <h2>How to Use</h2>
  <ol>
    <li>Type or paste Markdown in the left editor pane.</li>
    <li>The rendered HTML preview updates in real time on the right.</li>
    <li>Click <strong>Copy HTML</strong> to copy the rendered HTML to clipboard.</li>
    <li>Click <strong>Clear</strong> to start fresh.</li>
  </ol>

  <h2>Supported Syntax</h2>
  <ul>
    <li>Headings: <code># H1</code> through <code>###### H6</code></li>
    <li>Bold: <code>**text**</code> or <code>__text__</code></li>
    <li>Italic: <code>*text*</code> or <code>_text_</code></li>
    <li>Strikethrough: <code>~~text~~</code></li>
    <li>Inline code: <code>`code`</code></li>
    <li>Code block: triple backtick fence with optional language</li>
    <li>Links: <code>[label](url)</code></li>
    <li>Images: <code>![alt](url)</code></li>
    <li>Unordered lists: <code>- item</code></li>
    <li>Ordered lists: <code>1. item</code></li>
    <li>Blockquotes: <code>&gt; quote</code></li>
    <li>Tables (GFM)</li>
    <li>Task lists: <code>- [x] done</code> / <code>- [ ] todo</code></li>
    <li>Horizontal rule: <code>---</code></li>
  </ul>
</ToolLayout>

<style>
  .mp-wrap { display: flex; flex-direction: column; gap: 0.5rem; }

  .mp-toolbar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .mp-word-count {
    margin-left: auto;
    font-size: 0.8rem;
    color: #888;
  }

  .mp-panes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    min-height: 320px;
  }

  @media (max-width: 600px) {
    .mp-panes { grid-template-columns: 1fr; }
  }

  .mp-pane { display: flex; flex-direction: column; gap: 0.3rem; }

  .mp-pane-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .mp-editor-pane textarea {
    flex: 1;
    width: 100%;
    min-height: 300px;
    font-family: 'Fira Code', monospace;
    font-size: 0.86rem;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    resize: vertical;
    background: #fafafa;
    line-height: 1.6;
    box-sizing: border-box;
  }

  .mp-editor-pane textarea:focus { outline: none; border-color: #0070f3; background: #fff; }

  .mp-preview {
    flex: 1;
    min-height: 300px;
    padding: 0.75rem 1rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    background: #fff;
    overflow-y: auto;
    line-height: 1.7;
  }

  /* Prose styles inside preview */
  .mp-preview h1, .mp-preview h2, .mp-preview h3,
  .mp-preview h4, .mp-preview h5, .mp-preview h6 {
    margin: 1rem 0 0.4rem;
    line-height: 1.3;
  }
  .mp-preview h1 { font-size: 1.6rem; }
  .mp-preview h2 { font-size: 1.3rem; border-bottom: 1px solid #eee; padding-bottom: 0.2rem; }
  .mp-preview h3 { font-size: 1.1rem; }
  .mp-preview p { margin: 0.5rem 0; }
  .mp-preview code { background: #f0f4ff; padding: 0.1rem 0.3rem; border-radius: 3px; font-size: 0.88em; }
  .mp-preview pre { background: #1e1e1e; color: #d4d4d4; padding: 1rem; border-radius: 6px; overflow-x: auto; margin: 0.75rem 0; }
  .mp-preview pre code { background: none; padding: 0; color: inherit; font-size: 0.86rem; }
  .mp-preview blockquote { border-left: 3px solid #0070f3; margin: 0.75rem 0; padding: 0.25rem 1rem; color: #555; background: #f8f9ff; border-radius: 0 4px 4px 0; }
  .mp-preview ul, .mp-preview ol { padding-left: 1.5rem; margin: 0.4rem 0; }
  .mp-preview li { margin: 0.2rem 0; }
  .mp-preview table { border-collapse: collapse; width: 100%; margin: 0.75rem 0; font-size: 0.9rem; }
  .mp-preview th, .mp-preview td { border: 1px solid #ddd; padding: 0.4rem 0.75rem; text-align: left; }
  .mp-preview th { background: #f0f4ff; font-weight: 600; }
  .mp-preview hr { border: none; border-top: 1px solid #ddd; margin: 1rem 0; }
  .mp-preview a { color: #0070f3; }
  .mp-preview del { color: #888; }
  .mp-preview img { max-width: 100%; border-radius: 4px; }

  .mp-status { font-size: 0.85rem; min-height: 1.2rem; }

  .btn-secondary {
    padding: 0.35rem 1rem;
    background: #fff;
    color: #333;
    border: 1px solid #ddd;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.88rem;
  }
  .btn-secondary:hover { border-color: #0070f3; color: #0070f3; }

  .btn-ghost {
    padding: 0.35rem 0.8rem;
    background: none;
    color: #888;
    border: none;
    cursor: pointer;
    font-size: 0.88rem;
  }
  .btn-ghost:hover { color: #e00; }
</style>
