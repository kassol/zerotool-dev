---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  toolName="JSON Formatter"
  title="JSON Formatter & Validator — Free Online | ZeroTool"
  description="Free online JSON formatter and validator. Prettify or minify JSON instantly in your browser. No data sent to servers. Works offline."
  lang="en"
  faqItems={[
    {
      question: "Is my JSON data sent to any server?",
      answer: "No. All processing happens entirely in your browser using JavaScript. Nothing is sent to any server.",
    },
    {
      question: "What does the Validate button do?",
      answer: "It checks whether your JSON is syntactically valid and shows the error location if not.",
    },
    {
      question: "What indentation does the formatter use?",
      answer: "2 spaces by default, which is the most common convention for JSON.",
    },
    {
      question: "Can I use this on mobile?",
      answer: "Yes, ZeroTool is fully responsive and works on any device.",
    },
  ]}
>
  <div slot="tool">
    <div class="jf-wrap">
      <div class="jf-row">
        <label for="jf-input">Input JSON</label>
        <textarea
          id="jf-input"
          placeholder='{"name":"ZeroTool","free":true}'
          spellcheck="false"
        ></textarea>
      </div>

      <div class="jf-actions">
        <button id="jf-format" class="btn-primary">Format</button>
        <button id="jf-minify" class="btn-secondary">Minify</button>
        <button id="jf-validate" class="btn-secondary">Validate</button>
        <button id="jf-clear" class="btn-ghost">Clear</button>
      </div>

      <div id="jf-status" class="jf-status" aria-live="polite"></div>

      <div class="jf-row">
        <label for="jf-output">
          Output
          <button id="jf-copy" class="btn-copy" type="button">Copy</button>
        </label>
        <textarea
          id="jf-output"
          placeholder="Formatted JSON appears here..."
          readonly
          spellcheck="false"
        ></textarea>
      </div>
    </div>

    <script is:inline>
      (function () {
        var input = document.getElementById('jf-input');
        var output = document.getElementById('jf-output');
        var status = document.getElementById('jf-status');
        var copyBtn = document.getElementById('jf-copy');

        function setStatus(msg, isError) {
          status.textContent = msg;
          status.className = 'jf-status ' + (isError ? 'error' : 'success');
        }

        function clearStatus() {
          status.textContent = '';
          status.className = 'jf-status';
        }

        document.getElementById('jf-format').addEventListener('click', function () {
          var raw = input.value.trim();
          if (!raw) { clearStatus(); output.value = ''; return; }
          try {
            output.value = JSON.stringify(JSON.parse(raw), null, 2);
            setStatus('Valid JSON — formatted.', false);
            window.trackTool && window.trackTool('json_formatter', 'format');
          } catch (e) {
            output.value = '';
            setStatus('Invalid JSON: ' + e.message, true);
          }
        });

        document.getElementById('jf-minify').addEventListener('click', function () {
          var raw = input.value.trim();
          if (!raw) { clearStatus(); output.value = ''; return; }
          try {
            output.value = JSON.stringify(JSON.parse(raw));
            setStatus('Minified.', false);
            window.trackTool && window.trackTool('json_formatter', 'minify');
          } catch (e) {
            output.value = '';
            setStatus('Invalid JSON: ' + e.message, true);
          }
        });

        document.getElementById('jf-validate').addEventListener('click', function () {
          var raw = input.value.trim();
          if (!raw) { clearStatus(); return; }
          try {
            JSON.parse(raw);
            setStatus('Valid JSON.', false);
            window.trackTool && window.trackTool('json_formatter', 'validate');
          } catch (e) {
            setStatus('Invalid JSON: ' + e.message, true);
          }
        });

        document.getElementById('jf-clear').addEventListener('click', function () {
          input.value = '';
          output.value = '';
          clearStatus();
        });

        copyBtn.addEventListener('click', function () {
          var text = output.value;
          if (!text) return;
          navigator.clipboard.writeText(text).then(function () {
            var prev = copyBtn.textContent;
            copyBtn.textContent = 'Copied!';
            setTimeout(function () { copyBtn.textContent = prev; }, 1500);
          });
        });
      })();
    </script>
  </div>

  <h2>How to Use</h2>
  <ol>
    <li>Paste your JSON into the input box.</li>
    <li>Click <strong>Format</strong> to prettify with 2-space indentation.</li>
    <li>Click <strong>Minify</strong> to compress into a single line.</li>
    <li>Click <strong>Validate</strong> to check for syntax errors without modifying output.</li>
    <li>Click <strong>Copy</strong> to copy the result to clipboard.</li>
  </ol>

  <h2>About JSON Formatter</h2>
  <p>
    JSON (JavaScript Object Notation) is the most common data interchange format.
    A formatter makes nested structures readable by adding indentation, while a minifier
    strips whitespace to reduce payload size. Both operations are lossless — the parsed
    value is identical.
  </p>
  <p>
    This tool runs entirely in your browser. No data ever leaves your machine.
  </p>
</ToolLayout>

<style>
  .jf-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .jf-row { display: flex; flex-direction: column; gap: 0.4rem; }

  .jf-row label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #555;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .jf-row textarea {
    width: 100%;
    min-height: 160px;
    font-family: 'Fira Code', 'Cascadia Code', monospace;
    font-size: 0.88rem;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 6px;
    resize: vertical;
    background: #fafafa;
    line-height: 1.5;
  }

  .jf-row textarea:focus { outline: none; border-color: #0070f3; background: #fff; }

  .jf-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .btn-primary {
    padding: 0.45rem 1.25rem;
    background: #0070f3;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .btn-primary:hover { background: #005bd3; }

  .btn-secondary {
    padding: 0.45rem 1.25rem;
    background: #fff;
    color: #333;
    border: 1px solid #ddd;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .btn-secondary:hover { border-color: #0070f3; color: #0070f3; }

  .btn-ghost {
    padding: 0.45rem 1rem;
    background: none;
    color: #888;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
  }
  .btn-ghost:hover { color: #e00; }

  .btn-copy {
    padding: 0.2rem 0.7rem;
    font-size: 0.78rem;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 4px;
    cursor: pointer;
    color: #555;
  }
  .btn-copy:hover { border-color: #0070f3; color: #0070f3; }

  .jf-status { font-size: 0.85rem; min-height: 1.2rem; }
  .jf-status.success { color: #057a55; }
  .jf-status.error { color: #c0392b; }
</style>
