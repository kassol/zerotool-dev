---
import ToolLayout from '../../layouts/ToolLayout.astro';
import TimestampConverterTool from '../../components/tools/TimestampConverterTool.astro';
---

<ToolLayout
  toolName="Timestamp Converter"
  title="Unix Timestamp Converter — Free Online | ZeroTool"
  description="Convert Unix timestamps to human-readable dates and vice versa. Supports seconds and milliseconds. Shows UTC and local time. Free, browser-based."
  lang="en"
  faqItems={[
    {
      question: "What is a Unix timestamp?",
      answer: "A Unix timestamp (also called Epoch time) is the number of seconds elapsed since January 1, 1970 00:00:00 UTC. It is the universal time reference in computing.",
    },
    {
      question: "Seconds or milliseconds — how do I tell?",
      answer: "A 10-digit number is almost certainly seconds (valid until 2286). A 13-digit number is milliseconds. This tool auto-detects based on digit count.",
    },
    {
      question: "Why does local time differ from UTC?",
      answer: "UTC is the global reference point. Local time is UTC adjusted for your browser's timezone offset.",
    },
    {
      question: "Is this tool accurate for all timezones?",
      answer: "Yes. The JavaScript Date API uses your system's timezone data for the local time display.",
    },
  ]}
>
  <TimestampConverterTool slot="tool" />

  <h2>How to Use</h2>
  <h3>Timestamp to Date</h3>
  <ol>
    <li>Enter a Unix timestamp (seconds or milliseconds) in the first field.</li>
    <li>Click <strong>Convert</strong> or press Enter.</li>
    <li>Click <strong>Now</strong> to use the current time.</li>
  </ol>
  <h3>Date to Timestamp</h3>
  <ol>
    <li>Select a date and time using the date picker.</li>
    <li>Click <strong>Convert</strong> — results appear automatically.</li>
  </ol>

  <h2>About Unix Timestamps</h2>
  <p>
    The Unix epoch began at 1970-01-01 00:00:00 UTC. Every moment in time is stored
    as an integer offset from that point. Most systems use seconds; JavaScript uses milliseconds.
  </p>
  <p>
    The 32-bit signed timestamp will overflow (the <em>Year 2038 problem</em>) on
    January 19, 2038. Modern 64-bit systems are not affected.
  </p>
</ToolLayout>
