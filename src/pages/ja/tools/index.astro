---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDirectory from '../../../components/ToolDirectory.astro';
import { allTools } from '../../../data/tools';

const toolCount = allTools.length;
---

<BaseLayout
  title="全ツール一覧 — ZeroTool"
  description={`${toolCount}個の無料オンライン開発者ツールを閲覧：JSONフォーマット、Base64エンコード、UUID生成、URLエンコード、正規表現テストなど。`}
  lang="ja"
>
  <ToolDirectory lang="ja" mode="tools" />
</BaseLayout>
