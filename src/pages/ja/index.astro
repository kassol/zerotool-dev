---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolDirectory from '../../components/ToolDirectory.astro';
import { allTools } from '../../data/tools';

const toolCount = allTools.length;
---

<BaseLayout
  title="ZeroTool — 無料オンライン開発者ツール"
  description={`${toolCount}種類の無料・高速・ブラウザ完結の開発者ツール。JSON、Base64、UUID、URL、テキスト、セキュリティ、画像、APIに対応。`}
  lang="ja"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'ZeroTool',
      url: 'https://zerotool.dev/ja/',
      description: '無料・高速・ブラウザ完結の開発者ツール集。',
    })} />
  </Fragment>
  <ToolDirectory lang="ja" mode="home" />
</BaseLayout>
