---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolSearchBar from '../../components/ToolSearchBar.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import { getToolIcon } from '../../data/icons';
import { allTools, getToolName, getToolDescription } from '../../data/tools';

const tools = allTools.map(tool => ({
  href: `/ja/tools/${tool.slug}`,
  slug: tool.slug,
  name: getToolName(tool, 'ja'),
  description: getToolDescription(tool, 'ja'),
  category: tool.category,
}));
---

<BaseLayout
  title="ZeroTool — 無料オンライン開発者ツール"
  description="無料・高速・ブラウザ完結の開発者ツール集。JSONフォーマット、Base64エンコード、UUID生成、URLエンコード、文字列変換など。登録不要、オフライン対応。"
  lang="ja"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'ZeroTool',
      url: 'https://zerotool.dev/ja',
      description: '無料・高速・ブラウザ完結の開発者ツール集。登録不要。',
    })} />
  </Fragment>
  <div class="home">
    <section class="hero">
      <h1>無料オンライン開発者ツール</h1>
      <p class="hero-sub">高速・プライベート・ブラウザ完結。登録不要、オフライン対応。</p>
    </section>

    <ToolSearchBar lang="ja" />
    <CategoryFilter lang="ja" />

    <section class="tools-grid">
      {tools.map(tool => (
        <a href={tool.href} class="tool-card" data-keywords={`${tool.slug} ${tool.name.toLowerCase()} ${tool.description.toLowerCase()}`} data-category={tool.category} data-slug={tool.slug}>
          <span class="tool-icon" set:html={getToolIcon(tool.slug)} />
          <div class="tool-info">
            <h2>{tool.name}</h2>
            <p>{tool.description}</p>
          </div>
        </a>
      ))}
    </section>

    <section class="why-section">
      <h2>ZeroTool を選ぶ理由</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3>プライバシー優先</h3>
          <p>すべての処理はブラウザ内で完結し、サーバーへのリクエストはゼロ。あなたのデータがデバイス外に出ることはありません。</p>
        </div>
        <div class="why-card">
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3>超高速表示</h3>
          <p>JavaScriptフレームワーク不要の静的ページを Cloudflare グローバル CDN でエッジ配信。即時ロードを実現します。</p>
        </div>
        <div class="why-card">
          <div class="why-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3>ネイティブ多言語</h3>
          <p>英語・中国語・日本語に初めからネイティブ対応。機械翻訳ではなく、各言語のユーザーのために作られています。</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1rem 4rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .hero-sub {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    margin: 0;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 860px) {
    .tools-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .tools-grid { grid-template-columns: 1fr; }
    .tool-card {
      flex-direction: row;
      align-items: center;
      padding: 0.85rem 1rem;
      gap: 0.75rem;
    }
    .tool-icon {
      width: 36px;
      height: 36px;
    }
    .tool-icon :global(svg) {
      width: 18px;
      height: 18px;
    }
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: inherit;
    background: var(--color-bg);
    box-shadow: var(--shadow-card);
    transition: border-color var(--transition-fast), box-shadow var(--transition-med), transform var(--transition-med);
  }

  .tool-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .tool-icon {
    width: 44px;
    height: 44px;
    background: var(--color-bg-icon);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .tool-icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .tool-info h2 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
  }

  .tool-info p {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Why Section ── */
  .why-section {
    margin-top: 4rem;
  }

  .why-section h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    text-align: center;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 700px) {
    .why-grid { grid-template-columns: 1fr; }
  }

  .why-card {
    text-align: center;
    padding: 1.5rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    box-shadow: var(--shadow-card);
  }

  .why-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-icon);
    border-radius: var(--radius-sm);
    color: var(--color-primary);
  }

  .why-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .why-card p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }
</style>
