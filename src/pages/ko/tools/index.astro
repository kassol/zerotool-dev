---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDirectory from '../../../components/ToolDirectory.astro';
import { allTools } from '../../../data/tools';

const toolCount = allTools.length;
---

<BaseLayout
  title="전체 도구 — ZeroTool"
  description={`${toolCount}가지 무료 온라인 개발자 도구 목록: JSON 포매터, Base64 인코딩, UUID 생성기, URL 인코딩, 정규식 테스터 등.`}
  lang="ko"
>
  <ToolDirectory lang="ko" mode="tools" />
</BaseLayout>
