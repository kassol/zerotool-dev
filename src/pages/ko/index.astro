---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolDirectory from '../../components/ToolDirectory.astro';
import { allTools } from '../../data/tools';

const toolCount = allTools.length;
---

<BaseLayout
  title="ZeroTool — 무료 온라인 개발자 도구"
  description={`${toolCount}가지 무료·빠른·브라우저 완결 개발자 도구. JSON, Base64, UUID, URL, 텍스트, 보안, 이미지, API 작업을 지원합니다.`}
  lang="ko"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'ZeroTool',
      url: 'https://zerotool.dev/ko/',
      description: '무료·빠른·브라우저 완결 개발자 도구 모음.',
    })} />
  </Fragment>
  <ToolDirectory lang="ko" mode="home" />
</BaseLayout>
