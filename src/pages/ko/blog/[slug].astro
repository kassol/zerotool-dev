---
import { getCollection } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data, slug }) => {
    return !data.draft && data.lang === 'ko' && slug.endsWith('/ko');
  });
  return posts.map((post) => ({
    params: { slug: post.slug.replace(/\/ko$/, '') },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await post.render();
---

<ArticleLayout post={post} headings={headings} allPosts={allPosts}>
  <Content />
</ArticleLayout>
