---
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: string;
  pubDate?: Date;
  updatedDate?: Date;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage,
  noindex,
  lang = 'en',
  pubDate,
  updatedDate,
} = Astro.props;

const adsenseId = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID ?? '';
const ga4Id = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID ?? '';

const tools = [
  { href: '/tools/json-formatter', label: 'JSON Formatter' },
  { href: '/tools/base64', label: 'Base64' },
  { href: '/tools/uuid-generator', label: 'UUID' },
  { href: '/tools/url-encode', label: 'URL Encode' },
  { href: '/tools/text-case', label: 'Text Case' },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      noindex={noindex}
      lang={lang}
      pubDate={pubDate}
      updatedDate={updatedDate}
    />

    <!-- AdSense Auto Ads — loads via Partytown worker thread -->
    {adsenseId && (
      <script
        type="text/partytown"
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseId}`}
        crossorigin="anonymous"
      ></script>
    )}

    <!-- GA4 via Partytown — non-blocking -->
    {ga4Id && (
      <>
        <script
          type="text/partytown"
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}
        ></script>
        <script type="text/partytown" define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', ga4Id);
        </script>
      </>
    )}

    <!-- GA4 tool event helper — main thread, proxies to dataLayer (Partytown-forwarded) -->
    <script>
      window.trackTool = function(toolName, action) {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'tool_use',
          tool_name: toolName,
          tool_action: action,
        });
      };
    </script>

    <!-- Extra head content (JSON-LD, etc.) from child layouts -->
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/" class="site-brand">ZeroTool</a>
        <div class="nav-tools">
          {tools.map(t => (
            <a href={t.href}>{t.label}</a>
          ))}
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        &copy; {new Date().getFullYear()} <a href="/">ZeroTool</a> — Free online developer tools.
        No sign-up, no tracking, no BS.
      </p>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: #1a1a1a;
    background: #fff;
  }

  a { color: #0070f3; text-decoration: none; }
  a:hover { text-decoration: underline; }

  .site-header {
    border-bottom: 1px solid #eee;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .site-nav {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1rem;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    overflow-x: auto;
  }

  .site-brand {
    font-weight: 700;
    font-size: 1.15rem;
    color: #1a1a1a;
    white-space: nowrap;
  }

  .nav-tools {
    display: flex;
    gap: 1rem;
    flex-wrap: nowrap;
  }

  .nav-tools a {
    color: #555;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .nav-tools a:hover { color: #0070f3; }

  main { min-height: calc(100vh - 56px - 60px); }

  .site-footer {
    border-top: 1px solid #eee;
    text-align: center;
    padding: 1rem;
    font-size: 0.85rem;
    color: #888;
  }

  .site-footer a { color: #888; }
</style>
