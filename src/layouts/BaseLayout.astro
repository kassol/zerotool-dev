---
import SEO from '../components/SEO.astro';
import { t } from '../i18n/utils';
import { disabledPersistenceSlugs } from '../data/persistence';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: string;
  pubDate?: Date;
  updatedDate?: Date;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage,
  noindex,
  lang = 'en',
  pubDate,
  updatedDate,
} = Astro.props;

const adsenseId = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID ?? '';
const ga4Id = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID ?? '';

const isZh = lang === 'zh';
const isJa = lang === 'ja';
const isKo = lang === 'ko';
const homeBase = isZh ? '/zh/' : isJa ? '/ja/' : isKo ? '/ko/' : '/';
const toolBase = isZh ? '/zh/tools/' : isJa ? '/ja/tools/' : isKo ? '/ko/tools/' : '/tools/';
const blogBase = isZh ? '/zh/blog/' : isJa ? '/ja/blog/' : isKo ? '/ko/blog/' : '/blog/';
const aboutBase = isZh ? '/zh/about/' : isJa ? '/ja/about/' : isKo ? '/ko/about/' : '/about/';
const privacyBase = isZh ? '/zh/privacy/' : isJa ? '/ja/privacy/' : isKo ? '/ko/privacy/' : '/privacy/';
const termsBase = isZh ? '/zh/terms/' : isJa ? '/ja/terms/' : isKo ? '/ko/terms/' : '/terms/';
const contactBase = isZh ? '/zh/contact/' : isJa ? '/ja/contact/' : isKo ? '/ko/contact/' : '/contact/';
const pathname = Astro.url.pathname;
const blogPostMatch = pathname.match(/^\/(?:(zh|ja|ko)\/)?blog\/([^/]+)/);
const isBlogPost = !!blogPostMatch;
const blogBaseSlug = blogPostMatch ? blogPostMatch[2].replace(/\/$/, '') : null;
const ensureTrailingSlash = (path: string) => path.endsWith('/') ? path : `${path}/`;

// On blog-post pages we look up which language variants of this article exist
// so the language switcher can jump to the correct counterpart instead of
// dumping the user on the language home page.
let blogSlugSet: Set<string> = new Set();
if (isBlogPost) {
  // Exclude drafts: their routes aren't generated by [slug].astro, so jumping
  // to them via the language switcher would 404.
  const entries = await getCollection('blog', ({ data }) => !data.draft);
  blogSlugSet = new Set(entries.map(e => e.slug));
}

const langNames: Record<string, string> = { en: 'English', zh: '中文', ja: '日本語', ko: '한국어' };
const currentLangName = langNames[lang] ?? 'English';

// Language switch hrefs
const getLangHref = (targetLang: string) => {
  if (targetLang === lang) return ensureTrailingSlash(pathname);

  const prefix = targetLang === 'en' ? '' : `/${targetLang}`;

  if (isBlogPost && blogBaseSlug) {
    const targetKey = `${blogBaseSlug}/${targetLang}`;
    if (blogSlugSet.has(targetKey)) {
      return `${prefix}/blog/${blogBaseSlug}/`;
    }
    // No counterpart in target language — fall back to that language's blog index.
    return `${prefix}/blog/`;
  }

  const stripped = pathname.replace(/^\/(zh|ja|ko)(\/|$)/, '/') || '/';
  return ensureTrailingSlash(prefix + stripped);
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <!-- Anti-FOUC: apply stored theme before first paint -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || t === 'light') {
          document.documentElement.setAttribute('data-theme', t);
        }
      })();
    </script>
    <!-- Privacy hard guarantee: wipe sensitive tool input on every page load,
         not just when the user lands on the tool itself. Source of truth:
         disabledPersistenceSlugs in src/data/persistence.ts. -->
    <script is:inline define:vars={{ disabledPersistenceSlugs }}>
      (function() {
        var SENSITIVE = disabledPersistenceSlugs || [];
        for (var i = 0; i < SENSITIVE.length; i++) {
          try { localStorage.removeItem('zt-input-' + SENSITIVE[i]); } catch (e) {}
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      noindex={noindex}
      lang={lang}
      pubDate={pubDate}
      updatedDate={updatedDate}
    />

    <!-- AdSense Auto Ads — loads via Partytown worker thread -->
    {adsenseId && (
      <script
        type="text/partytown"
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseId}`}
        crossorigin="anonymous"
      ></script>
    )}

    <!-- GA4 via Partytown — non-blocking -->
    {ga4Id && (
      <>
        <script
          type="text/partytown"
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}
        ></script>
        <script type="text/partytown" define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', ga4Id);
        </script>
      </>
    )}

    <!-- GA4 tool event helper — main-thread gtag via Partytown-forwarded dataLayer.push -->
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() { window.dataLayer.push(arguments); }
      window.trackTool = function(toolName, action) {
        gtag('event', 'tool_use', {
          tool_name: toolName,
          tool_action: action,
        });
      };
    </script>

    <!-- Extra head content (JSON-LD, etc.) from child layouts -->
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href={homeBase} class="site-brand">ZeroTool</a>
        <div class="nav-links">
          <a href={toolBase}>{t(lang, 'nav.tools')}</a>
          <a href={blogBase}>{t(lang, 'nav.blog')}</a>
        </div>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
          <svg class="theme-icon theme-icon--light" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="theme-icon theme-icon--dark" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="theme-icon theme-icon--system" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </button>
        <div class="lang-switcher">
          <button class="lang-trigger" aria-haspopup="listbox" aria-expanded="false" aria-label="Select language">
            <svg class="lang-globe" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <span class="lang-current">{currentLangName}</span>
            <svg class="lang-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="lang-menu" role="listbox" hidden>
            {(['en', 'zh', 'ja', 'ko'] as const).map(l => (
              <a href={getLangHref(l)} class={`lang-option${l === lang ? ' lang-option--active' : ''}`} role="option" aria-selected={l === lang}>{langNames[l]}</a>
            ))}
          </div>
        </div>
        <button class="nav-hamburger" aria-label="Menu" aria-expanded="false">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </nav>
      <div class="nav-drawer" hidden>
        <div class="nav-drawer-links">
          <a href={toolBase}>{t(lang, 'nav.tools')}</a>
          <a href={blogBase}>{t(lang, 'nav.blog')}</a>
        </div>
      </div>
    </header>
    <div class="nav-overlay" hidden></div>
    <script is:inline>
      (function() {
        const btn = document.querySelector('.nav-hamburger');
        const drawer = document.querySelector('.nav-drawer');
        const overlay = document.querySelector('.nav-overlay');
        if (!btn || !drawer || !overlay) return;
        function toggle(open) {
          const isOpen = typeof open === 'boolean' ? open : drawer.hidden;
          drawer.hidden = !isOpen;
          overlay.hidden = !isOpen;
          btn.setAttribute('aria-expanded', String(isOpen));
          document.body.style.overflow = isOpen ? 'hidden' : '';
        }
        btn.addEventListener('click', function() { toggle(); });
        overlay.addEventListener('click', function() { toggle(false); });
      })();
      (function() {
        var trigger = document.querySelector('.lang-trigger');
        var menu = document.querySelector('.lang-menu');
        if (!trigger || !menu) return;
        function close() {
          menu.hidden = true;
          trigger.setAttribute('aria-expanded', 'false');
        }
        function open() {
          menu.hidden = false;
          trigger.setAttribute('aria-expanded', 'true');
        }
        trigger.addEventListener('click', function(e) {
          e.stopPropagation();
          menu.hidden ? open() : close();
        });
        document.addEventListener('click', function() { close(); });
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') close();
        });
      })();
      (function() {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        var MODES = ['system', 'light', 'dark'];
        function getMode() { return localStorage.getItem('theme') || 'system'; }
        function applyMode(mode) {
          if (mode === 'system') {
            document.documentElement.removeAttribute('data-theme');
          } else {
            document.documentElement.setAttribute('data-theme', mode);
          }
          btn.setAttribute('data-mode', mode);
        }
        applyMode(getMode());
        btn.addEventListener('click', function() {
          var cur = getMode();
          var next = MODES[(MODES.indexOf(cur) + 1) % MODES.length];
          localStorage.setItem('theme', next);
          applyMode(next);
        });
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function() {
          if (getMode() === 'system') applyMode('system');
        });
      })();
    </script>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-links">
        <a href={aboutBase}>{t(lang, 'nav.about')}</a>
        <a href={privacyBase}>{t(lang, 'nav.privacy')}</a>
        <a href={termsBase}>{t(lang, 'nav.terms')}</a>
        <a href={contactBase}>{t(lang, 'nav.contact')}</a>
      </div>
      <p>
        &copy; {new Date().getFullYear()} <a href={homeBase}>ZeroTool</a> — {t(lang, 'footer.tagline')}
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-primary: oklch(49% 0.095 48);
    --color-primary-hover: oklch(43% 0.105 48);
    --color-primary-contrast: oklch(98% 0.008 75);
    --color-primary-light: color-mix(in oklch, var(--color-primary) 12%, transparent);
    --color-accent: oklch(57% 0.09 78);
    --color-bg: oklch(98.4% 0.009 78);
    --color-bg-secondary: oklch(96.2% 0.011 78);
    --color-surface: oklch(99.4% 0.006 78);
    --color-surface-muted: oklch(97.1% 0.01 78);
    --color-bg-icon: color-mix(in oklch, var(--color-primary) 11%, var(--color-surface));
    --color-text: oklch(22% 0.018 70);
    --color-text-secondary: oklch(43% 0.016 70);
    --color-text-muted: oklch(58% 0.014 70);
    --color-border: oklch(87.5% 0.012 78);
    --color-border-light: oklch(91.5% 0.01 78);
    --color-border-soft: color-mix(in oklch, var(--color-border) 62%, transparent);
    --color-success: oklch(46% 0.11 150);
    --color-danger: oklch(50% 0.14 28);
    --color-cat-data: oklch(52% 0.085 210);
    --color-cat-color: oklch(56% 0.12 345);
    --color-cat-encoding: oklch(57% 0.11 82);
    --color-cat-text: oklch(49% 0.085 145);
    --color-cat-security: oklch(50% 0.13 28);
    --color-cat-dev: oklch(48% 0.075 255);
    --color-cat-api: oklch(52% 0.09 300);
    --color-cat-image: oklch(55% 0.12 58);
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 14px;
    --radius-pill: 999px;
    --shadow-subtle: 0 1px 2px rgba(75, 54, 33, 0.06);
    --shadow-card: 0 1px 2px rgba(75, 54, 33, 0.06), 0 8px 24px rgba(75, 54, 33, 0.045);
    --shadow-card-hover: 0 2px 3px rgba(75, 54, 33, 0.08), 0 16px 38px rgba(75, 54, 33, 0.08);
    --shadow-panel: 0 16px 46px rgba(75, 54, 33, 0.09), 0 1px 2px rgba(75, 54, 33, 0.06);
    --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    --transition-fast: 160ms var(--ease-out);
    --transition-med: 240ms var(--ease-out);
    --header-height: 64px;
    --footer-height: 60px;
    --max-width: 1180px;
    --font-display: Georgia, 'Times New Roman', ui-serif, serif;
    --font-mono: 'SFMono-Regular', 'Cascadia Code', 'Fira Code', ui-monospace, monospace;
    --font-sans: ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) {
      --color-primary: oklch(70% 0.105 58);
      --color-primary-hover: oklch(76% 0.11 58);
      --color-primary-contrast: oklch(16% 0.012 65);
      --color-primary-light: color-mix(in oklch, var(--color-primary) 16%, transparent);
      --color-accent: oklch(72% 0.08 90);
      --color-bg: oklch(15% 0.012 65);
      --color-bg-secondary: oklch(19% 0.014 65);
      --color-surface: color-mix(in oklch, var(--color-bg) 88%, white 4%);
      --color-surface-muted: color-mix(in oklch, var(--color-bg) 84%, white 6%);
      --color-bg-icon: color-mix(in oklch, var(--color-primary) 16%, var(--color-bg));
      --color-text: oklch(92% 0.011 78);
      --color-text-secondary: oklch(76% 0.012 78);
      --color-text-muted: oklch(62% 0.012 78);
      --color-border: rgba(255,255,255,0.10);
      --color-border-light: rgba(255,255,255,0.06);
      --color-border-soft: rgba(255,255,255,0.07);
      --color-success: oklch(76% 0.12 150);
      --color-danger: oklch(72% 0.14 28);
      --shadow-subtle: 0 1px 0 rgba(255,255,255,0.04);
      --shadow-card: inset 0 1px 0 rgba(255,255,255,0.04);
      --shadow-card-hover: inset 0 1px 0 rgba(255,255,255,0.07), 0 18px 44px rgba(0,0,0,0.22);
      --shadow-panel: inset 0 1px 0 rgba(255,255,255,0.06), 0 22px 58px rgba(0,0,0,0.28);
    }
  }

  [data-theme="dark"] {
    --color-primary: oklch(70% 0.105 58);
    --color-primary-hover: oklch(76% 0.11 58);
    --color-primary-contrast: oklch(16% 0.012 65);
    --color-primary-light: color-mix(in oklch, var(--color-primary) 16%, transparent);
    --color-accent: oklch(72% 0.08 90);
    --color-bg: oklch(15% 0.012 65);
    --color-bg-secondary: oklch(19% 0.014 65);
    --color-surface: color-mix(in oklch, var(--color-bg) 88%, white 4%);
    --color-surface-muted: color-mix(in oklch, var(--color-bg) 84%, white 6%);
    --color-bg-icon: color-mix(in oklch, var(--color-primary) 16%, var(--color-bg));
    --color-text: oklch(92% 0.011 78);
    --color-text-secondary: oklch(76% 0.012 78);
    --color-text-muted: oklch(62% 0.012 78);
    --color-border: rgba(255,255,255,0.10);
    --color-border-light: rgba(255,255,255,0.06);
    --color-border-soft: rgba(255,255,255,0.07);
    --color-success: oklch(76% 0.12 150);
    --color-danger: oklch(72% 0.14 28);
    --shadow-subtle: 0 1px 0 rgba(255,255,255,0.04);
    --shadow-card: inset 0 1px 0 rgba(255,255,255,0.04);
    --shadow-card-hover: inset 0 1px 0 rgba(255,255,255,0.07), 0 18px 44px rgba(0,0,0,0.22);
    --shadow-panel: inset 0 1px 0 rgba(255,255,255,0.06), 0 22px 58px rgba(0,0,0,0.28);
  }

  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text);
    background: var(--color-bg);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  button,
  a {
    touch-action: manipulation;
  }

  a {
    color: var(--color-primary);
    text-decoration: none;
  }

  @media (hover: hover) {
    a:hover { text-decoration: underline; }
  }

  :focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  /* ── Header ── */
  .site-header {
    border-bottom: 1px solid var(--color-border-light);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .site-nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem;
    height: var(--header-height);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 800;
    font-size: 1.05rem;
    color: var(--color-text);
    white-space: nowrap;
    letter-spacing: -0.012em;
  }

  .site-brand::before {
    content: "";
    width: 18px;
    height: 18px;
    border-radius: 5px;
    background:
      linear-gradient(135deg, var(--color-primary), var(--color-accent));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.32), 0 1px 2px rgba(75, 54, 33, 0.18);
  }

  .site-brand:hover {
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 0.35rem;
    flex: 1 1 auto;
  }

  .nav-links a {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    border-radius: var(--radius-pill);
    color: var(--color-text-secondary);
    padding: 0 0.75rem;
    font-size: 0.88rem;
    font-weight: 650;
    white-space: nowrap;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  @media (hover: hover) {
    .nav-links a:hover {
      background: var(--color-surface-muted);
      color: var(--color-primary);
      text-decoration: none;
    }
  }

  /* ── Theme Toggle ── */
  .theme-toggle {
    width: 40px;
    height: 40px;
    justify-content: center;
    background: var(--color-surface);
    border: 0;
    border-radius: var(--radius-sm);
    padding: 0;
    cursor: pointer;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    flex-shrink: 0;
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
    transition: color var(--transition-fast), background-color var(--transition-fast), transform var(--transition-fast);
  }
  .theme-toggle:hover {
    color: var(--color-primary);
    background: var(--color-surface-muted);
  }
  .theme-toggle:active {
    transform: scale(0.96);
  }
  .theme-icon { display: none; }
  .theme-toggle[data-mode="light"] .theme-icon--light { display: block; }
  .theme-toggle[data-mode="dark"] .theme-icon--dark { display: block; }
  .theme-toggle[data-mode="system"] .theme-icon--system,
  .theme-toggle:not([data-mode]) .theme-icon--system { display: block; }

  .lang-switcher {
    flex-shrink: 0;
    position: relative;
  }

  .lang-trigger {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.85rem;
    font-family: var(--font-sans);
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border: 0;
    border-radius: var(--radius-pill);
    padding: 0 0.75rem;
    min-height: 40px;
    cursor: pointer;
    white-space: nowrap;
    line-height: 1;
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
    transition: color var(--transition-fast), background-color var(--transition-fast), transform var(--transition-fast);
  }

  .lang-trigger:hover,
  .lang-trigger[aria-expanded="true"] {
    color: var(--color-primary);
    background: var(--color-surface-muted);
  }

  .lang-trigger:active {
    transform: scale(0.96);
  }

  .lang-chevron {
    transition: transform var(--transition-fast);
    flex-shrink: 0;
  }

  .lang-trigger[aria-expanded="true"] .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 130px;
    background: var(--color-surface);
    border-radius: var(--radius-md);
