---
// ToolLayout.astro — for SEO tool pages
// Pattern: "Free Online [Tool Name] - [Site Name]"
// Each tool gets its own URL, full SEO, and ad slots

import BaseLayout from './BaseLayout.astro';
import AdUnit from '../components/AdUnit.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { getRelatedTools } from '../data/tools';
import '../styles/tool-common.css';

interface Props {
  title: string;           // e.g. "Capitalize Title Online — Free Tool"
  description: string;     // 120-160 chars, keyword-rich
  toolName: string;        // e.g. "Title Case Converter"
  lang?: string;
  canonicalUrl?: string;
  faqItems?: { question: string; answer: string }[];
}

const {
  title,
  description,
  toolName,
  lang = 'en',
  canonicalUrl,
  faqItems = [],
} = Astro.props;

// Derive current tool slug from URL path
const pathParts = Astro.url.pathname.replace(/\/$/, '').split('/');
const currentSlug = pathParts[pathParts.length - 1];
const relatedTools = getRelatedTools(currentSlug, 4);
const toolBase = lang === 'zh' ? '/zh/tools' : '/tools';

// Per-tool OG image — generated by scripts/generate-og.mjs
const ogImage = `/og/${currentSlug}.png`;

// JSON-LD structured data for tool pages (SoftwareApplication schema)
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: toolName,
  description,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};

// FAQ schema when faqItems present
const faqJsonLd = faqItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
} : null;
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  lang={lang}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {faqJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    )}
  </Fragment>

  <div class="tool-page">
    <header class="tool-header">
      <h1>{toolName}</h1>
      <p class="tool-description">{description}</p>
    </header>

    <div class="trust-bar">
      <span class="trust-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        {lang === 'zh' ? '100% 浏览器端运行' : '100% Client-Side'}
      </span>
      <span class="trust-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
        {lang === 'zh' ? '数据不离开你的设备' : 'Your data never leaves your browser'}
      </span>
      <span class="trust-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        {lang === 'zh' ? '免费 · 无需注册' : 'Free · No Sign-Up'}
      </span>
    </div>

    <!-- Top ad: above the fold but below h1 -->
    <AdUnit slot={import.meta.env.PUBLIC_ADSENSE_SLOT_TOP ?? ''} format="horizontal" />

    <!-- Tool UI injected here -->
    <section class="tool-widget">
      <slot name="tool" />
      <ShareButtons toolName={toolName} lang={lang} />
    </section>

    <!-- Mid ad: between tool and instructions -->
    <AdUnit slot={import.meta.env.PUBLIC_ADSENSE_SLOT_MID ?? ''} format="rectangle" />

    <!-- How-to / instructions (SEO content) -->
    <section class="tool-content">
      <slot />
    </section>

    <!-- FAQ section -->
    {faqItems.length > 0 && (
      <section class="tool-faq">
        <h2>FAQ</h2>
        {faqItems.map(({ question, answer }) => (
          <details>
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </section>
    )}

    <!-- Related Tools -->
    {relatedTools.length > 0 && (
      <section class="related-tools">
        <h2>{lang === 'zh' ? '相关工具' : 'Related Tools'}</h2>
        <div class="related-grid">
          {relatedTools.map(tool => (
            <a href={`${toolBase}/${tool.slug}`} class="related-card">
              <strong>{lang === 'zh' ? tool.nameZh : tool.name}</strong>
              <span>{lang === 'zh' ? tool.descriptionZh : tool.description}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Bottom ad -->
    <AdUnit slot={import.meta.env.PUBLIC_ADSENSE_SLOT_BOTTOM ?? ''} format="rectangle" />
  </div>

  <!-- Tool UX enhancements: keyboard shortcuts + copy feedback -->
  <script is:inline>
    (function() {
      // Keyboard shortcuts: Ctrl/Cmd+Enter = primary action, Ctrl/Cmd+L = clear
      document.addEventListener('keydown', function(e) {
        var mod = e.metaKey || e.ctrlKey;
        if (!mod) return;
        if (e.key === 'Enter') {
          var btn = document.querySelector('.tool-widget .btn-primary');
          if (btn) { e.preventDefault(); btn.click(); }
        }
        if (e.key === 'l' || e.key === 'L') {
          var widget = document.querySelector('.tool-widget');
          if (widget && document.activeElement && widget.contains(document.activeElement)) {
            e.preventDefault();
            widget.querySelectorAll('textarea, input[type="text"]').forEach(function(el) { el.value = ''; });
          }
        }
      });

      // Copy button visual feedback: add .copied class for animation
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('.btn-copy, .btn-secondary');
        if (!btn) return;
        var observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(m) {
            if (btn.textContent.indexOf('Copied') !== -1 || btn.textContent.indexOf('复制') !== -1) {
              btn.classList.add('copied');
              setTimeout(function() { btn.classList.remove('copied'); }, 1500);
              observer.disconnect();
            }
          });
        });
        observer.observe(btn, { childList: true, characterData: true, subtree: true });
        setTimeout(function() { observer.disconnect(); }, 2000);
      });
    })();
  </script>
</BaseLayout>

<style>
  .tool-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .tool-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .tool-description {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
  }

  .trust-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .trust-item svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .tool-widget {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin: 1.5rem 0;
  }

  .tool-content {
    line-height: 1.8;
    margin: 1.5rem 0;
  }

  .tool-faq details {
    margin: 0.75rem 0;
    border-bottom: 1px solid var(--color-border-light);
    padding-bottom: 0.75rem;
  }

  .tool-faq summary {
    cursor: pointer;
    font-weight: 600;
    padding: 0.5rem 0;
  }

  .related-tools {
    margin: 2rem 0 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-light);
  }

  .related-tools h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 540px) {
    .related-grid { grid-template-columns: 1fr; }
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: inherit;
    text-decoration: none;
    box-shadow: var(--shadow-card);
    transition: border-color var(--transition-fast), box-shadow var(--transition-med);
  }

  .related-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
    text-decoration: none;
  }

  .related-card strong {
    font-size: 0.95rem;
    color: var(--color-primary);
  }

  .related-card span {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }
</style>
