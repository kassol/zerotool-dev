---
// ToolLayout.astro — for SEO tool pages
// Pattern: "Free Online [Tool Name] - [Site Name]"
// Each tool gets its own URL, full SEO, and ad slots

import BaseLayout from './BaseLayout.astro';
import AdUnit from '../components/AdUnit.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { getRelatedTools, getToolName, getToolDescription } from '../data/tools';
import { getToolIcon } from '../data/icons';
import { t } from '../i18n/utils';
import '../styles/tool-common.css';

interface Props {
  title: string;           // e.g. "Capitalize Title Online — Free Tool"
  description: string;     // 120-160 chars, keyword-rich
  toolName: string;        // e.g. "Title Case Converter"
  lang?: string;
  canonicalUrl?: string;
  faqItems?: { question: string; answer: string }[];
}

const {
  title,
  description,
  toolName,
  lang = 'en',
  canonicalUrl,
  faqItems = [],
} = Astro.props;

// Derive current tool slug from URL path
const pathParts = Astro.url.pathname.replace(/\/$/, '').split('/');
const currentSlug = pathParts[pathParts.length - 1];
const relatedTools = getRelatedTools(currentSlug, 6);
const toolBase = lang === 'zh' ? '/zh/tools' : lang === 'ja' ? '/ja/tools' : lang === 'ko' ? '/ko/tools' : '/tools';
const wideToolSlugs = new Set([
  'json-formatter',
  'json-diff',
  'json-schema-validator',
  'json-to-typescript',
  'json-to-zod',
  'json-to-go-struct',
  'json-to-java-pojo',
  'json-to-kotlin',
  'json-to-python-dataclass',
  'json-to-mongoose',
  'json-to-csv',
  'json-to-json-schema',
  'json-xml-converter',
  'yaml-json',
  'yaml-toml',
  'yaml-validator',
  'toml-json',
  'csv-json',
  'csv-to-markdown',
  'csv-to-sql',
  'xml-formatter',
  'sql-formatter',
  'markdown-preview',
  'markdown-linter',
  'markdown-table-generator',
  'diff-checker',
  'html-to-markdown',
  'html-to-jsx',
  'svg-to-jsx',
  'typescript-to-zod',
  'protobuf-to-json',
  'openapi-validator',
  'css-grid-generator',
  'css-flexbox-generator',
  'css-gradient-generator',
  'css-filter-generator',
  'css-clip-path-generator',
  'css-variables-generator',
  'css-to-tailwind',
  'glassmorphism-generator',
  'box-shadow-generator',
  'color-palette-generator',
  'color-shades-generator',
  'image-to-base64',
  'svg-to-png-converter',
  'webp-converter',
  'qr-code-decoder',
  'qr-code-generator',
  'curl-to-code',
  'docker-to-compose',
  'env-file-parser',
  'cookie-parser',
  'fake-data-generator',
  'robots-txt-generator',
  'htaccess-generator',
]);
const toolWidgetClass = wideToolSlugs.has(currentSlug) ? 'tool-widget tool-widget--wide' : 'tool-widget';

// Per-tool OG image — generated by scripts/generate-og.mjs
const ogImage = `/og/${currentSlug}.png`;

// JSON-LD structured data for tool pages (SoftwareApplication schema)
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: toolName,
  description,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};

// FAQ schema when faqItems present
const faqJsonLd = faqItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
} : null;

// Breadcrumb schema: Home > Tools > {Tool Name}
const langPrefix = lang === 'en' ? '' : `/${lang}`;
const siteUrl = Astro.site?.toString() ?? 'https://zerotool.dev/';
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: t(lang, 'nav.home'),
      item: new URL(`${langPrefix}/`, siteUrl).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: t(lang, 'nav.tools'),
      item: new URL(`${langPrefix}/tools/`, siteUrl).toString(),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: toolName,
      item: new URL(`${langPrefix}/tools/${currentSlug}/`, siteUrl).toString(),
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  lang={lang}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {faqJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    )}
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

    <!-- ztPersist must be defined before any tool body scripts run -->
    <script is:inline>
      (function() {
        var MAX_ENTRY = 50 * 1024;       // 50 KB per tool
        var MAX_TOTAL = 2 * 1024 * 1024; // 2 MB total

        function _ztEvictIfNeeded(savingSlug, incomingLen) {
          try {
            var recent = JSON.parse(localStorage.getItem('zt-recent') || '[]');
            var keys = [];
            for (var i = 0; i < localStorage.length; i++) {
              var k = localStorage.key(i);
              if (k && k.indexOf('zt-input-') === 0 && k !== 'zt-input-' + savingSlug) {
                keys.push(k);
              }
            }
            var total = incomingLen;
            keys.forEach(function(k) { total += (localStorage.getItem(k) || '').length; });
            if (total <= MAX_TOTAL) return;
            keys.sort(function(a, b) {
              var aIdx = recent.indexOf(a.replace('zt-input-', ''));
              var bIdx = recent.indexOf(b.replace('zt-input-', ''));
              if (aIdx === -1) aIdx = 9999;
              if (bIdx === -1) bIdx = 9999;
              return bIdx - aIdx;
            });
            while (total > MAX_TOTAL && keys.length > 0) {
              var evict = keys.shift();
              total -= (localStorage.getItem(evict) || '').length;
              localStorage.removeItem(evict);
            }
          } catch (e) {}
        }

        window.ztPersist = {
          save: function(slug, data) {
            try {
              var json = JSON.stringify(data);
              if (json.length > MAX_ENTRY) return;
              _ztEvictIfNeeded(slug, json.length);
              localStorage.setItem('zt-input-' + slug, json);
            } catch (e) {}
          },
          load: function(slug) {
            try {
              return JSON.parse(localStorage.getItem('zt-input-' + slug) || '{}');
            } catch (e) { return {}; }
          },
          clear: function(slug) {
            try { localStorage.removeItem('zt-input-' + slug); } catch (e) {}
          }
        };
      })();
    </script>
  </Fragment>

  <div class="tool-page">
    <header class="tool-header">
      <div class="tool-title-block">
        <span class="tool-header-icon" set:html={getToolIcon(currentSlug)} />
        <div>
          <p class="tool-kicker">ZeroTool Workbench</p>
          <h1>{toolName}</h1>
          <p class="tool-description">{description}</p>
        </div>
      </div>

      <div class="trust-bar">
        <span class="trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          {t(lang, 'tool.trustClient')}
        </span>
        <span class="trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
          {t(lang, 'tool.trustPrivacy')}
        </span>
        <span class="trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          {t(lang, 'tool.trustFree')}
        </span>
      </div>
    </header>

    <!-- Top ad: above the fold but below h1 -->
    <AdUnit slot={import.meta.env.PUBLIC_ADSENSE_SLOT_TOP ?? ''} format="horizontal" />

    <!-- Tool UI injected here -->
    <section class={toolWidgetClass}>
      <slot name="tool" />
      <ShareButtons toolName={toolName} lang={lang} />
    </section>

    <!-- Related Tools: immediately below the tool widget -->
    {relatedTools.length > 0 && (
      <section class="related-tools">
        <h2>{t(lang, 'tool.relatedTools')}</h2>
        <div class="related-grid">
          {relatedTools.map(tool => (
            <a href={`${toolBase}/${tool.slug}/`} class="related-card" data-category={tool.category}>
              <span class="related-icon" set:html={getToolIcon(tool.slug)} />
              <span class="related-copy">
                <strong>{getToolName(tool, lang)}</strong>
                <span>{getToolDescription(tool, lang)}</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Mid ad: between related tools and instructions -->
    <AdUnit slot={import.meta.env.PUBLIC_ADSENSE_SLOT_MID ?? ''} format="rectangle" />

    <!-- How-to / instructions (SEO content) -->
    <section class="tool-content">
      <slot />
    </section>

    <!-- FAQ section -->
    {faqItems.length > 0 && (
      <section class="tool-faq">
        <h2>FAQ</h2>
        {faqItems.map(({ question, answer }) => (
          <details>
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </section>
    )}

    <!-- Bottom ad -->
    <AdUnit slot={import.meta.env.PUBLIC_ADSENSE_SLOT_BOTTOM ?? ''} format="rectangle" />
  </div>

  <!-- Tool UX enhancements: keyboard shortcuts + copy feedback + zt-recent tracking -->
  <script is:inline>
    (function() {
      var _slug = (function() {
        var parts = location.pathname.replace(/\/$/, '').split('/');
        return parts[parts.length - 1];
      })();

      // ── Record visit in zt-recent ──────────────────────────────────────────
      try {
        var recent = JSON.parse(localStorage.getItem('zt-recent') || '[]');
        recent = recent.filter(function(s) { return s !== _slug; });
        recent.unshift(_slug);
        if (recent.length > 20) recent = recent.slice(0, 20);
        localStorage.setItem('zt-recent', JSON.stringify(recent));
      } catch (e) {}

      // ── Keyboard shortcuts: Ctrl/Cmd+Enter = primary action, Ctrl/Cmd+L = clear ──
      document.addEventListener('keydown', function(e) {
        var mod = e.metaKey || e.ctrlKey;
        if (!mod) return;
        if (e.key === 'Enter') {
          var btn = document.querySelector('.tool-widget .btn-primary');
          if (btn) { e.preventDefault(); btn.click(); }
        }
        if (e.key === 'l' || e.key === 'L') {
          var widget = document.querySelector('.tool-widget');
          if (widget && document.activeElement && widget.contains(document.activeElement)) {
            e.preventDefault();
            widget.querySelectorAll('textarea, input[type="text"]').forEach(function(el) { el.value = ''; });
            window.ztPersist.clear(_slug);
          }
        }
      });

      // ── Copy button visual feedback ────────────────────────────────────────
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('.btn-copy, .btn-secondary');
        if (!btn) return;
        var observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(m) {
            if (btn.textContent.indexOf('Copied') !== -1 || btn.textContent.indexOf('复制') !== -1 || btn.textContent.indexOf('コピー') !== -1 || btn.textContent.indexOf('복사') !== -1) {
              btn.classList.add('copied');
              setTimeout(function() { btn.classList.remove('copied'); }, 1500);
              observer.disconnect();
            }
          });
        });
        observer.observe(btn, { childList: true, characterData: true, subtree: true });
        setTimeout(function() { observer.disconnect(); }, 2000);
      });
    })();
  </script>
</BaseLayout>

<style>
  .tool-page {
    width: min(100% - 2rem, 1120px);
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 3.6rem) 0 4.5rem;
  }

  .tool-header {
    display: grid;
    gap: 1.2rem;
    margin-bottom: 1.25rem;
  }

  .tool-title-block {
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .tool-header-icon {
    display: grid;
    width: 64px;
    height: 64px;
    place-items: center;
    border-radius: var(--radius-lg);
    background: var(--color-bg-icon);
    color: var(--color-primary);
    box-shadow: var(--shadow-card);
    outline: 1px solid var(--color-border-soft);
    outline-offset: -1px;
  }

  .tool-header-icon :global(svg) {
    width: 30px;
    height: 30px;
  }

  .tool-kicker {
    margin: 0 0 0.45rem;
    color: var(--color-accent);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tool-header h1 {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(2.45rem, 5.4vw, 4.9rem);
    font-weight: 600;
    line-height: 0.96;
    letter-spacing: -0.03em;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .tool-description {
    max-width: 780px;
    margin: 0.9rem 0 0;
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.7vw, 1.16rem);
    line-height: 1.65;
    text-wrap: pretty;
  }

  .tool-description :global(code) {
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .trust-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .trust-item {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    gap: 0.45rem;
    border-radius: var(--radius-pill);
    background: var(--color-surface-muted);
    color: var(--color-text-secondary);
    padding: 0.4rem 0.75rem;
    font-size: 0.84rem;
    font-weight: 650;
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
  }

  .trust-item svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .tool-widget {
    width: 100%;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: clamp(1rem, 2.2vw, 1.5rem);
    margin: 1.25rem 0 1.75rem;
    box-shadow: var(--shadow-panel);
    outline: 1px solid var(--color-border-soft);
    outline-offset: -1px;
  }

  .tool-widget--wide {
    width: 100%;
    max-width: none;
  }

  .tool-content {
    max-width: 820px;
    line-height: 1.8;
    margin: 2rem auto;
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  .tool-content :global(h2),
  .tool-faq h2,
  .related-tools h2 {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.4vw, 2rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.022em;
  }

  .tool-content :global(h2) {
    margin-top: 2.1rem;
  }

  .tool-content :global(pre) {
    margin: 1rem 0 1.25rem;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary) !important;
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
  }

  .tool-content :global(pre code) {
    display: block;
    min-width: max-content;
    padding: 0 !important;
    background: transparent !important;
    color: var(--color-text) !important;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .tool-content :global(pre code *) {
    background: transparent !important;
    color: inherit !important;
  }

  .tool-content :global(:not(pre) > code) {
    border-radius: 5px;
    background: var(--color-surface-muted);
    color: var(--color-text);
    padding: 0.08rem 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.9em;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .tool-faq {
    max-width: 820px;
    margin: 2rem auto;
  }

  .tool-faq details {
    margin: 0.75rem 0;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    padding: 0.15rem 0.95rem;
    box-shadow: var(--shadow-card);
    outline: 1px solid var(--color-border-soft);
    outline-offset: -1px;
  }

  .tool-faq summary {
    cursor: pointer;
    font-weight: 700;
    padding: 0.75rem 0;
    color: var(--color-text);
  }

  .tool-faq p {
    color: var(--color-text-secondary);
  }

  .related-tools {
    margin: 2.25rem 0 1rem;
  }

  .related-tools h2 {
    margin: 0 0 1rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 310px), 1fr));
    gap: 0.8rem;
  }

  .related-card {
    --category-color: var(--color-primary);
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    gap: 0.8rem;
    align-items: center;
    min-height: 100px;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    color: inherit;
    padding: 0.95rem;
    text-decoration: none;
    box-shadow: var(--shadow-card);
    outline: 1px solid var(--color-border-soft);
    outline-offset: -1px;
    transition: background-color var(--transition-fast), box-shadow var(--transition-med), transform var(--transition-med);
  }

  @media (hover: hover) {
    .related-card:hover {
      background: color-mix(in oklch, var(--color-surface) 90%, var(--category-color) 5%);
      box-shadow: var(--shadow-card-hover);
      text-decoration: none;
      transform: translateY(-2px);
    }
  }

  .related-card:active {
    transform: scale(0.98);
  }

  .related-icon {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border-radius: var(--radius-sm);
    background: color-mix(in oklch, var(--category-color) 13%, var(--color-surface));
    color: var(--category-color);
  }

  .related-icon :global(svg) {
    width: 21px;
    height: 21px;
  }

  .related-copy {
    display: grid;
    min-width: 0;
    gap: 0.25rem;
  }

  .related-copy strong {
    color: var(--color-text);
    font-size: 0.97rem;
    line-height: 1.25;
  }

  .related-copy span {
    color: var(--color-text-secondary);
    font-size: 0.84rem;
    line-height: 1.45;
  }

  .related-card[data-category="data"] { --category-color: var(--color-cat-data); }
  .related-card[data-category="color"] { --category-color: var(--color-cat-color); }
  .related-card[data-category="encoding"] { --category-color: var(--color-cat-encoding); }
  .related-card[data-category="text"] { --category-color: var(--color-cat-text); }
  .related-card[data-category="security"] { --category-color: var(--color-cat-security); }
  .related-card[data-category="dev"] { --category-color: var(--color-cat-dev); }
  .related-card[data-category="api"] { --category-color: var(--color-cat-api); }
  .related-card[data-category="image"] { --category-color: var(--color-cat-image); }

  @media (max-width: 640px) {
    .tool-page {
      width: min(100% - 1rem, 1120px);
      padding-top: 1.25rem;
    }

    .tool-title-block {
      grid-template-columns: 52px minmax(0, 1fr);
      gap: 0.8rem;
    }

    .tool-header-icon {
      width: 52px;
      height: 52px;
      border-radius: var(--radius-md);
    }

    .tool-header-icon :global(svg) {
      width: 25px;
      height: 25px;
    }

    .tool-widget {
      border-radius: var(--radius-md);
    }
  }
</style>
