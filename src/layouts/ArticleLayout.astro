---
import BaseLayout from './BaseLayout.astro';
import AdUnit from '../components/AdUnit.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, lang, ogImage, canonicalUrl, noindex } = post.data;

// Estimate read time
const wordCount = post.body.split(/\s+/).length;
const readMinutes = Math.ceil(wordCount / 200);
---

<BaseLayout
  title={title}
  description={description}
  pubDate={pubDate}
  updatedDate={updatedDate}
  lang={lang}
  ogImage={ogImage}
  canonicalUrl={canonicalUrl}
  noindex={noindex}
>
  <article class="article-container">
    <header class="article-header">
      <h1>{title}</h1>
      <div class="article-meta">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
            year: 'numeric', month: 'long', day: 'numeric',
          })}
        </time>
        <span>{readMinutes} min read</span>
      </div>
    </header>

    <!-- Top ad: after article header, before content -->
    <AdUnit slot={import.meta.env.PUBLIC_ADSENSE_SLOT_TOP ?? ''} format="horizontal" />

    <div class="article-body">
      <slot />
    </div>

    <!-- Mid-content ad: injected via AdUnit in MDX, or add a marker here -->

    <!-- Bottom ad: after article content -->
    <AdUnit slot={import.meta.env.PUBLIC_ADSENSE_SLOT_BOTTOM ?? ''} format="rectangle" />
  </article>
</BaseLayout>

<style>
  .article-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .article-header h1 {
    font-size: 2rem;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .article-meta {
    display: flex;
    gap: 1rem;
    color: #666;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .article-body {
    line-height: 1.8;
    font-size: 1.05rem;
  }
</style>
