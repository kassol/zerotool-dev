---
import BaseLayout from './BaseLayout.astro';
import AdUnit from '../components/AdUnit.astro';
import { t } from '../i18n/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  headings?: { depth: number; slug: string; text: string }[];
  allPosts?: CollectionEntry<'blog'>[];
}

const { post, headings = [], allPosts = [] } = Astro.props;
const { title, description, pubDate, updatedDate, lang, ogImage, canonicalUrl, noindex, tags } = post.data;

// Estimate read time
const wordCount = post.body.split(/\s+/).length;
const readMinutes = Math.ceil(wordCount / 200);

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://zerotool.dev';
const canonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/og-default.png`;

const isZh = lang === 'zh';
const isJa = lang === 'ja';
const isKo = lang === 'ko';
const homeBase = isZh ? '/zh/' : isJa ? '/ja/' : isKo ? '/ko/' : '/';
const blogBase = isZh ? '/zh/blog/' : isJa ? '/ja/blog/' : isKo ? '/ko/blog/' : '/blog/';
const postUrlSlug = (slug: string) => slug.replace(/\/(en|zh|ja|ko)$/, '');

// TOC: only h2 and h3
const tocItems = headings.filter(h => h.depth === 2 || h.depth === 3);

// Related articles: same language, share at least one tag, exclude self
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.tags.some(t => tags.includes(t)))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

// Breadcrumb JSON-LD
const breadcrumbJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}${homeBase}` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}${blogBase}` },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
});

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  url: canonical,
  image: ogImageUrl,
  publisher: {
    '@type': 'Organization',
    name: 'ZeroTool',
    url: siteUrl,
  },
  author: {
    '@type': 'Organization',
    name: 'ZeroTool',
  },
});
---

<BaseLayout
  title={title}
  description={description}
  pubDate={pubDate}
  updatedDate={updatedDate}
  lang={lang}
  ogImage={ogImage}
  canonicalUrl={canonicalUrl}
  noindex={noindex}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
    <script type="application/ld+json" set:html={breadcrumbJsonLd} />
  </Fragment>

  <article class="article-container">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href={homeBase}>{t(lang, 'breadcrumb.home')}</a>
      <span aria-hidden="true">/</span>
      <a href={blogBase}>{t(lang, 'breadcrumb.blog')}</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{title}</span>
    </nav>

    <header class="article-header">
      <h1>{title}</h1>
      <div class="article-meta">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString(isZh ? 'zh-CN' : isJa ? 'ja-JP' : isKo ? 'ko-KR' : 'en-US', {
            year: 'numeric', month: 'long', day: 'numeric',
          })}
        </time>
        <span>{t(lang, 'article.readTime').replace('{minutes}', readMinutes.toString())}</span>
      </div>
    </header>

    <!-- Top ad: after article header, before content -->
    <AdUnit slot={import.meta.env.PUBLIC_ADSENSE_SLOT_TOP ?? ''} format="horizontal" />

    <!-- Table of Contents -->
    {tocItems.length >= 3 && (
      <nav class="toc" aria-label="Table of contents">
        <details open>
          <summary><strong>{t(lang, 'article.toc')}</strong></summary>
          <ul>
            {tocItems.map(h => (
              <li class={h.depth === 3 ? 'toc-h3' : ''}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </details>
      </nav>
    )}

    <div class="article-body">
      <slot />
    </div>

    <!-- Related Articles -->
    {relatedPosts.length > 0 && (
      <section class="related-articles">
        <h2>{t(lang, 'article.relatedArticles')}</h2>
        <ul>
          {relatedPosts.map(p => (
            <li>
              <a href={`${blogBase}${postUrlSlug(p.slug)}/`}>
                <strong>{p.data.title}</strong>
                <span>{p.data.description.slice(0, 100)}{p.data.description.length > 100 ? '...' : ''}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Bottom ad: after article content -->
    <AdUnit slot={import.meta.env.PUBLIC_ADSENSE_SLOT_BOTTOM ?? ''} format="rectangle" />
  </article>
</BaseLayout>

<style>
  .article-container {
    max-width: 760px;
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 3rem) 1rem 4rem;
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .breadcrumbs a {
    color: var(--color-text-secondary);
  }

  .breadcrumbs a:hover {
    color: var(--color-primary);
  }

  .breadcrumbs span[aria-current] {
    color: var(--color-text);
  }

  .article-header h1 {
    margin: 0 0 0.75rem;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.026em;
    text-wrap: balance;
  }

  .article-meta {
    display: flex;
    gap: 1rem;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .toc {
    margin: 1rem 0 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--color-bg-secondary);
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  .toc summary {
    cursor: pointer;
    user-select: none;
  }

  .toc ul {
    margin: 0.5rem 0 0;
    padding-left: 1.25rem;
    list-style: none;
  }

  .toc li {
    margin: 0.3rem 0;
    line-height: 1.5;
  }

  .toc li.toc-h3 {
    padding-left: 1rem;
  }

  .toc a {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .toc a:hover {
    color: var(--color-primary);
  }

  .article-body {
    line-height: 1.8;
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    text-wrap: pretty;
  }

  .article-body :global(h2),
  .article-body :global(h3) {
    color: var(--color-text);
    font-family: var(--font-display);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.018em;
  }

  .article-body :global(h2) {
    margin-top: 2.1rem;
    font-size: clamp(1.55rem, 3vw, 2.1rem);
  }

  .article-body :global(h3) {
    margin-top: 1.6rem;
    font-size: clamp(1.18rem, 2.3vw, 1.45rem);
  }

  /* Shiki injects inline `style="background-color:..."` on <pre> and
     `style="color:..."` on each <span>. !important is required to keep
     code blocks readable across both light and dark site themes — same
     pattern as ToolLayout. */
  .article-body :global(pre) {
    margin: 1.2rem 0;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary) !important;
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
  }

  .article-body :global(pre code) {
    display: block;
    min-width: max-content;
    padding: 0 !important;
    background: transparent !important;
    color: var(--color-text) !important;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .article-body :global(pre code *) {
    background: transparent !important;
    color: inherit !important;
  }

  .article-body :global(:not(pre) > code) {
    border-radius: 5px;
    background: var(--color-surface-muted);
    color: var(--color-text);
    padding: 0.1rem 0.32rem;
    font-family: var(--font-mono);
    font-size: 0.9em;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .article-body :global(blockquote) {
    margin: 1.4rem 0;
    border-left: 3px solid var(--color-primary);
    padding: 0.15rem 0 0.15rem 1rem;
    color: var(--color-text-secondary);
    background: color-mix(in oklch, var(--color-primary) 5%, transparent);
  }

  .article-body :global(table) {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    margin: 1.2rem 0;
    font-size: 0.95rem;
  }

  .article-body :global(th),
  .article-body :global(td) {
    border-bottom: 1px solid var(--color-border-light);
    padding: 0.58rem 0.7rem;
    text-align: left;
  }

  .related-articles {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-light);
  }

  .related-articles h2 {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
  }

  .related-articles ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .related-articles a {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .related-articles a:hover {
    border-color: var(--color-primary);
    box-shadow: 0 2px 8px var(--color-primary-light);
    text-decoration: none;
  }

  .related-articles a strong {
    font-size: 0.95rem;
    color: var(--color-primary);
  }

  .related-articles a span {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }
</style>
