---
import { t } from '../i18n/utils';

interface Props {
  lang: 'en' | 'zh' | 'ja' | 'ko';
}
const { lang } = Astro.props;
const placeholder = t(lang, 'search.placeholder');
const noResultsText = t(lang, 'search.noResults');
---

<div class="search-wrap">
  <div class="search-box">
    <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input
      type="search"
      id="tool-search"
      class="search-input"
      placeholder={placeholder}
      aria-label={placeholder}
      autocomplete="off"
      spellcheck="false"
    />
  </div>
  <p id="no-results" class="no-results" hidden>{noResultsText}</p>
</div>

<script is:inline>
  (function () {
    var input = document.getElementById('tool-search');
    var noResults = document.getElementById('no-results');
    if (!input || !noResults) return;

    var timer;
    input.addEventListener('input', function () {
      clearTimeout(timer);
      timer = setTimeout(filter, 150);
    });

    function filter() {
      var q = input.value.trim().toLowerCase();
      window.__ztSearch = q;
      // Delegate to shared filter if CategoryFilter is present
      if (typeof window.__ztApply === 'function') {
        window.__ztApply();
        return;
      }
      // Fallback: search-only filter
      var cards = document.querySelectorAll('.tool-card');
      var visible = 0;
      for (var i = 0; i < cards.length; i++) {
        var kw = cards[i].getAttribute('data-keywords') || '';
        if (!q || kw.indexOf(q) !== -1) {
          cards[i].style.display = '';
          visible++;
        } else {
          cards[i].style.display = 'none';
        }
      }
      noResults.hidden = visible > 0;
    }
  })();
</script>

<style>
  .search-wrap {
    margin-bottom: 0.85rem;
  }

  .search-box {
    position: relative;
    max-width: 100%;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    min-height: 54px;
    padding: 0.85rem 1rem 0.85rem 2.75rem;
    font-size: 1rem;
    border: 0;
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    outline: none;
    box-sizing: border-box;
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
    transition: box-shadow var(--transition-fast), background-color var(--transition-fast);
  }

  .search-input:focus {
    background: var(--color-surface);
    box-shadow: inset 0 0 0 1px var(--color-primary), 0 0 0 4px var(--color-primary-light);
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  /* Remove default search clear button */
  .search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .no-results {
    margin: 1.5rem 0 0;
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }
</style>
