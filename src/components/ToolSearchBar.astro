---
import { t } from '../i18n/utils';
import { allTools, getToolName } from '../data/tools';

interface Props {
  lang: 'en' | 'zh' | 'ja' | 'ko';
}
const { lang } = Astro.props;
const placeholder = t(lang, 'search.placeholder');
const noResultsPrefix = t(lang, 'search.noResultsPrefix');
const tryKeyword = t(lang, 'search.tryKeyword');
const clearSearch = t(lang, 'search.clearSearch');

const toolBase = lang === 'en' ? '/tools/' : `/${lang}/tools/`;
const popularSlugs = ['json-formatter', 'base64', 'uuid-generator', 'url-encode', 'password-generator'];
const suggestions = popularSlugs.map(slug => {
  const tool = allTools.find(t => t.slug === slug);
  return {
    slug,
    name: tool ? getToolName(tool, lang) : slug,
    href: `${toolBase}${slug}/`,
  };
});
---

<div class="search-wrap">
  <div class="search-box">
    <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input
      type="search"
      id="tool-search"
      class="search-input"
      placeholder={placeholder}
      autocomplete="off"
      spellcheck="false"
    />
  </div>
  <div id="no-results" class="no-results" hidden>
    <svg class="no-results-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      <line x1="8" y1="11" x2="14" y2="11"/>
    </svg>
    <p class="no-results-title">{noResultsPrefix} &ldquo;<span id="no-results-query"></span>&rdquo;</p>
    <p class="no-results-sub">{tryKeyword}</p>
    <ul class="no-results-suggestions">
      {suggestions.map(s => (
        <li><a href={s.href}>{s.name}</a></li>
      ))}
    </ul>
    <button id="clear-search" class="no-results-clear" type="button">{clearSearch}</button>
  </div>
</div>

<script is:inline>
  (function () {
    var input = document.getElementById('tool-search');
    var noResults = document.getElementById('no-results');
    if (!input || !noResults) return;

    function setQuery(q) {
      var el = document.getElementById('no-results-query');
      if (el) el.textContent = q;
    }

    var clearBtn = document.getElementById('clear-search');
    if (clearBtn) {
      clearBtn.addEventListener('click', function () {
        input.value = '';
        window.__ztSearch = '';
        if (typeof window.__ztApply === 'function') {
          window.__ztApply();
        } else {
          filter();
        }
        input.focus();
      });
    }

    var timer;
    input.addEventListener('input', function () {
      clearTimeout(timer);
      timer = setTimeout(filter, 150);
    });

    function filter() {
      var q = input.value.trim().toLowerCase();
      window.__ztSearch = q;
      // Delegate to shared filter if CategoryFilter is present
      if (typeof window.__ztApply === 'function') {
        window.__ztApply();
        return;
      }
      // Fallback: search-only filter
      var cards = document.querySelectorAll('.tool-card');
      var visible = 0;
      for (var i = 0; i < cards.length; i++) {
        var kw = cards[i].getAttribute('data-keywords') || '';
        if (!q || kw.indexOf(q) !== -1) {
          cards[i].style.display = '';
          visible++;
        } else {
          cards[i].style.display = 'none';
        }
      }
      noResults.hidden = visible > 0;
      if (visible === 0) setQuery(q);
    }
  })();
</script>

<style>
  .search-wrap {
    margin-bottom: 1.5rem;
  }

  .search-box {
    position: relative;
    max-width: 100%;
  }

  .search-icon {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 0.65rem 1rem 0.65rem 2.5rem;
    font-size: 0.95rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
    box-sizing: border-box;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .search-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  /* Remove default search clear button */
  .search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .no-results {
    margin: 2.5rem 0 0;
    text-align: center;
    padding: 0 1rem;
  }

  .no-results-icon {
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .no-results-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 0.4rem;
  }

  .no-results-sub {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0 0 1rem;
  }

  .no-results-suggestions {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .no-results-suggestions a {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-primary);
    text-decoration: none;
    background: var(--color-bg);
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }

  .no-results-suggestions a:hover {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    text-decoration: none;
  }

  .no-results-clear {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
  }

  .no-results-clear:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 5%, transparent);
  }
</style>
