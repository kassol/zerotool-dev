---
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: string;
  pubDate?: Date;
  updatedDate?: Date;
  translationSlug?: string;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage,
  noindex = false,
  lang = 'en',
  pubDate,
  updatedDate,
  translationSlug,
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? '';
const ensureTrailingSlash = (path: string) => path.endsWith('/') ? path : `${path}/`;
const canonical = canonicalUrl ?? new URL(ensureTrailingSlash(Astro.url.pathname), siteUrl).toString();
const ogImageUrl = ogImage
  ? new URL(ogImage, siteUrl).toString()
  : new URL('/og-default.png', siteUrl).toString();

// Build a set of existing blog slugs for hreflang existence checks
const blogEntries = await getCollection('blog');
const blogSlugs = new Set(blogEntries.map((e) => e.slug));
---

<!-- Primary Meta -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex,nofollow" />}
<meta name="language" content={lang} />

<!-- Open Graph -->
<meta property="og:site_name" content="ZeroTool" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:type" content={pubDate ? 'article' : 'website'} />
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- hreflang alternates for i18n -->
{(() => {
  const pathname = Astro.url.pathname;
  const isBlogPost = /^\/(zh|ja|ko)\/blog\/[^/]+/.test(pathname) || /^\/blog\/[^/]+/.test(pathname);

  if (isBlogPost) {
    // After migration: URL slug IS the base slug (no language suffix).
    // Collection entries are stored under `{baseSlug}/{lang}` keys.
    const baseSlug = pathname
      .replace(/^\/(zh|ja|ko)\/blog\//, '')
      .replace(/^\/blog\//, '')
      .replace(/\/$/, '');

    const langVariants = [
      { hreflang: 'en', collectionKey: `${baseSlug}/en`, prefix: '' },
      { hreflang: 'zh', collectionKey: `${baseSlug}/zh`, prefix: '/zh' },
      { hreflang: 'ja', collectionKey: `${baseSlug}/ja`, prefix: '/ja' },
      { hreflang: 'ko', collectionKey: `${baseSlug}/ko`, prefix: '/ko' },
    ];

    const links: any[] = langVariants
      .filter(({ collectionKey }) => blogSlugs.has(collectionKey))
      .map(({ hreflang: l, prefix }) =>
        <link rel="alternate" hreflang={l} href={new URL(`${prefix}/blog/${baseSlug}/`, siteUrl).toString()} />
      );
    // x-default always points to EN if it exists
    if (blogSlugs.has(`${baseSlug}/en`)) {
      links.push(<link rel="alternate" hreflang="x-default" href={new URL(`/blog/${baseSlug}/`, siteUrl).toString()} />);
    }
    return links;
  } else {
    // Non-blog pages: path-based swap works correctly
    const strippedPath = pathname.replace(/^\/(zh|ja|ko)(\/|$)/, '/') || '/';
    const enPath = ensureTrailingSlash(strippedPath);
    const zhPath = ensureTrailingSlash(strippedPath === '/' ? '/zh/' : `/zh${strippedPath}`);
    const jaPath = ensureTrailingSlash(strippedPath === '/' ? '/ja/' : `/ja${strippedPath}`);
    const koPath = ensureTrailingSlash(strippedPath === '/' ? '/ko/' : `/ko${strippedPath}`);
    return [
      <link rel="alternate" hreflang="en" href={new URL(enPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="zh" href={new URL(zhPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="ja" href={new URL(jaPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="ko" href={new URL(koPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="x-default" href={new URL(enPath, siteUrl).toString()} />,
    ];
  }
})()}
