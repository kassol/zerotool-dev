---
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: string;
  pubDate?: Date;
  updatedDate?: Date;
  translationSlug?: string;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage,
  noindex = false,
  lang = 'en',
  pubDate,
  updatedDate,
  translationSlug,
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? '';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = ogImage
  ? new URL(ogImage, siteUrl).toString()
  : new URL('/og-default.png', siteUrl).toString();

// Build a set of existing blog slugs for hreflang existence checks
const blogEntries = await getCollection('blog');
const blogSlugs = new Set(blogEntries.map((e) => e.slug));
---

<!-- Primary Meta -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex,nofollow" />}
<meta name="language" content={lang} />

<!-- Open Graph -->
<meta property="og:site_name" content="ZeroTool" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:type" content={pubDate ? 'article' : 'website'} />
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- hreflang alternates for i18n -->
{(() => {
  const pathname = Astro.url.pathname;
  const isBlogPost = /^\/(zh|ja|ko)\/blog\/[^/]+/.test(pathname) || /^\/blog\/[^/]+/.test(pathname);

  if (isBlogPost) {
    // Extract slug from pathname: strip /zh/blog/, /ja/blog/, /ko/blog/, or /blog/ prefix
    const pathSlug = pathname
      .replace(/^\/(zh|ja|ko)\/blog\//, '')
      .replace(/^\/blog\//, '')
      .replace(/\/$/, '');
    // Derive base slug by stripping language suffix
    const baseSlug = pathSlug.replace(/-(zh|ja|ko)$/, '');

    const langVariants = [
      { hreflang: 'en', slug: baseSlug, prefix: '' },
      { hreflang: 'zh', slug: `${baseSlug}-zh`, prefix: '/zh' },
      { hreflang: 'ja', slug: `${baseSlug}-ja`, prefix: '/ja' },
      { hreflang: 'ko', slug: `${baseSlug}-ko`, prefix: '/ko' },
    ];

    const links: any[] = langVariants
      .filter(({ slug }) => blogSlugs.has(slug))
      .map(({ hreflang: l, slug, prefix }) =>
        <link rel="alternate" hreflang={l} href={new URL(`${prefix}/blog/${slug}/`, siteUrl).toString()} />
      );
    // x-default always points to EN if it exists
    if (blogSlugs.has(baseSlug)) {
      links.push(<link rel="alternate" hreflang="x-default" href={new URL(`/blog/${baseSlug}/`, siteUrl).toString()} />);
    }
    return links;
  } else {
    // Non-blog pages: path-based swap works correctly
    const strippedPath = pathname.replace(/^\/(zh|ja|ko)(\/|$)/, '/') || '/';
    const enPath = strippedPath;
    const zhPath = '/zh' + (strippedPath === '/' ? '' : strippedPath);
    const jaPath = '/ja' + (strippedPath === '/' ? '' : strippedPath);
    const koPath = '/ko' + (strippedPath === '/' ? '' : strippedPath);
    return [
      <link rel="alternate" hreflang="en" href={new URL(enPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="zh" href={new URL(zhPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="ja" href={new URL(jaPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="ko" href={new URL(koPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="x-default" href={new URL(enPath, siteUrl).toString()} />,
    ];
  }
})()}
