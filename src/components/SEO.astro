---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: string;
  pubDate?: Date;
  updatedDate?: Date;
  translationSlug?: string;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage,
  noindex = false,
  lang = 'en',
  pubDate,
  updatedDate,
  translationSlug,
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? '';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = ogImage
  ? new URL(ogImage, siteUrl).toString()
  : new URL('/og-default.png', siteUrl).toString();
---

<!-- Primary Meta -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex,nofollow" />}
<meta name="language" content={lang} />

<!-- Open Graph -->
<meta property="og:site_name" content="ZeroTool" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:type" content={pubDate ? 'article' : 'website'} />
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- hreflang alternates for i18n -->
{(() => {
  const pathname = Astro.url.pathname;
  const isBlogPost = /^\/(zh\/)?blog\/[^/]+/.test(pathname);
  const isZh = lang === 'zh';

  if (isBlogPost && translationSlug) {
    // Blog post with a known translation counterpart
    const enUrl = new URL(`/blog/${isZh ? translationSlug : pathname.replace(/^\/(zh\/)?blog\//, '').replace(/\/$/, '')}/`, siteUrl).toString();
    const zhUrl = new URL(`/zh/blog/${isZh ? pathname.replace(/^\/zh\/blog\//, '').replace(/\/$/, '') : translationSlug}/`, siteUrl).toString();
    return [
      <link rel="alternate" hreflang="en" href={enUrl} />,
      <link rel="alternate" hreflang="zh" href={zhUrl} />,
      <link rel="alternate" hreflang="x-default" href={enUrl} />,
    ];
  } else if (isBlogPost) {
    // Blog post without translation — self-referencing only
    const selfUrl = new URL(pathname, siteUrl).toString();
    return <link rel="alternate" hreflang={lang} href={selfUrl} />;
  } else {
    // Non-blog pages: path-based swap works correctly
    const enPath = pathname.replace(/^\/zh/, '') || '/';
    const zhPath = '/zh' + (pathname.replace(/^\/zh/, '') || '/');
    return [
      <link rel="alternate" hreflang="en" href={new URL(enPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="zh" href={new URL(zhPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="x-default" href={new URL(enPath, siteUrl).toString()} />,
    ];
  }
})()}
