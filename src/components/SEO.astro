---
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: string;
  pubDate?: Date;
  updatedDate?: Date;
  translationSlug?: string;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage,
  noindex = false,
  lang = 'en',
  pubDate,
  updatedDate,
  translationSlug,
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? '';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = ogImage
  ? new URL(ogImage, siteUrl).toString()
  : new URL('/og-default.png', siteUrl).toString();

// Build a set of existing blog slugs for hreflang existence checks
const blogEntries = await getCollection('blog');
const blogSlugs = new Set(blogEntries.map((e) => e.slug));
---

<!-- Primary Meta -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex,nofollow" />}
<meta name="language" content={lang} />

<!-- Open Graph -->
<meta property="og:site_name" content="ZeroTool" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:type" content={pubDate ? 'article' : 'website'} />
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- hreflang alternates for i18n -->
{(() => {
  const pathname = Astro.url.pathname;
  const isBlogPost = /^\/(zh|ja|ko)\/blog\/[^/]+/.test(pathname) || /^\/blog\/[^/]+/.test(pathname);

  if (isBlogPost && translationSlug) {
    // Derive the EN base slug from translationSlug
    // EN posts: translationSlug = "<base>-zh", so base = translationSlug without -zh
    // ZH/JA/KO posts: translationSlug = EN base slug directly
    const enBaseSlug = lang === 'en' ? translationSlug.replace(/-zh$/, '') : translationSlug;

    // Convention-based slug map
    const slugMap: Record<string, { slug: string; prefix: string }> = {
      en: { slug: enBaseSlug, prefix: '/blog' },
      zh: { slug: `${enBaseSlug}-zh`, prefix: '/zh/blog' },
      ja: { slug: `${enBaseSlug}-ja`, prefix: '/ja/blog' },
      ko: { slug: `${enBaseSlug}-ko`, prefix: '/ko/blog' },
    };

    const links: any[] = [];
    for (const [hreflang, { slug, prefix }] of Object.entries(slugMap)) {
      if (blogSlugs.has(slug)) {
        links.push(<link rel="alternate" hreflang={hreflang} href={new URL(`${prefix}/${slug}/`, siteUrl).toString()} />);
      }
    }
    // x-default always points to EN if it exists
    if (blogSlugs.has(enBaseSlug)) {
      links.push(<link rel="alternate" hreflang="x-default" href={new URL(`/blog/${enBaseSlug}/`, siteUrl).toString()} />);
    }
    return links;
  } else if (isBlogPost) {
    // Blog post without translation — self-referencing only
    const selfUrl = new URL(pathname, siteUrl).toString();
    return <link rel="alternate" hreflang={lang} href={selfUrl} />;
  } else {
    // Non-blog pages: path-based swap works correctly
    const strippedPath = pathname.replace(/^\/(zh|ja|ko)(\/|$)/, '/') || '/';
    const enPath = strippedPath;
    const zhPath = '/zh' + (strippedPath === '/' ? '' : strippedPath);
    const jaPath = '/ja' + (strippedPath === '/' ? '' : strippedPath);
    const koPath = '/ko' + (strippedPath === '/' ? '' : strippedPath);
    return [
      <link rel="alternate" hreflang="en" href={new URL(enPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="zh" href={new URL(zhPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="ja" href={new URL(jaPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="ko" href={new URL(koPath, siteUrl).toString()} />,
      <link rel="alternate" hreflang="x-default" href={new URL(enPath, siteUrl).toString()} />,
    ];
  }
})()}
