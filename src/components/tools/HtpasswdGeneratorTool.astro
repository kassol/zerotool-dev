---
// HtpasswdGeneratorTool — Apache htpasswd generator, 100% client-side
---
<div class="htpw-wrap">
  <div class="htpw-privacy">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
    <span data-i18n="privacy">All hashing is done 100% in your browser. Passwords never leave this page.</span>
  </div>

  <div class="htpw-form">
    <div class="htpw-row">
      <label class="htpw-label" for="htpw-username" data-i18n="username">Username</label>
      <input id="htpw-username" class="htpw-input" type="text" spellcheck="false" autocomplete="off" placeholder="admin" />
    </div>

    <div class="htpw-row">
      <label class="htpw-label" for="htpw-password" data-i18n="password">Password</label>
      <div class="htpw-pw-row">
        <input id="htpw-password" class="htpw-input htpw-input--pw" type="text" spellcheck="false" autocomplete="off" placeholder="••••••••" />
        <button id="htpw-gen-pw" class="htpw-btn-secondary" data-i18n="generate">Generate</button>
      </div>
    </div>

    <div class="htpw-row">
      <label class="htpw-label" data-i18n="algorithm">Algorithm</label>
      <div class="htpw-algo-group">
        <label class="htpw-radio">
          <input type="radio" name="htpw-algo" value="bcrypt" checked />
          <span>bcrypt</span>
        </label>
        <label class="htpw-radio">
          <input type="radio" name="htpw-algo" value="apr1" />
          <span>MD5 (APR1)</span>
        </label>
        <label class="htpw-radio">
          <input type="radio" name="htpw-algo" value="sha1" />
          <span>SHA1</span>
        </label>
        <label class="htpw-radio">
          <input type="radio" name="htpw-algo" value="plain" />
          <span data-i18n="plaintext">Plaintext</span>
        </label>
      </div>
    </div>

    <div class="htpw-row" id="htpw-cost-row">
      <label class="htpw-label" for="htpw-cost">
        <span data-i18n="cost">bcrypt cost</span>
        <span id="htpw-cost-val" class="htpw-cost-num">10</span>
      </label>
      <input id="htpw-cost" class="htpw-slider" type="range" min="4" max="12" value="10" />
    </div>

    <button id="htpw-generate" class="htpw-btn-primary" data-i18n="generateLine">Generate htpasswd line</button>
  </div>

  <div class="htpw-result" id="htpw-result-section" style="display:none">
    <div class="htpw-result-header">
      <label class="htpw-label" data-i18n="output">Output</label>
      <button id="htpw-copy" class="htpw-copy-btn" data-i18n="copy">Copy</button>
    </div>
    <textarea id="htpw-output" class="htpw-output" readonly spellcheck="false"></textarea>
  </div>

  <div class="htpw-batch">
    <div class="htpw-batch-header">
      <span class="htpw-label" data-i18n="batchMode">Batch mode</span>
      <span class="htpw-hint" data-i18n="batchHint">One user:password per line</span>
    </div>
    <textarea id="htpw-batch-input" class="htpw-textarea" spellcheck="false" autocomplete="off" data-i18n-ph="batchPlaceholder" placeholder="admin:secret&#10;user1:pass123"></textarea>
    <div class="htpw-batch-controls">
      <button id="htpw-batch-gen" class="htpw-btn-primary" data-i18n="generateBatch">Generate batch</button>
    </div>
    <div class="htpw-result" id="htpw-batch-result-section" style="display:none">
      <div class="htpw-result-header">
        <label class="htpw-label" data-i18n="batchOutput">Batch output</label>
        <button id="htpw-batch-copy" class="htpw-copy-btn" data-i18n="copy">Copy</button>
      </div>
      <textarea id="htpw-batch-output" class="htpw-output" readonly spellcheck="false"></textarea>
    </div>
  </div>

  <!-- bcryptjs vendor -->
  <script src="/vendor/bcryptjs.min.js" is:inline></script>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: {
          privacy: 'All hashing is done 100% in your browser. Passwords never leave this page.',
          username: 'Username',
          password: 'Password',
          generate: 'Generate',
          algorithm: 'Algorithm',
          plaintext: 'Plaintext',
          cost: 'bcrypt cost:',
          generateLine: 'Generate htpasswd line',
          output: 'Output',
          copy: 'Copy',
          copied: 'Copied!',
          batchMode: 'Batch mode',
          batchHint: 'One user:password per line',
          batchPlaceholder: 'admin:secret\nuser1:pass123',
          generateBatch: 'Generate batch',
          batchOutput: 'Batch output',
