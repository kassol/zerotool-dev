          generate: '随机生成',
          algorithm: '算法',
          plaintext: '明文',
          cost: 'bcrypt 强度：',
          generateLine: '生成 htpasswd 行',
          output: '输出',
          copy: '复制',
          copied: '已复制！',
          batchMode: '批量模式',
          batchHint: '每行一个 user:password',
          batchPlaceholder: 'admin:secret\nuser1:pass123',
          generateBatch: '批量生成',
          batchOutput: '批量输出',
          errUser: '用户名不能为空',
          errPass: '密码不能为空',
          errBatchEmpty: '批量输入为空',
        },
        ja: {
          privacy: 'すべてのハッシュ計算はブラウザ内で完結します。パスワードはこのページ外に送信されません。',
          username: 'ユーザー名',
          password: 'パスワード',
          generate: '生成',
          algorithm: 'アルゴリズム',
          plaintext: '平文',
          cost: 'bcryptコスト：',
          generateLine: 'htpasswdラインを生成',
          output: '出力',
          copy: 'コピー',
          copied: 'コピー済み！',
          batchMode: 'バッチモード',
          batchHint: '1行に1つの user:password',
          batchPlaceholder: 'admin:secret\nuser1:pass123',
          generateBatch: 'バッチ生成',
          batchOutput: 'バッチ出力',
          errUser: 'ユーザー名を入力してください',
          errPass: 'パスワードを入力してください',
          errBatchEmpty: 'バッチ入力が空です',
        },
        ko: {
          privacy: '모든 해싱은 브라우저에서 100% 처리됩니다. 비밀번호는 이 페이지를 벗어나지 않습니다.',
          username: '사용자 이름',
          password: '비밀번호',
          generate: '생성',
          algorithm: '알고리즘',
          plaintext: '평문',
          cost: 'bcrypt 비용:',
          generateLine: 'htpasswd 줄 생성',
          output: '출력',
          copy: '복사',
          copied: '복사됨!',
          batchMode: '일괄 모드',
          batchHint: '한 줄에 user:password 하나',
          batchPlaceholder: 'admin:secret\nuser1:pass123',
          generateBatch: '일괄 생성',
          batchOutput: '일괄 출력',
          errUser: '사용자 이름을 입력하세요',
          errPass: '비밀번호를 입력하세요',
          errBatchEmpty: '일괄 입력이 비어 있습니다',
        },
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;

      document.querySelectorAll('.htpw-wrap [data-i18n]').forEach(function (el) {
        var key = el.getAttribute('data-i18n');
        if (t[key] !== undefined) el.textContent = t[key];
      });
      document.querySelectorAll('.htpw-wrap [data-i18n-ph]').forEach(function (el) {
        var key = el.getAttribute('data-i18n-ph');
        if (t[key]) el.placeholder = t[key];
      });

      // ---- APR1-MD5 implementation (pure JS) ----
      // Based on the Apache apr_md5 algorithm
      function md5(data) {
        // data: Uint8Array or string → Uint8Array
        if (typeof data === 'string') {
          data = new TextEncoder().encode(data);
        }
        // Using SubtleCrypto is async, so we use a sync implementation
        // Compact sync MD5 (adapted from blueimp-md5)
        function safe_add(x, y) { var lsw=(x&0xFFFF)+(y&0xFFFF); var msw=(x>>16)+(y>>16)+(lsw>>16); return (msw<<16)|(lsw&0xFFFF); }
        function bit_rol(num, cnt) { return (num<<cnt)|(num>>>(32-cnt)); }
        function md5_cmn(q,a,b,x,s,t){ return safe_add(bit_rol(safe_add(safe_add(a,q),safe_add(x,t)),s),b); }
        function md5_ff(a,b,c,d,x,s,t){ return md5_cmn((b&c)|((~b)&d),a,b,x,s,t); }
        function md5_gg(a,b,c,d,x,s,t){ return md5_cmn((b&d)|(c&(~d)),a,b,x,s,t); }
        function md5_hh(a,b,c,d,x,s,t){ return md5_cmn(b^c^d,a,b,x,s,t); }
        function md5_ii(a,b,c,d,x,s,t){ return md5_cmn(c^(b|(~d)),a,b,x,s,t); }
        function md5blks(s) {
          var md5blks=[], i;
          for(i=0;i<64;i+=4) md5blks[i>>2]=s.charCodeAt(i)+(s.charCodeAt(i+1)<<8)+(s.charCodeAt(i+2)<<16)+(s.charCodeAt(i+3)<<24);
          return md5blks;
        }
        var hexchars='0123456789abcdef';
        function rhex(n){ var s='',j; for(j=0;j<4;j++) s+=hexchars.charAt((n>>(j*8+4))&0x0F)+hexchars.charAt((n>>(j*8))&0x0F); return s; }
        function hex_md5(s){ return binl_md5(str2binl(s),s.length*8); }
        function str2binl(str) {
          var bin=[]; var mask=(1<<8)-1;
          for(var i=0;i<str.length*8;i+=8) bin[i>>5]|=(str.charCodeAt(i/8)&mask)<<(i%32);
          return bin;
        }
        function binl2hex(binarray) {
          var hex=''; var hexchars='0123456789abcdef';
          for(var i=0;i<binarray.length*4;i++) hex+=hexchars.charAt((binarray[i>>2]>>((i%4)*8+4))&0xF)+hexchars.charAt((binarray[i>>2]>>((i%4)*8))&0xF);
          return hex;
        }
        function binl_md5(x,len) {
          x[len>>5]|=0x80<<((len)%32); x[(((len+64)>>>9)<<4)+14]=len;
          var a=1732584193,b=-271733879,c=-1732584194,d=271733878,olda,oldb,oldc,oldd;
          for(var i=0;i<x.length;i+=16){
            olda=a; oldb=b; oldc=c; oldd=d;
            a=md5_ff(a,b,c,d,x[i+0],7,-680876936); d=md5_ff(d,a,b,c,x[i+1],12,-389564586); c=md5_ff(c,d,a,b,x[i+2],17,606105819); b=md5_ff(b,c,d,a,x[i+3],22,-1044525330);
            a=md5_ff(a,b,c,d,x[i+4],7,-176418897); d=md5_ff(d,a,b,c,x[i+5],12,1200080426); c=md5_ff(c,d,a,b,x[i+6],17,-1473231341); b=md5_ff(b,c,d,a,x[i+7],22,-45705983);
            a=md5_ff(a,b,c,d,x[i+8],7,1770035416); d=md5_ff(d,a,b,c,x[i+9],12,-1958414417); c=md5_ff(c,d,a,b,x[i+10],17,-42063); b=md5_ff(b,c,d,a,x[i+11],22,-1990404162);
            a=md5_ff(a,b,c,d,x[i+12],7,1804603682); d=md5_ff(d,a,b,c,x[i+13],12,-40341101); c=md5_ff(c,d,a,b,x[i+14],17,-1502002290); b=md5_ff(b,c,d,a,x[i+15],22,1236535329);
            a=md5_gg(a,b,c,d,x[i+1],5,-165796510); d=md5_gg(d,a,b,c,x[i+6],9,-1069501632); c=md5_gg(c,d,a,b,x[i+11],14,643717713); b=md5_gg(b,c,d,a,x[i+0],20,-373897302);
            a=md5_gg(a,b,c,d,x[i+5],5,-701558691); d=md5_gg(d,a,b,c,x[i+10],9,38016083); c=md5_gg(c,d,a,b,x[i+15],14,-660478335); b=md5_gg(b,c,d,a,x[i+4],20,-405537848);
            a=md5_gg(a,b,c,d,x[i+9],5,568446438); d=md5_gg(d,a,b,c,x[i+14],9,-1019803690); c=md5_gg(c,d,a,b,x[i+3],14,-187363961); b=md5_gg(b,c,d,a,x[i+8],20,1163531501);
            a=md5_gg(a,b,c,d,x[i+13],5,-1444681467); d=md5_gg(d,a,b,c,x[i+2],9,-51403784); c=md5_gg(c,d,a,b,x[i+7],14,1735328473); b=md5_gg(b,c,d,a,x[i+12],20,-1926607734);
            a=md5_hh(a,b,c,d,x[i+5],4,-378558); d=md5_hh(d,a,b,c,x[i+8],11,-2022574463); c=md5_hh(c,d,a,b,x[i+11],16,1839030562); b=md5_hh(b,c,d,a,x[i+14],23,-35309556);
            a=md5_hh(a,b,c,d,x[i+1],4,-1530992060); d=md5_hh(d,a,b,c,x[i+4],11,1272893353); c=md5_hh(c,d,a,b,x[i+7],16,-155497632); b=md5_hh(b,c,d,a,x[i+10],23,-1094730640);
            a=md5_hh(a,b,c,d,x[i+13],4,681279174); d=md5_hh(d,a,b,c,x[i+0],11,-358537222); c=md5_hh(c,d,a,b,x[i+3],16,-722521979); b=md5_hh(b,c,d,a,x[i+6],23,76029189);
            a=md5_hh(a,b,c,d,x[i+9],4,-640364487); d=md5_hh(d,a,b,c,x[i+12],11,-421815835); c=md5_hh(c,d,a,b,x[i+15],16,530742520); b=md5_hh(b,c,d,a,x[i+2],23,-995338651);
            a=md5_ii(a,b,c,d,x[i+0],6,-198630844); d=md5_ii(d,a,b,c,x[i+7],10,1126891415); c=md5_ii(c,d,a,b,x[i+14],15,-1416354905); b=md5_ii(b,c,d,a,x[i+5],21,-57434055);
            a=md5_ii(a,b,c,d,x[i+12],6,1700485571); d=md5_ii(d,a,b,c,x[i+3],10,-1894986606); c=md5_ii(c,d,a,b,x[i+10],15,-1051523); b=md5_ii(b,c,d,a,x[i+1],21,-2054922799);
            a=md5_ii(a,b,c,d,x[i+8],6,1873313359); d=md5_ii(d,a,b,c,x[i+15],10,-30611744); c=md5_ii(c,d,a,b,x[i+6],15,-1560198380); b=md5_ii(b,c,d,a,x[i+13],21,1309151649);
            a=md5_ii(a,b,c,d,x[i+4],6,-145523070); d=md5_ii(d,a,b,c,x[i+11],10,-1120210379); c=md5_ii(c,d,a,b,x[i+2],15,718787259); b=md5_ii(b,c,d,a,x[i+9],21,-343485551);
            a=safe_add(a,olda); b=safe_add(b,oldb); c=safe_add(c,oldc); d=safe_add(d,oldd);
          }
          return [a,b,c,d];
        }
        // Convert Uint8Array to latin1 string for the sync md5
        var s = '';
        for (var i = 0; i < data.length; i++) s += String.fromCharCode(data[i]);
        var result = binl_md5(str2binl(s), s.length * 8);
        // Return as Uint8Array (raw bytes, little-endian 32-bit words)
        var out = new Uint8Array(16);
        for (var j = 0; j < 4; j++) {
          out[j*4]   = (result[j])       & 0xFF;
          out[j*4+1] = (result[j] >> 8)  & 0xFF;
          out[j*4+2] = (result[j] >> 16) & 0xFF;
          out[j*4+3] = (result[j] >> 24) & 0xFF;
        }
        return out;
      }

      // ---- APR1-MD5 (Apache $apr1$) ----
      // Reference: https://apr.apache.org/docs/apr/trunk/md5_8h.html
      var APR1_CHARS = './0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';

      function to64(v, n) {
        var s = '';
        while (--n >= 0) {
          s += APR1_CHARS[v & 0x3f];
          v >>= 6;
        }
        return s;
      }

      function concat() {
        var total = 0;
        for (var i = 0; i < arguments.length; i++) total += arguments[i].length;
        var out = new Uint8Array(total);
        var pos = 0;
        for (var i = 0; i < arguments.length; i++) {
          out.set(arguments[i], pos);
          pos += arguments[i].length;
        }
        return out;
      }

      function strToBytes(s) { return new TextEncoder().encode(s); }

      function generateSalt(len) {
        var chars = APR1_CHARS;
        var result = '';
        var arr = new Uint8Array(len);
        crypto.getRandomValues(arr);
        for (var i = 0; i < len; i++) result += chars[arr[i] % chars.length];
        return result;
      }

      function apr1(password, salt) {
        var pw = strToBytes(password);
        var s  = strToBytes(salt);
        var magic = strToBytes('$apr1$');

        // Step 1: digest A = MD5(pw + magic + salt)
        var digestA = md5(concat(pw, magic, s));

        // Step 2: digest B = MD5(pw + salt + pw)
        var digestB = md5(concat(pw, s, pw));

        // Step 3: build intermediate using digestB
        var inter = concat(pw, magic, s);
        // Append digestB bytes based on password length
        var plen = pw.length;
        var digestBExt = new Uint8Array(plen);
        for (var i = 0; i < plen; i++) digestBExt[i] = digestB[i % 16];
        inter = concat(inter, digestBExt);

        // Steps with bit manipulation on password length
        var n = plen;
        while (n > 0) {
          if (n & 1) {
            inter = concat(inter, new Uint8Array([0]));
          } else {
            inter = concat(inter, new Uint8Array([pw[0]]));
          }
          n >>= 1;
        }

        digestA = md5(inter);

        // 1000 rounds
        for (var i = 0; i < 1000; i++) {
          var ctx = new Uint8Array(0);
          if (i & 1) ctx = concat(ctx, pw);
          else        ctx = concat(ctx, digestA);
          if (i % 3) ctx = concat(ctx, s);
          if (i % 7) ctx = concat(ctx, pw);
          if (i & 1) ctx = concat(ctx, digestA);
          else        ctx = concat(ctx, pw);
          digestA = md5(ctx);
        }

        // Encode output
        var d = digestA;
        var hash =
          to64((d[0]<<16)|(d[6]<<8)|d[12], 4) +
          to64((d[1]<<16)|(d[7]<<8)|d[13], 4) +
          to64((d[2]<<16)|(d[8]<<8)|d[14], 4) +
          to64((d[3]<<16)|(d[9]<<8)|d[15], 4) +
          to64((d[4]<<16)|(d[10]<<8)|d[5], 4) +
          to64(d[11], 2);

        return '$apr1$' + salt + '$' + hash;
      }

      // ---- SHA1 via SubtleCrypto ----
      async function sha1Hash(password) {
        var data = new TextEncoder().encode(password);
        var hashBuf = await crypto.subtle.digest('SHA-1', data);
        var bytes = new Uint8Array(hashBuf);
        // Base64 encode
        var binary = '';
        for (var i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
        return '{SHA}' + btoa(binary);
      }

      // ---- Random password generator ----
      function randPw(len) {
        len = len || 16;
        var chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789!@#$%^&*';
        var arr = new Uint8Array(len);
        crypto.getRandomValues(arr);
        var s = '';
        for (var i = 0; i < len; i++) s += chars[arr[i] % chars.length];
        return s;
      }

      // ---- UI wiring ----
      var usernameEl    = document.getElementById('htpw-username');
      var passwordEl    = document.getElementById('htpw-password');
      var genPwBtn      = document.getElementById('htpw-gen-pw');
      var costEl        = document.getElementById('htpw-cost');
      var costValEl     = document.getElementById('htpw-cost-val');
      var costRowEl     = document.getElementById('htpw-cost-row');
      var generateBtn   = document.getElementById('htpw-generate');
      var outputEl      = document.getElementById('htpw-output');
      var resultSection = document.getElementById('htpw-result-section');
      var copyBtn       = document.getElementById('htpw-copy');
      var batchInput    = document.getElementById('htpw-batch-input');
      var batchGenBtn   = document.getElementById('htpw-batch-gen');
      var batchOutput   = document.getElementById('htpw-batch-output');
      var batchResultSection = document.getElementById('htpw-batch-result-section');
      var batchCopyBtn  = document.getElementById('htpw-batch-copy');

      function getAlgo() {
        return document.querySelector('input[name="htpw-algo"]:checked').value;
      }

      document.querySelectorAll('input[name="htpw-algo"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
          costRowEl.style.display = (getAlgo() === 'bcrypt') ? '' : 'none';
        });
      });

      costEl.addEventListener('input', function () {
        costValEl.textContent = costEl.value;
      });

      genPwBtn.addEventListener('click', function () {
        passwordEl.value = randPw(16);
      });

      async function hashOne(user, pass) {
        var algo = getAlgo();
        var hash;
        if (algo === 'bcrypt') {
          var cost = parseInt(costEl.value, 10);
          hash = await dcodeIO.bcrypt.hash(pass, cost);
        } else if (algo === 'apr1') {
          var salt = generateSalt(8);
          hash = apr1(pass, salt);
        } else if (algo === 'sha1') {
          hash = await sha1Hash(pass);
        } else {
          hash = pass;
        }
        return user + ':' + hash;
      }

      generateBtn.addEventListener('click', async function () {
        var user = usernameEl.value.trim();
        var pass = passwordEl.value;
        if (!user) { alert(t.errUser); return; }
        if (!pass) { alert(t.errPass); return; }
        generateBtn.disabled = true;
        generateBtn.textContent = '...';
        try {
          outputEl.value = await hashOne(user, pass);
          resultSection.style.display = '';
          window.trackTool && window.trackTool('htpasswd_generator', 'generate');
        } finally {
          generateBtn.disabled = false;
          generateBtn.setAttribute('data-i18n', 'generateLine');
          generateBtn.textContent = t.generateLine;
        }
      });

      batchGenBtn.addEventListener('click', async function () {
        var raw = batchInput.value.trim();
        if (!raw) { alert(t.errBatchEmpty); return; }
        var lines = raw.split('\n');
        var results = [];
        batchGenBtn.disabled = true;
        batchGenBtn.textContent = '...';
        for (var i = 0; i < lines.length; i++) {
          var line = lines[i].trim();
          if (!line) continue;
          var colon = line.indexOf(':');
          if (colon === -1) {
            results.push('# invalid: ' + line);
            continue;
          }
          var u = line.slice(0, colon);
          var p = line.slice(colon + 1);
          try {
            results.push(await hashOne(u, p));
          } catch (e) {
            results.push('# error: ' + u);
          }
        }
        batchOutput.value = results.join('\n');
        batchResultSection.style.display = '';
        batchGenBtn.disabled = false;
        batchGenBtn.textContent = t.generateBatch;
      });

      function makeCopyHandler(outputEl, btn) {
        btn.addEventListener('click', function () {
          var text = outputEl.value;
          if (!text) return;
          navigator.clipboard.writeText(text).then(function () {
            btn.textContent = t.copied;
            setTimeout(function () { btn.textContent = t.copy; }, 1500);
          });
        });
      }

      makeCopyHandler(outputEl, copyBtn);
      makeCopyHandler(batchOutput, batchCopyBtn);
    })();
  </script>
</div>

