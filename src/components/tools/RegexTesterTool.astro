---
// RegexTesterTool — reusable widget, no props needed
---
<div>
  <div class="rt-wrap">
    <div class="rt-pattern-row">
      <span class="rt-slash">/</span>
      <input id="rt-pattern" type="text" placeholder="(\\w+)@(\\w+\\.\\w+)" spellcheck="false" autocomplete="off" />
      <span class="rt-slash">/</span>
      <div class="rt-flags">
        <label title="global"><input type="checkbox" value="g" checked /> g</label>
        <label title="case-insensitive"><input type="checkbox" value="i" /> i</label>
        <label title="multiline"><input type="checkbox" value="m" /> m</label>
        <label title="dotAll"><input type="checkbox" value="s" /> s</label>
      </div>
    </div>

    <div class="rt-field">
      <label for="rt-test" data-i18n="testString">Test String</label>
      <textarea
        id="rt-test"
        data-i18n-ph="testPlaceholder"
        placeholder="Paste your text here..."
        spellcheck="false"
      ></textarea>
    </div>

    <div id="rt-status" class="rt-status" aria-live="polite"></div>

    <div class="rt-field">
      <label data-i18n="highlightedMatches">Highlighted Matches</label>
      <div id="rt-highlight" class="rt-highlight"></div>
    </div>

    <div id="rt-matches" class="rt-matches"></div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: {
          testString: 'Test String', testPlaceholder: 'Paste your text here...', highlightedMatches: 'Highlighted Matches',
          noMatches: 'No matches.', matchFound: function(n) { return n + ' match' + (n > 1 ? 'es' : '') + ' found.'; },
          invalidRegex: 'Invalid regex: ', matchLabel: 'Match', groupLabel: 'Group', andMore: function(n) { return '... and ' + n + ' more matches.'; }
        },
        zh: {
          testString: '测试字符串', testPlaceholder: '在此粘贴文本...', highlightedMatches: '高亮匹配',
          noMatches: '无匹配项。', matchFound: function(n) { return '找到 ' + n + ' 个匹配项。'; },
          invalidRegex: '无效的正则表达式：', matchLabel: '匹配', groupLabel: '组', andMore: function(n) { return '... 还有 ' + n + ' 个匹配项。'; }
        },
        ja: {
          testString: 'テスト文字列', testPlaceholder: 'テキストを貼り付け...', highlightedMatches: 'マッチのハイライト',
          noMatches: 'マッチなし。', matchFound: function(n) { return n + ' 件マッチしました。'; },
          invalidRegex: '無効な正規表現：', matchLabel: 'マッチ', groupLabel: 'グループ', andMore: function(n) { return '... 他 ' + n + ' 件のマッチ。'; }
        },
        ko: {
          testString: '테스트 문자열', testPlaceholder: '텍스트를 붙여넣으세요...', highlightedMatches: '일치 항목 강조',
          noMatches: '일치하는 항목이 없습니다.', matchFound: function(n) { return n + '개 일치 항목을 찾았습니다.'; },
          invalidRegex: '유효하지 않은 정규식: ', matchLabel: '일치', groupLabel: '그룹', andMore: function(n) { return '... 외 ' + n + '개 일치 항목.'; }
        }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });
      document.querySelectorAll('[data-i18n-ph]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-ph'); if (t[key]) el.placeholder = t[key];
      });

      var patternEl = document.getElementById('rt-pattern');
      var testEl = document.getElementById('rt-test');
      var statusEl = document.getElementById('rt-status');
      var highlightEl = document.getElementById('rt-highlight');
      var matchesEl = document.getElementById('rt-matches');
      var flagCheckboxes = document.querySelectorAll('.rt-flags input[type="checkbox"]');
      var rtTracked = false;

      function getFlags() {
        var f = '';
        flagCheckboxes.forEach(function (cb) { if (cb.checked) f += cb.value; });
        return f;
      }

      function escapeHtml(str) {
        return str
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function run() {
        var pattern = patternEl.value;
        var text = testEl.value;
        highlightEl.innerHTML = '';
        matchesEl.innerHTML = '';

        if (!pattern) {
          highlightEl.textContent = text;
          statusEl.textContent = '';
          statusEl.className = 'rt-status';
          return;
        }

        var flags = getFlags();
        var re;
        try {
          re = new RegExp(pattern, flags.includes('g') ? flags : flags + 'g');
        } catch (e) {
          statusEl.textContent = t.invalidRegex + e.message;
          statusEl.className = 'rt-status error';
          highlightEl.textContent = text;
          return;
        }

        var allMatches = [];
        var m;
        re.lastIndex = 0;
        while ((m = re.exec(text)) !== null) {
          allMatches.push({ index: m.index, end: m.index + m[0].length, match: m[0], groups: Array.from(m).slice(1) });
          if (m[0].length === 0) re.lastIndex++; // avoid infinite loop on zero-length match
          if (!flags.includes('g')) break;
        }

        var count = allMatches.length;
        statusEl.textContent = count === 0 ? t.noMatches : t.matchFound(count);
        statusEl.className = 'rt-status ' + (count > 0 ? 'success' : 'none');
        if (count > 0 && !rtTracked) { rtTracked = true; window.trackTool && window.trackTool('regex_tester', 'match'); }

        // Build highlighted HTML
        var html = '';
        var cursor = 0;
        allMatches.forEach(function (match) {
          html += escapeHtml(text.slice(cursor, match.index));
          html += '<mark>' + escapeHtml(match.match) + '</mark>';
          cursor = match.end;
        });
        html += escapeHtml(text.slice(cursor));
        highlightEl.innerHTML = html;

        // List matches
        if (count > 0) {
          var ul = document.createElement('ul');
          ul.className = 'rt-match-list';
          allMatches.slice(0, 100).forEach(function (match, i) {
            var li = document.createElement('li');
            var header = '<strong>' + t.matchLabel + ' ' + (i + 1) + ':</strong> <code>' + escapeHtml(match.match) + '</code> <span class="rt-pos">(index ' + match.index + ')</span>';
            if (match.groups.length > 0 && match.groups.some(function(g){ return g !== undefined; })) {
              header += '<ul class="rt-groups">' + match.groups.map(function(g, j) {
                return '<li>' + t.groupLabel + ' ' + (j+1) + ': <code>' + (g !== undefined ? escapeHtml(g) : '<em>undefined</em>') + '</code></li>';
              }).join('') + '</ul>';
            }
            li.innerHTML = header;
            ul.appendChild(li);
          });
          if (count > 100) {
            var more = document.createElement('li');
            more.textContent = t.andMore(count - 100);
            ul.appendChild(more);
          }
          matchesEl.appendChild(ul);
        }
      }

      var _rtTimer = null;
      function debouncedRun() {
        clearTimeout(_rtTimer);
        _rtTimer = setTimeout(run, 300);
      }
      patternEl.addEventListener('input', debouncedRun);
      testEl.addEventListener('input', debouncedRun);
      flagCheckboxes.forEach(function (cb) { cb.addEventListener('change', debouncedRun); });
    })();
  </script>
</div>

<style>
  .rt-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .rt-pattern-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .rt-slash {
    font-size: 1.4rem;
    color: var(--color-primary);
    font-weight: 700;
    font-family: var(--font-mono);
    line-height: 1;
    user-select: none;
  }

  .rt-pattern-row > input[type="text"] {
    flex: 1;
    min-width: 120px;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .rt-pattern-row > input[type="text"]:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .rt-flags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.9rem;
    font-family: var(--font-mono);
  }

  .rt-flags label {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    cursor: pointer;
    color: var(--color-text-secondary);
  }

  .rt-field { display: flex; flex-direction: column; gap: 0.3rem; }

  .rt-field > label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .rt-field textarea {
    width: 100%;
    min-height: 100px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .rt-field textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .rt-highlight {
    min-height: 60px;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    font-family: var(--font-mono);
    font-size: 0.88rem;
    white-space: pre-wrap;
    word-break: break-all;
    line-height: 1.6;
    color: var(--color-text);
  }

  .rt-highlight :global(mark) {
    background: #ffe082;
    color: #111;
    border-radius: 2px;
    padding: 0 1px;
  }

  .rt-status { font-size: 0.85rem; min-height: 1.2rem; }
  .rt-status.success { color: #057a55; }
  .rt-status.error { color: #c0392b; }
  .rt-status.none { color: var(--color-text-muted); }

  .rt-match-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .rt-match-list > li {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .rt-match-list code {
    background: var(--color-bg-icon);
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
    font-family: var(--font-mono);
  }

  .rt-pos { color: var(--color-text-muted); font-size: 0.82rem; }

  .rt-groups {
    list-style: none;
    padding: 0.3rem 0 0 1rem;
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.84rem;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .rt-highlight :global(mark) { background: #b8860b; color: #fff; }
    :root:not([data-theme="light"]) .rt-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .rt-status.error { color: #f87171; }
  }
  [data-theme="dark"] .rt-highlight :global(mark) { background: #b8860b; color: #fff; }
  [data-theme="dark"] .rt-status.success { color: #34d399; }
  [data-theme="dark"] .rt-status.error { color: #f87171; }
</style>
