---
// QrCodeDecoderTool — client-side QR code decoder using jsQR
---
<div class="qrd-wrap">
  <!-- Upload / drag zone -->
  <div id="qrd-dropzone" class="qrd-dropzone" tabindex="0" role="button" aria-label="Upload QR code image">
    <svg class="qrd-dz-icon" xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="5" height="5" x="3" y="3" rx="1"/><rect width="5" height="5" x="16" y="3" rx="1"/><rect width="5" height="5" x="3" y="16" rx="1"/><path d="M21 16h-3a2 2 0 0 0-2 2v3"/><path d="M21 21v.01"/><path d="M12 7v3a2 2 0 0 1-2 2H7"/><path d="M3 12h.01"/><path d="M12 3h.01"/><path d="M12 16v.01"/><path d="M16 12h1"/><path d="M21 12v.01"/><path d="M12 21v-1"/></svg>
    <p id="qrd-dz-hint" class="qrd-dz-hint" data-i18n="dropHint">Drop image here, click to upload, or paste (Ctrl+V)</p>
    <p class="qrd-dz-sub" data-i18n="dropSub">PNG · JPG · GIF · WebP · BMP</p>
    <input type="file" id="qrd-file" accept="image/*" hidden />
  </div>

  <!-- Preview + result -->
  <div id="qrd-result-area" class="qrd-result-area" style="display:none">
    <div class="qrd-preview-col">
      <img id="qrd-preview-img" class="qrd-preview-img" alt="QR code preview" />
      <button id="qrd-reset" class="btn-secondary qrd-reset-btn" data-i18n="decodeAnother">Decode another</button>
    </div>

    <div class="qrd-output-col">
      <div id="qrd-status" class="qrd-status" aria-live="polite"></div>

      <div id="qrd-success-block" style="display:none">
        <div class="qrd-type-badge-row">
          <span id="qrd-type-badge" class="qrd-type-badge"></span>
        </div>

        <!-- Generic result -->
        <div id="qrd-generic" class="qrd-card" style="display:none">
          <div class="qrd-card-header" data-i18n="decodedContent">Decoded Content</div>
          <pre id="qrd-text" class="qrd-text-result"></pre>
          <div class="qrd-card-actions">
            <button id="qrd-copy" class="btn-primary btn-sm" data-i18n="copy">Copy</button>
          </div>
        </div>

        <!-- URL result -->
        <div id="qrd-url" class="qrd-card" style="display:none">
          <div class="qrd-card-header" data-i18n="decodedUrl">Decoded URL</div>
          <a id="qrd-url-link" class="qrd-url-link" href="#" target="_blank" rel="noopener noreferrer"></a>
          <div class="qrd-card-actions">
            <button id="qrd-copy-url" class="btn-primary btn-sm" data-i18n="copy">Copy</button>
          </div>
        </div>

        <!-- WiFi result -->
        <div id="qrd-wifi" class="qrd-card" style="display:none">
          <div class="qrd-card-header" data-i18n="wifiNetwork">Wi-Fi Network</div>
          <table class="qrd-wifi-table">
            <tbody>
              <tr><th data-i18n="ssid">SSID</th><td id="qrd-wifi-ssid"></td></tr>
              <tr><th data-i18n="password">Password</th><td id="qrd-wifi-pass"></td></tr>
              <tr><th data-i18n="encryption">Encryption</th><td id="qrd-wifi-enc"></td></tr>
              <tr id="qrd-wifi-hidden-row"><th data-i18n="hiddenNetwork">Hidden</th><td id="qrd-wifi-hidden"></td></tr>
            </tbody>
          </table>
          <div class="qrd-card-actions">
            <button id="qrd-copy-wifi" class="btn-primary btn-sm" data-i18n="copy">Copy</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Privacy badge -->
  <p class="qrd-privacy" data-i18n="privacy">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    100% client-side — no data uploaded
  </p>

  <!-- Cross-link to generator -->
  <p class="qrd-crosslink">
    <span data-i18n="crosslinkText">Need to create a QR code?</span>
    <a href="/tools/qr-code-generator" data-i18n="crosslinkLink">QR Code Generator →</a>
  </p>

  <!-- jsQR library -->
  <script src="/vendor/jsqr.min.js" is:inline></script>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: {
          dropHint: 'Drop image here, click to upload, or paste (Ctrl+V)',
          dropSub: 'PNG · JPG · GIF · WebP · BMP',
          decodeAnother: 'Decode another',
          decodedContent: 'Decoded Content',
          decodedUrl: 'Decoded URL',
          wifiNetwork: 'Wi-Fi Network',
          ssid: 'SSID',
          password: 'Password',
          encryption: 'Encryption',
          hiddenNetwork: 'Hidden',
          copy: 'Copy',
          copied: 'Copied!',
          privacy: '100% client-side — no data uploaded',
          crosslinkText: 'Need to create a QR code?',
          crosslinkLink: 'QR Code Generator →',
          types: { url: 'URL', wifi: 'Wi-Fi', vcard: 'vCard', email: 'Email', phone: 'Phone', sms: 'SMS', text: 'Text' },
          errNoQr: 'No QR code found in this image.',
          errNoLib: 'jsQR library not loaded. Please check your network connection.',
          errRead: 'Could not read image. Please try a different file.',
          decoding: 'Decoding…',
        },
        zh: {
          dropHint: '拖拽图片到此处、点击上传，或粘贴 (Ctrl+V)',
          dropSub: 'PNG · JPG · GIF · WebP · BMP',
          decodeAnother: '解码其他图片',
          decodedContent: '解码内容',
          decodedUrl: '解码 URL',
          wifiNetwork: 'Wi-Fi 网络',
          ssid: 'SSID',
          password: '密码',
          encryption: '加密方式',
          hiddenNetwork: '隐藏网络',
          copy: '复制',
          copied: '已复制！',
          privacy: '纯浏览器端运行，数据不会上传',
          crosslinkText: '需要生成二维码？',
          crosslinkLink: '二维码生成器 →',
          types: { url: 'URL', wifi: 'Wi-Fi', vcard: 'vCard', email: '邮箱', phone: '电话', sms: '短信', text: '文本' },
          errNoQr: '未在图片中找到二维码。',
          errNoLib: 'jsQR 库未加载，请检查网络连接。',
          errRead: '无法读取图片，请尝试其他文件。',
          decoding: '解码中…',
        },
        ja: {
          dropHint: '画像をドロップ、クリックしてアップロード、またはペースト (Ctrl+V)',
          dropSub: 'PNG · JPG · GIF · WebP · BMP',
          decodeAnother: '別の画像を解読',
          decodedContent: 'デコード結果',
          decodedUrl: 'デコード URL',
          wifiNetwork: 'Wi-Fiネットワーク',
          ssid: 'SSID',
          password: 'パスワード',
          encryption: '暗号化',
          hiddenNetwork: '非表示ネットワーク',
          copy: 'コピー',
          copied: 'コピーしました！',
          privacy: '完全ブラウザ完結 — データはアップロードされません',
          crosslinkText: 'QRコードを作成したい方は',
          crosslinkLink: 'QRコードジェネレーター →',
          types: { url: 'URL', wifi: 'Wi-Fi', vcard: 'vCard', email: 'メール', phone: '電話', sms: 'SMS', text: 'テキスト' },
          errNoQr: 'この画像にQRコードが見つかりませんでした。',
          errNoLib: 'jsQRライブラリを読み込めませんでした。',
          errRead: '画像を読み込めませんでした。別のファイルをお試しください。',
          decoding: 'デコード中…',
        },
        ko: {
          dropHint: '이미지를 드롭하거나 클릭해서 업로드, 또는 붙여넣기 (Ctrl+V)',
          dropSub: 'PNG · JPG · GIF · WebP · BMP',
          decodeAnother: '다른 이미지 디코딩',
          decodedContent: '디코딩 결과',
          decodedUrl: '디코딩된 URL',
          wifiNetwork: 'Wi-Fi 네트워크',
          ssid: 'SSID',
          password: '비밀번호',
          encryption: '암호화',
          hiddenNetwork: '숨겨진 네트워크',
          copy: '복사',
          copied: '복사됨!',
          privacy: '100% 클라이언트 처리 — 데이터 업로드 없음',
          crosslinkText: 'QR 코드를 만들어야 하나요?',
          crosslinkLink: 'QR 코드 생성기 →',
          types: { url: 'URL', wifi: 'Wi-Fi', vcard: 'vCard', email: '이메일', phone: '전화', sms: 'SMS', text: '텍스트' },
          errNoQr: '이미지에서 QR 코드를 찾을 수 없습니다.',
          errNoLib: 'jsQR 라이브러리를 불러올 수 없습니다.',
          errRead: '이미지를 읽을 수 없습니다. 다른 파일을 시도해 주세요.',
          decoding: '디코딩 중…',
        },
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;

      /* Apply i18n */
      document.querySelectorAll('[data-i18n]').forEach(function (el) {
        var key = el.getAttribute('data-i18n');
        if (t[key]) el.textContent = t[key];
      });

      /* Override cross-link href based on lang */
      var crosslinkAnchor = document.querySelector('.qrd-crosslink a');
      if (crosslinkAnchor && pageLang !== 'en') {
        crosslinkAnchor.href = '/' + pageLang + '/tools/qr-code-generator';
      }

      /* Element refs */
      var dropzone   = document.getElementById('qrd-dropzone');
      var fileInput  = document.getElementById('qrd-file');
      var resultArea = document.getElementById('qrd-result-area');
      var previewImg = document.getElementById('qrd-preview-img');
      var statusEl   = document.getElementById('qrd-status');
      var resetBtn   = document.getElementById('qrd-reset');
      var successBlock = document.getElementById('qrd-success-block');

      var genericCard = document.getElementById('qrd-generic');
      var urlCard     = document.getElementById('qrd-url');
      var wifiCard    = document.getElementById('qrd-wifi');

      var textPre   = document.getElementById('qrd-text');
      var typeBadge = document.getElementById('qrd-type-badge');

      /* ── Content type detection ── */
      function detectType(text) {
        if (/^https?:\/\//i.test(text)) return 'url';
        if (/^WIFI:/i.test(text)) return 'wifi';
        if (/^BEGIN:VCARD/i.test(text)) return 'vcard';
        if (/^mailto:/i.test(text)) return 'email';
        if (/^tel:/i.test(text)) return 'phone';
        if (/^smsto:/i.test(text) || /^sms:/i.test(text)) return 'sms';
        return 'text';
      }

      /* ── WiFi parser: WIFI:T:WPA;S:ssid;P:pass;H:true;; ── */
      function parseWifi(text) {
        var result = { ssid: '', pass: '', enc: '', hidden: false };
        var m;
        m = text.match(/S:([^;]*)/); if (m) result.ssid = m[1];
        m = text.match(/P:([^;]*)/); if (m) result.pass = m[1];
        m = text.match(/T:([^;]*)/); if (m) result.enc = m[1];
        m = text.match(/H:([^;]*)/); if (m) result.hidden = m[1].toLowerCase() === 'true';
        return result;
      }

      /* ── Copy helper ── */
      function copyText(text, btn) {
        navigator.clipboard.writeText(text).then(function () {
          var orig = btn.textContent;
          btn.textContent = t.copied;
          setTimeout(function () { btn.textContent = orig; }, 1500);
        });
      }

      /* ── Show result ── */
      function showResult(data) {
        var text = data.data;
        var type = detectType(text);

        typeBadge.textContent = t.types[type] || type;
        typeBadge.className = 'qrd-type-badge qrd-type-' + type;

        /* Hide all cards */
        genericCard.style.display = 'none';
        urlCard.style.display     = 'none';
        wifiCard.style.display    = 'none';

        if (type === 'url') {
          var urlLink = document.getElementById('qrd-url-link');
          urlLink.href = text;
          urlLink.textContent = text;
          urlCard.style.display = '';
          document.getElementById('qrd-copy-url').onclick = function () {
            copyText(text, this);
            window.trackTool && window.trackTool('qr-code-decoder', 'copy_url');
          };
        } else if (type === 'wifi') {
          var wifi = parseWifi(text);
          document.getElementById('qrd-wifi-ssid').textContent = wifi.ssid;
          document.getElementById('qrd-wifi-pass').textContent = wifi.pass || '—';
          document.getElementById('qrd-wifi-enc').textContent  = wifi.enc  || '—';
          document.getElementById('qrd-wifi-hidden').textContent = wifi.hidden ? '✓' : '—';
          wifiCard.style.display = '';
          document.getElementById('qrd-copy-wifi').onclick = function () {
            copyText(text, this);
            window.trackTool && window.trackTool('qr-code-decoder', 'copy_wifi');
          };
        } else {
          textPre.textContent = text;
          genericCard.style.display = '';
          document.getElementById('qrd-copy').onclick = function () {
            copyText(text, this);
            window.trackTool && window.trackTool('qr-code-decoder', 'copy_text');
          };
        }

        successBlock.style.display = '';
        statusEl.textContent = '';
        statusEl.className = 'qrd-status';
        window.trackTool && window.trackTool('qr-code-decoder', 'decode_' + type);
      }

      /* ── Decode image via jsQR ── */
      function decodeImage(src) {
        if (typeof jsQR === 'undefined') {
          statusEl.textContent = t.errNoLib;
          statusEl.className = 'qrd-status error';
          return;
        }

        statusEl.textContent = t.decoding;
        statusEl.className = 'qrd-status';
        successBlock.style.display = 'none';

        var img = new Image();
        img.onload = function () {
          var canvas = document.createElement('canvas');
          canvas.width  = img.naturalWidth;
          canvas.height = img.naturalHeight;
          var ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0);
          try {
            var imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            var code = jsQR(imageData.data, imageData.width, imageData.height, { inversionAttempts: 'dontInvert' });
            if (!code) {
              /* Try inverted (dark background) */
              code = jsQR(imageData.data, imageData.width, imageData.height, { inversionAttempts: 'onlyInvert' });
            }
            if (code) {
              showResult(code);
            } else {
              statusEl.textContent = t.errNoQr;
              statusEl.className = 'qrd-status error';
            }
          } catch (e) {
            statusEl.textContent = t.errRead;
            statusEl.className = 'qrd-status error';
          }
        };
        img.onerror = function () {
          statusEl.textContent = t.errRead;
          statusEl.className = 'qrd-status error';
        };
        img.src = src;
      }

      /* ── Process file ── */
      function processFile(file) {
        if (!file || !file.type.startsWith('image/')) return;
        var reader = new FileReader();
        reader.onload = function (e) {
          var dataUrl = e.target.result;
          previewImg.src = dataUrl;
          dropzone.style.display = 'none';
          resultArea.style.display = '';
          decodeImage(dataUrl);
        };
        reader.readAsDataURL(file);
      }

      /* ── Events ── */
      dropzone.addEventListener('click', function () { fileInput.click(); });
      dropzone.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });

      fileInput.addEventListener('change', function () {
        if (fileInput.files && fileInput.files[0]) processFile(fileInput.files[0]);
        fileInput.value = '';
      });

      dropzone.addEventListener('dragover', function (e) {
        e.preventDefault();
        dropzone.classList.add('drag-over');
      });
      dropzone.addEventListener('dragleave', function () {
        dropzone.classList.remove('drag-over');
      });
      dropzone.addEventListener('drop', function (e) {
        e.preventDefault();
        dropzone.classList.remove('drag-over');
        var file = e.dataTransfer.files[0];
        if (file) processFile(file);
      });

      /* Clipboard paste */
      document.addEventListener('paste', function (e) {
        var items = e.clipboardData && e.clipboardData.items;
        if (!items) return;
        for (var i = 0; i < items.length; i++) {
          if (items[i].type.startsWith('image/')) {
            processFile(items[i].getAsFile());
            break;
          }
        }
      });

      /* Reset */
      resetBtn.addEventListener('click', function () {
        resultArea.style.display = 'none';
        dropzone.style.display   = '';
        previewImg.src = '';
        statusEl.textContent = '';
        statusEl.className = 'qrd-status';
        successBlock.style.display = 'none';
      });
    })();
  </script>
</div>

<style>
  .qrd-wrap { display: flex; flex-direction: column; gap: 1rem; }

  /* ── Drop zone ── */
  .qrd-dropzone {
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-md);
    padding: 2.5rem 1.5rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    background: var(--color-bg-secondary);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    outline: none;
  }
  .qrd-dropzone:hover,
  .qrd-dropzone:focus,
  .qrd-dropzone.drag-over {
    border-color: var(--color-primary);
    background: var(--color-bg);
  }
  .qrd-dz-icon { color: var(--color-text-muted); }
  .qrd-dz-hint { font-size: 0.92rem; color: var(--color-text-secondary); margin: 0; font-weight: 500; }
  .qrd-dz-sub  { font-size: 0.78rem; color: var(--color-text-muted); margin: 0; }

  /* ── Result area ── */
  .qrd-result-area {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 600px) {
    .qrd-result-area { grid-template-columns: 1fr; }
  }

  .qrd-preview-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
  }

  .qrd-preview-img {
    max-width: 200px;
    max-height: 200px;
    width: 100%;
    object-fit: contain;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    display: block;
  }

  .qrd-reset-btn { font-size: 0.82rem; padding: 0.3rem 0.75rem; }

  /* ── Output col ── */
  .qrd-output-col { display: flex; flex-direction: column; gap: 0.75rem; }

  .qrd-status { font-size: 0.88rem; min-height: 1.2rem; }
  .qrd-status.error { color: #c0392b; }
  [data-theme="dark"] .qrd-status.error { color: #f87171; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .qrd-status.error { color: #f87171; }
  }

  /* ── Type badge ── */
  .qrd-type-badge-row { display: flex; align-items: center; gap: 0.5rem; }
  .qrd-type-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background: var(--color-primary);
    color: #fff;
    text-transform: uppercase;
  }
  .qrd-type-url   { background: #2563eb; }
  .qrd-type-wifi  { background: #059669; }
  .qrd-type-vcard { background: #7c3aed; }
  .qrd-type-email { background: #d97706; }
  .qrd-type-phone { background: #0891b2; }
  .qrd-type-sms   { background: #db2777; }
  .qrd-type-text  { background: #6b7280; }

  /* ── Cards ── */
  .qrd-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .qrd-card-header {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    padding: 0.4rem 0.75rem;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .qrd-text-result {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.6rem 0.75rem;
    margin: 0;
    white-space: pre-wrap;
    word-break: break-all;
    color: var(--color-text);
    background: var(--color-bg);
    max-height: 160px;
    overflow-y: auto;
  }
  .qrd-url-link {
    display: block;
    font-size: 0.88rem;
    padding: 0.6rem 0.75rem;
    word-break: break-all;
    color: var(--color-primary);
    background: var(--color-bg);
    text-decoration: none;
  }
  .qrd-url-link:hover { text-decoration: underline; }

  .qrd-card-actions {
    padding: 0.4rem 0.75rem;
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
  }
  .btn-sm { font-size: 0.8rem; padding: 0.25rem 0.65rem; }

  /* ── WiFi table ── */
  .qrd-wifi-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
    background: var(--color-bg);
  }
  .qrd-wifi-table th,
  .qrd-wifi-table td {
    padding: 0.35rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }
  .qrd-wifi-table tr:last-child th,
  .qrd-wifi-table tr:last-child td { border-bottom: none; }
  .qrd-wifi-table th {
    font-weight: 600;
    color: var(--color-text-secondary);
    width: 110px;
    background: var(--color-bg-secondary);
  }

  /* ── Privacy + cross-link ── */
  .qrd-privacy {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .qrd-crosslink {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .qrd-crosslink a {
    color: var(--color-primary);
    text-decoration: none;
    margin-left: 0.3rem;
  }
  .qrd-crosslink a:hover { text-decoration: underline; }
</style>
