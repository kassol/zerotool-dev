---
// No props needed — tool widget is language-independent
---

<div>
  <div class="uuid-wrap">
    <div class="uuid-single">
      <div class="uuid-display" id="uuid-output" data-i18n="clickGenerate">Click Generate</div>
      <div class="uuid-actions">
        <button id="uuid-generate" class="btn-primary" data-i18n="generate">Generate</button>
        <button id="uuid-copy-single" class="btn-secondary" data-i18n="copy">Copy</button>
      </div>
    </div>

    <hr class="uuid-divider" />

    <div class="uuid-batch-section">
      <label class="batch-label">
        <span data-i18n="batch">Batch:</span>
        <input type="number" id="uuid-count" value="5" min="1" max="100" />
        <span data-i18n="uuids">UUIDs</span>
      </label>
      <div class="uuid-actions">
        <button id="uuid-batch-gen" class="btn-primary" data-i18n="generateBatch">Generate Batch</button>
        <button id="uuid-batch-copy" class="btn-secondary" data-i18n="copyAll">Copy All</button>
        <button id="uuid-batch-clear" class="btn-ghost" data-i18n="clear">Clear</button>
      </div>
      <textarea id="uuid-batch-output" readonly data-i18n-ph="batchPlaceholder" placeholder="Batch UUIDs appear here..." spellcheck="false"></textarea>
    </div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: { clickGenerate: 'Click Generate', generate: 'Generate', copy: 'Copy', copied: 'Copied!', batch: 'Batch:', uuids: 'UUIDs', generateBatch: 'Generate Batch', copyAll: 'Copy All', clear: 'Clear', batchPlaceholder: 'Batch UUIDs appear here...' },
        zh: { clickGenerate: '点击生成', generate: '生成', copy: '复制', copied: '已复制！', batch: '批量：', uuids: '个 UUID', generateBatch: '批量生成', copyAll: '全部复制', clear: '清除', batchPlaceholder: '批量 UUID 显示在此...' },
        ja: { clickGenerate: '生成をクリック', generate: '生成', copy: 'コピー', copied: 'コピー済み！', batch: 'バッチ：', uuids: '件の UUID', generateBatch: 'バッチ生成', copyAll: 'すべてコピー', clear: 'クリア', batchPlaceholder: 'バッチ UUID がここに表示されます...' },
        ko: { clickGenerate: '생성 클릭', generate: '생성', copy: '복사', copied: '복사됨!', batch: '배치:', uuids: '개 UUID', generateBatch: '배치 생성', copyAll: '모두 복사', clear: '지우기', batchPlaceholder: '배치 UUID가 여기에 표시됩니다...' }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });
      document.querySelectorAll('[data-i18n-ph]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-ph'); if (t[key]) el.placeholder = t[key];
      });

      var singleOut = document.getElementById('uuid-output');
      var batchOut = document.getElementById('uuid-batch-output');
      var countInput = document.getElementById('uuid-count');

      function genUUID() {
        return crypto.randomUUID();
      }

      document.getElementById('uuid-generate').addEventListener('click', function () {
        singleOut.textContent = genUUID();
        singleOut.classList.add('has-value');
        window.trackTool && window.trackTool('uuid_generator', 'generate');
      });

      document.getElementById('uuid-copy-single').addEventListener('click', function () {
        var val = singleOut.textContent;
        if (val === t.clickGenerate) return;
        navigator.clipboard.writeText(val).then(function () {
          var btn = document.getElementById('uuid-copy-single');
          btn.textContent = t.copied;
          setTimeout(function () { btn.textContent = t.copy; }, 1500);
        });
      });

      document.getElementById('uuid-batch-gen').addEventListener('click', function () {
        var count = Math.min(100, Math.max(1, parseInt(countInput.value) || 5));
        var uuids = [];
        for (var i = 0; i < count; i++) uuids.push(genUUID());
        batchOut.value = uuids.join('\n');
        window.trackTool && window.trackTool('uuid_generator', 'generate_batch');
      });

      document.getElementById('uuid-batch-copy').addEventListener('click', function () {
        if (!batchOut.value) return;
        navigator.clipboard.writeText(batchOut.value).then(function () {
          var btn = document.getElementById('uuid-batch-copy');
          btn.textContent = t.copied;
          setTimeout(function () { btn.textContent = t.copyAll; }, 1500);
        });
      });

      document.getElementById('uuid-batch-clear').addEventListener('click', function () {
        batchOut.value = '';
      });

      // Restore saved count preference
      if (window.ztPersist) {
        var _savedCount = window.ztPersist.load('uuid-generator')['count'];
        if (_savedCount !== undefined) countInput.value = _savedCount;
      }

      // Save count on change
      countInput.addEventListener('change', function () {
        if (window.ztPersist) window.ztPersist.save('uuid-generator', { count: countInput.value });
      });

      // Auto-generate one on load
      singleOut.textContent = genUUID();
      singleOut.classList.add('has-value');
    })();
  </script>
</div>

<style>
  .uuid-wrap { display: flex; flex-direction: column; gap: 1.25rem; }

  .uuid-single { display: flex; flex-direction: column; gap: 0.75rem; align-items: flex-start; }

  .uuid-display {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    letter-spacing: 0.02em;
    padding: 0.75rem 1rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    width: 100%;
    color: var(--color-text-muted);
    user-select: all;
  }

  .uuid-display.has-value { color: var(--color-text); }

  .uuid-divider {
    border: none;
    border-top: 1px solid var(--color-border-light);
    margin: 0;
  }

  .uuid-batch-section { display: flex; flex-direction: column; gap: 0.75rem; }

  .batch-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .batch-label input {
    width: 70px;
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 5px;
    font-size: 0.9rem;
    text-align: center;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .uuid-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  #uuid-batch-output {
    width: 100%;
    min-height: 140px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    resize: vertical;
  }
</style>
