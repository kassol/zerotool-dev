---
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    inputLabel: 'Input',
    inputPlaceholder: 'Paste suspicious text here — emails, copied paragraphs, AI output...',
    clear: 'Clear',
    samples: 'Try a sample:',
    sampleTrojan: 'Trojan-Source',
    sampleWatermark: 'ChatGPT watermark',
    sampleBom: 'BOM + ZWSP',
    detectionLabel: 'Detection',
    nothingFound: 'No invisible characters detected.',
    foundOne: '1 invisible character found',
    foundN: '{n} invisible characters found',
    legend: 'Legend',
    catZw: 'Zero-Width',
    catBidi: 'Bidi',
    catTag: 'Tag',
    catVariation: 'Variation',
    catFormatting: 'Formatting',
    statsLabel: 'Stats',
    cleanedLabel: 'Cleaned',
    copy: 'Copy',
    copied: 'Copied',
    download: 'Download .txt',
    stripLabel: 'Strip:',
    stripAll: 'All',
    stripZw: 'Zero-Width only',
    stripBidi: 'Bidi only',
    stripTag: 'Tag only',
    stripVariation: 'Variation only',
    emptyAfterStrip: '(empty after stripping)',
    visibleLength: 'Visible',
    totalCodepoints: 'Code points',
  },
  zh: {
    inputLabel: '输入文本',
    inputPlaceholder: '粘贴可疑文本：邮件正文、网页复制、AI 输出……',
    clear: '清空',
    samples: '示例：',
    sampleTrojan: 'Trojan-Source',
    sampleWatermark: 'ChatGPT 水印',
    sampleBom: 'BOM + 零宽空格',
    detectionLabel: '检测结果',
    nothingFound: '未发现不可见字符。',
    foundOne: '发现 1 个不可见字符',
    foundN: '发现 {n} 个不可见字符',
    legend: '类别',
    catZw: '零宽',
    catBidi: '双向控制',
    catTag: 'Tag 字符',
    catVariation: '变体选择符',
    catFormatting: '排版控制',
    statsLabel: '统计',
    cleanedLabel: '清洁文本',
    copy: '复制',
    copied: '已复制',
    download: '下载 .txt',
    stripLabel: '清除范围：',
    stripAll: '全部',
    stripZw: '仅零宽',
    stripBidi: '仅双向',
    stripTag: '仅 Tag',
    stripVariation: '仅变体',
    emptyAfterStrip: '（清除后为空）',
    visibleLength: '可见字符',
    totalCodepoints: '码点总数',
  },
  ja: {
    inputLabel: '入力テキスト',
    inputPlaceholder: '疑わしいテキストを貼り付け：メール、コピー文、AI出力など…',
    clear: 'クリア',
    samples: 'サンプル：',
    sampleTrojan: 'Trojan-Source',
    sampleWatermark: 'ChatGPT 透かし',
    sampleBom: 'BOM + ゼロ幅空白',
    detectionLabel: '検出結果',
    nothingFound: '不可視文字は検出されませんでした。',
    foundOne: '不可視文字を 1 件検出',
    foundN: '不可視文字を {n} 件検出',
    legend: 'カテゴリ',
    catZw: 'ゼロ幅',
    catBidi: '双方向制御',
    catTag: 'Tag 文字',
    catVariation: 'バリエーション',
    catFormatting: '書式制御',
    statsLabel: '統計',
    cleanedLabel: 'クリーン版',
    copy: 'コピー',
    copied: 'コピー済み',
    download: '.txt をダウンロード',
    stripLabel: '除去対象：',
    stripAll: 'すべて',
    stripZw: 'ゼロ幅のみ',
    stripBidi: '双方向のみ',
    stripTag: 'Tag のみ',
    stripVariation: 'バリエーションのみ',
    emptyAfterStrip: '（除去後は空）',
    visibleLength: '可視文字数',
    totalCodepoints: 'コードポイント',
  },
  ko: {
    inputLabel: '입력 텍스트',
    inputPlaceholder: '의심스러운 텍스트 붙여넣기: 이메일, 복사된 문장, AI 출력...',
    clear: '지우기',
    samples: '샘플:',
    sampleTrojan: 'Trojan-Source',
    sampleWatermark: 'ChatGPT 워터마크',
    sampleBom: 'BOM + ZWSP',
    detectionLabel: '감지 결과',
    nothingFound: '보이지 않는 문자가 감지되지 않았습니다.',
    foundOne: '보이지 않는 문자 1개 감지',
    foundN: '보이지 않는 문자 {n}개 감지',
    legend: '범주',
    catZw: '제로폭',
    catBidi: '양방향',
    catTag: 'Tag 문자',
    catVariation: '변형 선택자',
    catFormatting: '서식 제어',
    statsLabel: '통계',
    cleanedLabel: '정리된 텍스트',
    copy: '복사',
    copied: '복사됨',
    download: '.txt 다운로드',
    stripLabel: '제거 범위:',
    stripAll: '전체',
    stripZw: '제로폭만',
    stripBidi: '양방향만',
    stripTag: 'Tag만',
    stripVariation: '변형만',
    emptyAfterStrip: '(제거 후 비어있음)',
    visibleLength: '보이는 문자',
    totalCodepoints: '코드포인트',
  },
} as const;

const L = labels[lang];
---

<div
  class="zwcd-wrap"
  data-copy={L.copy}
  data-copied={L.copied}
  data-nothing={L.nothingFound}
  data-found-one={L.foundOne}
  data-found-n={L.foundN}
  data-empty-strip={L.emptyAfterStrip}
>
  <section class="zwcd-section">
    <div class="zwcd-row">
      <label class="tool-label" for="zwcd-input">{L.inputLabel}</label>
      <button id="zwcd-clear" class="btn-ghost zwcd-btn-sm" type="button">{L.clear}</button>
    </div>
    <textarea
      id="zwcd-input"
      class="tool-textarea"
      placeholder={L.inputPlaceholder}
      spellcheck="false"
      rows="6"
    ></textarea>
    <div class="zwcd-samples">
      <span class="zwcd-samples-label">{L.samples}</span>
      <button class="zwcd-sample" type="button" data-sample="trojan">{L.sampleTrojan}</button>
      <button class="zwcd-sample" type="button" data-sample="watermark">{L.sampleWatermark}</button>
      <button class="zwcd-sample" type="button" data-sample="bom">{L.sampleBom}</button>
    </div>
  </section>

  <section class="zwcd-section">
    <div class="zwcd-row">
      <label class="tool-label">{L.detectionLabel}</label>
      <span id="zwcd-summary" class="tool-status none" aria-live="polite">{L.nothingFound}</span>
    </div>
    <div class="zwcd-grid">
      <div class="zwcd-viz-wrap">
        <pre id="zwcd-viz" class="zwcd-viz" aria-label={L.detectionLabel}></pre>
      </div>
      <aside class="zwcd-stats" aria-label={L.statsLabel}>
        <div class="zwcd-stats-title">{L.statsLabel}</div>
        <div class="zwcd-stats-row" data-cat="zero-width">
          <span class="zwcd-chip zwcd-chip-zero-width" aria-hidden="true">{L.catZw}</span>
          <span class="zwcd-stats-count" data-count="zero-width">0</span>
        </div>
        <div class="zwcd-stats-row" data-cat="bidi">
          <span class="zwcd-chip zwcd-chip-bidi" aria-hidden="true">{L.catBidi}</span>
          <span class="zwcd-stats-count" data-count="bidi">0</span>
        </div>
        <div class="zwcd-stats-row" data-cat="tag">
          <span class="zwcd-chip zwcd-chip-tag" aria-hidden="true">{L.catTag}</span>
          <span class="zwcd-stats-count" data-count="tag">0</span>
        </div>
        <div class="zwcd-stats-row" data-cat="variation">
          <span class="zwcd-chip zwcd-chip-variation" aria-hidden="true">{L.catVariation}</span>
          <span class="zwcd-stats-count" data-count="variation">0</span>
        </div>
        <div class="zwcd-stats-row" data-cat="formatting">
          <span class="zwcd-chip zwcd-chip-formatting" aria-hidden="true">{L.catFormatting}</span>
          <span class="zwcd-stats-count" data-count="formatting">0</span>
        </div>
        <div class="zwcd-stats-meta">
          <div><span class="zwcd-meta-label">{L.visibleLength}</span><span data-meta="visible">0</span></div>
          <div><span class="zwcd-meta-label">{L.totalCodepoints}</span><span data-meta="total">0</span></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="zwcd-section">
    <div class="zwcd-row">
      <label class="tool-label" for="zwcd-cleaned">{L.cleanedLabel}</label>
      <div class="zwcd-actions">
        <button id="zwcd-copy" class="btn-copy" type="button">{L.copy}</button>
        <button id="zwcd-download" class="btn-ghost zwcd-btn-sm" type="button">{L.download}</button>
      </div>
    </div>
    <textarea
      id="zwcd-cleaned"
      class="tool-textarea"
      readonly
      rows="4"
    ></textarea>
    <div class="zwcd-strip">
      <span class="zwcd-strip-label">{L.stripLabel}</span>
      <label class="zwcd-strip-opt"><input type="radio" name="zwcd-mode" value="all" checked/> {L.stripAll}</label>
      <label class="zwcd-strip-opt"><input type="radio" name="zwcd-mode" value="zero-width"/> {L.stripZw}</label>
      <label class="zwcd-strip-opt"><input type="radio" name="zwcd-mode" value="bidi"/> {L.stripBidi}</label>
      <label class="zwcd-strip-opt"><input type="radio" name="zwcd-mode" value="tag"/> {L.stripTag}</label>
      <label class="zwcd-strip-opt"><input type="radio" name="zwcd-mode" value="variation"/> {L.stripVariation}</label>
    </div>
  </section>
</div>

<script is:inline>
  (function () {
    var wrap = document.querySelector('.zwcd-wrap');
    if (!wrap) return;

    var COPY = wrap.dataset.copy || 'Copy';
    var COPIED = wrap.dataset.copied || 'Copied';
    var NOTHING = wrap.dataset.nothing || 'No invisible characters detected.';
    var FOUND_ONE = wrap.dataset.foundOne || '1 invisible character found';
    var FOUND_N = wrap.dataset.foundN || '{n} invisible characters found';
    var EMPTY_STRIP = wrap.dataset.emptyStrip || '(empty after stripping)';

    var input = wrap.querySelector('#zwcd-input');
    var viz = wrap.querySelector('#zwcd-viz');
    var summary = wrap.querySelector('#zwcd-summary');
    var cleaned = wrap.querySelector('#zwcd-cleaned');
    var copyBtn = wrap.querySelector('#zwcd-copy');
    var downloadBtn = wrap.querySelector('#zwcd-download');
    var clearBtn = wrap.querySelector('#zwcd-clear');
    var modeRadios = wrap.querySelectorAll('input[name="zwcd-mode"]');
    var sampleBtns = wrap.querySelectorAll('.zwcd-sample');
    var statCounts = wrap.querySelectorAll('[data-count]');
    var visibleEl = wrap.querySelector('[data-meta="visible"]');
    var totalEl = wrap.querySelector('[data-meta="total"]');

    var SINGLE = {
      0x00AD: { name: 'SHY', category: 'formatting', desc: 'Soft Hyphen' },
      0x180E: { name: 'MVS', category: 'zero-width', desc: 'Mongolian Vowel Separator' },
      0x200B: { name: 'ZWSP', category: 'zero-width', desc: 'Zero Width Space' },
      0x200C: { name: 'ZWNJ', category: 'zero-width', desc: 'Zero Width Non-Joiner' },
      0x200D: { name: 'ZWJ', category: 'zero-width', desc: 'Zero Width Joiner' },
      0x200E: { name: 'LRM', category: 'bidi', desc: 'Left-to-Right Mark' },
      0x200F: { name: 'RLM', category: 'bidi', desc: 'Right-to-Left Mark' },
      0x202A: { name: 'LRE', category: 'bidi', desc: 'Left-to-Right Embedding' },
      0x202B: { name: 'RLE', category: 'bidi', desc: 'Right-to-Left Embedding' },
      0x202C: { name: 'PDF', category: 'bidi', desc: 'Pop Directional Formatting' },
      0x202D: { name: 'LRO', category: 'bidi', desc: 'Left-to-Right Override' },
      0x202E: { name: 'RLO', category: 'bidi', desc: 'Right-to-Left Override (Trojan-Source)' },
      0x2060: { name: 'WJ', category: 'zero-width', desc: 'Word Joiner' },
      0x2061: { name: 'F-APP', category: 'zero-width', desc: 'Function Application' },
      0x2062: { name: 'I-TIMES', category: 'zero-width', desc: 'Invisible Times' },
      0x2063: { name: 'I-SEP', category: 'zero-width', desc: 'Invisible Separator' },
      0x2064: { name: 'I-PLUS', category: 'zero-width', desc: 'Invisible Plus' },
      0x2066: { name: 'LRI', category: 'bidi', desc: 'Left-to-Right Isolate' },
      0x2067: { name: 'RLI', category: 'bidi', desc: 'Right-to-Left Isolate' },
      0x2068: { name: 'FSI', category: 'bidi', desc: 'First Strong Isolate' },
      0x2069: { name: 'PDI', category: 'bidi', desc: 'Pop Directional Isolate' },
      0x3164: { name: 'HF', category: 'zero-width', desc: 'Hangul Filler' },
      0xFEFF: { name: 'BOM', category: 'zero-width', desc: 'Byte Order Mark / ZWNBSP' },
    };

    function classifyRange(cp) {
      if (cp >= 0xFE00 && cp <= 0xFE0F) {
        return { name: 'VS' + (cp - 0xFE00 + 1), category: 'variation', desc: 'Variation Selector ' + (cp - 0xFE00 + 1) };
      }
      if (cp >= 0xE0100 && cp <= 0xE01EF) {
        return { name: 'VS' + (cp - 0xE0100 + 17), category: 'variation', desc: 'Variation Selector ' + (cp - 0xE0100 + 17) };
      }
      if (cp >= 0xE0000 && cp <= 0xE007F) {
        var ascii = cp >= 0xE0020 && cp <= 0xE007E ? String.fromCodePoint(cp - 0xE0000) : null;
        return { name: ascii ? 'TAG-' + ascii : 'TAG', category: 'tag', desc: 'Tag character U+' + cp.toString(16).toUpperCase() };
      }
      return null;
    }

    function classify(cp) {
      return SINGLE[cp] || classifyRange(cp);
    }

    function escapeHtml(s) {
      return s.replace(/[&<>"]/g, function (c) {
        return c === '&' ? '&amp;' : c === '<' ? '&lt;' : c === '>' ? '&gt;' : '&quot;';
      });
    }

    function scan(text) {
      var hits = [];
      var visible = 0;
      var total = 0;
      var i = 0;
      while (i < text.length) {
        var cp = text.codePointAt(i);
        var width = cp > 0xFFFF ? 2 : 1;
        total++;
        var meta = classify(cp);
        if (meta) {
          hits.push({ index: i, width: width, codePoint: cp, meta: meta });
        } else {
          visible++;
        }
        i += width;
      }
      return { hits: hits, visible: visible, total: total };
    }

    function renderViz(text, hits) {
      var html = '';
      var cursor = 0;
      for (var k = 0; k < hits.length; k++) {
        var h = hits[k];
        if (h.index > cursor) {
          html += escapeHtml(text.slice(cursor, h.index));
        }
        var hex = 'U+' + h.codePoint.toString(16).toUpperCase().padStart(4, '0');
        var title = hex + ' · ' + h.meta.desc;
        html += '<span class="zwcd-chip zwcd-chip-' + h.meta.category + '" title="' + escapeHtml(title) + '" data-cp="' + hex + '">' + escapeHtml(h.meta.name) + '</span>';
        cursor = h.index + h.width;
      }
      if (cursor < text.length) {
        html += escapeHtml(text.slice(cursor));
      }
      return html;
    }

    function strip(text, hits, mode) {
      if (!hits.length) return text;
      var keep = function (h) {
        if (mode === 'all') return false;
        return h.meta.category !== mode;
      };
      var out = '';
      var cursor = 0;
      for (var k = 0; k < hits.length; k++) {
        var h = hits[k];
        if (h.index > cursor) out += text.slice(cursor, h.index);
        if (keep(h)) out += text.slice(h.index, h.index + h.width);
        cursor = h.index + h.width;
      }
      if (cursor < text.length) out += text.slice(cursor);
      return out;
    }

    function getMode() {
      for (var r = 0; r < modeRadios.length; r++) {
        if (modeRadios[r].checked) return modeRadios[r].value;
      }
      return 'all';
    }

    function update() {
      var text = input.value;
      var result = scan(text);
      var hits = result.hits;

      if (!text) {
        viz.textContent = '';
        cleaned.value = '';
        summary.textContent = NOTHING;
        summary.className = 'tool-status none';
      } else if (!hits.length) {
        viz.textContent = text;
        cleaned.value = text;
        summary.textContent = NOTHING;
        summary.className = 'tool-status success';
      } else {
        viz.innerHTML = renderViz(text, hits);
        var msg = hits.length === 1 ? FOUND_ONE : FOUND_N.replace('{n}', String(hits.length));
        summary.textContent = msg;
        summary.className = 'tool-status error';
        var cleanedText = strip(text, hits, getMode());
        cleaned.value = cleanedText || (text.length > 0 ? EMPTY_STRIP : '');
      }

      var counts = { 'zero-width': 0, 'bidi': 0, 'tag': 0, 'variation': 0, 'formatting': 0 };
      for (var j = 0; j < hits.length; j++) counts[hits[j].meta.category]++;
      for (var s = 0; s < statCounts.length; s++) {
        var cat = statCounts[s].getAttribute('data-count');
        statCounts[s].textContent = String(counts[cat] || 0);
      }
      visibleEl.textContent = String(result.visible);
      totalEl.textContent = String(result.total);
    }

    function copy(text) {
      if (!text) return Promise.resolve(false);
      if (navigator.clipboard && navigator.clipboard.writeText) {
        return navigator.clipboard.writeText(text).then(function () { return true; }, function () { return fallbackCopy(text); });
      }
      return Promise.resolve(fallbackCopy(text));
    }
    function fallbackCopy(text) {
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.left = '-9999px';
      document.body.appendChild(ta);
      ta.select();
      var ok = false;
      try { ok = document.execCommand('copy'); } catch (_) {}
      document.body.removeChild(ta);
      return ok;
    }

    var SAMPLES = {
      // Trojan-Source style: visible code with RLO + LRO override
      // Demonstrates CVE-2021-42574 (https://trojansource.codes/)
      trojan: 'access_level = "user\u202E \u2066// Check if admin\u2069 \u2066"; if (access_level == "user") {\n  // logic',
      // ChatGPT-style invisible tag-character watermark (E0020 = space tag, etc.)
      watermark: 'Hello\u200B world\uDB40\uDC68\uDB40\uDC65\uDB40\uDC6C\uDB40\uDC6C\uDB40\uDC6F. The signal is hidden inside.',
      // BOM-prefixed text with ZWSP scattered between letters
      bom: '\uFEFFhello\u200Bworld — the BOM and \u200Bzero-width spaces are invisible.',
    };

    sampleBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var k = btn.getAttribute('data-sample');
        input.value = SAMPLES[k] || '';
        update();
      });
    });

    modeRadios.forEach(function (r) { r.addEventListener('change', update); });

    input.addEventListener('input', update);

    clearBtn.addEventListener('click', function () {
      input.value = '';
      update();
      input.focus();
    });

    copyBtn.addEventListener('click', function () {
      copy(cleaned.value).then(function (ok) {
        if (!ok) return;
        copyBtn.textContent = COPIED;
        copyBtn.classList.add('copied');
        setTimeout(function () {
          copyBtn.textContent = COPY;
          copyBtn.classList.remove('copied');
        }, 1400);
      });
    });

    downloadBtn.addEventListener('click', function () {
      var text = cleaned.value;
      if (!text) return;
      var blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = 'cleaned.txt';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(function () { URL.revokeObjectURL(url); }, 100);
    });

    update();
  })();
</script>

<style is:global>
  .zwcd-wrap {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .zwcd-section {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .zwcd-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .zwcd-btn-sm {
    padding: 0.35rem 0.85rem;
    font-size: 0.82rem;
    border-radius: var(--radius-pill);
  }
  .zwcd-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .zwcd-samples {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
  }
  .zwcd-samples-label {
    color: var(--color-text-muted);
  }
  .zwcd-sample {
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-pill);
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-soft);
    font: inherit;
    font-size: 0.82rem;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  @media (hover: hover) {
    .zwcd-sample:hover {
      background: var(--color-surface-muted);
      color: var(--color-text);
      border-color: var(--color-border);
    }
  }
  .zwcd-sample:active { transform: scale(0.96); }

  .zwcd-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(180px, 24%, 240px);
    gap: 1rem;
  }
  .zwcd-viz-wrap {
    min-width: 0;
    background: var(--color-bg-secondary);
    border-radius: var(--radius-md);
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
    overflow: auto;
    max-height: 280px;
  }
  .zwcd-viz {
    margin: 0;
    padding: 0.85rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.65;
    white-space: pre-wrap;
    word-wrap: break-word;
    color: var(--color-text);
    background: transparent;
    min-height: 2.4em;
  }
  .zwcd-viz:empty::before {
    content: ' ';
    color: var(--color-text-muted);
  }

  .zwcd-chip {
    display: inline-flex;
    align-items: center;
    padding: 0 0.4em;
    margin: 0 0.1em;
    border-radius: var(--radius-sm);
    font-size: 0.7em;
    font-weight: 650;
    font-family: var(--font-sans);
    letter-spacing: 0.02em;
