---
// AesEncryptDecryptTool — AES-GCM encrypt/decrypt via Web Crypto API
---

<div class="aes-wrap">
  <div class="aes-field">
    <label class="aes-label" for="aes-password" data-i18n="password">Password</label>
    <div class="aes-pw-row">
      <input type="password" id="aes-password" class="aes-input" placeholder="Enter a strong password…" data-i18n-ph="passwordPlaceholder" autocomplete="off" />
      <button id="aes-toggle-pw" class="btn-ghost aes-btn-sm" type="button" title="Show / hide password" data-i18n="show">Show</button>
    </div>
  </div>

  <div class="aes-panes">
    <div class="aes-pane">
      <div class="aes-pane-header">
        <span class="aes-pane-label" data-i18n="plaintext">Plaintext</span>
        <button id="aes-encrypt" class="btn-primary aes-btn-sm" type="button" data-i18n="encrypt">Encrypt →</button>
      </div>
      <textarea id="aes-plaintext" class="aes-textarea" spellcheck="false" placeholder="Enter text to encrypt…" data-i18n-ph="encryptPlaceholder"></textarea>
    </div>
    <div class="aes-pane">
      <div class="aes-pane-header">
        <span class="aes-pane-label" data-i18n="ciphertext">Ciphertext (Base64)</span>
        <div class="aes-actions">
          <button id="aes-decrypt" class="btn-primary aes-btn-sm" type="button" data-i18n="decrypt">← Decrypt</button>
          <button id="aes-copy" class="btn-ghost aes-btn-sm" type="button" data-i18n="copy">Copy</button>
        </div>
      </div>
      <textarea id="aes-ciphertext" class="aes-textarea" spellcheck="false" placeholder="Paste ciphertext here to decrypt…" data-i18n-ph="decryptPlaceholder"></textarea>
    </div>
  </div>
  <div id="aes-status" class="aes-status" hidden></div>

  <div class="aes-note">
    AES-256-GCM · PBKDF2 key derivation · random salt + IV per encryption · runs entirely in your browser
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: { password: 'Password', plaintext: 'Plaintext', ciphertext: 'Ciphertext (Base64)', encrypt: 'Encrypt →', decrypt: '← Decrypt', copy: 'Copy', copied: 'Copied!', show: 'Show', hide: 'Hide', encryptPlaceholder: 'Enter text to encrypt…', decryptPlaceholder: 'Paste ciphertext here to decrypt…', passwordPlaceholder: 'Enter a strong password…', encryptedOk: 'Encrypted successfully.', decryptedOk: 'Decrypted successfully.', errNoPw: 'Please enter a password.', errNoPlain: 'Plaintext is empty.', errNoCipher: 'Ciphertext is empty.' },
        zh: { password: '密码', plaintext: '明文', ciphertext: '密文 (Base64)', encrypt: '加密 →', decrypt: '← 解密', copy: '复制', copied: '已复制！', show: '显示', hide: '隐藏', encryptPlaceholder: '输入要加密的文本…', decryptPlaceholder: '粘贴密文以解密…', passwordPlaceholder: '输入强密码…', encryptedOk: '加密成功。', decryptedOk: '解密成功。', errNoPw: '请输入密码。', errNoPlain: '明文为空。', errNoCipher: '密文为空。' },
        ja: { password: 'パスワード', plaintext: '平文', ciphertext: '暗号文 (Base64)', encrypt: '暗号化 →', decrypt: '← 復号', copy: 'コピー', copied: 'コピー済み！', show: '表示', hide: '非表示', encryptPlaceholder: '暗号化するテキストを入力…', decryptPlaceholder: '復号する暗号文を貼り付け…', passwordPlaceholder: '強力なパスワードを入力…', encryptedOk: '暗号化しました。', decryptedOk: '復号しました。', errNoPw: 'パスワードを入力してください。', errNoPlain: '平文が空です。', errNoCipher: '暗号文が空です。' },
        ko: { password: '비밀번호', plaintext: '평문', ciphertext: '암호문 (Base64)', encrypt: '암호화 →', decrypt: '← 복호화', copy: '복사', copied: '복사됨!', show: '표시', hide: '숨기기', encryptPlaceholder: '암호화할 텍스트를 입력…', decryptPlaceholder: '복호화할 암호문을 붙여넣기…', passwordPlaceholder: '강력한 비밀번호를 입력…', encryptedOk: '암호화 완료.', decryptedOk: '복호화 완료.', errNoPw: '비밀번호를 입력해 주세요.', errNoPlain: '평문이 비어 있습니다.', errNoCipher: '암호문이 비어 있습니다.' }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;

      document.querySelectorAll('.aes-wrap [data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });
      document.querySelectorAll('.aes-wrap [data-i18n-ph]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-ph'); if (t[key]) el.placeholder = t[key];
      });

      var pwEl        = document.getElementById('aes-password');
      var togglePwBtn = document.getElementById('aes-toggle-pw');
      var encBtn      = document.getElementById('aes-encrypt');
      var decBtn      = document.getElementById('aes-decrypt');
      var copyBtn     = document.getElementById('aes-copy');
      var plainEl     = document.getElementById('aes-plaintext');
      var cipherEl    = document.getElementById('aes-ciphertext');
      var statusEl    = document.getElementById('aes-status');

      togglePwBtn.addEventListener('click', function () {
        if (pwEl.type === 'password') {
          pwEl.type = 'text';
          togglePwBtn.textContent = t.hide;
        } else {
          pwEl.type = 'password';
          togglePwBtn.textContent = t.show;
        }
      });

      function showStatus(msg, isError) {
        statusEl.textContent = msg;
        statusEl.className = 'aes-status' + (isError ? ' aes-status-error' : ' aes-status-ok');
        statusEl.hidden = false;
        setTimeout(function () { statusEl.hidden = true; }, 3000);
      }

      function getPassword() {
        var pw = pwEl.value;
        if (!pw) { showStatus(t.errNoPw, true); return null; }
        return pw;
      }

      async function deriveKey(password, salt) {
        var enc = new TextEncoder();
        var keyMaterial = await crypto.subtle.importKey(
          'raw', enc.encode(password), 'PBKDF2', false, ['deriveKey']
        );
        return crypto.subtle.deriveKey(
          { name: 'PBKDF2', salt: salt, iterations: 200000, hash: 'SHA-256' },
          keyMaterial,
          { name: 'AES-GCM', length: 256 },
          false,
          ['encrypt', 'decrypt']
        );
      }

      function bufToBase64(buf) {
        var bytes = new Uint8Array(buf);
        var bin = '';
        for (var i = 0; i < bytes.length; i++) bin += String.fromCharCode(bytes[i]);
        return btoa(bin);
      }

      function base64ToBuf(b64) {
        var bin = atob(b64);
        var buf = new Uint8Array(bin.length);
        for (var i = 0; i < bin.length; i++) buf[i] = bin.charCodeAt(i);
        return buf;
      }

      // NOTE: AES encrypt/decrypt intentionally keeps manual button triggers only.
      // Auto-processing on input would be a security risk: it could silently encrypt/decrypt
      // partial input and expose intermediate plaintext or ciphertext states unexpectedly.
      encBtn.addEventListener('click', async function () {
        var pw = getPassword();
        if (!pw) return;
        var text = plainEl.value;
        if (!text) { showStatus(t.errNoPlain, true); return; }
        try {
          var salt = crypto.getRandomValues(new Uint8Array(16));
          var iv   = crypto.getRandomValues(new Uint8Array(12));
          var key  = await deriveKey(pw, salt);
          var enc  = new TextEncoder();
          var cipherBuf = await crypto.subtle.encrypt(
            { name: 'AES-GCM', iv: iv }, key, enc.encode(text)
          );
          // Pack: [salt(16)] [iv(12)] [ciphertext]
          var combined = new Uint8Array(16 + 12 + cipherBuf.byteLength);
          combined.set(salt, 0);
          combined.set(iv, 16);
          combined.set(new Uint8Array(cipherBuf), 28);
          cipherEl.value = bufToBase64(combined);
          showStatus(t.encryptedOk, false);
          window.trackTool && window.trackTool('aes-encrypt-decrypt', 'encrypt');
        } catch (e) {
          showStatus('Encryption failed: ' + e.message, true);
        }
      });

      decBtn.addEventListener('click', async function () {
        var pw = getPassword();
        if (!pw) return;
        var b64 = cipherEl.value.trim();
        if (!b64) { showStatus(t.errNoCipher, true); return; }
        try {
          var combined = base64ToBuf(b64);
          if (combined.length < 29) throw new Error('Ciphertext too short.');
          var salt      = combined.slice(0, 16);
          var iv        = combined.slice(16, 28);
          var cipherBuf = combined.slice(28);
          var key       = await deriveKey(pw, salt);
          var plainBuf  = await crypto.subtle.decrypt(
            { name: 'AES-GCM', iv: iv }, key, cipherBuf
          );
          plainEl.value = new TextDecoder().decode(plainBuf);
          showStatus(t.decryptedOk, false);
          window.trackTool && window.trackTool('aes-encrypt-decrypt', 'decrypt');
        } catch (e) {
          showStatus('Decryption failed — wrong password or corrupted ciphertext.', true);
        }
      });

      copyBtn.addEventListener('click', function () {
        var text = cipherEl.value;
        if (!text) return;
        navigator.clipboard.writeText(text).then(function () {
          copyBtn.textContent = t.copied;
          setTimeout(function () { copyBtn.textContent = t.copy; }, 1500);
        });
      });
    })();
  </script>
</div>

<style>
  .aes-wrap { display: flex; flex-direction: column; gap: 0.85rem; }

  .aes-field { display: flex; flex-direction: column; gap: 0.35rem; }

  .aes-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .aes-pw-row { display: flex; gap: 0.5rem; align-items: center; }

  .aes-input {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    padding: 0.4rem 0.65rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    flex: 1;
  }

  .aes-panes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  @media (max-width: 680px) {
    .aes-panes { grid-template-columns: 1fr; }
  }

  .aes-pane { display: flex; flex-direction: column; gap: 0.4rem; }

  .aes-pane-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .aes-pane-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .aes-actions { display: flex; gap: 0.35rem; }

  .aes-btn-sm {
    font-size: 0.75rem;
    padding: 0.2rem 0.55rem;
  }

  .aes-textarea {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.5;
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    width: 100%;
    min-height: 200px;
    resize: vertical;
    box-sizing: border-box;
  }

  .aes-status {
    font-size: 0.82rem;
    padding: 0.4rem 0.65rem;
    border-radius: var(--radius-sm);
  }

  .aes-status-ok {
    color: #059669;
    background: #ecfdf5;
    border: 1px solid #6ee7b7;
  }

  .aes-status-error {
    color: #ef4444;
    background: #fef2f2;
    border: 1px solid #fca5a5;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .aes-status-ok {
      background: #052e1c;
      border-color: #065f46;
      color: #6ee7b7;
    }
    :root:not([data-theme="light"]) .aes-status-error {
      background: #2d1515;
      border-color: #7f1d1d;
      color: #fca5a5;
    }
  }

  .aes-note {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
  }
</style>
