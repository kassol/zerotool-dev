---
// TomlJsonTool — bidirectional TOML ↔ JSON converter (uses smol-toml via Astro bundle)
---

<div>
  <div class="tj-wrap"
    data-msg-toml-to-json=""
    data-msg-json-to-toml=""
    data-msg-invalid-toml=""
    data-msg-invalid-json=""
    data-msg-error=""
    data-copy=""
    data-copied=""
  >
    <div class="tj-panels">
      <div class="tj-panel">
        <label for="tj-toml">
          <span>TOML</span>
          <button id="tj-copy-toml" class="btn-copy" type="button" data-i18n="copy">Copy</button>
        </label>
        <textarea
          id="tj-toml"
          placeholder={'[database]\nhost = "localhost"\nport = 5432\nenabled = true'}
          spellcheck="false"
        ></textarea>
      </div>
      <div class="tj-panel">
        <label for="tj-json">
          <span>JSON</span>
          <button id="tj-copy-json" class="btn-copy" type="button" data-i18n="copy">Copy</button>
        </label>
        <textarea
          id="tj-json"
          placeholder='{"database":{"host":"localhost","port":5432,"enabled":true}}'
          spellcheck="false"
        ></textarea>
      </div>
    </div>

    <div class="tj-actions">
      <button id="tj-to-json" class="btn-primary" data-i18n="tomlToJson">TOML → JSON</button>
      <button id="tj-to-toml" class="btn-primary" data-i18n="jsonToToml">JSON → TOML</button>
      <button id="tj-clear" class="btn-ghost" data-i18n="clear">Clear</button>
    </div>

    <div id="tj-status" class="tj-status" aria-live="polite"></div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: { copy: 'Copy', copied: 'Copied!', clear: 'Clear', tomlToJson: 'TOML \u2192 JSON', jsonToToml: 'JSON \u2192 TOML', msgTomlToJson: 'Converted TOML to JSON.', msgJsonToToml: 'Converted JSON to TOML.', msgInvalidToml: 'Invalid TOML', msgInvalidJson: 'Invalid JSON', msgError: 'Error' },
        zh: { copy: '复制', copied: '已复制！', clear: '清除', tomlToJson: 'TOML \u2192 JSON', jsonToToml: 'JSON \u2192 TOML', msgTomlToJson: '已将 TOML 转换为 JSON。', msgJsonToToml: '已将 JSON 转换为 TOML。', msgInvalidToml: '无效 TOML', msgInvalidJson: '无效 JSON', msgError: '错误' },
        ja: { copy: 'コピー', copied: 'コピー済み！', clear: 'クリア', tomlToJson: 'TOML \u2192 JSON', jsonToToml: 'JSON \u2192 TOML', msgTomlToJson: 'TOML を JSON に変換しました。', msgJsonToToml: 'JSON を TOML に変換しました。', msgInvalidToml: '無効な TOML', msgInvalidJson: '無効な JSON', msgError: 'エラー' },
        ko: { copy: '복사', copied: '복사됨!', clear: '지우기', tomlToJson: 'TOML \u2192 JSON', jsonToToml: 'JSON \u2192 TOML', msgTomlToJson: 'TOML을 JSON으로 변환했습니다.', msgJsonToToml: 'JSON을 TOML로 변환했습니다.', msgInvalidToml: '유효하지 않은 TOML', msgInvalidJson: '유효하지 않은 JSON', msgError: '오류' }
      };
      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;
      document.querySelectorAll('.tj-wrap [data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });
      var wrap = document.querySelector('.tj-wrap');
      if (wrap) {
        wrap.dataset.msgTomlToJson = t.msgTomlToJson;
        wrap.dataset.msgJsonToToml = t.msgJsonToToml;
        wrap.dataset.msgInvalidToml = t.msgInvalidToml;
        wrap.dataset.msgInvalidJson = t.msgInvalidJson;
        wrap.dataset.msgError = t.msgError;
        wrap.dataset.copy = t.copy;
        wrap.dataset.copied = t.copied;
      }
    })();
  </script>

  <script>
    import { parse, stringify } from 'smol-toml';

    const tomlEl = document.getElementById('tj-toml') as HTMLTextAreaElement;
    const jsonEl = document.getElementById('tj-json') as HTMLTextAreaElement;
    const statusEl = document.getElementById('tj-status') as HTMLElement;
    const copyTomlBtn = document.getElementById('tj-copy-toml') as HTMLButtonElement;
    const copyJsonBtn = document.getElementById('tj-copy-json') as HTMLButtonElement;
    let lastValidJsonOutput = '';
    let lastValidTomlOutput = '';

    const tjWrap = document.querySelector('.tj-wrap') as HTMLElement;
    const MSG_TOML_TO_JSON  = tjWrap?.dataset.msgTomlToJson  || 'Converted TOML to JSON.';
    const MSG_JSON_TO_TOML  = tjWrap?.dataset.msgJsonToToml  || 'Converted JSON to TOML.';
    const MSG_INVALID_TOML  = tjWrap?.dataset.msgInvalidToml || 'Invalid TOML';
    const MSG_INVALID_JSON  = tjWrap?.dataset.msgInvalidJson || 'Invalid JSON';
    const MSG_ERROR         = tjWrap?.dataset.msgError       || 'Error';
    const COPY_LABEL        = tjWrap?.dataset.copy           || 'Copy';
    const COPIED_LABEL      = tjWrap?.dataset.copied         || 'Copied!';

    function setStatus(msg: string, isError: boolean) {
      statusEl.textContent = msg;
      statusEl.className = 'tj-status ' + (isError ? 'error' : 'success');
    }

    function clearStatus() {
      statusEl.textContent = '';
      statusEl.className = 'tj-status';
    }

    /* ── Real-time TOML → JSON (debounced 300ms) ── */
    let _tjTomlTimer: ReturnType<typeof setTimeout> | null = null;
    tomlEl.addEventListener('input', () => {
      if (_tjTomlTimer) clearTimeout(_tjTomlTimer);
      _tjTomlTimer = setTimeout(() => {
        const raw = tomlEl.value.trim();
        if (!raw) { clearStatus(); return; }
        try {
          const data = parse(raw);
          jsonEl.value = JSON.stringify(data, null, 2);
          lastValidJsonOutput = jsonEl.value;
          setStatus(MSG_TOML_TO_JSON, false);
        } catch (e: any) {
          setStatus(MSG_INVALID_TOML + ': ' + e.message, true);
        }
      }, 300);
    });

    /* ── Real-time JSON → TOML (debounced 300ms) ── */
    let _tjJsonTimer: ReturnType<typeof setTimeout> | null = null;
    jsonEl.addEventListener('input', () => {
      if (_tjJsonTimer) clearTimeout(_tjJsonTimer);
      _tjJsonTimer = setTimeout(() => {
        const raw = jsonEl.value.trim();
        if (!raw) { clearStatus(); return; }
        try {
          const data = JSON.parse(raw);
          tomlEl.value = stringify(data);
          lastValidTomlOutput = tomlEl.value;
          setStatus(MSG_JSON_TO_TOML, false);
        } catch (e: any) {
          setStatus(MSG_ERROR + ': ' + e.message, true);
        }
      }, 300);
    });

    /* ── TOML → JSON button ── */
    document.getElementById('tj-to-json')!.addEventListener('click', () => {
      const raw = tomlEl.value.trim();
      if (!raw) { clearStatus(); return; }
      try {
        const data = parse(raw);
        jsonEl.value = JSON.stringify(data, null, 2);
        lastValidJsonOutput = jsonEl.value;
        setStatus(MSG_TOML_TO_JSON, false);
        (window as any).trackTool && (window as any).trackTool('toml_json', 'toml_to_json');
      } catch (e: any) {
        setStatus(MSG_INVALID_TOML + ': ' + e.message, true);
      }
    });

    /* ── JSON → TOML button ── */
    document.getElementById('tj-to-toml')!.addEventListener('click', () => {
      const raw = jsonEl.value.trim();
      if (!raw) { clearStatus(); return; }
      try {
        const data = JSON.parse(raw);
        tomlEl.value = stringify(data);
        lastValidTomlOutput = tomlEl.value;
        setStatus(MSG_JSON_TO_TOML, false);
        (window as any).trackTool && (window as any).trackTool('toml_json', 'json_to_toml');
      } catch (e: any) {
        setStatus(MSG_ERROR + ': ' + e.message, true);
      }
    });

    /* ── Clear ── */
    document.getElementById('tj-clear')!.addEventListener('click', () => {
      tomlEl.value = '';
      jsonEl.value = '';
      clearStatus();
    });

    /* ── Copy buttons ── */
    copyTomlBtn.addEventListener('click', () => {
      if (!tomlEl.value) return;
      navigator.clipboard.writeText(tomlEl.value).then(() => {
        copyTomlBtn.textContent = COPIED_LABEL;
        setTimeout(() => { copyTomlBtn.textContent = COPY_LABEL; }, 1500);
      });
    });

    copyJsonBtn.addEventListener('click', () => {
      if (!jsonEl.value) return;
      navigator.clipboard.writeText(jsonEl.value).then(() => {
        copyJsonBtn.textContent = COPIED_LABEL;
        setTimeout(() => { copyJsonBtn.textContent = COPY_LABEL; }, 1500);
      });
    });

    /* ── Keyboard shortcut: Ctrl/Cmd+Enter ── */
    tomlEl.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) {
        document.getElementById('tj-to-json')!.click();
      }
    });

    jsonEl.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) {
        document.getElementById('tj-to-toml')!.click();
      }
    });
  </script>
</div>

<style>
  .tj-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .tj-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  @media (max-width: 600px) {
    .tj-panels { grid-template-columns: 1fr; }
  }

  .tj-panel { display: flex; flex-direction: column; gap: 0.4rem; }

  .tj-panel label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .tj-panel textarea {
    width: 100%;
    min-height: 200px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
    line-height: 1.5;
  }

  .tj-panel textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .tj-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .tj-status { font-size: 0.85rem; min-height: 1.2rem; }
  .tj-status.success { color: #057a55; }
  .tj-status.error { color: #c0392b; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .tj-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .tj-status.error { color: #f87171; }
  }
  [data-theme="dark"] .tj-status.success { color: #34d399; }
  [data-theme="dark"] .tj-status.error { color: #f87171; }
</style>
