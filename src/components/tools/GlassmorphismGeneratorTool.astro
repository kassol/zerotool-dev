---
// GlassmorphismGeneratorTool — CSS glassmorphism card visual generator
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    bgColor: 'Background Color',
    bgAlpha: 'Background Opacity',
    blur: 'Blur',
    saturation: 'Saturation',
    borderColor: 'Border Color',
    borderAlpha: 'Border Opacity',
    borderWidth: 'Border Width',
    radius: 'Border Radius',
    shadowColor: 'Shadow Color',
    shadowOpacity: 'Shadow Opacity',
    bgPreset: 'Background',
    preview: 'Preview',
    outputLabel: 'Generated CSS',
    copy: 'Copy',
    copied: 'Copied!',
    px: 'px',
    pct: '%',
    sunset: 'Sunset',
    ocean: 'Ocean',
    forest: 'Forest',
    night: 'Night',
    aurora: 'Aurora',
  },
  zh: {
    bgColor: '背景颜色',
    bgAlpha: '背景透明度',
    blur: '模糊',
    saturation: '饱和度',
    borderColor: '边框颜色',
    borderAlpha: '边框透明度',
    borderWidth: '边框宽度',
    radius: '圆角',
    shadowColor: '阴影颜色',
    shadowOpacity: '阴影透明度',
    bgPreset: '背景',
    preview: '预览',
    outputLabel: '生成的 CSS',
    copy: '复制',
    copied: '已复制！',
    px: 'px',
    pct: '%',
    sunset: '日落',
    ocean: '海洋',
    forest: '森林',
    night: '深夜',
    aurora: '极光',
  },
  ja: {
    bgColor: '背景色',
    bgAlpha: '背景の不透明度',
    blur: 'ブラー',
    saturation: '彩度',
    borderColor: 'ボーダー色',
    borderAlpha: 'ボーダーの不透明度',
    borderWidth: 'ボーダー幅',
    radius: '角丸',
    shadowColor: 'シャドウカラー',
    shadowOpacity: 'シャドウの不透明度',
    bgPreset: '背景',
    preview: 'プレビュー',
    outputLabel: '生成された CSS',
    copy: 'コピー',
    copied: 'コピーしました！',
    px: 'px',
    pct: '%',
    sunset: 'サンセット',
    ocean: 'オーシャン',
    forest: 'フォレスト',
    night: 'ナイト',
    aurora: 'オーロラ',
  },
  ko: {
    bgColor: '배경 색상',
    bgAlpha: '배경 투명도',
    blur: '블러',
    saturation: '채도',
    borderColor: '테두리 색상',
    borderAlpha: '테두리 투명도',
    borderWidth: '테두리 너비',
    radius: '모서리 반경',
    shadowColor: '그림자 색상',
    shadowOpacity: '그림자 투명도',
    bgPreset: '배경',
    preview: '미리보기',
    outputLabel: '생성된 CSS',
    copy: '복사',
    copied: '복사됨!',
    px: 'px',
    pct: '%',
    sunset: '선셋',
    ocean: '오션',
    forest: '포레스트',
    night: '나이트',
    aurora: '오로라',
  },
};

const L = labels[lang] ?? labels['en'];
---

<div
  class="gsg-wrap"
  data-copy={L.copy}
  data-copied={L.copied}
>
  <!-- Controls column -->
  <div class="gsg-controls">

    <!-- Background Color + Opacity row -->
    <div class="gsg-row-two">
      <div class="gsg-field gsg-field-color">
        <label class="gsg-label" for="gsg-bg-color">{L.bgColor}</label>
        <div class="gsg-color-input-wrap">
          <input id="gsg-bg-color" class="gsg-swatch" type="color" value="#ffffff" />
          <input id="gsg-bg-hex" class="gsg-hex-input" type="text" value="#ffffff" spellcheck="false" autocomplete="off" maxlength="7" />
        </div>
      </div>
      <div class="gsg-field">
        <div class="gsg-field-header">
          <label class="gsg-label" for="gsg-bg-alpha">{L.bgAlpha}</label>
          <span class="gsg-val" id="gsg-bg-alpha-val">15%</span>
        </div>
        <input id="gsg-bg-alpha" class="gsg-slider" type="range" min="0" max="100" value="15" />
      </div>
    </div>

    <!-- Blur -->
    <div class="gsg-field">
      <div class="gsg-field-header">
        <label class="gsg-label" for="gsg-blur">{L.blur}</label>
        <span class="gsg-val" id="gsg-blur-val">12px</span>
      </div>
      <input id="gsg-blur" class="gsg-slider" type="range" min="0" max="40" value="12" />
    </div>

    <!-- Saturation -->
    <div class="gsg-field">
      <div class="gsg-field-header">
        <label class="gsg-label" for="gsg-sat">{L.saturation}</label>
        <span class="gsg-val" id="gsg-sat-val">180%</span>
      </div>
      <input id="gsg-sat" class="gsg-slider" type="range" min="100" max="200" value="180" />
    </div>

    <!-- Border Color + Opacity row -->
    <div class="gsg-row-two">
      <div class="gsg-field gsg-field-color">
        <label class="gsg-label" for="gsg-border-color">{L.borderColor}</label>
        <div class="gsg-color-input-wrap">
          <input id="gsg-border-color" class="gsg-swatch" type="color" value="#ffffff" />
          <input id="gsg-border-hex" class="gsg-hex-input" type="text" value="#ffffff" spellcheck="false" autocomplete="off" maxlength="7" />
        </div>
      </div>
      <div class="gsg-field">
        <div class="gsg-field-header">
          <label class="gsg-label" for="gsg-border-alpha">{L.borderAlpha}</label>
          <span class="gsg-val" id="gsg-border-alpha-val">30%</span>
        </div>
        <input id="gsg-border-alpha" class="gsg-slider" type="range" min="0" max="100" value="30" />
      </div>
    </div>

    <!-- Border Width + Radius row -->
    <div class="gsg-row-two">
      <div class="gsg-field">
        <div class="gsg-field-header">
          <label class="gsg-label" for="gsg-border-width">{L.borderWidth}</label>
          <span class="gsg-val" id="gsg-border-width-val">1px</span>
        </div>
        <input id="gsg-border-width" class="gsg-slider" type="range" min="0" max="4" value="1" step="0.5" />
      </div>
      <div class="gsg-field">
        <div class="gsg-field-header">
          <label class="gsg-label" for="gsg-radius">{L.radius}</label>
          <span class="gsg-val" id="gsg-radius-val">16px</span>
        </div>
        <input id="gsg-radius" class="gsg-slider" type="range" min="0" max="40" value="16" />
      </div>
    </div>

    <!-- Shadow Color + Opacity row -->
    <div class="gsg-row-two">
      <div class="gsg-field gsg-field-color">
        <label class="gsg-label" for="gsg-shadow-color">{L.shadowColor}</label>
        <div class="gsg-color-input-wrap">
          <input id="gsg-shadow-color" class="gsg-swatch" type="color" value="#000000" />
          <input id="gsg-shadow-hex" class="gsg-hex-input" type="text" value="#000000" spellcheck="false" autocomplete="off" maxlength="7" />
        </div>
      </div>
      <div class="gsg-field">
        <div class="gsg-field-header">
          <label class="gsg-label" for="gsg-shadow-opacity">{L.shadowOpacity}</label>
          <span class="gsg-val" id="gsg-shadow-opacity-val">20%</span>
        </div>
        <input id="gsg-shadow-opacity" class="gsg-slider" type="range" min="0" max="60" value="20" />
      </div>
    </div>

    <!-- Background preset -->
    <div class="gsg-field">
      <label class="gsg-label">{L.bgPreset}</label>
      <div class="gsg-presets">
        <button class="gsg-preset gsg-preset-sunset active" data-preset="sunset" title={L.sunset} aria-label={L.sunset}></button>
        <button class="gsg-preset gsg-preset-ocean" data-preset="ocean" title={L.ocean} aria-label={L.ocean}></button>
        <button class="gsg-preset gsg-preset-forest" data-preset="forest" title={L.forest} aria-label={L.forest}></button>
        <button class="gsg-preset gsg-preset-night" data-preset="night" title={L.night} aria-label={L.night}></button>
        <button class="gsg-preset gsg-preset-aurora" data-preset="aurora" title={L.aurora} aria-label={L.aurora}></button>
      </div>
    </div>
  </div>

  <!-- Preview -->
  <div class="gsg-preview-section">
    <span class="gsg-section-label">{L.preview}</span>
    <div id="gsg-preview-canvas" class="gsg-preview-canvas">
      <div id="gsg-card" class="gsg-card">
        <div class="gsg-card-dot"></div>
        <div class="gsg-card-title">Glassmorphism</div>
        <div class="gsg-card-sub">CSS Effect Generator</div>
        <div class="gsg-card-btn"></div>
      </div>
    </div>
  </div>

  <!-- Output -->
  <div class="gsg-output-section">
    <div class="gsg-output-header">
      <span class="gsg-section-label">{L.outputLabel}</span>
      <button id="gsg-copy" class="btn-copy" type="button">{L.copy}</button>
    </div>
    <pre class="gsg-pre"><code id="gsg-code" class="gsg-code"></code></pre>
  </div>

  <script is:inline>
    (function () {
      var wrap = document.currentScript
        ? document.currentScript.closest('.gsg-wrap')
        : document.querySelector('.gsg-wrap');

      var COPY_LABEL   = wrap.dataset.copy;
      var COPIED_LABEL = wrap.dataset.copied;

      var bgColorEl      = wrap.querySelector('#gsg-bg-color');
      var bgHexEl        = wrap.querySelector('#gsg-bg-hex');
      var bgAlphaEl      = wrap.querySelector('#gsg-bg-alpha');
      var bgAlphaValEl   = wrap.querySelector('#gsg-bg-alpha-val');
      var blurEl         = wrap.querySelector('#gsg-blur');
      var blurValEl      = wrap.querySelector('#gsg-blur-val');
      var satEl          = wrap.querySelector('#gsg-sat');
      var satValEl       = wrap.querySelector('#gsg-sat-val');
      var borderColorEl  = wrap.querySelector('#gsg-border-color');
      var borderHexEl    = wrap.querySelector('#gsg-border-hex');
      var borderAlphaEl  = wrap.querySelector('#gsg-border-alpha');
      var borderAlphaValEl = wrap.querySelector('#gsg-border-alpha-val');
      var borderWidthEl  = wrap.querySelector('#gsg-border-width');
      var borderWidthValEl = wrap.querySelector('#gsg-border-width-val');
      var radiusEl       = wrap.querySelector('#gsg-radius');
      var radiusValEl    = wrap.querySelector('#gsg-radius-val');
      var shadowColorEl  = wrap.querySelector('#gsg-shadow-color');
      var shadowHexEl    = wrap.querySelector('#gsg-shadow-hex');
      var shadowOpEl     = wrap.querySelector('#gsg-shadow-opacity');
      var shadowOpValEl  = wrap.querySelector('#gsg-shadow-opacity-val');
      var canvasEl       = wrap.querySelector('#gsg-preview-canvas');
      var cardEl         = wrap.querySelector('#gsg-card');
      var codeEl         = wrap.querySelector('#gsg-code');
      var copyBtn        = wrap.querySelector('#gsg-copy');
      var presetBtns     = wrap.querySelectorAll('.gsg-preset');

      var PRESETS = {
        sunset: 'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)',
        ocean:  'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)',
        forest: 'linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)',
        night:  'linear-gradient(135deg, #2d2b55 0%, #0c0c1e 100%)',
        aurora: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
      };

      var currentPreset = 'sunset';
      canvasEl.style.background = PRESETS[currentPreset];

      function hexToRgb(hex) {
        var r = parseInt(hex.slice(1, 3), 16);
        var g = parseInt(hex.slice(3, 5), 16);
        var b = parseInt(hex.slice(5, 7), 16);
        return { r: r, g: g, b: b };
      }

      function fmtRgba(hex, alpha) {
        var c = hexToRgb(hex);
        return 'rgba(' + c.r + ', ' + c.g + ', ' + c.b + ', ' + alpha.toFixed(2) + ')';
      }

      function generate() {
        var bgAlpha     = parseInt(bgAlphaEl.value) / 100;
        var blur        = parseInt(blurEl.value);
        var sat         = parseInt(satEl.value);
        var borderAlpha = parseInt(borderAlphaEl.value) / 100;
        var borderWidth = parseFloat(borderWidthEl.value);
        var radius      = parseInt(radiusEl.value);
        var shadowOp    = parseInt(shadowOpEl.value) / 100;

        bgAlphaValEl.textContent     = Math.round(bgAlpha * 100) + '%';
        blurValEl.textContent        = blur + 'px';
        satValEl.textContent         = sat + '%';
        borderAlphaValEl.textContent = Math.round(borderAlpha * 100) + '%';
        borderWidthValEl.textContent = borderWidth + 'px';
        radiusValEl.textContent      = radius + 'px';
        shadowOpValEl.textContent    = Math.round(shadowOp * 100) + '%';

        var bgRgba     = fmtRgba(bgColorEl.value, bgAlpha);
        var borderRgba = fmtRgba(borderColorEl.value, borderAlpha);
        var shadowRgba = fmtRgba(shadowColorEl.value, shadowOp);
        var bdFilter   = 'blur(' + blur + 'px) saturate(' + sat + '%)';
        var boxShadow  = '0 4px 24px ' + shadowRgba;
        var border     = borderWidth + 'px solid ' + borderRgba;

        cardEl.style.background          = bgRgba;
        cardEl.style.backdropFilter      = bdFilter;
        cardEl.style.webkitBackdropFilter = bdFilter;
        cardEl.style.border              = border;
        cardEl.style.borderRadius        = radius + 'px';
        cardEl.style.boxShadow           = boxShadow;

        var css =
          '.glass {\n' +
          '  background: ' + bgRgba + ';\n' +
          '  backdrop-filter: ' + bdFilter + ';\n' +
          '  -webkit-backdrop-filter: ' + bdFilter + ';\n' +
          '  border: ' + border + ';\n' +
          '  border-radius: ' + radius + 'px;\n' +
          '  box-shadow: ' + boxShadow + ';\n' +
          '}';

        codeEl.innerHTML =
          '<span class="gsg-hl-sel">.glass</span> <span class="gsg-hl-brace">{</span>\n' +
          '  <span class="gsg-hl-prop">background</span><span class="gsg-hl-colon">: </span><span class="gsg-hl-val">' + escHtml(bgRgba) + '</span><span class="gsg-hl-semi">;</span>\n' +
          '  <span class="gsg-hl-prop">backdrop-filter</span><span class="gsg-hl-colon">: </span><span class="gsg-hl-val">' + escHtml(bdFilter) + '</span><span class="gsg-hl-semi">;</span>\n' +
          '  <span class="gsg-hl-prop">-webkit-backdrop-filter</span><span class="gsg-hl-colon">: </span><span class="gsg-hl-val">' + escHtml(bdFilter) + '</span><span class="gsg-hl-semi">;</span>\n' +
          '  <span class="gsg-hl-prop">border</span><span class="gsg-hl-colon">: </span><span class="gsg-hl-val">' + escHtml(border) + '</span><span class="gsg-hl-semi">;</span>\n' +
          '  <span class="gsg-hl-prop">border-radius</span><span class="gsg-hl-colon">: </span><span class="gsg-hl-num">' + radius + 'px</span><span class="gsg-hl-semi">;</span>\n' +
          '  <span class="gsg-hl-prop">box-shadow</span><span class="gsg-hl-colon">: </span><span class="gsg-hl-val">' + escHtml(boxShadow) + '</span><span class="gsg-hl-semi">;</span>\n' +
          '<span class="gsg-hl-brace">}</span>';

        copyBtn._cssText = css;
        window.trackTool && window.trackTool('glassmorphism-generator', 'generate');
      }

      function escHtml(s) {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }

      function syncColor(swatchEl, hexInputEl) {
        swatchEl.addEventListener('input', function () {
          hexInputEl.value = swatchEl.value;
          generate();
        });
        hexInputEl.addEventListener('input', function () {
          var v = hexInputEl.value.trim();
          if (/^#[0-9a-fA-F]{6}$/.test(v)) {
            swatchEl.value = v;
          }
          generate();
        });
      }

      syncColor(bgColorEl, bgHexEl);
      syncColor(borderColorEl, borderHexEl);
      syncColor(shadowColorEl, shadowHexEl);

      [bgAlphaEl, blurEl, satEl, borderAlphaEl, borderWidthEl, radiusEl, shadowOpEl].forEach(function (el) {
        el.addEventListener('input', generate);
      });

      presetBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          presetBtns.forEach(function (b) { b.classList.remove('active'); });
          btn.classList.add('active');
          currentPreset = btn.dataset.preset;
          canvasEl.style.background = PRESETS[currentPreset];
        });
      });

      copyBtn.addEventListener('click', function () {
        var text = copyBtn._cssText || codeEl.textContent;
        if (!text) return;
        navigator.clipboard.writeText(text).then(function () {
          copyBtn.textContent = COPIED_LABEL;
          setTimeout(function () { copyBtn.textContent = COPY_LABEL; }, 1500);
          window.trackTool && window.trackTool('glassmorphism-generator', 'copy');
        });
      });

      generate();
    })();
  </script>
</div>

<style>
  .gsg-wrap { display: flex; flex-direction: column; gap: 1.25rem; }

  /* ── Controls ── */
  .gsg-controls { display: flex; flex-direction: column; gap: 0.75rem; }

  .gsg-field { display: flex; flex-direction: column; gap: 0.3rem; }

  .gsg-row-two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    align-items: start;
  }

  .gsg-field-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .gsg-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .gsg-val {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--color-primary);
    min-width: 3.5rem;
    text-align: right;
  }

  /* ── Slider ── */
  .gsg-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 4px;
    border-radius: 2px;
    background: var(--color-border);
    outline: none;
    cursor: pointer;
  }

  .gsg-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-primary);
    cursor: pointer;
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 1px var(--color-primary);
  }

  .gsg-slider::-moz-range-thumb {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-primary);
    cursor: pointer;
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 0 1px var(--color-primary);
  }

  /* ── Color inputs ── */
  .gsg-color-input-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.2rem;
  }

  .gsg-swatch {
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 2px;
    cursor: pointer;
    background: none;
    flex-shrink: 0;
  }

  .gsg-hex-input {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    width: 100%;
    min-width: 0;
  }

  .gsg-hex-input:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  /* ── Background presets ── */
  .gsg-presets {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .gsg-preset {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 0;
    transition: transform 0.15s, border-color 0.15s;
    outline: none;
  }

  .gsg-preset:hover { transform: scale(1.12); }
  .gsg-preset.active { border-color: var(--color-text); transform: scale(1.12); }

  .gsg-preset-sunset { background: linear-gradient(135deg, #f093fb, #f5576c); }
  .gsg-preset-ocean  { background: linear-gradient(135deg, #4facfe, #00f2fe); }
  .gsg-preset-forest { background: linear-gradient(135deg, #43e97b, #38f9d7); }
  .gsg-preset-night  { background: linear-gradient(135deg, #2d2b55, #0c0c1e); }
  .gsg-preset-aurora { background: linear-gradient(135deg, #667eea, #764ba2); }

  /* ── Preview ── */
  .gsg-section-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    display: block;
    margin-bottom: 0.5rem;
  }

  .gsg-preview-canvas {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 2.5rem 1.5rem;
    min-height: 180px;
    position: relative;
    overflow: hidden;
  }

  .gsg-card {
    position: relative;
    z-index: 1;
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 180px;
    transition: all 0.1s;
  }

  .gsg-card-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.7);
    margin-bottom: 0.25rem;
  }

  .gsg-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.92);
    letter-spacing: 0.01em;
  }

  .gsg-card-sub {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .gsg-card-btn {
    margin-top: 0.5rem;
    height: 24px;
    width: 80px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.25);
  }

  /* ── Output ── */
  .gsg-output-section { display: flex; flex-direction: column; gap: 0.4rem; }

  .gsg-output-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .gsg-pre {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    overflow-x: auto;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.7;
  }

