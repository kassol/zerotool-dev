---
// HashGeneratorTool — reusable widget, no props needed
---
<div>
  <div class="hg-wrap">
    <div class="hg-field">
      <label for="hg-input">Input Text</label>
      <textarea
        id="hg-input"
        placeholder="Enter text to hash..."
        spellcheck="false"
      ></textarea>
    </div>

    <div class="hg-actions">
      <button id="hg-hash" class="btn-primary">Generate Hashes</button>
      <button id="hg-clear" class="btn-ghost">Clear</button>
    </div>

    <div id="hg-status" class="hg-status" aria-live="polite"></div>

    <div id="hg-results" class="hg-results"></div>
  </div>

  <script is:inline>
    (function () {
      // Compact MD5 — public domain implementation
      function md5(str) {
        function safeAdd(x, y) { var lsw=(x&0xffff)+(y&0xffff); return (((x>>16)+(y>>16)+(lsw>>16))<<16)|(lsw&0xffff); }
        function bitRotateLeft(num, cnt) { return (num<<cnt)|(num>>>(32-cnt)); }
        function md5cmn(q,a,b,x,s,t) { return safeAdd(bitRotateLeft(safeAdd(safeAdd(a,q),safeAdd(x,t)),s),b); }
        function md5ff(a,b,c,d,x,s,t) { return md5cmn((b&c)|((~b)&d),a,b,x,s,t); }
        function md5gg(a,b,c,d,x,s,t) { return md5cmn((b&d)|(c&(~d)),a,b,x,s,t); }
        function md5hh(a,b,c,d,x,s,t) { return md5cmn(b^c^d,a,b,x,s,t); }
        function md5ii(a,b,c,d,x,s,t) { return md5cmn(c^(b|(~d)),a,b,x,s,t); }
        function str2rstr_utf8(input) {
          var output='',i=-1,x,y;
          while(++i<input.length){
            x=input.charCodeAt(i);
            if(x<=0x7f){output+=String.fromCharCode(x);}
            else if(x<=0x7ff){output+=String.fromCharCode(0xc0|(x>>>6),0x80|(x&0x3f));}
            else if(x<=0xd7ff||x>=0xe000){output+=String.fromCharCode(0xe0|(x>>>12),0x80|((x>>>6)&0x3f),0x80|(x&0x3f));}
            else{x=0x10000+(((x&0x3ff)<<10)|(input.charCodeAt(++i)&0x3ff));output+=String.fromCharCode(0xf0|(x>>>18),0x80|((x>>>12)&0x3f),0x80|((x>>>6)&0x3f),0x80|(x&0x3f));}
          }
          return output;
        }
        function rstr2binl(input) {
          var output=new Array(input.length>>2);
          for(var i=0;i<output.length;i++){output[i]=0;}
          for(var i=0;i<input.length*8;i+=8){output[i>>5]|=(input.charCodeAt(i/8)&0xff)<<(i%32);}
          return output;
        }
        function binl2rstr(input) {
          var output='';
          for(var i=0;i<input.length*32;i+=8){output+=String.fromCharCode((input[i>>5]>>>(i%32))&0xff);}
          return output;
        }
        function binlMD5(x,len) {
          x[len>>5]|=0x80<<(len%32);x[(((len+64)>>>9)<<4)+14]=len;
          var i,olda,oldb,oldc,oldd,a=1732584193,b=-271733879,c=-1732584194,d=271733878;
          for(i=0;i<x.length;i+=16){
            olda=a;oldb=b;oldc=c;oldd=d;
            a=md5ff(a,b,c,d,x[i],7,-680876936);d=md5ff(d,a,b,c,x[i+1],12,-389564586);c=md5ff(c,d,a,b,x[i+2],17,606105819);b=md5ff(b,c,d,a,x[i+3],22,-1044525330);
            a=md5ff(a,b,c,d,x[i+4],7,-176418897);d=md5ff(d,a,b,c,x[i+5],12,1200080426);c=md5ff(c,d,a,b,x[i+6],17,-1473231341);b=md5ff(b,c,d,a,x[i+7],22,-45705983);
            a=md5ff(a,b,c,d,x[i+8],7,1770035416);d=md5ff(d,a,b,c,x[i+9],12,-1958414417);c=md5ff(c,d,a,b,x[i+10],17,-42063);b=md5ff(b,c,d,a,x[i+11],22,-1990404162);
            a=md5ff(a,b,c,d,x[i+12],7,1804603682);d=md5ff(d,a,b,c,x[i+13],12,-40341101);c=md5ff(c,d,a,b,x[i+14],17,-1502002290);b=md5ff(b,c,d,a,x[i+15],22,1236535329);
            a=md5gg(a,b,c,d,x[i+1],5,-165796510);d=md5gg(d,a,b,c,x[i+6],9,-1069501632);c=md5gg(c,d,a,b,x[i+11],14,643717713);b=md5gg(b,c,d,a,x[i],20,-373897302);
            a=md5gg(a,b,c,d,x[i+5],5,-701558691);d=md5gg(d,a,b,c,x[i+10],9,38016083);c=md5gg(c,d,a,b,x[i+15],14,-660478335);b=md5gg(b,c,d,a,x[i+4],20,-405537848);
            a=md5gg(a,b,c,d,x[i+9],5,568446438);d=md5gg(d,a,b,c,x[i+14],9,-1019803690);c=md5gg(c,d,a,b,x[i+3],14,-187363961);b=md5gg(b,c,d,a,x[i+8],20,1163531501);
            a=md5gg(a,b,c,d,x[i+13],5,-1444681467);d=md5gg(d,a,b,c,x[i+2],9,-51403784);c=md5gg(c,d,a,b,x[i+7],14,1735328473);b=md5gg(b,c,d,a,x[i+12],20,-1926607734);
            a=md5hh(a,b,c,d,x[i+5],4,-378558);d=md5hh(d,a,b,c,x[i+8],11,-2022574463);c=md5hh(c,d,a,b,x[i+11],16,1839030562);b=md5hh(b,c,d,a,x[i+14],23,-35309556);
            a=md5hh(a,b,c,d,x[i+1],4,-1530992060);d=md5hh(d,a,b,c,x[i+4],11,1272893353);c=md5hh(c,d,a,b,x[i+7],16,-155497632);b=md5hh(b,c,d,a,x[i+10],23,-1094730640);
            a=md5hh(a,b,c,d,x[i+13],4,681279174);d=md5hh(d,a,b,c,x[i],11,-358537222);c=md5hh(c,d,a,b,x[i+3],16,-722521979);b=md5hh(b,c,d,a,x[i+6],23,76029189);
            a=md5hh(a,b,c,d,x[i+9],4,-640364487);d=md5hh(d,a,b,c,x[i+12],11,-421815835);c=md5hh(c,d,a,b,x[i+15],16,530742520);b=md5hh(b,c,d,a,x[i+2],23,-995338651);
            a=md5ii(a,b,c,d,x[i],6,-198630844);d=md5ii(d,a,b,c,x[i+7],10,1126891415);c=md5ii(c,d,a,b,x[i+14],15,-1416354905);b=md5ii(b,c,d,a,x[i+5],21,-57434055);
            a=md5ii(a,b,c,d,x[i+12],6,1700485571);d=md5ii(d,a,b,c,x[i+3],10,-1894986606);c=md5ii(c,d,a,b,x[i+10],15,-1051523);b=md5ii(b,c,d,a,x[i+1],21,-2054922799);
            a=md5ii(a,b,c,d,x[i+8],6,1873313359);d=md5ii(d,a,b,c,x[i+15],10,-30611744);c=md5ii(c,d,a,b,x[i+6],15,-1560198380);b=md5ii(b,c,d,a,x[i+13],21,1309151649);
            a=md5ii(a,b,c,d,x[i+4],6,-145523070);d=md5ii(d,a,b,c,x[i+11],10,-1120210379);c=md5ii(c,d,a,b,x[i+2],15,718787259);b=md5ii(b,c,d,a,x[i+9],21,-343485551);
            a=safeAdd(a,olda);b=safeAdd(b,oldb);c=safeAdd(c,oldc);d=safeAdd(d,oldd);
          }
          return [a,b,c,d];
        }
        function rstr2hex(input) {
          var hex='0123456789abcdef',output='';
          for(var i=0;i<input.length;i++){var x=input.charCodeAt(i);output+=hex.charAt((x>>>4)&0x0f)+hex.charAt(x&0x0f);}
          return output;
        }
        return rstr2hex(binl2rstr(binlMD5(rstr2binl(str2rstr_utf8(str)),str2rstr_utf8(str).length*8)));
      }

      async function sha(text, algo) {
        var enc = new TextEncoder();
        var buf = await crypto.subtle.digest(algo, enc.encode(text));
        return Array.from(new Uint8Array(buf)).map(function(b){ return ('0'+b.toString(16)).slice(-2); }).join('');
      }

      var inputEl = document.getElementById('hg-input');
      var statusEl = document.getElementById('hg-status');
      var resultsEl = document.getElementById('hg-results');

      function makeRow(label, value) {
        var row = document.createElement('div');
        row.className = 'hg-row';
        row.innerHTML = '<span class="hg-label">' + label + '</span><code class="hg-value" id="hg-val-' + label + '">' + value + '</code><button class="btn-copy" data-label="' + label + '">Copy</button>';
        return row;
      }

      document.getElementById('hg-hash').addEventListener('click', async function () {
        var text = inputEl.value;
        if (!text) {
          statusEl.textContent = 'Please enter some text.';
          statusEl.className = 'hg-status error';
          return;
        }
        statusEl.textContent = 'Hashing...';
        statusEl.className = 'hg-status';
        resultsEl.innerHTML = '';

        try {
          var md5val = md5(text);
          var sha1val = await sha(text, 'SHA-1');
          var sha256val = await sha(text, 'SHA-256');
          var sha384val = await sha(text, 'SHA-384');
          var sha512val = await sha(text, 'SHA-512');

          [
            ['MD5', md5val],
            ['SHA-1', sha1val],
            ['SHA-256', sha256val],
            ['SHA-384', sha384val],
            ['SHA-512', sha512val],
          ].forEach(function(pair) {
            resultsEl.appendChild(makeRow(pair[0], pair[1]));
          });

          statusEl.textContent = 'Hashes generated.';
          statusEl.className = 'hg-status success';
          window.trackTool && window.trackTool('hash_generator', 'generate');

          resultsEl.querySelectorAll('.btn-copy').forEach(function (btn) {
            btn.addEventListener('click', function () {
              var label = btn.getAttribute('data-label');
              var val = document.getElementById('hg-val-' + label).textContent;
              navigator.clipboard.writeText(val).then(function () {
                var prev = btn.textContent;
                btn.textContent = 'Copied!';
                setTimeout(function () { btn.textContent = prev; }, 1500);
              });
            });
          });
        } catch (e) {
          statusEl.textContent = 'Error: ' + e.message;
          statusEl.className = 'hg-status error';
        }
      });

      document.getElementById('hg-clear').addEventListener('click', function () {
        inputEl.value = '';
        resultsEl.innerHTML = '';
        statusEl.textContent = '';
        statusEl.className = 'hg-status';
      });
    })();
  </script>
</div>

<style>
  .hg-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .hg-field { display: flex; flex-direction: column; gap: 0.3rem; }

  .hg-field label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .hg-field textarea {
    width: 100%;
    min-height: 100px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .hg-field textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .hg-actions { display: flex; gap: 0.5rem; }

  .hg-status { font-size: 0.85rem; min-height: 1.2rem; }
  .hg-status.success { color: #057a55; }
  .hg-status.error { color: #c0392b; }

  .hg-results { display: flex; flex-direction: column; gap: 0.5rem; }

  .hg-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    flex-wrap: wrap;
  }

  .hg-label {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    min-width: 56px;
    letter-spacing: 0.04em;
  }

  .hg-value {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-text);
    word-break: break-all;
    min-width: 0;
  }

  @media (prefers-color-scheme: dark) {
    .hg-status.success { color: #34d399; }
    .hg-status.error { color: #f87171; }
  }
</style>
