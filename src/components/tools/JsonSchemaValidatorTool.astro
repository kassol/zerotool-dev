---
// JsonSchemaValidatorTool — validate JSON data against a JSON Schema (Draft-07 / Draft 2020-12)
---

<div>
  <div class="jsv-wrap"
    data-msg-paste=""
    data-msg-invalid-schema=""
    data-msg-invalid-data=""
    data-msg-valid=""
    data-msg-invalid=""
    data-msg-schema-error=""
  >

    <div class="jsv-toolbar">
      <label for="jsv-draft-select" class="jsv-label" data-i18n="schemaDraft">Schema Draft:</label>
      <select id="jsv-draft-select" class="jsv-select">
        <option value="07" selected>Draft-07 (most common)</option>
        <option value="2020">Draft 2020-12</option>
      </select>
      <button id="jsv-load-example" class="btn-ghost" type="button" data-i18n="loadExample">Load Example</button>
      <button id="jsv-validate" class="btn-primary" type="button" data-i18n="validate">Validate</button>
    </div>

    <div class="jsv-panels">
      <div class="jsv-panel">
        <label for="jsv-schema">
          <span data-i18n="jsonSchema">JSON Schema</span>
          <button id="jsv-clear-schema" class="btn-ghost btn-xs" type="button" data-i18n="clear">Clear</button>
        </label>
        <textarea id="jsv-schema" spellcheck="false" placeholder='{"type":"object","properties":{"name":{"type":"string"}}}' ></textarea>
      </div>
      <div class="jsv-panel">
        <label for="jsv-data">
          <span data-i18n="jsonData">JSON Data</span>
          <button id="jsv-clear-data" class="btn-ghost btn-xs" type="button" data-i18n="clear">Clear</button>
        </label>
        <textarea id="jsv-data" spellcheck="false" placeholder='{"name":"Alice"}'></textarea>
      </div>
    </div>

    <div id="jsv-status" class="jsv-status" aria-live="polite"></div>

    <div id="jsv-errors" class="jsv-errors" style="display:none"></div>

  </div>
</div>

<script is:inline>
  (function () {
    var STRINGS = {
      en: { schemaDraft: 'Schema Draft:', loadExample: 'Load Example', validate: 'Validate', jsonSchema: 'JSON Schema', jsonData: 'JSON Data', clear: 'Clear', msgPaste: 'Paste a JSON Schema and JSON Data, then click Validate.', msgInvalidSchema: 'Invalid JSON Schema: ', msgInvalidData: 'Invalid JSON Data: ', msgValid: 'Valid \u2014 JSON data matches the schema.', msgInvalid: 'Invalid \u2014 JSON data does not match the schema.', msgSchemaError: 'Schema compilation error: ' },
      zh: { schemaDraft: 'Schema 草案：', loadExample: '加载示例', validate: '验证', jsonSchema: 'JSON Schema', jsonData: 'JSON 数据', clear: '清除', msgPaste: '粘贴 JSON Schema 和 JSON 数据，然后点击验证。', msgInvalidSchema: '无效 JSON Schema：', msgInvalidData: '无效 JSON 数据：', msgValid: '有效 \u2014 JSON 数据符合 Schema。', msgInvalid: '无效 \u2014 JSON 数据不符合 Schema。', msgSchemaError: 'Schema 编译错误：' },
      ja: { schemaDraft: 'Schema ドラフト：', loadExample: '例を読み込む', validate: '検証', jsonSchema: 'JSON Schema', jsonData: 'JSON データ', clear: 'クリア', msgPaste: 'JSON Schema と JSON データを貼り付けて検証をクリックしてください。', msgInvalidSchema: '無効な JSON Schema：', msgInvalidData: '無効な JSON データ：', msgValid: '有効 \u2014 JSON データは Schema に適合します。', msgInvalid: '無効 \u2014 JSON データは Schema に適合しません。', msgSchemaError: 'Schema コンパイルエラー：' },
      ko: { schemaDraft: 'Schema 초안:', loadExample: '예제 불러오기', validate: '검증', jsonSchema: 'JSON Schema', jsonData: 'JSON 데이터', clear: '지우기', msgPaste: 'JSON Schema와 JSON 데이터를 붙여넣고 검증을 클릭하세요.', msgInvalidSchema: '유효하지 않은 JSON Schema: ', msgInvalidData: '유효하지 않은 JSON 데이터: ', msgValid: '유효 \u2014 JSON 데이터가 Schema에 적합합니다.', msgInvalid: '유효하지 않음 \u2014 JSON 데이터가 Schema에 적합하지 않습니다.', msgSchemaError: 'Schema 컴파일 오류: ' }
    };
    var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
    var t = STRINGS[pageLang] || STRINGS.en;
    document.querySelectorAll('.jsv-wrap [data-i18n]').forEach(function(el) {
      var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
    });
    var wrap = document.querySelector('.jsv-wrap');
    if (wrap) {
      wrap.dataset.msgPaste = t.msgPaste;
      wrap.dataset.msgInvalidSchema = t.msgInvalidSchema;
      wrap.dataset.msgInvalidData = t.msgInvalidData;
      wrap.dataset.msgValid = t.msgValid;
      wrap.dataset.msgInvalid = t.msgInvalid;
      wrap.dataset.msgSchemaError = t.msgSchemaError;
    }
  })();
</script>

<script>
  import Ajv from 'ajv';
  import Ajv2020 from 'ajv/dist/2020';

  const schemaEl  = document.getElementById('jsv-schema') as HTMLTextAreaElement;
  const dataEl    = document.getElementById('jsv-data') as HTMLTextAreaElement;
  const statusEl  = document.getElementById('jsv-status')!;
  const errorsEl  = document.getElementById('jsv-errors')!;
  const draftSel  = document.getElementById('jsv-draft-select') as HTMLSelectElement;
  const validateBtn  = document.getElementById('jsv-validate')!;
  const loadExBtn    = document.getElementById('jsv-load-example')!;
  const clearSchBtn  = document.getElementById('jsv-clear-schema')!;
  const clearDataBtn = document.getElementById('jsv-clear-data')!;

  const jsvWrap = document.querySelector('.jsv-wrap') as HTMLElement;
  const MSG_PASTE          = jsvWrap?.dataset.msgPaste          || 'Paste a JSON Schema and JSON Data, then click Validate.';
  const MSG_INVALID_SCHEMA = jsvWrap?.dataset.msgInvalidSchema  || 'Invalid JSON Schema: ';
  const MSG_INVALID_DATA   = jsvWrap?.dataset.msgInvalidData    || 'Invalid JSON Data: ';
  const MSG_VALID          = jsvWrap?.dataset.msgValid          || 'Valid \u2014 JSON data matches the schema.';
  const MSG_INVALID        = jsvWrap?.dataset.msgInvalid        || 'Invalid \u2014 JSON data does not match the schema.';
  const MSG_SCHEMA_ERROR   = jsvWrap?.dataset.msgSchemaError    || 'Schema compilation error: ';

  const EXAMPLE_SCHEMA = JSON.stringify({
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "User",
    "type": "object",
    "required": ["name", "age", "email"],
    "properties": {
      "name":  { "type": "string",  "minLength": 1 },
      "age":   { "type": "integer", "minimum": 0, "maximum": 120 },
      "email": { "type": "string",  "format": "email" },
      "role":  { "type": "string",  "enum": ["admin", "user", "guest"] }
    },
    "additionalProperties": false
  }, null, 2);

  const EXAMPLE_DATA = JSON.stringify({
    "name": "Alice",
    "age": 30,
    "email": "alice@example.com",
    "role": "admin"
  }, null, 2);

  const EXAMPLE_DATA_INVALID = JSON.stringify({
    "name": "",
    "age": -5,
    "email": "not-an-email",
    "role": "superuser",
    "extra": "not allowed"
  }, null, 2);

  function setStatus(msg: string, type: 'success' | 'error' | 'info' | '') {
    statusEl.textContent = msg;
    statusEl.className = 'jsv-status ' + type;
  }

  function escapeHtml(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function renderErrors(errors: any[]) {
    if (!errors || errors.length === 0) {
      errorsEl.style.display = 'none';
      return;
    }
    let html = `<div class="jsv-err-count">${errors.length} error${errors.length !== 1 ? 's' : ''} found</div>`;
    html += '<ul class="jsv-err-list">';
    for (const err of errors) {
      const path = err.instancePath || '(root)';
      const msg  = err.message || 'Validation failed';
      const extra = err.params ? Object.entries(err.params).map(([k, v]) => `${k}: ${JSON.stringify(v)}`).join(', ') : '';
      html += `<li class="jsv-err-item">`;
      html += `<span class="jsv-err-path">${escapeHtml(path)}</span> `;
      html += `<span class="jsv-err-msg">${escapeHtml(msg)}</span>`;
      if (extra) html += ` <span class="jsv-err-extra">(${escapeHtml(extra)})</span>`;
      html += `</li>`;
    }
    html += '</ul>';
    errorsEl.innerHTML = html;
    errorsEl.style.display = '';
  }

  function validate() {
    const schemaRaw = schemaEl.value.trim();
    const dataRaw   = dataEl.value.trim();

    if (!schemaRaw || !dataRaw) {
      setStatus(MSG_PASTE, '');
      errorsEl.style.display = 'none';
      return;
    }

    let schema: any, data: any;
    try {
      schema = JSON.parse(schemaRaw);
    } catch (e: any) {
      setStatus(MSG_INVALID_SCHEMA + e.message, 'error');
      errorsEl.style.display = 'none';
      return;
    }
    try {
      data = JSON.parse(dataRaw);
    } catch (e: any) {
      setStatus(MSG_INVALID_DATA + e.message, 'error');
      errorsEl.style.display = 'none';
      return;
    }

    const draft = draftSel.value;
    let ajv: any;
    try {
      if (draft === '2020') {
        ajv = new Ajv2020({ allErrors: true, strict: false });
      } else {
        ajv = new Ajv({ allErrors: true, strict: false });
      }
      const validateFn = ajv.compile(schema);
      const valid = validateFn(data);

      if (valid) {
        errorsEl.style.display = 'none';
        setStatus(MSG_VALID, 'success');
        window.trackTool?.('json-schema-validator', 'validate_success');
      } else {
        renderErrors(validateFn.errors ?? []);
        setStatus(MSG_INVALID, 'error');
        window.trackTool?.('json-schema-validator', 'validate_error');
      }
    } catch (e: any) {
      setStatus(MSG_SCHEMA_ERROR + e.message, 'error');
      errorsEl.style.display = 'none';
    }
  }

  validateBtn.addEventListener('click', validate);

  /* ── Real-time validate (debounced 300ms) ── */
  let _jsvTimer: ReturnType<typeof setTimeout> | null = null;
  function debouncedValidate() {
    if (_jsvTimer) clearTimeout(_jsvTimer);
    _jsvTimer = setTimeout(validate, 300);
  }
  schemaEl.addEventListener('input', debouncedValidate);
  dataEl.addEventListener('input', debouncedValidate);

  loadExBtn.addEventListener('click', () => {
    schemaEl.value = EXAMPLE_SCHEMA;
    dataEl.value   = EXAMPLE_DATA;
    setStatus('', '');
    errorsEl.style.display = 'none';
  });

  clearSchBtn.addEventListener('click', () => {
    schemaEl.value = '';
    if (!dataEl.value.trim()) {
      setStatus('', '');
      errorsEl.style.display = 'none';
    }
  });

  clearDataBtn.addEventListener('click', () => {
    dataEl.value = '';
    if (!schemaEl.value.trim()) {
      setStatus('', '');
      errorsEl.style.display = 'none';
    }
  });

  /* Ctrl/Cmd+Enter to validate from either panel */
  [schemaEl, dataEl].forEach(el => {
    el.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) validate();
    });
  });

  /* Pre-load example on first visit */
  if (!schemaEl.value.trim() && !dataEl.value.trim()) {
    schemaEl.value = EXAMPLE_SCHEMA;
    dataEl.value   = EXAMPLE_DATA;
  }
</script>

<style>
  .jsv-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .jsv-toolbar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .jsv-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .jsv-select {
    font-size: 0.82rem;
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    cursor: pointer;
  }

  .jsv-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .jsv-panels { grid-template-columns: 1fr; }
  }

  .jsv-panel { display: flex; flex-direction: column; gap: 0.35rem; }

  .jsv-panel label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .jsv-panel textarea {
    width: 100%;
    min-height: 220px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
    line-height: 1.5;
  }

  .jsv-panel textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .btn-xs { font-size: 0.75rem !important; padding: 0.2rem 0.5rem !important; }

  .jsv-status { font-size: 0.85rem; min-height: 1.2rem; }
  .jsv-status.success { color: #057a55; }
  .jsv-status.error   { color: #c0392b; }
  .jsv-status.info    { color: var(--color-text-secondary); }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .jsv-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .jsv-status.error   { color: #f87171; }
  }
  [data-theme="dark"] .jsv-status.success { color: #34d399; }
  [data-theme="dark"] .jsv-status.error   { color: #f87171; }

  /* Errors panel */
  .jsv-errors {
    border: 1px solid rgba(192, 57, 43, 0.35);
    border-left: 3px solid #c0392b;
    border-radius: var(--radius-sm);
    background: rgba(192, 57, 43, 0.04);
    padding: 0.65rem 1rem;
  }

  [data-theme="dark"] .jsv-errors {
    border-color: rgba(248, 113, 113, 0.3);
    border-left-color: #f87171;
    background: rgba(248, 113, 113, 0.06);
  }

  .jsv-err-count {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #c0392b;
    margin-bottom: 0.4rem;
  }

  [data-theme="dark"] .jsv-err-count { color: #f87171; }

  .jsv-err-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .jsv-err-item { font-size: 0.83rem; line-height: 1.4; }

  .jsv-err-path {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .jsv-err-msg { color: var(--color-text); }

  .jsv-err-extra {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }
</style>
