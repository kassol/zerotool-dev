---
// FaviconGeneratorTool — generates a complete favicon package (ICO + multi-size PNGs + manifest) from emoji, text, image, or SVG. 100% client-side via Canvas API.
---

<div>
  <div class="fg-wrap">

    <!-- Source tabs -->
    <div class="fg-tabs" role="tablist" aria-label="Source type">
      <button id="fg-tab-emoji" class="fg-tab fg-tab--active" role="tab" aria-selected="true" data-tab="emoji" data-i18n="tabEmoji">Emoji</button>
      <button id="fg-tab-text" class="fg-tab" role="tab" aria-selected="false" data-tab="text" data-i18n="tabText">Text</button>
      <button id="fg-tab-image" class="fg-tab" role="tab" aria-selected="false" data-tab="image" data-i18n="tabImage">Image</button>
      <button id="fg-tab-svg" class="fg-tab" role="tab" aria-selected="false" data-tab="svg" data-i18n="tabSvg">SVG</button>
    </div>

    <!-- Source panels -->
    <div class="fg-source">
      <!-- Emoji -->
      <div id="fg-panel-emoji" class="fg-panel" role="tabpanel">
        <div class="fg-emoji-row" id="fg-emoji-presets" role="group" aria-label="Common emoji">
          <button class="fg-emoji-btn" data-emoji="🚀" type="button" aria-label="Rocket">🚀</button>
          <button class="fg-emoji-btn" data-emoji="⚡" type="button" aria-label="Lightning">⚡</button>
          <button class="fg-emoji-btn" data-emoji="🔥" type="button" aria-label="Fire">🔥</button>
          <button class="fg-emoji-btn" data-emoji="🌟" type="button" aria-label="Star">🌟</button>
          <button class="fg-emoji-btn" data-emoji="✨" type="button" aria-label="Sparkles">✨</button>
          <button class="fg-emoji-btn" data-emoji="🎯" type="button" aria-label="Target">🎯</button>
          <button class="fg-emoji-btn" data-emoji="💡" type="button" aria-label="Bulb">💡</button>
          <button class="fg-emoji-btn" data-emoji="🛠️" type="button" aria-label="Tools">🛠️</button>
          <button class="fg-emoji-btn" data-emoji="📦" type="button" aria-label="Package">📦</button>
          <button class="fg-emoji-btn" data-emoji="🔧" type="button" aria-label="Wrench">🔧</button>
          <button class="fg-emoji-btn" data-emoji="🎨" type="button" aria-label="Palette">🎨</button>
          <button class="fg-emoji-btn" data-emoji="❤️" type="button" aria-label="Heart">❤️</button>
        </div>
        <div class="fg-field">
          <label for="fg-emoji-input" class="tool-label" data-i18n="emojiCustom">Or paste any emoji</label>
          <input type="text" id="fg-emoji-input" class="tool-input fg-emoji-custom" placeholder="🚀" maxlength="6" />
        </div>
      </div>

      <!-- Text -->
      <div id="fg-panel-text" class="fg-panel" role="tabpanel" hidden>
        <div class="fg-field">
          <label for="fg-text-input" class="tool-label" data-i18n="textChars">Characters (1–4)</label>
          <input type="text" id="fg-text-input" class="tool-input" placeholder="Z" maxlength="4" />
        </div>
        <div class="fg-row">
          <div class="fg-field">
            <label for="fg-text-font" class="tool-label" data-i18n="textFont">Font</label>
            <select id="fg-text-font" class="fg-select">
              <option value="system-ui">System UI</option>
              <option value="serif">Serif</option>
              <option value="monospace">Monospace</option>
              <option value="sans-serif">Sans Serif</option>
            </select>
          </div>
          <div class="fg-field">
            <label for="fg-text-color" class="tool-label" data-i18n="textColor">Text color</label>
            <input type="color" id="fg-text-color" class="fg-color-input" value="#ffffff" />
          </div>
          <div class="fg-field">
            <label for="fg-text-weight" class="tool-label" data-i18n="textWeight">Weight</label>
            <select id="fg-text-weight" class="fg-select">
              <option value="700">Bold</option>
              <option value="500">Medium</option>
              <option value="400">Regular</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Image -->
      <div id="fg-panel-image" class="fg-panel" role="tabpanel" hidden>
        <div id="fg-drop" class="fg-drop" role="button" tabindex="0" aria-label="Drop image here or click to select">
          <div class="fg-drop-inner">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
            </svg>
            <p class="fg-drop-text"><span data-i18n="dropImageA">Drop PNG / JPG / SVG, or </span><strong data-i18n="dropImageB">click to select</strong></p>
            <p class="fg-hint" data-i18n="imageHint">Up to 10 MB. Square images work best.</p>
          </div>
          <input type="file" id="fg-file" accept="image/png,image/jpeg,image/svg+xml,.png,.jpg,.jpeg,.svg" class="fg-file-input" />
        </div>
        <div id="fg-image-info" class="fg-image-info" hidden></div>
      </div>

      <!-- SVG -->
      <div id="fg-panel-svg" class="fg-panel" role="tabpanel" hidden>
        <div class="fg-field">
          <label for="fg-svg-input" class="tool-label" data-i18n="pasteSvgCode">Paste SVG markup</label>
          <textarea id="fg-svg-input" class="tool-textarea" rows="6" placeholder='<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">...</svg>' spellcheck="false"></textarea>
        </div>
      </div>
    </div>

    <!-- Configuration -->
    <div class="fg-config">
      <div class="fg-config-row">
        <div class="fg-field">
          <span class="tool-label" data-i18n="background">Background</span>
          <div class="fg-control-row">
            <label class="fg-radio">
              <input type="radio" name="fg-bg" value="transparent" checked />
              <span data-i18n="bgTransparent">Transparent</span>
            </label>
            <label class="fg-radio">
              <input type="radio" name="fg-bg" value="color" />
              <span data-i18n="bgColor">Color</span>
            </label>
            <input type="color" id="fg-bg-color" class="fg-color-input" value="#0ea5e9" disabled />
          </div>
        </div>
      </div>

      <div class="fg-config-row">
        <div class="fg-field">
          <span class="tool-label" data-i18n="shape">Shape</span>
          <div class="fg-control-row">
            <label class="fg-radio"><input type="radio" name="fg-shape" value="square" checked /><span data-i18n="shapeSquare">Square</span></label>
            <label class="fg-radio"><input type="radio" name="fg-shape" value="rounded" /><span data-i18n="shapeRounded">Rounded</span></label>
            <label class="fg-radio"><input type="radio" name="fg-shape" value="circle" /><span data-i18n="shapeCircle">Circle</span></label>
          </div>
        </div>

        <div class="fg-field fg-padding-field">
          <label for="fg-padding" class="tool-label">
            <span data-i18n="padding">Padding</span>
            <span id="fg-padding-val" class="fg-padding-val">8%</span>
          </label>
          <input type="range" id="fg-padding" min="0" max="30" value="8" step="1" />
        </div>

        <div class="fg-field">
          <label for="fg-theme-color" class="tool-label" data-i18n="themeColor">Theme color</label>
          <input type="color" id="fg-theme-color" class="fg-color-input" value="#ffffff" />
        </div>
      </div>
    </div>

    <!-- Live preview -->
    <div class="fg-preview-section">
      <div class="fg-preview-header">
        <span class="fg-preview-label" data-i18n="livePreview">Live preview</span>
        <span class="fg-preview-hint" data-i18n="previewHint">16 / 32 / 64 / 180 px</span>
      </div>
      <div class="fg-preview-grid">
        <div class="fg-preview-cell"><div class="fg-prev-frame" style="--p:16px"><canvas id="fg-prev-16" width="16" height="16" aria-label="16 px favicon preview"></canvas></div><span class="fg-prev-label">16 px</span></div>
        <div class="fg-preview-cell"><div class="fg-prev-frame" style="--p:32px"><canvas id="fg-prev-32" width="32" height="32"></canvas></div><span class="fg-prev-label">32 px</span></div>
        <div class="fg-preview-cell"><div class="fg-prev-frame" style="--p:64px"><canvas id="fg-prev-64" width="64" height="64"></canvas></div><span class="fg-prev-label">64 px</span></div>
        <div class="fg-preview-cell"><div class="fg-prev-frame" style="--p:96px"><canvas id="fg-prev-180" width="180" height="180"></canvas></div><span class="fg-prev-label">180 px</span></div>
      </div>
    </div>

    <!-- Generate -->
    <div class="fg-actions">
      <button id="fg-generate" class="btn-primary" disabled data-i18n="generatePackage">Generate package</button>
    </div>

    <!-- Result -->
    <div id="fg-result" class="fg-result" hidden>
      <div class="fg-result-header">
        <span class="fg-result-label" data-i18n="resultLabel">Package ready</span>
        <span id="fg-result-stats" class="fg-result-stats"></span>
      </div>
      <ul id="fg-file-list" class="fg-file-list"></ul>

      <div class="fg-snippet">
        <div class="fg-snippet-header">
          <span class="tool-label" data-i18n="snippetLabel">HTML snippet</span>
          <button id="fg-copy-snippet" class="btn-copy" data-i18n="copy">Copy</button>
        </div>
        <pre id="fg-snippet-code" class="fg-snippet-code"></pre>
      </div>

      <div class="fg-result-actions">
        <button id="fg-download-zip" class="btn-primary" data-i18n="downloadZip">Download ZIP</button>
      </div>
    </div>

    <div id="fg-status" class="tool-status" aria-live="polite"></div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: {
          tabEmoji: 'Emoji', tabText: 'Text', tabImage: 'Image', tabSvg: 'SVG',
          emojiCustom: 'Or paste any emoji',
          textChars: 'Characters (1–4)', textFont: 'Font', textColor: 'Text color', textWeight: 'Weight',
          dropImageA: 'Drop PNG / JPG / SVG, or ', dropImageB: 'click to select',
          imageHint: 'Up to 10 MB. Square images work best.',
          pasteSvgCode: 'Paste SVG markup',
          background: 'Background', bgTransparent: 'Transparent', bgColor: 'Color',
          shape: 'Shape', shapeSquare: 'Square', shapeRounded: 'Rounded', shapeCircle: 'Circle',
          padding: 'Padding', themeColor: 'Theme color',
          livePreview: 'Live preview', previewHint: '16 / 32 / 64 / 180 px',
          generatePackage: 'Generate package',
          resultLabel: 'Package ready', snippetLabel: 'HTML snippet',
          copy: 'Copy', copied: 'Copied', downloadZip: 'Download ZIP',
          provideSource: 'Provide a source first.',
          fileTooLarge: 'File too large (max 10 MB).',
          invalidFile: 'Please select a PNG, JPG, or SVG file.',
          invalidSvg: 'SVG markup is invalid.',
          svgTainted: 'SVG references external resources. Inline images first.',
          generated: 'Generated 9 files',
          generating: 'Generating package…',
          imageLoaded: 'Image loaded.',
          svgLoaded: 'SVG loaded.',
          emojiFontWarn: 'Your system has no color emoji font. Output may render as an empty box.'
        },
        zh: {
          tabEmoji: 'Emoji', tabText: '文字', tabImage: '图片', tabSvg: 'SVG',
          emojiCustom: '或粘贴任意 emoji',
          textChars: '字符（1–4 个）', textFont: '字体', textColor: '文字颜色', textWeight: '字重',
          dropImageA: '拖入 PNG / JPG / SVG，或 ', dropImageB: '点击选择',
          imageHint: '最大 10 MB，方形图片效果最佳。',
          pasteSvgCode: '粘贴 SVG 代码',
          background: '背景', bgTransparent: '透明', bgColor: '颜色',
          shape: '形状', shapeSquare: '方形', shapeRounded: '圆角', shapeCircle: '圆形',
          padding: '内边距', themeColor: '主题色',
          livePreview: '实时预览', previewHint: '16 / 32 / 64 / 180 px',
          generatePackage: '生成图标包',
          resultLabel: '图标包已就绪', snippetLabel: 'HTML 代码片段',
          copy: '复制', copied: '已复制', downloadZip: '下载 ZIP',
          provideSource: '请先提供素材。',
          fileTooLarge: '文件过大（最大 10 MB）。',
          invalidFile: '请选择 PNG、JPG 或 SVG 文件。',
          invalidSvg: 'SVG 代码无效。',
          svgTainted: 'SVG 引用了外部资源，请先内联图片。',
          generated: '已生成 9 个文件',
          generating: '正在生成图标包…',
          imageLoaded: '图片已加载。',
          svgLoaded: 'SVG 已加载。',
          emojiFontWarn: '系统未安装彩色 emoji 字体，输出可能为空框。'
        },
        ja: {
          tabEmoji: '絵文字', tabText: 'テキスト', tabImage: '画像', tabSvg: 'SVG',
          emojiCustom: 'または任意の絵文字を貼り付け',
          textChars: '文字 (1–4)', textFont: 'フォント', textColor: '文字色', textWeight: '太さ',
          dropImageA: 'PNG / JPG / SVG をドロップ、または ', dropImageB: 'クリックして選択',
          imageHint: '最大 10 MB。正方形画像が最適。',
          pasteSvgCode: 'SVG マークアップを貼り付け',
          background: '背景', bgTransparent: '透過', bgColor: 'カラー',
          shape: '形状', shapeSquare: '正方形', shapeRounded: '角丸', shapeCircle: '円形',
          padding: '余白', themeColor: 'テーマカラー',
          livePreview: 'ライブプレビュー', previewHint: '16 / 32 / 64 / 180 px',
          generatePackage: 'パッケージ生成',
          resultLabel: 'パッケージ完成', snippetLabel: 'HTML スニペット',
          copy: 'コピー', copied: 'コピー済み', downloadZip: 'ZIP をダウンロード',
          provideSource: '先に素材を指定してください。',
          fileTooLarge: 'ファイルが大きすぎます（最大 10 MB）。',
          invalidFile: 'PNG・JPG・SVG ファイルを選択してください。',
          invalidSvg: 'SVG マークアップが無効です。',
          svgTainted: 'SVG が外部リソースを参照しています。画像をインライン化してください。',
          generated: '9 個のファイルを生成しました',
          generating: 'パッケージを生成中…',
          imageLoaded: '画像を読み込みました。',
          svgLoaded: 'SVG を読み込みました。',
          emojiFontWarn: 'カラー絵文字フォントがありません。空の枠で表示される可能性があります。'
        },
        ko: {
          tabEmoji: '이모지', tabText: '텍스트', tabImage: '이미지', tabSvg: 'SVG',
          emojiCustom: '또는 이모지 붙여넣기',
          textChars: '문자 (1–4)', textFont: '글꼴', textColor: '글자 색', textWeight: '굵기',
          dropImageA: 'PNG / JPG / SVG 끌어다 놓기 또는 ', dropImageB: '클릭하여 선택',
          imageHint: '최대 10 MB. 정사각형 이미지가 가장 좋음.',
          pasteSvgCode: 'SVG 마크업 붙여넣기',
          background: '배경', bgTransparent: '투명', bgColor: '색상',
          shape: '모양', shapeSquare: '정사각형', shapeRounded: '둥근 모서리', shapeCircle: '원형',
          padding: '여백', themeColor: '테마 색상',
          livePreview: '실시간 미리보기', previewHint: '16 / 32 / 64 / 180 px',
          generatePackage: '패키지 생성',
          resultLabel: '패키지 준비 완료', snippetLabel: 'HTML 스니펫',
          copy: '복사', copied: '복사됨', downloadZip: 'ZIP 다운로드',
          provideSource: '먼저 소스를 제공하세요.',
          fileTooLarge: '파일이 너무 큽니다 (최대 10 MB).',
          invalidFile: 'PNG, JPG, SVG 파일을 선택하세요.',
          invalidSvg: 'SVG 마크업이 잘못되었습니다.',
          svgTainted: 'SVG가 외부 리소스를 참조합니다. 이미지를 인라인하세요.',
          generated: '9개 파일이 생성되었습니다',
          generating: '패키지를 생성 중…',
          imageLoaded: '이미지를 불러왔습니다.',
          svgLoaded: 'SVG를 불러왔습니다.',
          emojiFontWarn: '컬러 이모지 글꼴이 없습니다. 빈 상자로 표시될 수 있습니다.'
        }
      };
      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;
      document.querySelectorAll('[data-i18n]').forEach(function (el) {
        var key = el.getAttribute('data-i18n');
        if (t[key]) el.textContent = t[key];
      });

      /* ── State ── */
      var state = {
        sourceType: 'emoji',  // 'emoji' | 'text' | 'image' | 'svg'
        emoji: '🚀',
        text: '',
        textFont: 'system-ui',
        textColor: '#ffffff',
        textWeight: '700',
        image: null,             // HTMLImageElement
        svgImg: null,            // HTMLImageElement (rendered from SVG)
        bgMode: 'transparent',
        bgColor: '#0ea5e9',
        shape: 'square',
        padding: 8,              // %
        themeColor: '#ffffff'
      };

      var TARGET_SIZES = [16, 32, 48, 64, 96, 128, 180, 192, 512];
      var ICO_SIZES = [16, 32, 48];
      var lastZipUrl = '';

      /* ── DOM refs ── */
      var $ = function (id) { return document.getElementById(id); };
      var statusEl = $('fg-status');
      var generateBtn = $('fg-generate');
      var resultEl = $('fg-result');
      var fileListEl = $('fg-file-list');
      var snippetCodeEl = $('fg-snippet-code');
      var resultStatsEl = $('fg-result-stats');

      function setStatus(msg, level) {
        statusEl.textContent = msg || '';
        statusEl.className = 'tool-status ' + (level || 'none');
      }

      /* ── Tab switching ── */
      var tabs = ['emoji', 'text', 'image', 'svg'];
      tabs.forEach(function (name) {
        $('fg-tab-' + name).addEventListener('click', function () {
          state.sourceType = name;
          tabs.forEach(function (n) {
            var btn = $('fg-tab-' + n);
            var pnl = $('fg-panel-' + n);
            var active = (n === name);
            btn.classList.toggle('fg-tab--active', active);
            btn.setAttribute('aria-selected', active ? 'true' : 'false');
            pnl.hidden = !active;
          });
          updateAll();
        });
      });

      /* ── Emoji handlers ── */
      document.querySelectorAll('.fg-emoji-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          state.emoji = btn.getAttribute('data-emoji');
          $('fg-emoji-input').value = state.emoji;
          document.querySelectorAll('.fg-emoji-btn').forEach(function (b) { b.classList.remove('fg-emoji-btn--active'); });
          btn.classList.add('fg-emoji-btn--active');
          updateAll();
        });
      });
      $('fg-emoji-input').addEventListener('input', function () {
        var v = this.value.trim();
        state.emoji = v;
        document.querySelectorAll('.fg-emoji-btn').forEach(function (b) { b.classList.remove('fg-emoji-btn--active'); });
        updateAll();
      });

      /* ── Text handlers ── */
      $('fg-text-input').addEventListener('input', function () { state.text = this.value; updateAll(); });
      $('fg-text-font').addEventListener('change', function () { state.textFont = this.value; updateAll(); });
      $('fg-text-color').addEventListener('input', function () { state.textColor = this.value; updateAll(); });
      $('fg-text-weight').addEventListener('change', function () { state.textWeight = this.value; updateAll(); });

      /* ── Image handlers ── */
      var dropEl = $('fg-drop');
      var fileInput = $('fg-file');
      var imageInfo = $('fg-image-info');

      dropEl.addEventListener('click', function (e) {
        if (e.target !== fileInput) fileInput.click();
      });
      dropEl.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
      });
      dropEl.addEventListener('dragover', function (e) { e.preventDefault(); dropEl.classList.add('drag-over'); });
      dropEl.addEventListener('dragleave', function () { dropEl.classList.remove('drag-over'); });
      dropEl.addEventListener('drop', function (e) {
        e.preventDefault();
        dropEl.classList.remove('drag-over');
        var f = e.dataTransfer.files && e.dataTransfer.files[0];
        if (f) handleFile(f);
      });
      fileInput.addEventListener('change', function () {
        if (this.files && this.files[0]) handleFile(this.files[0]);
      });

      function handleFile(file) {
        if (file.size > 10 * 1024 * 1024) { setStatus(t.fileTooLarge, 'error'); return; }
        var ok = /\.(png|jpe?g|svg)$/i.test(file.name) || /^image\/(png|jpeg|svg\+xml)$/.test(file.type);
        if (!ok) { setStatus(t.invalidFile, 'error'); return; }
        var reader = new FileReader();
        var isSvg = /svg/i.test(file.type) || /\.svg$/i.test(file.name);
        reader.onload = function (ev) {
          if (isSvg) {
            loadSvgFromString(ev.target.result, function (img) {
              if (!img) return;
              state.image = img;
              showImageInfo(file, img);
              setStatus(t.imageLoaded, 'success');
              updateAll();
            });
          } else {
            var url = URL.createObjectURL(file);
            var im = new Image();
            im.onload = function () {
              state.image = im;
              showImageInfo(file, im);
              setStatus(t.imageLoaded, 'success');
              updateAll();
            };
            im.onerror = function () {
              URL.revokeObjectURL(url);
              setStatus(t.invalidFile, 'error');
            };
            im.src = url;
          }
        };
        reader.onerror = function () { setStatus(t.invalidFile, 'error'); };
        if (isSvg) reader.readAsText(file);
        else reader.readAsDataURL(file);
      }

      function showImageInfo(file, img) {
        var w = img.naturalWidth || img.width;
        var h = img.naturalHeight || img.height;
        var kb = (file.size / 1024).toFixed(1) + ' KB';
        imageInfo.textContent = file.name + ' · ' + w + ' × ' + h + ' · ' + kb;
        imageInfo.hidden = false;
      }

      /* ── SVG handlers ── */
      var svgInput = $('fg-svg-input');
      var svgDebounce;
      svgInput.addEventListener('input', function () {
        clearTimeout(svgDebounce);
        var v = svgInput.value;
        svgDebounce = setTimeout(function () {
          if (!v.trim()) { state.svgImg = null; updateAll(); return; }
          if (!/<svg[\s>]/i.test(v)) { setStatus(t.invalidSvg, 'error'); return; }
          loadSvgFromString(v, function (img) {
            if (!img) return;
            state.svgImg = img;
            setStatus(t.svgLoaded, 'success');
            updateAll();
          });
        }, 300);
      });

