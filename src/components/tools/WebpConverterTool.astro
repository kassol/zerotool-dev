---
// WebpConverterTool — converts images to/from WebP using Canvas API
---

<div>
  <div class="wc-wrap">
    <!-- Mode selector -->
    <div class="wc-mode-row">
      <label class="wc-mode-label">
        <input type="radio" name="wc-mode" value="to-webp" id="wc-mode-to" checked />
        PNG / JPG / GIF → WebP
      </label>
      <label class="wc-mode-label">
        <input type="radio" name="wc-mode" value="from-webp" id="wc-mode-from" />
        WebP → PNG
      </label>
    </div>

    <!-- Quality slider (to-webp only) -->
    <div class="wc-quality-row" id="wc-quality-row">
      <label for="wc-quality" class="wc-quality-label">
        Quality: <strong id="wc-quality-val">85</strong>
      </label>
      <input type="range" id="wc-quality" min="0" max="100" value="85" step="1" />
    </div>

    <!-- Drop zone -->
    <div id="wc-drop" class="wc-drop" role="button" tabindex="0" aria-label="Drop images here or click to select">
      <div class="wc-drop-inner">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
        </svg>
        <p>Drop images here, or <strong>click to select</strong></p>
        <p class="wc-hint" id="wc-hint">Supports PNG, JPG, GIF</p>
      </div>
      <input type="file" id="wc-file" accept="image/png,image/jpeg,image/gif,image/webp" multiple class="wc-file-input" aria-label="Select image files" />
    </div>

    <!-- Results list -->
    <div id="wc-results" class="wc-results" hidden></div>

    <!-- Actions -->
    <div class="wc-actions" id="wc-actions" hidden>
      <button id="wc-download-all" class="btn-primary" type="button">Download All (ZIP)</button>
      <button id="wc-clear" class="btn-ghost" type="button">Clear</button>
    </div>

    <div id="wc-status" class="wc-status" aria-live="polite"></div>
  </div>

  <script is:inline>
    (function () {
      var dropEl    = document.getElementById('wc-drop');
      var fileInput = document.getElementById('wc-file');
      var resultsEl = document.getElementById('wc-results');
      var actionsEl = document.getElementById('wc-actions');
      var statusEl  = document.getElementById('wc-status');
      var qualityRow = document.getElementById('wc-quality-row');
      var qualityInput = document.getElementById('wc-quality');
      var qualityVal   = document.getElementById('wc-quality-val');
      var hintEl    = document.getElementById('wc-hint');
      var modeRadios = document.querySelectorAll('input[name="wc-mode"]');
      var dlAllBtn  = document.getElementById('wc-download-all');

      var convertedItems = []; // [{name, blob}]

      /* ── Helpers ── */
      function getMode() {
        for (var i = 0; i < modeRadios.length; i++) {
          if (modeRadios[i].checked) return modeRadios[i].value;
        }
        return 'to-webp';
      }

      function formatBytes(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1048576).toFixed(2) + ' MB';
      }

      function esc(s) {
        var d = document.createElement('span');
        d.textContent = s;
        return d.innerHTML;
      }

      function setStatus(msg, isError) {
        statusEl.textContent = msg;
        statusEl.className = 'wc-status ' + (isError ? 'error' : 'success');
      }

      /* ── Mode change ── */
      function onModeChange() {
        var mode = getMode();
        if (mode === 'to-webp') {
          qualityRow.hidden = false;
          fileInput.accept = 'image/png,image/jpeg,image/gif';
          hintEl.textContent = 'Supports PNG, JPG, GIF';
        } else {
          qualityRow.hidden = true;
          fileInput.accept = 'image/webp';
          hintEl.textContent = 'Supports WebP';
        }
      }

      for (var ri = 0; ri < modeRadios.length; ri++) {
        modeRadios[ri].addEventListener('change', onModeChange);
      }

      /* ── Quality slider ── */
      qualityInput.addEventListener('input', function () {
        qualityVal.textContent = qualityInput.value;
      });

      /* ── Convert one file ── */
      function convertFile(file, idx) {
        return new Promise(function (resolve) {
          var mode = getMode();
          var quality = parseInt(qualityInput.value, 10) / 100;

          // Validate type
          var validTo = ['image/png', 'image/jpeg', 'image/gif'];
          var validFrom = ['image/webp'];
          if (mode === 'to-webp' && validTo.indexOf(file.type) === -1) {
            resolve({ ok: false, name: file.name, error: 'Not a supported format (PNG/JPG/GIF)' });
            return;
          }
          if (mode === 'from-webp' && validFrom.indexOf(file.type) === -1) {
            resolve({ ok: false, name: file.name, error: 'Not a WebP file' });
            return;
          }

          var url = URL.createObjectURL(file);
          var img = new Image();
          img.onload = function () {
            var canvas = document.createElement('canvas');
            canvas.width  = img.naturalWidth;
            canvas.height = img.naturalHeight;
            var ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0);
            URL.revokeObjectURL(url);

            var outMime, outExt, outName;
            if (mode === 'to-webp') {
              outMime = 'image/webp';
              outExt  = '.webp';
              outName = file.name.replace(/\.[^.]+$/, '') + '.webp';
            } else {
              outMime = 'image/png';
              outExt  = '.png';
              outName = file.name.replace(/\.[^.]+$/, '') + '.png';
            }

            canvas.toBlob(function (blob) {
              if (!blob) {
                resolve({ ok: false, name: file.name, error: 'Conversion failed (canvas.toBlob returned null)' });
                return;
              }
              var thumbUrl = URL.createObjectURL(blob);
              resolve({
                ok: true,
                idx: idx,
                origName: file.name,
                outName: outName,
                origSize: file.size,
                outSize: blob.size,
                blob: blob,
                thumbUrl: thumbUrl,
                origUrl: URL.createObjectURL(file),
              });
            }, outMime, mode === 'to-webp' ? quality : undefined);
          };
          img.onerror = function () {
            URL.revokeObjectURL(url);
            resolve({ ok: false, name: file.name, error: 'Failed to load image' });
          };
          img.src = url;
        });
      }

      /* ── Render result card ── */
      function renderCard(item) {
        var card = document.createElement('div');
        card.className = 'wc-card';

        var ratio = ((1 - item.outSize / item.origSize) * 100).toFixed(1);
        var saved = item.outSize < item.origSize;
        var ratioHtml = saved
          ? '<span class="wc-saved">−' + ratio + '%</span>'
          : '<span class="wc-larger">+' + Math.abs(ratio) + '%</span>';

        card.innerHTML =
          '<img class="wc-thumb" src="' + esc(item.thumbUrl) + '" alt="' + esc(item.outName) + '" />' +
          '<div class="wc-card-info">' +
            '<div class="wc-card-name" title="' + esc(item.outName) + '">' + esc(item.outName) + '</div>' +
            '<div class="wc-card-sizes">' +
              esc(formatBytes(item.origSize)) + ' → ' + esc(formatBytes(item.outSize)) + ' ' + ratioHtml +
            '</div>' +
          '</div>' +
          '<a class="btn-primary wc-dl" href="#" download="' + esc(item.outName) + '">Download</a>';

        // Set download href
        var dlLink = card.querySelector('.wc-dl');
        dlLink.href = URL.createObjectURL(item.blob);

        resultsEl.appendChild(card);
      }

      /* ── Process files ── */
      function processFiles(files) {
        if (!files || files.length === 0) return;

        // Reset
        convertedItems = [];
        resultsEl.innerHTML = '';
        resultsEl.hidden = false;
        actionsEl.hidden = true;
        statusEl.textContent = 'Converting…';
        statusEl.className = 'wc-status';

        var promises = [];
        for (var i = 0; i < files.length; i++) {
          promises.push(convertFile(files[i], i));
        }

        Promise.all(promises).then(function (results) {
          var ok = 0, fail = 0;
          for (var j = 0; j < results.length; j++) {
            var r = results[j];
            if (r.ok) {
              ok++;
              convertedItems.push({ name: r.outName, blob: r.blob });
              renderCard(r);
            } else {
              fail++;
              var errEl = document.createElement('div');
              errEl.className = 'wc-card wc-card-error';
              errEl.textContent = esc(r.name) + ': ' + r.error;
              resultsEl.appendChild(errEl);
            }
          }

          if (ok > 0) {
            actionsEl.hidden = false;
            dlAllBtn.hidden = ok < 2;
          }

          var msg = ok + ' file(s) converted';
          if (fail > 0) msg += ', ' + fail + ' failed';
          setStatus(msg, fail > 0 && ok === 0);

          window.trackTool && window.trackTool('webp-converter', 'convert');
        });
      }

      /* ── File input / drag & drop ── */
      dropEl.addEventListener('click', function (e) {
        if (e.target !== fileInput) fileInput.click();
      });

      dropEl.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
      });

      fileInput.addEventListener('change', function () {
        if (this.files && this.files.length) processFiles(this.files);
      });

      dropEl.addEventListener('dragover', function (e) {
        e.preventDefault();
        dropEl.classList.add('drag-over');
      });

      dropEl.addEventListener('dragleave', function () {
        dropEl.classList.remove('drag-over');
      });

      dropEl.addEventListener('drop', function (e) {
        e.preventDefault();
        dropEl.classList.remove('drag-over');
        if (e.dataTransfer.files && e.dataTransfer.files.length) {
          processFiles(e.dataTransfer.files);
        }
      });

      /* ── Download all as ZIP (using Blob concatenation trick; no JSZip dependency) ── */
      dlAllBtn.addEventListener('click', function () {
        if (convertedItems.length === 0) return;
        // For single file, already have individual download; this handles multi.
        // Simple approach: download each sequentially via anchor clicks.
        for (var k = 0; k < convertedItems.length; k++) {
          (function (item) {
            var a = document.createElement('a');
            a.href = URL.createObjectURL(item.blob);
            a.download = item.name;
            document.body.appendChild(a);
            a.click();
            setTimeout(function () {
              URL.revokeObjectURL(a.href);
              document.body.removeChild(a);
            }, 1000);
          })(convertedItems[k]);
        }
      });

      /* ── Clear ── */
      document.getElementById('wc-clear').addEventListener('click', function () {
        fileInput.value = '';
        convertedItems = [];
        resultsEl.innerHTML = '';
        resultsEl.hidden = true;
        actionsEl.hidden = true;
        statusEl.textContent = '';
        statusEl.className = 'wc-status';
      });
    })();
  </script>
</div>

<style>
  .wc-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  /* Mode selector */
  .wc-mode-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.88rem;
  }

  .wc-mode-label {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    cursor: pointer;
    color: var(--color-text-secondary);
  }

  .wc-mode-label input[type="radio"] { accent-color: var(--color-primary); }

  /* Quality row */
  .wc-quality-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .wc-quality-label { white-space: nowrap; min-width: 90px; }

  .wc-quality-row input[type="range"] {
    flex: 1;
    accent-color: var(--color-primary);
    cursor: pointer;
  }

  /* Drop zone */
  .wc-drop {
    position: relative;
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-sm);
    padding: 2rem 1rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    background: var(--color-bg-secondary);
  }

  .wc-drop:hover,
  .wc-drop.drag-over {
    border-color: var(--color-primary);
    background: var(--color-bg);
  }

  .wc-drop-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
    pointer-events: none;
  }

  .wc-drop-inner p { margin: 0; font-size: 0.95rem; }
  .wc-hint { font-size: 0.8rem; opacity: 0.7; }

  .wc-file-input {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
  }

  /* Results */
  .wc-results {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .wc-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
  }

  .wc-card-error {
    color: #c0392b;
    font-size: 0.82rem;
    border-color: #f5c6cb;
    background: #fff5f5;
  }

  .wc-thumb {
    width: 52px;
    height: 52px;
    object-fit: cover;
    border-radius: calc(var(--radius-sm) / 2);
    border: 1px solid var(--color-border);
    flex-shrink: 0;
    background: repeating-conic-gradient(#ccc 0% 25%, transparent 0% 50%) 0 0 / 12px 12px;
  }

  .wc-card-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .wc-card-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .wc-card-sizes {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
  }

  .wc-saved { color: #057a55; font-weight: 600; }
  .wc-larger { color: #b45309; font-weight: 600; }

  .wc-dl {
    flex-shrink: 0;
    font-size: 0.8rem;
    padding: 0.3rem 0.75rem;
    text-decoration: none;
  }

  /* Actions */
  .wc-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  /* Status */
  .wc-status { font-size: 0.85rem; min-height: 1.2rem; }
  .wc-status.success { color: #057a55; }
  .wc-status.error   { color: #c0392b; }

  /* Dark mode */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .wc-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .wc-status.error   { color: #f87171; }
    :root:not([data-theme="light"]) .wc-saved          { color: #34d399; }
    :root:not([data-theme="light"]) .wc-larger         { color: #fbbf24; }
    :root:not([data-theme="light"]) .wc-card-error     { background: #2d1515; border-color: #7f2020; color: #f87171; }
    :root:not([data-theme="light"]) .wc-thumb {
      background: repeating-conic-gradient(#444 0% 25%, #2a2a2a 0% 50%) 0 0 / 12px 12px;
    }
  }
  [data-theme="dark"] .wc-status.success { color: #34d399; }
  [data-theme="dark"] .wc-status.error   { color: #f87171; }
  [data-theme="dark"] .wc-saved          { color: #34d399; }
  [data-theme="dark"] .wc-larger         { color: #fbbf24; }
  [data-theme="dark"] .wc-card-error     { background: #2d1515; border-color: #7f2020; color: #f87171; }
  [data-theme="dark"] .wc-thumb {
    background: repeating-conic-gradient(#444 0% 25%, #2a2a2a 0% 50%) 0 0 / 12px 12px;
  }
</style>
