---
// No props needed — tool widget is language-independent
---

<div>
  <div class="tc-wrap">
    <div class="tc-row">
      <label for="tc-input" data-i18n="inputText">Input Text</label>
      <textarea
        id="tc-input"
        data-i18n-ph="inputPlaceholder"
        placeholder="Enter your text here..."
        rows="4"
        spellcheck="false"
      ></textarea>
    </div>

    <div class="tc-cases" id="tc-cases">
      <!-- Populated by JS -->
    </div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: { inputText: 'Input Text', inputPlaceholder: 'Enter your text here...', copy: 'Copy', copied: 'Copied!' },
        zh: { inputText: '输入文本', inputPlaceholder: '在此输入文本...', copy: '复制', copied: '已复制！' },
        ja: { inputText: '入力テキスト', inputPlaceholder: 'テキストを入力してください...', copy: 'コピー', copied: 'コピー済み！' },
        ko: { inputText: '입력 텍스트', inputPlaceholder: '텍스트를 입력하세요...', copy: '복사', copied: '복사됨!' }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });
      document.querySelectorAll('[data-i18n-ph]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-ph'); if (t[key]) el.placeholder = t[key];
      });

      var inputEl = document.getElementById('tc-input');
      var casesEl = document.getElementById('tc-cases');

      var converters = [
        {
          id: 'upper',
          label: 'UPPER CASE',
          fn: function (s) { return s.toUpperCase(); },
        },
        {
          id: 'lower',
          label: 'lower case',
          fn: function (s) { return s.toLowerCase(); },
        },
        {
          id: 'title',
          label: 'Title Case',
          fn: function (s) {
            return s.replace(/\w\S*/g, function (w) {
              return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
            });
          },
        },
        {
          id: 'sentence',
          label: 'Sentence case',
          fn: function (s) {
            return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase();
          },
        },
        {
          id: 'camel',
          label: 'camelCase',
          fn: function (s) {
            return s
              .toLowerCase()
              .replace(/[^a-z0-9]+(.)/g, function (_, c) { return c.toUpperCase(); });
          },
        },
        {
          id: 'pascal',
          label: 'PascalCase',
          fn: function (s) {
            return s
              .toLowerCase()
              .replace(/(^|[^a-z0-9]+)(.)/g, function (_, __, c) { return c.toUpperCase(); });
          },
        },
        {
          id: 'kebab',
          label: 'kebab-case',
          fn: function (s) {
            return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
          },
        },
        {
          id: 'snake',
          label: 'snake_case',
          fn: function (s) {
            return s.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
          },
        },
        {
          id: 'constant',
          label: 'CONSTANT_CASE',
          fn: function (s) {
            return s.toUpperCase().replace(/[^A-Z0-9]+/g, '_').replace(/^_|_$/g, '');
          },
        },
      ];

      // Build output rows
      converters.forEach(function (c) {
        var row = document.createElement('div');
        row.className = 'tc-output-row';

        var lbl = document.createElement('span');
        lbl.className = 'tc-case-label';
        lbl.textContent = c.label;

        var out = document.createElement('input');
        out.type = 'text';
        out.id = 'tc-out-' + c.id;
        out.readOnly = true;
        out.className = 'tc-case-output';
        out.placeholder = c.fn('hello world');

        var btn = document.createElement('button');
        btn.className = 'btn-copy';
        btn.textContent = t.copy;
        btn.addEventListener('click', function () {
          if (!out.value) return;
          navigator.clipboard.writeText(out.value).then(function () {
            btn.textContent = t.copied;
            setTimeout(function () { btn.textContent = t.copy; }, 1500);
          });
          window.trackTool && window.trackTool('text_case', 'copy_' + c.id);
        });

        row.appendChild(lbl);
        row.appendChild(out);
        row.appendChild(btn);
        casesEl.appendChild(row);
      });

      function convert(text) {
        converters.forEach(function (c) {
          document.getElementById('tc-out-' + c.id).value = text ? c.fn(text) : '';
        });
      }

      inputEl.addEventListener('input', function () {
        convert(inputEl.value);
      });
    })();
  </script>
</div>

<style is:global>
  .tc-wrap { display: flex; flex-direction: column; gap: 1rem; }

  .tc-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tc-row label {
    color: var(--color-text-secondary);
    font-size: 0.82rem;
    font-weight: 760;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .tc-row textarea {
    width: 100%;
    min-height: 160px;
    font-family: var(--font-sans);
    font-size: 1rem;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
    line-height: 1.6;
  }

  .tc-row textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background: var(--color-surface);
    box-shadow: 0 0 0 4px var(--color-primary-light);
  }

  .tc-cases {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 270px), 1fr));
    gap: 0.8rem;
  }

  .tc-output-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.65rem;
    align-items: start;
    min-height: 112px;
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    padding: 0.85rem;
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
  }

  .tc-case-label {
    grid-column: 1;
    grid-row: 1;
    align-self: center;
    overflow: hidden;
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 760;
    letter-spacing: 0.02em;
    line-height: 1.3;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tc-case-output {
    grid-column: 1 / -1;
    grid-row: 2;
    width: 100%;
    min-height: 44px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
    min-width: 0;
  }

  .tc-output-row .btn-copy {
    grid-column: 2;
    grid-row: 1;
    justify-self: end;
    align-self: center;
    min-width: 72px;
  }

  @media (max-width: 500px) {
    .tc-cases {
      grid-template-columns: 1fr;
    }
  }
</style>
