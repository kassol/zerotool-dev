---
// No props needed — tool widget is language-independent
---

<div>
  <div class="tc-wrap">
    <div class="tc-row">
      <label for="tc-input" data-i18n="inputText">Input Text</label>
      <textarea
        id="tc-input"
        data-i18n-ph="inputPlaceholder"
        placeholder="Enter your text here..."
        rows="4"
        spellcheck="false"
      ></textarea>
    </div>

    <div class="tc-cases" id="tc-cases">
      <!-- Populated by JS -->
    </div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: { inputText: 'Input Text', inputPlaceholder: 'Enter your text here...', copy: 'Copy', copied: 'Copied!' },
        zh: { inputText: '输入文本', inputPlaceholder: '在此输入文本...', copy: '复制', copied: '已复制！' },
        ja: { inputText: '入力テキスト', inputPlaceholder: 'テキストを入力してください...', copy: 'コピー', copied: 'コピー済み！' },
        ko: { inputText: '입력 텍스트', inputPlaceholder: '텍스트를 입력하세요...', copy: '복사', copied: '복사됨!' }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });
      document.querySelectorAll('[data-i18n-ph]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-ph'); if (t[key]) el.placeholder = t[key];
      });

      var inputEl = document.getElementById('tc-input');
      var casesEl = document.getElementById('tc-cases');

      var converters = [
        {
          id: 'upper',
          label: 'UPPER CASE',
          fn: function (s) { return s.toUpperCase(); },
        },
        {
          id: 'lower',
          label: 'lower case',
          fn: function (s) { return s.toLowerCase(); },
        },
        {
          id: 'title',
          label: 'Title Case',
          fn: function (s) {
            return s.replace(/\w\S*/g, function (w) {
              return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();
            });
          },
        },
        {
          id: 'sentence',
          label: 'Sentence case',
          fn: function (s) {
            return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase();
          },
        },
        {
          id: 'camel',
          label: 'camelCase',
          fn: function (s) {
            return s
              .toLowerCase()
              .replace(/[^a-z0-9]+(.)/g, function (_, c) { return c.toUpperCase(); });
          },
        },
        {
          id: 'pascal',
          label: 'PascalCase',
          fn: function (s) {
            return s
              .toLowerCase()
              .replace(/(^|[^a-z0-9]+)(.)/g, function (_, __, c) { return c.toUpperCase(); });
          },
        },
        {
          id: 'kebab',
          label: 'kebab-case',
          fn: function (s) {
            return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
          },
        },
        {
          id: 'snake',
          label: 'snake_case',
          fn: function (s) {
            return s.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
          },
        },
        {
          id: 'constant',
          label: 'CONSTANT_CASE',
          fn: function (s) {
            return s.toUpperCase().replace(/[^A-Z0-9]+/g, '_').replace(/^_|_$/g, '');
          },
        },
      ];

      // Build output rows
      converters.forEach(function (c) {
        var row = document.createElement('div');
        row.className = 'tc-output-row';

        var lbl = document.createElement('span');
        lbl.className = 'tc-case-label';
        lbl.textContent = c.label;

        var out = document.createElement('input');
        out.type = 'text';
        out.id = 'tc-out-' + c.id;
        out.readOnly = true;
        out.className = 'tc-case-output';
        out.placeholder = c.fn('hello world');

        var btn = document.createElement('button');
        btn.className = 'btn-copy';
        btn.textContent = t.copy;
        btn.addEventListener('click', function () {
          if (!out.value) return;
          navigator.clipboard.writeText(out.value).then(function () {
            btn.textContent = t.copied;
            setTimeout(function () { btn.textContent = t.copy; }, 1500);
          });
          window.trackTool && window.trackTool('text_case', 'copy_' + c.id);
        });

        row.appendChild(lbl);
        row.appendChild(out);
        row.appendChild(btn);
        casesEl.appendChild(row);
      });

      function convert(text) {
        converters.forEach(function (c) {
          document.getElementById('tc-out-' + c.id).value = text ? c.fn(text) : '';
        });
      }

      inputEl.addEventListener('input', function () {
        convert(inputEl.value);
      });
    })();
  </script>
</div>

<style>
  .tc-wrap { display: flex; flex-direction: column; gap: 1rem; }

  .tc-row { display: flex; flex-direction: column; gap: 0.4rem; }

  .tc-row label { font-size: 0.85rem; font-weight: 600; color: var(--color-text-secondary); }

  .tc-row textarea {
    width: 100%;
    font-family: inherit;
    font-size: 0.95rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .tc-row textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .tc-cases { display: flex; flex-direction: column; gap: 0.5rem; }

  .tc-output-row {
    display: grid;
    grid-template-columns: 130px 1fr auto;
    gap: 0.5rem;
    align-items: center;
  }

  .tc-case-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    font-family: monospace;
    white-space: nowrap;
  }

  .tc-case-output {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: 5px;
    background: var(--color-bg-secondary);
    color: var(--color-text);
    min-width: 0;
  }

  @media (max-width: 500px) {
    .tc-output-row { grid-template-columns: 110px 1fr auto; }
  }
</style>
