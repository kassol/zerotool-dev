---
// IbanValidatorParserTool — IBAN (ISO 13616) validator + BBAN parser.
// 100% client-side: mod-97 over BigInt + an inlined SWIFT IBAN Registry snapshot.
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;
---

<div>
  <div class="ivp-wrap">
    <div class="ivp-input-section">
      <label for="ivp-input" class="tool-label">
        <span data-i18n="inputLabel">Enter an IBAN</span>
      </label>
      <input
        id="ivp-input"
        class="tool-input ivp-input"
        type="text"
        placeholder="GB82 WEST 1234 5698 7654 32"
        data-i18n-placeholder="placeholder"
        spellcheck="false"
        autocomplete="off"
        autocapitalize="characters"
        autocorrect="off"
        maxlength="60"
      />
    </div>

    <div class="ivp-actions">
      <button id="ivp-validate" class="btn-primary" type="button" data-i18n="validate">Validate</button>
      <details class="ivp-example-wrap">
        <summary class="btn-ghost ivp-example-summary" data-i18n="loadExample">Load Example</summary>
        <div class="ivp-example-list" role="listbox"></div>
      </details>
      <button id="ivp-clear" class="btn-ghost" type="button" data-i18n="clear">Clear</button>
    </div>

    <div id="ivp-status" class="tool-status none" aria-live="polite"></div>

    <div id="ivp-results" class="ivp-results" hidden></div>
  </div>

