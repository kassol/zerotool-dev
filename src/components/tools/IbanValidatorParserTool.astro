      // ── Field labels ───────────────────────────────────────────────────
      var FIELD_LABEL_KEYS = {
        bank: 'fieldBank', branch: 'fieldBranch', account: 'fieldAccount',
        check: 'fieldCheck', check2: 'fieldCheck2', type: 'fieldType',
        holder: 'fieldHolder', currency: 'fieldCurrency', id: 'fieldId',
        kennitala: 'fieldKennitala', reserved: 'fieldReserved', owner: 'fieldOwner'
      };
      function fieldLabel(role) {
        var key = FIELD_LABEL_KEYS[role];
        return (key && t[key]) ? t[key] : role;
      }
      function typeName(type) {
        if (type === 'n') return t.typeN;
        if (type === 'a') return t.typeA;
        return t.typeC;
      }

      // ── Normalisation ─────────────────────────────────────────────────
      function normalise(raw) {
        // Strip every code point that is not A-Z or 0-9 (uppercase letters and
        // digits). This drops spaces, hyphens, dots, NBSP, zero-width chars, etc.
        return String(raw || '').toUpperCase().replace(/[^A-Z0-9]/g, '');
      }

      function flagEmoji(cc) {
        if (!/^[A-Z]{2}$/.test(cc)) return '';
        return String.fromCodePoint(0x1F1E6 + cc.charCodeAt(0) - 65) +
               String.fromCodePoint(0x1F1E6 + cc.charCodeAt(1) - 65);
      }

      // ── mod 97 over a numeric string (avoids BigInt incompatibility risks). ──
      function mod97(numericStr) {
        // Use BigInt where available; otherwise fall back to chunked remainder.
        if (typeof BigInt === 'function') {
          try { return Number(BigInt(numericStr) % 97n); } catch (e) {}
        }
        var rem = 0;
        for (var i = 0; i < numericStr.length; i++) {
          rem = (rem * 10 + (numericStr.charCodeAt(i) - 48)) % 97;
        }
        return rem;
      }

      function toNumeric(s) {
        // Move first 4 chars to the end and replace letters with 10..35.
        var rearranged = s.slice(4) + s.slice(0, 4);
        var out = '';
        for (var i = 0; i < rearranged.length; i++) {
          var ch = rearranged.charCodeAt(i);
          if (ch >= 48 && ch <= 57) out += rearranged.charAt(i);
          else if (ch >= 65 && ch <= 90) out += (ch - 55).toString();
          else return null;
        }
        return out;
      }

      function bbanTypeOk(ch, type) {
        if (type === 'n') return ch >= '0' && ch <= '9';
        if (type === 'a') return ch >= 'A' && ch <= 'Z';
        return (ch >= '0' && ch <= '9') || (ch >= 'A' && ch <= 'Z');
      }

      function splitBban(bban, fields) {
        var parts = [];
        var pos = 0;
        for (var i = 0; i < fields.length; i++) {
          var role = fields[i][0], len = fields[i][1], type = fields[i][2];
          var chunk = bban.substr(pos, len);
          for (var j = 0; j < chunk.length; j++) {
            if (!bbanTypeOk(chunk.charAt(j), type)) {
              return { error: { pos: pos + j + 5, type: type } };
            }
          }
          parts.push({ role: role, value: chunk });
          pos += len;
        }
        return { parts: parts };
      }

      function printFormat(s) {
        return s.replace(/(.{4})/g, '$1 ').trim();
      }

      // ── Validation orchestrator ───────────────────────────────────────
      function validate(raw) {
        if (raw.length > 200) return { ok: false, error: t.errLong };
        var s = normalise(raw);
        if (!s) return { empty: true };
        if (!/^[A-Z]{2}[0-9]{2}[A-Z0-9]+$/.test(s)) return { ok: false, error: t.errFormat };

        var cc = s.slice(0, 2);
        var reg = REG[cc];
        if (!reg) return { ok: false, error: t.errCountry.replace('{cc}', cc) };

        if (s.length !== reg.len) {
          return { ok: false, error: t.errLength
            .replace('{country}', reg.name)
            .replace('{exp}', String(reg.len))
            .replace('{got}', String(s.length)) };
        }

        var numeric = toNumeric(s);
        if (!numeric || mod97(numeric) !== 1) {
          return { ok: false, error: t.errChecksum };
        }

        var bban = s.slice(4);
        var split = splitBban(bban, reg.fields);
        var bbanError = null;
        if (split.error) {
          bbanError = t.errBbanType
            .replace('{pos}', String(split.error.pos))
            .replace('{type}', typeName(split.error.type));
        }

        return {
          ok: true,
          machine: s,
          cc: cc,
          country: reg.name,
          checkDigits: s.slice(2, 4),
          length: s.length,
          expectedLength: reg.len,
          flag: flagEmoji(cc),
          bban: bban,
          parts: split.parts || [],
          bbanError: bbanError
        };
      }

      // ── Rendering ─────────────────────────────────────────────────────
      function escapeHtml(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function renderRow(label, valueHtml, copy) {
        var copyAttr = copy ? ' data-copy="' + escapeHtml(copy) + '"' : '';
        var copyBtn = copy
          ? '<button class="btn-copy ivp-copy" type="button"' + copyAttr + '>' + escapeHtml(t.copy) + '</button>'
          : '';
        return '<div class="tool-result-row ivp-row">' +
          '<span class="tool-result-label ivp-row-label">' + escapeHtml(label) + '</span>' +
          '<span class="tool-result-value ivp-row-value">' + valueHtml + '</span>' +
          copyBtn + '</div>';
      }

      function renderCard(title, body) {
        return '<section class="ivp-card">' +
          '<h3 class="ivp-card-title">' + escapeHtml(title) + '</h3>' +
          '<div class="ivp-card-body">' + body + '</div></section>';
      }

      function render(result) {
        var html = '';

        // Status card
        var resultChip = '<span class="ivp-tag ivp-tag-valid">' + escapeHtml(t.tagValid) + '</span>';
        var countryLine = '<span class="ivp-flag">' + result.flag + '</span> ' +
          '<span class="ivp-country">' + escapeHtml(result.country) + '</span> ' +
          '<span class="ivp-country-code">(' + escapeHtml(result.cc) + ')</span>';
        var lengthLine = t.lengthExpected
          .replace('{got}', String(result.length))
          .replace('{exp}', String(result.expectedLength))
          .replace('{country}', escapeHtml(result.cc));

        var statusBody =
          renderRow(t.rowResult, resultChip) +
          renderRow(t.rowCountry, countryLine) +
          renderRow(t.rowCheckDigits, '<span class="ivp-mono">' + escapeHtml(result.checkDigits) + '</span>') +
          renderRow(t.rowLength, escapeHtml(lengthLine));
        html += renderCard(t.sectionStatus, statusBody);

        // BBAN components card (when split is available)
        if (result.parts && result.parts.length && !result.bbanError) {
          var bbanBody = result.parts.map(function (p) {
            return renderRow(fieldLabel(p.role), '<span class="ivp-mono">' + escapeHtml(p.value) + '</span>', p.value);
          }).join('');
          html += renderCard(t.sectionBban, bbanBody);
        }

        // Formats card
        var print = printFormat(result.machine);
        var formatsBody =
          renderRow(t.rowPrint, '<span class="ivp-mono">' + escapeHtml(print) + '</span>', print) +
          renderRow(t.rowMachine, '<span class="ivp-mono">' + escapeHtml(result.machine) + '</span>', result.machine) +
          renderRow(t.rowBbanOnly, '<span class="ivp-mono">' + escapeHtml(result.bban) + '</span>', result.bban);
        html += renderCard(t.sectionFormats, formatsBody);

        return html;
      }

      function renderInvalid(message) {
        var statusBody =
          renderRow(t.rowResult, '<span class="ivp-tag ivp-tag-invalid">' + escapeHtml(t.tagInvalid) + '</span>') +
          renderRow('—', escapeHtml(message));
        return renderCard(t.sectionStatus, statusBody);
      }

      // ── State & wiring ───────────────────────────────────────────────
      var inputEl = document.getElementById('ivp-input');
      var statusEl = document.getElementById('ivp-status');
      var resultsEl = document.getElementById('ivp-results');
      var btnValidate = document.getElementById('ivp-validate');
      var btnClear = document.getElementById('ivp-clear');
      var exampleWrap = document.querySelector('.ivp-example-wrap');
      var exampleList = document.querySelector('.ivp-example-list');

      function setStatus(msg, type) {
        statusEl.textContent = msg || '';
        statusEl.className = 'tool-status ' + (type || 'none');
      }

      function show(result) {
        if (result.empty) {
          resultsEl.hidden = true;
          resultsEl.innerHTML = '';
          setStatus(t.statusEmpty, 'none');
          return;
        }
        if (!result.ok) {
          resultsEl.innerHTML = renderInvalid(result.error);
          resultsEl.hidden = false;
          setStatus(result.error, 'error');
          return;
        }
        resultsEl.innerHTML = render(result);
        resultsEl.hidden = false;
        if (result.bbanError) {
          setStatus(t.okBbanUnavailable + ' — ' + result.bbanError, 'info');
        } else if (!result.parts.length) {
          setStatus(t.okBbanUnavailable, 'info');
        } else {
          setStatus(t.okValid, 'success');
        }
        wireCopyButtons();
        if (window.trackTool) window.trackTool('iban-validator-parser', 'validate');
      }

      function runValidate() {
        show(validate(inputEl.value));
      }

      function wireCopyButtons() {
        resultsEl.querySelectorAll('.ivp-copy').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var v = btn.getAttribute('data-copy') || '';
            if (!v || !navigator.clipboard) return;
            navigator.clipboard.writeText(v).then(function () {
              var original = btn.textContent;
              btn.classList.add('copied');
              btn.textContent = t.copied;
              setTimeout(function () { btn.classList.remove('copied'); btn.textContent = original; }, 1400);
            }).catch(function () {});
          });
        });
      }

      function buildExampleList() {
        EXAMPLES.forEach(function (ex) {
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'ivp-example-item';
          btn.innerHTML =
            '<span class="ivp-example-flag">' + flagEmoji(ex.cc) + '</span>' +
            '<span class="ivp-example-cc">' + escapeHtml(ex.cc) + '</span>' +
            '<span class="ivp-example-iban">' + escapeHtml(ex.iban) + '</span>';
          btn.addEventListener('click', function () {
            inputEl.value = ex.iban;
            if (exampleWrap) exampleWrap.removeAttribute('open');
            runValidate();
            persist();
          });
          exampleList.appendChild(btn);
        });
      }

      btnValidate.addEventListener('click', runValidate);
      btnClear.addEventListener('click', function () {
        inputEl.value = '';
        resultsEl.hidden = true;
        resultsEl.innerHTML = '';
        setStatus('', 'none');
        if (window.ztPersist) {
          try { window.ztPersist.clear('iban-validator-parser'); } catch (e) {}
        }
      });

      inputEl.addEventListener('input', function () {
        // Live validate on input (cheap; mod 97 is sub-millisecond).
        runValidate();
        persist();
      });
      inputEl.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); runValidate(); }
      });

      function persist() {
        if (window.ztPersist) {
          try { window.ztPersist.save('iban-validator-parser', inputEl.value); } catch (e) {}
        }
      }
      if (window.ztPersist) {
        try {
          var saved = window.ztPersist.load('iban-validator-parser');
          if (saved && typeof saved === 'string') {
            inputEl.value = saved;
            runValidate();
          }
        } catch (e) {}
      }

      buildExampleList();
    })();
  </script>

  <style is:global>
    .ivp-wrap {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .ivp-input-section {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .ivp-input {
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .ivp-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .ivp-example-wrap {
      position: relative;
    }
    .ivp-example-summary {
      list-style: none;
      cursor: pointer;
    }
    .ivp-example-summary::-webkit-details-marker { display: none; }
    .ivp-example-summary::after {
      content: '▾';
      margin-left: 0.35rem;
      font-size: 0.78rem;
      opacity: 0.65;
    }
    .ivp-example-wrap[open] .ivp-example-summary::after {
      content: '▴';
    }
    .ivp-example-list {
      display: none;
      position: absolute;
      top: calc(100% + 0.4rem);
      left: 0;
      min-width: 18rem;
      max-width: min(90vw, 28rem);
      max-height: 22rem;
      overflow-y: auto;
      padding: 0.4rem;
      background: var(--color-surface);
      border-radius: var(--radius-md);
      box-shadow: inset 0 0 0 1px var(--color-border-soft), var(--shadow-card);
      z-index: 12;
      flex-direction: column;
      gap: 0.25rem;
    }
    .ivp-example-wrap[open] .ivp-example-list {
      display: flex;
    }
    .ivp-example-item {
      display: grid;
      grid-template-columns: 1.6rem 2rem 1fr;
      align-items: center;
      gap: 0.55rem;
      padding: 0.45rem 0.6rem;
      border: 0;
      border-radius: var(--radius-sm);
      background: transparent;
      color: var(--color-text);
      font: inherit;
      text-align: left;
      cursor: pointer;
      transition: background-color var(--transition-fast);
    }
    @media (hover: hover) {
      .ivp-example-item:hover {
        background: var(--color-bg-secondary);
      }
    }
    .ivp-example-flag { font-size: 1.05rem; line-height: 1; }
    .ivp-example-cc {
      font-size: 0.78rem;
      font-weight: 700;
      color: var(--color-text-secondary);
      letter-spacing: 0.04em;
    }
    .ivp-example-iban {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--color-text);
      word-break: break-all;
    }

    .ivp-results {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    @media (min-width: 780px) {
      .ivp-results {
        grid-template-columns: 1fr 1fr;
      }
      /* Status card spans full width; BBAN + Formats sit side-by-side. */
      .ivp-card:first-child {
        grid-column: 1 / -1;
      }
    }
    .ivp-card {
      background: var(--color-surface);
      border-radius: var(--radius-lg);
      padding: 0.9rem 1rem;
      box-shadow: inset 0 0 0 1px var(--color-border-soft), var(--shadow-card);
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      min-width: 0;
    }
    .ivp-card-title {
      margin: 0;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-primary);
    }
    .ivp-card-body {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      min-width: 0;
    }
    .ivp-row {
      gap: 0.7rem;
    }
    .ivp-row-label {
      min-width: 8.5rem;
      flex: 0 0 auto;
    }
    .ivp-row-value {
      flex: 1 1 auto;
      min-width: 0;
      word-break: break-all;
      overflow-wrap: anywhere;
    }
    .ivp-mono {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      letter-spacing: 0.02em;
    }
    .ivp-flag {
      font-size: 1.08rem;
      line-height: 1;
      margin-right: 0.1rem;
    }
    .ivp-country {
      font-weight: 700;
    }
    .ivp-country-code {
      color: var(--color-text-muted);
      margin-left: 0.2rem;
      font-size: 0.85rem;
    }
    .ivp-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.2rem 0.7rem;
      border-radius: var(--radius-pill);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      box-shadow: inset 0 0 0 1px color-mix(in oklch, currentColor 35%, transparent);
      background: color-mix(in oklch, currentColor 14%, transparent);
    }
    .ivp-tag-valid { color: var(--color-success); }
    .ivp-tag-invalid { color: var(--color-danger); }
    .ivp-copy {
      flex: 0 0 auto;
    }

    @media (max-width: 640px) {
      .ivp-row-label {
        min-width: 0;
        flex: 0 0 100%;
      }
      .ivp-example-list {
        min-width: min(90vw, 20rem);
      }
    }
  </style>
</div>
