---
// No props — widget is language-aware via document.documentElement.lang
---

<div>
  <div class="kce-wrap">
    <div
      id="kce-pad"
      class="kce-pad"
      tabindex="0"
      role="application"
      aria-label="Keyboard event capture pad"
    >
      <div class="kce-pad-prompt" id="kce-pad-prompt" data-i18n="prompt">
        Click here, then press any key
      </div>
      <div class="kce-pad-display" id="kce-pad-display" aria-live="polite">
        <span class="kce-pad-glyph" id="kce-pad-glyph">⌨</span>
        <span class="kce-pad-key" id="kce-pad-key"></span>
      </div>
      <div class="kce-pad-meta" id="kce-pad-meta">
        <span class="kce-pad-count" id="kce-pad-count">0</span>
        <span class="kce-pad-count-label" data-i18n="countLabel">keys captured</span>
      </div>
    </div>

    <div class="kce-mobile-fallback" id="kce-mobile-fallback" hidden>
      <div class="kce-mobile-note" data-i18n="mobileNote">
        Physical keyboard events differ on mobile. Use a desktop browser for full signal, or type a
        single character below for a partial readout.
      </div>
      <input
        id="kce-mobile-input"
        class="tool-input"
        type="text"
        maxlength="1"
        autocapitalize="none"
        autocomplete="off"
        spellcheck="false"
      />
    </div>

    <section class="kce-section" aria-labelledby="kce-section-event">
      <h3 id="kce-section-event" class="kce-section-title" data-i18n="eventProps">
        Event properties
      </h3>
      <div class="kce-grid">
        <div class="kce-row">
          <span class="kce-row-label">event.key</span>
          <code class="kce-row-value" id="kce-key">—</code>
        </div>
        <div class="kce-row">
          <span class="kce-row-label">event.code</span>
          <code class="kce-row-value" id="kce-code">—</code>
        </div>
        <div class="kce-row">
          <span class="kce-row-label">keyCode <em data-i18n="deprecated">(deprecated)</em></span>
          <code class="kce-row-value" id="kce-keycode">—</code>
        </div>
        <div class="kce-row">
          <span class="kce-row-label">which <em data-i18n="deprecated">(deprecated)</em></span>
          <code class="kce-row-value" id="kce-which">—</code>
        </div>
        <div class="kce-row">
          <span class="kce-row-label">charCode <em data-i18n="deprecated">(deprecated)</em></span>
          <code class="kce-row-value" id="kce-charcode">—</code>
        </div>
        <div class="kce-row">
          <span class="kce-row-label">location</span>
          <code class="kce-row-value" id="kce-location">—</code>
        </div>
        <div class="kce-row">
          <span class="kce-row-label">repeat</span>
          <code class="kce-row-value" id="kce-repeat">—</code>
        </div>
        <div class="kce-row">
          <span class="kce-row-label">isComposing</span>
          <code class="kce-row-value" id="kce-composing">—</code>
        </div>
      </div>
    </section>

    <section class="kce-section" aria-labelledby="kce-section-mod">
      <h3 id="kce-section-mod" class="kce-section-title" data-i18n="modifiers">
        Modifier keys
      </h3>
      <div class="kce-mods" id="kce-mods">
        <span class="kce-mod" data-mod="shift">Shift</span>
        <span class="kce-mod" data-mod="ctrl">Ctrl</span>
        <span class="kce-mod" data-mod="alt">Alt</span>
        <span class="kce-mod" data-mod="meta">Meta</span>
      </div>
    </section>

    <section class="kce-section" aria-labelledby="kce-section-snippet">
      <div class="kce-snippet-header">
        <h3 id="kce-section-snippet" class="kce-section-title" data-i18n="snippet">
          Ready-to-copy JS snippet
        </h3>
        <button id="kce-copy" class="btn-copy" type="button" data-i18n="copy">Copy</button>
      </div>
      <pre class="kce-snippet"><code id="kce-snippet-code"></code></pre>
    </section>

    <section class="kce-section" aria-labelledby="kce-section-history">
      <div class="kce-history-header">
        <h3 id="kce-section-history" class="kce-section-title" data-i18n="recentKeys">
          Recent keys
        </h3>
        <button id="kce-clear" class="btn-ghost" type="button" data-i18n="clear">Clear</button>
      </div>
      <div class="kce-history" id="kce-history" aria-live="polite"></div>
    </section>

    <div id="kce-status" class="tool-status" aria-live="polite"></div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: {
          prompt: 'Click here, then press any key',
          countLabel: 'keys captured',
          eventProps: 'Event properties',
          modifiers: 'Modifier keys',
          snippet: 'Ready-to-copy JS snippet',
          recentKeys: 'Recent keys',
          deprecated: '(deprecated)',
          copy: 'Copy',
          copied: 'Snippet copied to clipboard.',
          copyFailed: 'Copy failed.',
          clear: 'Clear',
          padFocused: 'Pad focused. Press any key.',
          padBlurred: 'Pad blurred. Click the pad to resume capture.',
          mobileNote:
            'Physical keyboard events differ on mobile. Use a desktop browser for full signal, or type a single character below for a partial readout.',
        },
        zh: {
          prompt: '点击此处，然后按任意键',
          countLabel: '次按键',
          eventProps: '事件属性',
          modifiers: '修饰键',
          snippet: '可复制的 JS 代码片段',
          recentKeys: '最近按键',
          deprecated: '（已废弃）',
          copy: '复制',
          copied: '代码片段已复制到剪贴板。',
          copyFailed: '复制失败。',
          clear: '清除',
          padFocused: '已聚焦捕获区，按任意键。',
          padBlurred: '已离开捕获区，点击区域恢复监听。',
          mobileNote:
            '移动端物理键盘事件不一致。建议使用桌面浏览器获取完整信号；或在下方输入单个字符获取有限信息。',
        },
        ja: {
          prompt: 'ここをクリックしてキーを押してください',
          countLabel: 'キー入力',
          eventProps: 'イベントプロパティ',
          modifiers: '修飾キー',
          snippet: 'コピー可能な JS スニペット',
          recentKeys: '最近のキー',
          deprecated: '（非推奨）',
          copy: 'コピー',
          copied: 'スニペットをコピーしました。',
          copyFailed: 'コピーに失敗しました。',
          clear: 'クリア',
          padFocused: 'パッドにフォーカスしました。キーを押してください。',
          padBlurred: 'パッドからフォーカスが外れました。クリックして再開してください。',
          mobileNote:
            'モバイル端末では物理キーボードイベントが一貫しません。完全な情報はデスクトップブラウザで確認するか、下記で 1 文字入力して部分情報を取得してください。',
        },
        ko: {
          prompt: '여기를 클릭한 후 아무 키나 누르세요',
          countLabel: '회 키 입력',
          eventProps: '이벤트 속성',
          modifiers: '수정자 키',
          snippet: '복사 가능한 JS 스니펫',
          recentKeys: '최근 키',
          deprecated: '(폐지됨)',
          copy: '복사',
          copied: '스니펫이 클립보드에 복사되었습니다.',
          copyFailed: '복사 실패.',
          clear: '지우기',
          padFocused: '캡처 패드가 포커스되었습니다. 키를 누르세요.',
          padBlurred: '캡처 패드 포커스가 해제되었습니다. 패드를 클릭하여 재개하세요.',
          mobileNote:
            '모바일에서는 물리적 키보드 이벤트가 일관되지 않습니다. 데스크톱 브라우저를 사용하거나 아래에 한 글자를 입력하여 부분 정보를 확인하세요.',
        },
      };

      var PREVENT_DEFAULT_KEYS = new Set([
        'Tab',
        ' ',
        'Backspace',
        'ArrowUp',
        'ArrowDown',
        'ArrowLeft',
        'ArrowRight',
        'F1', 'F2', 'F3', 'F4', 'F5', 'F6', 'F7', 'F8', 'F9', 'F10', 'F11', 'F12',
      ]);
      var MAX_HISTORY = 8;

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;

      document.querySelectorAll('[data-i18n]').forEach(function (el) {
        var key = el.getAttribute('data-i18n');
        if (t[key]) el.textContent = t[key];
      });

      var pad = document.getElementById('kce-pad');
      var padGlyph = document.getElementById('kce-pad-glyph');
      var padKey = document.getElementById('kce-pad-key');
      var padCount = document.getElementById('kce-pad-count');
      var statusEl = document.getElementById('kce-status');
      var historyEl = document.getElementById('kce-history');
      var snippetEl = document.getElementById('kce-snippet-code');
      var copyBtn = document.getElementById('kce-copy');
      var clearBtn = document.getElementById('kce-clear');
      var modsEl = document.getElementById('kce-mods');
      var mobileFallback = document.getElementById('kce-mobile-fallback');
      var mobileInput = document.getElementById('kce-mobile-input');

      var fields = {
        key: document.getElementById('kce-key'),
        code: document.getElementById('kce-code'),
        keyCode: document.getElementById('kce-keycode'),
        which: document.getElementById('kce-which'),
        charCode: document.getElementById('kce-charcode'),
        location: document.getElementById('kce-location'),
        repeat: document.getElementById('kce-repeat'),
        composing: document.getElementById('kce-composing'),
      };

      var capturedCount = 0;
      var history = [];

      function setStatus(msg, type) {
        statusEl.textContent = msg || '';
        statusEl.className = 'tool-status ' + (type || '');
      }

      function setText(el, val) {
        el.textContent = val == null ? '—' : String(val);
      }

      function escapeForString(str) {
        return String(str).replace(/\\/g, '\\\\').replace(/'/g, "\\'");
      }

      function formatKeyLabel(key) {
        if (key === ' ') return 'Space';
        if (key.length === 1) return key;
        return key;
      }

      function setMods(e) {
        var states = { shift: e.shiftKey, ctrl: e.ctrlKey, alt: e.altKey, meta: e.metaKey };
        Object.keys(states).forEach(function (m) {
          var el = modsEl.querySelector('[data-mod="' + m + '"]');
          if (!el) return;
          if (states[m]) {
            el.classList.add('active');
          } else {
            el.classList.remove('active');
          }
        });
      }

      function buildSnippet(e) {
        if (!e || e.key == null) {
          snippetEl.textContent =
            "document.addEventListener('keydown', (e) => {\n  // press a key in the pad above to generate a snippet\n});";
          return;
        }
        var mods = [];
        var modifierKeys = new Set(['Shift', 'Control', 'Alt', 'Meta']);
        if (!modifierKeys.has(e.key)) {
          if (e.ctrlKey) mods.push('e.ctrlKey');
          if (e.shiftKey) mods.push('e.shiftKey');
          if (e.altKey) mods.push('e.altKey');
          if (e.metaKey) mods.push('e.metaKey');
        }
        var modClause = mods.length ? ' && ' + mods.join(' && ') : '';
        var keyExpr = "e.key === '" + escapeForString(e.key) + "'";
        snippetEl.textContent =
          "document.addEventListener('keydown', (e) => {\n" +
          '  if (' + keyExpr + modClause + ') {\n' +
          '    // your handler\n' +
          '  }\n' +
          '});';
      }

      function pushHistory(label) {
        history.unshift(label);
        if (history.length > MAX_HISTORY) history.length = MAX_HISTORY;
        renderHistory();
      }

      function renderHistory() {
        historyEl.innerHTML = '';
        history.forEach(function (k) {
          var chip = document.createElement('span');
          chip.className = 'kce-history-chip';
          chip.textContent = k;
          historyEl.appendChild(chip);
        });
      }

      function captureFromKeyboardEvent(e) {
        if (PREVENT_DEFAULT_KEYS.has(e.key)) {
          e.preventDefault();
        }
        capturedCount += 1;
        padCount.textContent = String(capturedCount);
        padKey.textContent = formatKeyLabel(e.key);
        padGlyph.classList.add('kce-pad-glyph-flash');
        window.setTimeout(function () {
          padGlyph.classList.remove('kce-pad-glyph-flash');
        }, 140);

        setText(fields.key, JSON.stringify(e.key));
        setText(fields.code, JSON.stringify(e.code));
        setText(fields.keyCode, e.keyCode);
        setText(fields.which, e.which);
        setText(fields.charCode, e.charCode);
        setText(fields.location, e.location);
        setText(fields.repeat, e.repeat);
        setText(fields.composing, e.isComposing);

        setMods(e);
        buildSnippet(e);
        pushHistory(formatKeyLabel(e.key));

        window.trackTool && window.trackTool('keycode-explorer', 'keydown');
      }

      function captureFromMobileInput(ev) {
        var ch = (ev && ev.data) || (mobileInput.value || '');
        if (!ch) return;
        capturedCount += 1;
        padCount.textContent = String(capturedCount);
        padKey.textContent = ch;
        padGlyph.classList.add('kce-pad-glyph-flash');
        window.setTimeout(function () {
          padGlyph.classList.remove('kce-pad-glyph-flash');
        }, 140);

        setText(fields.key, JSON.stringify(ch));
        var inferredCode = ch.length === 1 && /[a-z]/i.test(ch) ? 'Key' + ch.toUpperCase() : '—';
        setText(fields.code, JSON.stringify(inferredCode));
        setText(fields.keyCode, '—');
        setText(fields.which, '—');
        setText(fields.charCode, ch.charCodeAt(0));
        setText(fields.location, '—');
        setText(fields.repeat, '—');
        setText(fields.composing, '—');

        setMods({ shiftKey: false, ctrlKey: false, altKey: false, metaKey: false });
        buildSnippet({ key: ch, ctrlKey: false, shiftKey: false, altKey: false, metaKey: false });
        pushHistory(ch);

        mobileInput.value = '';

        window.trackTool && window.trackTool('keycode-explorer', 'mobile_input');
      }

      function isCoarsePointer() {
        return typeof window.matchMedia === 'function' && window.matchMedia('(pointer: coarse)').matches;
      }

      if (isCoarsePointer()) {
        mobileFallback.hidden = false;
      }

      pad.addEventListener('keydown', captureFromKeyboardEvent);
      pad.addEventListener('focus', function () {
        pad.classList.add('kce-pad-active');
        setStatus(t.padFocused, 'info');
      });
      pad.addEventListener('blur', function () {
        pad.classList.remove('kce-pad-active');
        setStatus(t.padBlurred, 'none');
      });

      mobileInput.addEventListener('input', captureFromMobileInput);

      copyBtn.addEventListener('click', function () {
        var text = snippetEl.textContent || '';
        if (navigator.clipboard) {
          navigator.clipboard.writeText(text).then(function () {
            copyBtn.classList.add('copied');
            copyBtn.textContent = t.copied;
            setTimeout(function () {
              copyBtn.classList.remove('copied');
              copyBtn.textContent = t.copy;
            }, 1500);
          }).catch(function () {
            setStatus(t.copyFailed, 'error');
          });
        } else {
          var ta = document.createElement('textarea');
          ta.value = text;
          document.body.appendChild(ta);
          ta.select();
          try {
            document.execCommand('copy');
            copyBtn.classList.add('copied');
            copyBtn.textContent = t.copied;
            setTimeout(function () {
              copyBtn.classList.remove('copied');
              copyBtn.textContent = t.copy;
            }, 1500);
          } catch (err) {
            setStatus(t.copyFailed, 'error');
          }
          document.body.removeChild(ta);
        }
        window.trackTool && window.trackTool('keycode-explorer', 'copy_snippet');
      });

      clearBtn.addEventListener('click', function () {
        history = [];
        renderHistory();
        capturedCount = 0;
        padCount.textContent = '0';
        padKey.textContent = '';
        Object.keys(fields).forEach(function (k) { setText(fields[k], null); });
        setMods({ shiftKey: false, ctrlKey: false, altKey: false, metaKey: false });
        buildSnippet(null);
        setStatus('', '');
      });

      buildSnippet(null);
      window.setTimeout(function () { pad.focus(); }, 60);
    })();
  </script>
</div>

<style is:global>
  .kce-wrap {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .kce-pad {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 2rem 1rem;
    min-height: 220px;
    border-radius: var(--radius-lg);
    background: var(--color-bg-secondary);
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
    cursor: text;
    transition: background-color var(--transition-fast), box-shadow var(--transition-fast);
    text-align: center;
  }
  .kce-pad:focus {
    outline: none;
    background: var(--color-surface);
    box-shadow: inset 0 0 0 1px var(--color-primary), 0 0 0 4px var(--color-primary-light);
  }
  .kce-pad-active {
    background: var(--color-surface);
  }

  .kce-pad-prompt {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .kce-pad-display {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.65rem;
    font-family: var(--font-display);
    line-height: 1;
  }
  .kce-pad-glyph {
    font-size: 2.4rem;
    color: var(--color-text-muted);
    transition: transform var(--transition-fast), color var(--transition-fast);
  }
  .kce-pad-glyph-flash {
    color: var(--color-primary);
    transform: scale(1.12);
  }
  .kce-pad-key {
    font-size: 3.6rem;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
    font-family: var(--font-display);
    min-height: 3.6rem;
  }

  .kce-pad-meta {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .kce-pad-count {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--color-primary);
  }

  .kce-mobile-fallback {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.85rem 0.95rem;
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
  }
  .kce-mobile-note {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    line-height: 1.45;
  }

  .kce-section {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .kce-section-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .kce-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.45rem 0.6rem;
  }

  .kce-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
    min-width: 0;
  }
  .kce-row-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }
  .kce-row-label em {
    font-style: normal;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: none;
    letter-spacing: 0;
    margin-left: 0.25rem;
    font-size: 0.72rem;
  }
  .kce-row-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text);
    word-break: break-all;
    text-align: right;
  }

  .kce-mods {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .kce-mod {
    padding: 0.35rem 0.85rem;
    font-size: 0.82rem;
    font-weight: 700;
    border-radius: var(--radius-pill);
    background: var(--color-bg-secondary);
    color: var(--color-text-muted);
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
    font-family: var(--font-mono);
    transition: background-color var(--transition-fast), color var(--transition-fast), box-shadow var(--transition-fast);
  }
  .kce-mod.active {
    background: var(--color-primary);
    color: var(--color-primary-contrast);
    box-shadow: inset 0 0 0 1px var(--color-primary);
  }

  .kce-snippet-header,
  .kce-history-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .kce-snippet {
    margin: 0;
    padding: 0.95rem 1.05rem;
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-text);
    overflow-x: auto;
    white-space: pre;
  }
  .kce-snippet code {
    background: transparent;
    color: inherit;
    font-family: inherit;
    white-space: pre;
  }

  .kce-history {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    min-height: 1.6rem;
  }
  :global(.kce-history-chip) {
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-pill);
    background: var(--color-bg-secondary);
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 640px) {
    .kce-grid {
      grid-template-columns: 1fr;
    }
    .kce-pad-key {
      font-size: 2.8rem;
    }
    .kce-pad {
      min-height: 180px;
      padding: 1.5rem 0.75rem;
    }
  }
</style>
