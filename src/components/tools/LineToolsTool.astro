---
// LineToolsTool — deduplicate, sort, and transform text lines (pure JS)
---

<div>
  <div class="lt-wrap">
    <div class="lt-field">
      <label for="lt-input">
        <span data-i18n="inputLines">Input Lines</span>
        <span id="lt-count" class="lt-count"></span>
      </label>
      <textarea
        id="lt-input"
        placeholder="apple&#10;banana&#10;cherry&#10;apple&#10;banana&#10;date"
        spellcheck="false"
      ></textarea>
    </div>

    <div class="lt-actions">
      <button id="lt-dedup" class="btn-secondary" data-i18n="dedup">Remove Duplicates</button>
      <button id="lt-sort-asc" class="btn-secondary" data-i18n="sortAsc">Sort A→Z</button>
      <button id="lt-sort-desc" class="btn-secondary" data-i18n="sortDesc">Sort Z→A</button>
      <button id="lt-sort-num" class="btn-secondary" data-i18n="sortNum">Sort Numeric</button>
      <button id="lt-reverse" class="btn-secondary" data-i18n="reverse">Reverse</button>
      <button id="lt-shuffle" class="btn-secondary" data-i18n="shuffle">Shuffle</button>
      <button id="lt-trim" class="btn-secondary" data-i18n="trim">Trim Lines</button>
      <button id="lt-empty" class="btn-secondary" data-i18n="removeEmpty">Remove Empty</button>
      <button id="lt-clear" class="btn-ghost" data-i18n="clear">Clear</button>
    </div>

    <div id="lt-status" class="lt-status" aria-live="polite"></div>

    <div class="lt-field">
      <label for="lt-output">
        <span data-i18n="output">Output</span>
        <button id="lt-copy" class="btn-copy" type="button" data-i18n="copy">Copy</button>
      </label>
      <textarea id="lt-output" readonly spellcheck="false"></textarea>
    </div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: {
          inputLines: 'Input Lines', output: 'Output', copy: 'Copy', copied: 'Copied!', clear: 'Clear',
          dedup: 'Remove Duplicates', sortAsc: 'Sort A→Z', sortDesc: 'Sort Z→A', sortNum: 'Sort Numeric',
          reverse: 'Reverse', shuffle: 'Shuffle', trim: 'Trim Lines', removeEmpty: 'Remove Empty',
          line: 'line', lines: 'lines',
          removedDup: function(n) { return 'Removed ' + n + ' duplicate' + (n === 1 ? '' : 's') + '.'; },
          uniqueLines: function(n) { return n + ' unique ' + (n === 1 ? 'line' : 'lines') + '.'; },
          sortedAlphaAsc: function(n) { return 'Sorted ' + n + ' ' + (n === 1 ? 'line' : 'lines') + ' alphabetically (A→Z).'; },
          sortedAlphaDesc: function(n) { return 'Sorted ' + n + ' ' + (n === 1 ? 'line' : 'lines') + ' reverse alphabetically (Z→A).'; },
          sortedNum: function(n) { return 'Sorted ' + n + ' ' + (n === 1 ? 'line' : 'lines') + ' numerically.'; },
          reversed: function(n) { return 'Reversed ' + n + ' ' + (n === 1 ? 'line' : 'lines') + '.'; },
          shuffled: function(n) { return 'Shuffled ' + n + ' ' + (n === 1 ? 'line' : 'lines') + '.'; },
          trimmed: function(n) { return 'Trimmed whitespace from ' + n + ' ' + (n === 1 ? 'line' : 'lines') + '.'; },
          removedEmpty: function(n) { return 'Removed ' + n + ' empty ' + (n === 1 ? 'line' : 'lines') + '.'; },
          remaining: function(n) { return n + ' ' + (n === 1 ? 'line' : 'lines') + ' remaining.'; },
          lineCount: function(n) { return n + ' ' + (n === 1 ? 'line' : 'lines'); }
        },
        zh: {
          inputLines: '输入行', output: '输出', copy: '复制', copied: '已复制！', clear: '清除',
          dedup: '去除重复', sortAsc: 'A→Z 排序', sortDesc: 'Z→A 排序', sortNum: '数值排序',
          reverse: '反转', shuffle: '随机排序', trim: '去除首尾空格', removeEmpty: '删除空行',
          removedDup: function(n) { return '已删除 ' + n + ' 个重复行。'; },
          uniqueLines: function(n) { return n + ' 个唯一行。'; },
          sortedAlphaAsc: function(n) { return '已将 ' + n + ' 行按字母升序（A→Z）排序。'; },
          sortedAlphaDesc: function(n) { return '已将 ' + n + ' 行按字母降序（Z→A）排序。'; },
          sortedNum: function(n) { return '已将 ' + n + ' 行按数值排序。'; },
          reversed: function(n) { return '已反转 ' + n + ' 行。'; },
          shuffled: function(n) { return '已随机排序 ' + n + ' 行。'; },
          trimmed: function(n) { return '已去除 ' + n + ' 行的首尾空格。'; },
          removedEmpty: function(n) { return '已删除 ' + n + ' 个空行。'; },
          remaining: function(n) { return '剩余 ' + n + ' 行。'; },
          lineCount: function(n) { return n + ' 行'; }
        },
        ja: {
          inputLines: '入力行', output: '出力', copy: 'コピー', copied: 'コピー済み！', clear: 'クリア',
          dedup: '重複削除', sortAsc: 'A→Z 並び替え', sortDesc: 'Z→A 並び替え', sortNum: '数値順',
          reverse: '逆順', shuffle: 'シャッフル', trim: '行トリム', removeEmpty: '空行削除',
          removedDup: function(n) { return '重複 ' + n + ' 行を削除しました。'; },
          uniqueLines: function(n) { return n + ' 行（ユニーク）。'; },
          sortedAlphaAsc: function(n) { return n + ' 行をアルファベット昇順（A→Z）に並び替えました。'; },
          sortedAlphaDesc: function(n) { return n + ' 行をアルファベット降順（Z→A）に並び替えました。'; },
          sortedNum: function(n) { return n + ' 行を数値順に並び替えました。'; },
          reversed: function(n) { return n + ' 行を逆順にしました。'; },
          shuffled: function(n) { return n + ' 行をシャッフルしました。'; },
          trimmed: function(n) { return n + ' 行の空白をトリムしました。'; },
          removedEmpty: function(n) { return '空行 ' + n + ' 行を削除しました。'; },
          remaining: function(n) { return '残り ' + n + ' 行。'; },
          lineCount: function(n) { return n + ' 行'; }
        },
        ko: {
          inputLines: '입력 줄', output: '출력', copy: '복사', copied: '복사됨!', clear: '지우기',
          dedup: '중복 제거', sortAsc: 'A→Z 정렬', sortDesc: 'Z→A 정렬', sortNum: '숫자 정렬',
          reverse: '역순', shuffle: '섞기', trim: '공백 제거', removeEmpty: '빈 줄 제거',
          removedDup: function(n) { return '중복 ' + n + '개를 제거했습니다.'; },
          uniqueLines: function(n) { return '고유 줄 ' + n + '개.'; },
          sortedAlphaAsc: function(n) { return n + '줄을 알파벳 오름차순(A→Z)으로 정렬했습니다.'; },
          sortedAlphaDesc: function(n) { return n + '줄을 알파벳 내림차순(Z→A)으로 정렬했습니다.'; },
          sortedNum: function(n) { return n + '줄을 숫자 순으로 정렬했습니다.'; },
          reversed: function(n) { return n + '줄을 역순으로 뒤집었습니다.'; },
          shuffled: function(n) { return n + '줄을 섞었습니다.'; },
          trimmed: function(n) { return n + '줄의 공백을 제거했습니다.'; },
          removedEmpty: function(n) { return '빈 줄 ' + n + '개를 제거했습니다.'; },
          remaining: function(n) { return '남은 줄 ' + n + '개.'; },
          lineCount: function(n) { return n + '줄'; }
        }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });
      document.querySelectorAll('[data-i18n-ph]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-ph'); if (t[key]) el.placeholder = t[key];
      });

      var inputEl = document.getElementById('lt-input');
      var outputEl = document.getElementById('lt-output');
      var statusEl = document.getElementById('lt-status');
      var countEl = document.getElementById('lt-count');
      var copyBtn = document.getElementById('lt-copy');

      function setStatus(msg, isError) {
        statusEl.textContent = msg;
        statusEl.className = 'lt-status ' + (isError ? 'error' : 'success');
      }

      function clearStatus() {
        statusEl.textContent = '';
        statusEl.className = 'lt-status';
      }

      function getLines() {
        var raw = inputEl.value;
        if (!raw) return [];
        return raw.split('\n');
      }

      function updateCount() {
        var raw = inputEl.value.trim();
        if (!raw) { countEl.textContent = ''; return; }
        var lines = raw.split('\n');
        countEl.textContent = t.lineCount(lines.length);
      }

      inputEl.addEventListener('input', updateCount);
      updateCount();

      /* ── Remove Duplicates ── */
      document.getElementById('lt-dedup').addEventListener('click', function () {
        var lines = getLines();
        if (!lines.length) { clearStatus(); outputEl.value = ''; return; }

        var seen = {};
        var result = [];
        var removed = 0;
        for (var i = 0; i < lines.length; i++) {
          if (!seen.hasOwnProperty(lines[i])) {
            seen[lines[i]] = true;
            result.push(lines[i]);
          } else {
            removed++;
          }
        }
        outputEl.value = result.join('\n');
        setStatus(t.removedDup(removed) + ' ' + t.uniqueLines(result.length), false);
        window.trackTool && window.trackTool('line_tools', 'deduplicate');
      });

      /* ── Sort A→Z ── */
      document.getElementById('lt-sort-asc').addEventListener('click', function () {
        var lines = getLines();
        if (!lines.length) { clearStatus(); outputEl.value = ''; return; }

        var sorted = lines.slice().sort(function (a, b) {
          return a.localeCompare(b);
        });
        outputEl.value = sorted.join('\n');
        setStatus(t.sortedAlphaAsc(sorted.length), false);
        window.trackTool && window.trackTool('line_tools', 'sort_asc');
      });

      /* ── Sort Z→A ── */
      document.getElementById('lt-sort-desc').addEventListener('click', function () {
        var lines = getLines();
        if (!lines.length) { clearStatus(); outputEl.value = ''; return; }

        var sorted = lines.slice().sort(function (a, b) {
          return b.localeCompare(a);
        });
        outputEl.value = sorted.join('\n');
        setStatus(t.sortedAlphaDesc(sorted.length), false);
        window.trackTool && window.trackTool('line_tools', 'sort_desc');
      });

      /* ── Sort Numeric ── */
      document.getElementById('lt-sort-num').addEventListener('click', function () {
        var lines = getLines();
        if (!lines.length) { clearStatus(); outputEl.value = ''; return; }

        var sorted = lines.slice().sort(function (a, b) {
          var na = parseFloat(a);
          var nb = parseFloat(b);
          if (isNaN(na) && isNaN(nb)) return a.localeCompare(b);
          if (isNaN(na)) return 1;
          if (isNaN(nb)) return -1;
          return na - nb;
        });
        outputEl.value = sorted.join('\n');
        setStatus(t.sortedNum(sorted.length), false);
        window.trackTool && window.trackTool('line_tools', 'sort_numeric');
      });

      /* ── Reverse ── */
      document.getElementById('lt-reverse').addEventListener('click', function () {
        var lines = getLines();
        if (!lines.length) { clearStatus(); outputEl.value = ''; return; }

        outputEl.value = lines.slice().reverse().join('\n');
        setStatus(t.reversed(lines.length), false);
        window.trackTool && window.trackTool('line_tools', 'reverse');
      });

      /* ── Shuffle ── */
      document.getElementById('lt-shuffle').addEventListener('click', function () {
        var lines = getLines();
        if (!lines.length) { clearStatus(); outputEl.value = ''; return; }

        var arr = lines.slice();
        for (var i = arr.length - 1; i > 0; i--) {
          var j = Math.floor(Math.random() * (i + 1));
          var tmp = arr[i];
          arr[i] = arr[j];
          arr[j] = tmp;
        }
        outputEl.value = arr.join('\n');
        setStatus(t.shuffled(arr.length), false);
        window.trackTool && window.trackTool('line_tools', 'shuffle');
      });

      /* ── Trim Lines ── */
      document.getElementById('lt-trim').addEventListener('click', function () {
        var lines = getLines();
        if (!lines.length) { clearStatus(); outputEl.value = ''; return; }

        var trimmed = lines.map(function (l) { return l.trim(); });
        outputEl.value = trimmed.join('\n');
        setStatus(t.trimmed(trimmed.length), false);
        window.trackTool && window.trackTool('line_tools', 'trim');
      });

      /* ── Remove Empty ── */
      document.getElementById('lt-empty').addEventListener('click', function () {
        var lines = getLines();
        if (!lines.length) { clearStatus(); outputEl.value = ''; return; }

        var result = lines.filter(function (l) { return l.trim() !== ''; });
        var removed = lines.length - result.length;
        outputEl.value = result.join('\n');
        setStatus(t.removedEmpty(removed) + ' ' + t.remaining(result.length), false);
        window.trackTool && window.trackTool('line_tools', 'remove_empty');
      });

      /* ── Clear ── */
      document.getElementById('lt-clear').addEventListener('click', function () {
        inputEl.value = '';
        outputEl.value = '';
        countEl.textContent = '';
        clearStatus();
      });

      /* ── Copy ── */
      copyBtn.addEventListener('click', function () {
        if (!outputEl.value) return;
        navigator.clipboard.writeText(outputEl.value).then(function () {
          copyBtn.textContent = t.copied;
          setTimeout(function () { copyBtn.textContent = t.copy; }, 1500);
        });
      });
    })();
  </script>
</div>

<style>
  .lt-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .lt-field { display: flex; flex-direction: column; gap: 0.4rem; }

  .lt-field label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .lt-count {
    font-weight: 400;
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .lt-field textarea {
    width: 100%;
    min-height: 180px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
    line-height: 1.5;
  }

  .lt-field textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .lt-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .lt-status { font-size: 0.85rem; min-height: 1.2rem; }
  .lt-status.success { color: #057a55; }
  .lt-status.error { color: #c0392b; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .lt-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .lt-status.error { color: #f87171; }
  }
  [data-theme="dark"] .lt-status.success { color: #34d399; }
  [data-theme="dark"] .lt-status.error { color: #f87171; }
</style>
