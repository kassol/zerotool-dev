---
// CssToTailwindTool — CSS properties → Tailwind CSS class suggestions
---

<div>
  <div class="c2t-wrap">
    <div class="c2t-panels">
      <div class="c2t-panel">
        <label for="c2t-css">
          <span>CSS Input</span>
        </label>
        <textarea
          id="c2t-css"
          placeholder={`.card {\n  display: flex;\n  flex-direction: column;\n  padding: 1rem;\n  margin: 0 auto;\n  font-size: 1rem;\n  color: #111;\n  background: #fff;\n  border-radius: 0.5rem;\n  gap: 0.5rem;\n}`}
          spellcheck="false"
        ></textarea>
      </div>
      <div class="c2t-panel">
        <label for="c2t-output">
          <span>Tailwind Classes</span>
          <button id="c2t-copy" class="btn-copy" type="button">Copy</button>
        </label>
        <textarea
          id="c2t-output"
          readonly
          spellcheck="false"
          placeholder="Tailwind classes appear here..."
        ></textarea>
      </div>
    </div>

    <div class="c2t-actions">
      <button id="c2t-convert" class="btn-primary">Convert to Tailwind</button>
      <button id="c2t-clear" class="btn-ghost">Clear</button>
    </div>

    <div id="c2t-status" class="c2t-status" aria-live="polite"></div>

    <details class="c2t-coverage">
      <summary>Coverage notes</summary>
      <p>Covers ~80% of common CSS properties. Unmapped properties are listed as <code>/* keep: property: value */</code> comments in the output so you can handle them manually.</p>
    </details>
  </div>

  <script is:inline>
    (function () {
      /* ── Mapping table: CSS value → Tailwind class ── */
      var MAP = {
        /* display */
        'display:block': 'block',
        'display:inline': 'inline',
        'display:inline-block': 'inline-block',
        'display:flex': 'flex',
        'display:inline-flex': 'inline-flex',
        'display:grid': 'grid',
        'display:inline-grid': 'inline-grid',
        'display:none': 'hidden',
        'display:contents': 'contents',
        'display:table': 'table',
        'display:table-row': 'table-row',
        'display:table-cell': 'table-cell',

        /* position */
        'position:static': 'static',
        'position:relative': 'relative',
        'position:absolute': 'absolute',
        'position:fixed': 'fixed',
        'position:sticky': 'sticky',

        /* visibility */
        'visibility:visible': 'visible',
        'visibility:hidden': 'invisible',

        /* overflow */
        'overflow:auto': 'overflow-auto',
        'overflow:hidden': 'overflow-hidden',
        'overflow:visible': 'overflow-visible',
        'overflow:scroll': 'overflow-scroll',
        'overflow-x:auto': 'overflow-x-auto',
        'overflow-x:hidden': 'overflow-x-hidden',
        'overflow-x:scroll': 'overflow-x-scroll',
        'overflow-y:auto': 'overflow-y-auto',
        'overflow-y:hidden': 'overflow-y-hidden',
        'overflow-y:scroll': 'overflow-y-scroll',

        /* flex */
        'flex-direction:row': 'flex-row',
        'flex-direction:row-reverse': 'flex-row-reverse',
        'flex-direction:column': 'flex-col',
        'flex-direction:column-reverse': 'flex-col-reverse',
        'flex-wrap:wrap': 'flex-wrap',
        'flex-wrap:nowrap': 'flex-nowrap',
        'flex-wrap:wrap-reverse': 'flex-wrap-reverse',
        'flex:1': 'flex-1',
        'flex:auto': 'flex-auto',
        'flex:none': 'flex-none',
        'flex-grow:0': 'grow-0',
        'flex-grow:1': 'grow',
        'flex-shrink:0': 'shrink-0',
        'flex-shrink:1': 'shrink',

        /* grid */
        'grid-flow:row': 'grid-flow-row',
        'grid-flow:col': 'grid-flow-col',
        'grid-flow:dense': 'grid-flow-dense',

        /* align / justify */
        'align-items:flex-start': 'items-start',
        'align-items:flex-end': 'items-end',
        'align-items:center': 'items-center',
        'align-items:baseline': 'items-baseline',
        'align-items:stretch': 'items-stretch',
        'align-self:auto': 'self-auto',
        'align-self:flex-start': 'self-start',
        'align-self:flex-end': 'self-end',
        'align-self:center': 'self-center',
        'align-self:stretch': 'self-stretch',
        'justify-content:flex-start': 'justify-start',
        'justify-content:flex-end': 'justify-end',
        'justify-content:center': 'justify-center',
        'justify-content:space-between': 'justify-between',
        'justify-content:space-around': 'justify-around',
        'justify-content:space-evenly': 'justify-evenly',
        'justify-items:start': 'justify-items-start',
        'justify-items:end': 'justify-items-end',
        'justify-items:center': 'justify-items-center',
        'justify-items:stretch': 'justify-items-stretch',

        /* text-align */
        'text-align:left': 'text-left',
        'text-align:center': 'text-center',
        'text-align:right': 'text-right',
        'text-align:justify': 'text-justify',
        'text-align:start': 'text-start',
        'text-align:end': 'text-end',

        /* font-weight */
        'font-weight:100': 'font-thin',
        'font-weight:200': 'font-extralight',
        'font-weight:300': 'font-light',
        'font-weight:400': 'font-normal',
        'font-weight:500': 'font-medium',
        'font-weight:600': 'font-semibold',
        'font-weight:700': 'font-bold',
        'font-weight:800': 'font-extrabold',
        'font-weight:900': 'font-black',
        'font-weight:bold': 'font-bold',
        'font-weight:normal': 'font-normal',

        /* font-style */
        'font-style:italic': 'italic',
        'font-style:normal': 'not-italic',

        /* text-decoration */
        'text-decoration:underline': 'underline',
        'text-decoration:line-through': 'line-through',
        'text-decoration:none': 'no-underline',

        /* text-transform */
        'text-transform:uppercase': 'uppercase',
        'text-transform:lowercase': 'lowercase',
        'text-transform:capitalize': 'capitalize',
        'text-transform:none': 'normal-case',

        /* vertical-align */
        'vertical-align:baseline': 'align-baseline',
        'vertical-align:top': 'align-top',
        'vertical-align:middle': 'align-middle',
        'vertical-align:bottom': 'align-bottom',
        'vertical-align:text-top': 'align-text-top',
        'vertical-align:text-bottom': 'align-text-bottom',

        /* white-space */
        'white-space:normal': 'whitespace-normal',
        'white-space:nowrap': 'whitespace-nowrap',
        'white-space:pre': 'whitespace-pre',
        'white-space:pre-wrap': 'whitespace-pre-wrap',
        'white-space:pre-line': 'whitespace-pre-line',

        /* word-break */
        'word-break:normal': 'break-normal',
        'word-break:break-all': 'break-all',
        'word-break:keep-all': 'break-keep',
        'overflow-wrap:break-word': 'break-words',

        /* cursor */
        'cursor:pointer': 'cursor-pointer',
        'cursor:default': 'cursor-default',
        'cursor:not-allowed': 'cursor-not-allowed',
        'cursor:wait': 'cursor-wait',
        'cursor:text': 'cursor-text',
        'cursor:move': 'cursor-move',
        'cursor:grab': 'cursor-grab',
        'cursor:grabbing': 'cursor-grabbing',
        'cursor:crosshair': 'cursor-crosshair',

        /* pointer-events */
        'pointer-events:none': 'pointer-events-none',
        'pointer-events:auto': 'pointer-events-auto',

        /* user-select */
        'user-select:none': 'select-none',
        'user-select:text': 'select-text',
        'user-select:all': 'select-all',
        'user-select:auto': 'select-auto',

        /* list-style */
        'list-style-type:none': 'list-none',
        'list-style-type:disc': 'list-disc',
        'list-style-type:decimal': 'list-decimal',
        'list-style-position:inside': 'list-inside',
        'list-style-position:outside': 'list-outside',

        /* appearance */
        'appearance:none': 'appearance-none',

        /* object-fit */
        'object-fit:contain': 'object-contain',
        'object-fit:cover': 'object-cover',
        'object-fit:fill': 'object-fill',
        'object-fit:none': 'object-none',
        'object-fit:scale-down': 'object-scale-down',

        /* box-sizing */
        'box-sizing:border-box': 'box-border',
        'box-sizing:content-box': 'box-content',
      };

      /* ── Spacing converter: px/rem → Tailwind scale ── */
      var SPACING_SCALE = {
        '0': '0', '0px': '0', '0rem': '0',
        '1px': 'px',
        '0.125rem': '0.5', '2px': '0.5',
        '0.25rem': '1', '4px': '1',
        '0.375rem': '1.5', '6px': '1.5',
        '0.5rem': '2', '8px': '2',
        '0.625rem': '2.5', '10px': '2.5',
        '0.75rem': '3', '12px': '3',
        '0.875rem': '3.5', '14px': '3.5',
        '1rem': '4', '16px': '4',
        '1.25rem': '5', '20px': '5',
        '1.5rem': '6', '24px': '6',
        '1.75rem': '7', '28px': '7',
        '2rem': '8', '32px': '8',
        '2.25rem': '9', '36px': '9',
        '2.5rem': '10', '40px': '10',
        '2.75rem': '11', '44px': '11',
        '3rem': '12', '48px': '12',
        '3.5rem': '14', '56px': '14',
        '4rem': '16', '64px': '16',
        '5rem': '20', '80px': '20',
        '6rem': '24', '96px': '24',
        '8rem': '32', '128px': '32',
        '10rem': '40', '160px': '40',
        '12rem': '48', '192px': '48',
        '14rem': '56', '224px': '56',
        '16rem': '64', '256px': '64',
        'auto': 'auto',
      };

      var FONT_SIZE_SCALE = {
        '0.75rem': 'xs', '12px': 'xs',
        '0.875rem': 'sm', '14px': 'sm',
        '1rem': 'base', '16px': 'base',
        '1.125rem': 'lg', '18px': 'lg',
        '1.25rem': 'xl', '20px': 'xl',
        '1.5rem': '2xl', '24px': '2xl',
        '1.875rem': '3xl', '30px': '3xl',
        '2.25rem': '4xl', '36px': '4xl',
        '3rem': '5xl', '48px': '5xl',
        '3.75rem': '6xl', '60px': '6xl',
        '4.5rem': '7xl', '72px': '7xl',
        '6rem': '8xl', '96px': '8xl',
        '8rem': '9xl', '128px': '9xl',
      };

      var BORDER_RADIUS_SCALE = {
        '0': 'rounded-none',
        '0px': 'rounded-none',
        '0.125rem': 'rounded-sm',
        '2px': 'rounded-sm',
        '0.25rem': 'rounded',
        '4px': 'rounded',
        '0.375rem': 'rounded-md',
        '6px': 'rounded-md',
        '0.5rem': 'rounded-lg',
        '8px': 'rounded-lg',
        '0.75rem': 'rounded-xl',
        '12px': 'rounded-xl',
        '1rem': 'rounded-2xl',
        '16px': 'rounded-2xl',
        '1.5rem': 'rounded-3xl',
        '24px': 'rounded-3xl',
        '9999px': 'rounded-full',
        '50%': 'rounded-full',
      };

      var BORDER_WIDTH_SCALE = {
        '0': 'border-0', '0px': 'border-0',
        '1px': 'border',
        '2px': 'border-2',
        '4px': 'border-4',
        '8px': 'border-8',
      };

      var OPACITY_SCALE = {
        '0': 'opacity-0', '0%': 'opacity-0',
        '5%': 'opacity-5', '0.05': 'opacity-5',
        '10%': 'opacity-10', '0.1': 'opacity-10',
        '20%': 'opacity-20', '0.2': 'opacity-20',
        '25%': 'opacity-25', '0.25': 'opacity-25',
        '30%': 'opacity-30', '0.3': 'opacity-30',
        '40%': 'opacity-40', '0.4': 'opacity-40',
        '50%': 'opacity-50', '0.5': 'opacity-50',
        '60%': 'opacity-60', '0.6': 'opacity-60',
        '70%': 'opacity-70', '0.7': 'opacity-70',
        '75%': 'opacity-75', '0.75': 'opacity-75',
        '80%': 'opacity-80', '0.8': 'opacity-80',
        '90%': 'opacity-90', '0.9': 'opacity-90',
        '95%': 'opacity-95', '0.95': 'opacity-95',
        '100%': 'opacity-100', '1': 'opacity-100',
      };

      /* width/height percentage + keyword mapping */
      var SIZE_KEYWORD = {
        'auto': 'auto',
        '100%': 'full',
        '50%': '1/2',
        '33.333%': '1/3', '33.33%': '1/3',
        '66.667%': '2/3', '66.67%': '2/3',
        '25%': '1/4',
        '75%': '3/4',
        '20%': '1/5',
        '40%': '2/5',
        '60%': '3/5',
        '80%': '4/5',
        '100vw': 'screen', '100vh': 'screen',
        'min-content': 'min',
        'max-content': 'max',
        'fit-content': 'fit',
      };

      function spacingClass(prefix, val) {
        var v = val.trim();
        if (SPACING_SCALE[v] !== undefined) return prefix + '-' + SPACING_SCALE[v];
        /* shorthand: try splitting e.g. "1rem 2rem" */
        return null;
      }

      function sizeClass(prefix, val) {
        var v = val.trim();
        if (SIZE_KEYWORD[v] !== undefined) return prefix + '-' + SIZE_KEYWORD[v];
        if (SPACING_SCALE[v] !== undefined) return prefix + '-' + SPACING_SCALE[v];
        return null;
      }

      /* ── Parse a CSS declarations block ── */
      function parseDeclarations(block) {
        /* strip comments */
        block = block.replace(/\/\*[\s\S]*?\*\//g, '');
        var results = [];
        var lines = block.split(';');
        lines.forEach(function (line) {
          line = line.trim();
          if (!line) return;
          var colon = line.indexOf(':');
          if (colon < 0) return;
          var prop = line.slice(0, colon).trim().toLowerCase();
          var val = line.slice(colon + 1).trim().toLowerCase();
          results.push([prop, val]);
        });
        return results;
      }

      function convertDeclarations(decls) {
        var classes = [];
        var unmapped = [];

        decls.forEach(function (pair) {
          var prop = pair[0];
          var val = pair[1];
          var key = prop + ':' + val;

          /* 1. Exact match */
          if (MAP[key]) { classes.push(MAP[key]); return; }

          /* 2. Property-specific value mapping */
          var cls = null;

          switch (prop) {
            case 'padding':
            case 'padding-top':
            case 'padding-right':
            case 'padding-bottom':
            case 'padding-left': {
              var pfx = { 'padding': 'p', 'padding-top': 'pt', 'padding-right': 'pr', 'padding-bottom': 'pb', 'padding-left': 'pl' }[prop];
              /* shorthand e.g. "1rem 2rem" → px-8 py-4 */
              if (prop === 'padding') {
                var parts = val.split(/\s+/);
                if (parts.length === 1) { cls = spacingClass('p', parts[0]); }
                else if (parts.length === 2) {
                  var cy = spacingClass('py', parts[0]);
                  var cx = spacingClass('px', parts[1]);
                  if (cy && cx) { classes.push(cy, cx); return; }
                }
              } else {
                cls = spacingClass(pfx, val);
              }
              break;
            }
            case 'margin':
            case 'margin-top':
            case 'margin-right':
            case 'margin-bottom':
            case 'margin-left': {
              var mpfx = { 'margin': 'm', 'margin-top': 'mt', 'margin-right': 'mr', 'margin-bottom': 'mb', 'margin-left': 'ml' }[prop];
              if (prop === 'margin') {
                var mparts = val.split(/\s+/);
                if (mparts.length === 1) { cls = spacingClass('m', mparts[0]); }
                else if (mparts.length === 2) {
                  var my = spacingClass('my', mparts[0]);
                  var mx = spacingClass('mx', mparts[1]);
                  if (my && mx) { classes.push(my, mx); return; }
                }
              } else {
                cls = spacingClass(mpfx, val);
              }
              break;
            }
            case 'gap':
              cls = spacingClass('gap', val);
              break;
            case 'row-gap':
            case 'grid-row-gap':
              cls = spacingClass('gap-y', val);
              break;
            case 'column-gap':
            case 'grid-column-gap':
              cls = spacingClass('gap-x', val);
              break;
            case 'width':
              cls = sizeClass('w', val);
              break;
            case 'min-width':
              cls = sizeClass('min-w', val);
              break;
            case 'max-width':
              cls = sizeClass('max-w', val);
              break;
            case 'height':
              cls = sizeClass('h', val);
              break;
            case 'min-height':
              cls = sizeClass('min-h', val);
              break;
            case 'max-height':
              cls = sizeClass('max-h', val);
              break;
            case 'font-size':
              if (FONT_SIZE_SCALE[val]) { cls = 'text-' + FONT_SIZE_SCALE[val]; }
              break;
            case 'line-height':
              var lhMap = { '1': 'none', '1.25': 'tight', '1.375': 'snug', '1.5': 'normal', '1.625': 'relaxed', '2': 'loose' };
              if (lhMap[val]) { cls = 'leading-' + lhMap[val]; }
              break;
            case 'letter-spacing':
              var lsMap = { '-0.05em': 'tighter', '-0.025em': 'tight', '0em': 'normal', '0.025em': 'wide', '0.05em': 'wider', '0.1em': 'widest' };
              if (lsMap[val]) { cls = 'tracking-' + lsMap[val]; }
              break;
            case 'border-radius':
              if (BORDER_RADIUS_SCALE[val]) { cls = BORDER_RADIUS_SCALE[val]; }
              break;
            case 'border-width':
            case 'border':
              /* "border: 1px solid ..." → border + border-solid */
              if (prop === 'border') {
                var bparts = val.split(/\s+/);
                var bw = bparts[0]; var bs = bparts[1];
                if (BORDER_WIDTH_SCALE[bw]) classes.push(BORDER_WIDTH_SCALE[bw]);
                if (bs) {
                  var bsMap = { 'solid': 'border-solid', 'dashed': 'border-dashed', 'dotted': 'border-dotted', 'double': 'border-double', 'hidden': 'border-hidden', 'none': 'border-none' };
                  if (bsMap[bs]) classes.push(bsMap[bs]);
                }
                return;
              }
              if (BORDER_WIDTH_SCALE[val]) { cls = BORDER_WIDTH_SCALE[val]; }
              break;
            case 'border-style':
              var bordStyleMap = { 'solid': 'border-solid', 'dashed': 'border-dashed', 'dotted': 'border-dotted', 'double': 'border-double', 'hidden': 'border-hidden', 'none': 'border-none' };
              if (bordStyleMap[val]) { cls = bordStyleMap[val]; }
              break;
            case 'opacity':
              if (OPACITY_SCALE[val]) { cls = OPACITY_SCALE[val]; }
              break;
            case 'z-index':
              var ziMap = { 'auto': 'z-auto', '0': 'z-0', '10': 'z-10', '20': 'z-20', '30': 'z-30', '40': 'z-40', '50': 'z-50' };
              if (ziMap[val]) { cls = ziMap[val]; }
              break;
            case 'top': cls = spacingClass('top', val); break;
            case 'right': cls = spacingClass('right', val); break;
            case 'bottom': cls = spacingClass('bottom', val); break;
            case 'left': cls = spacingClass('left', val); break;
            case 'inset':
              cls = spacingClass('inset', val);
              break;
            case 'grid-template-columns': {
              var repMatch = val.match(/^repeat\((\d+),/);
              if (repMatch) { cls = 'grid-cols-' + repMatch[1]; }
              break;
            }
            case 'grid-template-rows': {
              var repRowMatch = val.match(/^repeat\((\d+),/);
              if (repRowMatch) { cls = 'grid-rows-' + repRowMatch[1]; }
              break;
            }
            case 'grid-column': {
              var spanColMatch = val.match(/^span\s+(\d+)/);
              if (spanColMatch) { cls = 'col-span-' + spanColMatch[1]; }
              break;
            }
            case 'grid-row': {
              var spanRowMatch = val.match(/^span\s+(\d+)/);
              if (spanRowMatch) { cls = 'row-span-' + spanRowMatch[1]; }
              break;
            }
            case 'transition':
              if (val === 'all') { cls = 'transition-all'; }
              else if (val.includes('color')) { cls = 'transition-colors'; }
              else if (val.includes('opacity')) { cls = 'transition-opacity'; }
              else if (val.includes('shadow')) { cls = 'transition-shadow'; }
              else if (val.includes('transform')) { cls = 'transition-transform'; }
              else { cls = 'transition'; }
              break;
            case 'box-shadow':
              if (val === 'none') { cls = 'shadow-none'; }
              else { cls = 'shadow'; }
              break;
            case 'outline':
              if (val === 'none' || val === '0') { cls = 'outline-none'; }
              break;
          }

          if (cls) { classes.push(cls); }
          else { unmapped.push(prop + ': ' + val); }
        });

        return { classes: classes, unmapped: unmapped };
      }

      /* ── Parse full CSS (may have multiple selectors) ── */
      function convertCss(input) {
        var lines = [];
        /* check if input contains braces (selector blocks) */
        if (input.indexOf('{') >= 0) {
          var re = /([^{]+)\{([^}]*)\}/g;
          var m;
          while ((m = re.exec(input)) !== null) {
            var selector = m[1].trim();
            var block = m[2];
            var decls = parseDeclarations(block);
            var res = convertDeclarations(decls);
            if (res.classes.length || res.unmapped.length) {
              lines.push('/* ' + selector + ' */');
              if (res.classes.length) lines.push(res.classes.join(' '));
              res.unmapped.forEach(function (u) { lines.push('/* keep: ' + u + ' */'); });
              lines.push('');
            }
          }
        } else {
          /* bare declarations */
          var decls2 = parseDeclarations(input);
          var res2 = convertDeclarations(decls2);
          if (res2.classes.length) lines.push(res2.classes.join(' '));
          res2.unmapped.forEach(function (u) { lines.push('/* keep: ' + u + ' */'); });
        }
        return lines.join('\n').trim();
      }

      /* ── UI ── */
      var cssEl = document.getElementById('c2t-css');
      var outEl = document.getElementById('c2t-output');
      var statusEl = document.getElementById('c2t-status');
      var copyBtn = document.getElementById('c2t-copy');

      function setStatus(msg, isError) {
        statusEl.textContent = msg;
        statusEl.className = 'c2t-status ' + (isError ? 'error' : 'success');
      }

      document.getElementById('c2t-convert').addEventListener('click', function () {
        var raw = cssEl.value.trim();
        if (!raw) { outEl.value = ''; statusEl.textContent = ''; statusEl.className = 'c2t-status'; return; }
        try {
          var result = convertCss(raw);
          outEl.value = result || '/* No mappable properties found */';
          setStatus('Converted.', false);
          window.trackTool && window.trackTool('css_to_tailwind', 'convert');
        } catch (e) {
          outEl.value = '';
          setStatus('Error: ' + e.message, true);
        }
      });

      document.getElementById('c2t-clear').addEventListener('click', function () {
        cssEl.value = '';
        outEl.value = '';
        statusEl.textContent = '';
        statusEl.className = 'c2t-status';
      });

      copyBtn.addEventListener('click', function () {
        if (!outEl.value) return;
        navigator.clipboard.writeText(outEl.value).then(function () {
          copyBtn.textContent = 'Copied!';
          setTimeout(function () { copyBtn.textContent = 'Copy'; }, 1500);
        });
      });

      /* Ctrl/Cmd+Enter shortcut */
      cssEl.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) {
          document.getElementById('c2t-convert').click();
        }
      });
    })();
  </script>
</div>

