---
// No props needed — tool widget is language-independent
---

<div>
  <div class="jf-wrap">
    <div class="jf-row">
      <label for="jf-input" data-i18n="inputJson">Input JSON</label>
      <textarea
        id="jf-input"
        placeholder='{"name":"ZeroTool","free":true}'
        spellcheck="false"
      ></textarea>
    </div>

    <div class="jf-actions">
      <button id="jf-format" class="btn-primary" data-i18n="format">Format</button>
      <button id="jf-minify" class="btn-secondary" data-i18n="minify">Minify</button>
      <button id="jf-validate" class="btn-secondary" data-i18n="validate">Validate</button>
      <button id="jf-clear" class="btn-ghost" data-i18n="clear">Clear</button>
    </div>

    <div id="jf-status" class="jf-status" aria-live="polite"></div>

    <div class="jf-row">
      <span class="jf-row-label">
        <span data-i18n="output">Output</span>
        <button id="jf-copy" class="btn-copy" type="button" data-i18n="copy">Copy</button>
      </span>
      <pre id="jf-output" class="jf-output" aria-label="Formatted JSON output"><code id="jf-output-code"></code></pre>
    </div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: { inputJson: 'Input JSON', output: 'Output', format: 'Format', minify: 'Minify', validate: 'Validate', clear: 'Clear', copy: 'Copy', copied: 'Copied!', outputPlaceholder: 'Formatted JSON appears here...', validFormatted: 'Valid JSON \u2014 formatted.', invalidJson: 'Invalid JSON', minified: 'Minified.', valid: 'Valid JSON.' },
        zh: { inputJson: '输入 JSON', output: '输出', format: '格式化', minify: '压缩', validate: '验证', clear: '清除', copy: '复制', copied: '已复制！', outputPlaceholder: '格式化结果显示在此处…', validFormatted: '有效 JSON \u2014 已格式化。', invalidJson: '无效 JSON', minified: '已压缩。', valid: '有效 JSON。' },
        ja: { inputJson: 'JSON 入力', output: '出力', format: 'フォーマット', minify: '圧縮', validate: '検証', clear: 'クリア', copy: 'コピー', copied: 'コピー済み！', outputPlaceholder: 'フォーマット結果がここに表示されます…', validFormatted: '有効な JSON \u2014 フォーマット済み。', invalidJson: '無効な JSON', minified: '圧縮済み。', valid: '有効な JSON。' },
        ko: { inputJson: 'JSON 입력', output: '출력', format: '포맷', minify: '압축', validate: '검증', clear: '지우기', copy: '복사', copied: '복사됨!', outputPlaceholder: '포맷된 결과가 여기에 표시됩니다…', validFormatted: '유효한 JSON \u2014 포맷 완료.', invalidJson: '유효하지 않은 JSON', minified: '압축 완료.', valid: '유효한 JSON.' }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;

      document.querySelectorAll('.jf-wrap [data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });

      var input = document.getElementById('jf-input');
      var outputPre = document.getElementById('jf-output');
      var outputCode = document.getElementById('jf-output-code');
      var status = document.getElementById('jf-status');
      var copyBtn = document.getElementById('jf-copy');
      var plainText = '';

      function highlightJson(jsonStr) {
        // Escape HTML first to prevent injection
        var escaped = jsonStr
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;');
        return escaped.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+-]?\d+)?)/g, function (match) {
          var cls = 'jv-num';
          if (/^"/.test(match)) {
            cls = /:$/.test(match) ? 'jv-key' : 'jv-str';
          } else if (/true|false/.test(match)) {
            cls = 'jv-bool';
          } else if (/null/.test(match)) {
            cls = 'jv-null';
          }
          return '<span class="' + cls + '">' + match + '</span>';
        });
      }

      function setOutput(jsonStr, isError) {
        plainText = jsonStr;
        if (isError) {
          outputCode.className = 'jf-output-error';
          outputCode.textContent = jsonStr;
        } else {
          outputCode.className = '';
          outputCode.innerHTML = highlightJson(jsonStr);
        }
      }

      function clearOutput() {
        plainText = '';
        outputCode.className = '';
        outputCode.textContent = t.outputPlaceholder;
      }

      function setStatus(msg, isError) {
        status.textContent = msg;
        status.className = 'jf-status ' + (isError ? 'error' : 'success');
      }

      function clearStatus() {
        status.textContent = '';
        status.className = 'jf-status';
      }

      function setInputError(hasError) {
        if (hasError) {
          input.classList.add('jf-input-error');
        } else {
          input.classList.remove('jf-input-error');
        }
      }

      // Restore saved input
      var _slug = 'json-formatter';
      if (window.ztPersist) {
        var _saved = window.ztPersist.load(_slug)['input'];
        if (_saved) input.value = _saved;
      }

      // Real-time format on input (debounced 300ms) + save at 500ms
      var _debounceTimer = null;
      var _saveTimer = null;
      input.addEventListener('input', function () {
        clearTimeout(_debounceTimer);
        clearTimeout(_saveTimer);
        _debounceTimer = setTimeout(function () {
          var raw = input.value.trim();
          if (!raw) {
            setInputError(false);
            clearStatus();
            return;
          }
          try {
            var formatted = JSON.stringify(JSON.parse(raw), null, 2);
            setOutput(formatted, false);
            setInputError(false);
            setStatus(t.validFormatted, false);
          } catch (e) {
            setInputError(true);
            setStatus(t.invalidJson + ': ' + e.message, true);
          }
        }, 300);
        _saveTimer = setTimeout(function () {
          if (window.ztPersist) window.ztPersist.save(_slug, { input: input.value });
        }, 500);
      });

      document.getElementById('jf-format').addEventListener('click', function () {
        var raw = input.value.trim();
        if (!raw) { clearStatus(); clearOutput(); return; }
        try {
          var formatted = JSON.stringify(JSON.parse(raw), null, 2);
          setOutput(formatted, false);
          setInputError(false);
          setStatus(t.validFormatted, false);
          window.trackTool && window.trackTool('json_formatter', 'format');
        } catch (e) {
          setInputError(true);
          setStatus(t.invalidJson + ': ' + e.message, true);
        }
      });

      document.getElementById('jf-minify').addEventListener('click', function () {
        var raw = input.value.trim();
        if (!raw) { clearStatus(); clearOutput(); return; }
        try {
          var minified = JSON.stringify(JSON.parse(raw));
          setOutput(minified, false);
          setInputError(false);
          setStatus(t.minified, false);
          window.trackTool && window.trackTool('json_formatter', 'minify');
        } catch (e) {
          setInputError(true);
          setStatus(t.invalidJson + ': ' + e.message, true);
        }
      });

      document.getElementById('jf-validate').addEventListener('click', function () {
        var raw = input.value.trim();
        if (!raw) { clearStatus(); return; }
        try {
          JSON.parse(raw);
          setInputError(false);
          setStatus(t.valid, false);
          window.trackTool && window.trackTool('json_formatter', 'validate');
        } catch (e) {
          setInputError(true);
          setStatus(t.invalidJson + ': ' + e.message, true);
        }
      });

      document.getElementById('jf-clear').addEventListener('click', function () {
        input.value = '';
        clearOutput();
        clearStatus();
        setInputError(false);
      });

      copyBtn.addEventListener('click', function () {
        if (!plainText) return;
        navigator.clipboard.writeText(plainText).then(function () {
          copyBtn.textContent = t.copied;
          setTimeout(function () { copyBtn.textContent = t.copy; }, 1500);
        });
      });
    })();
  </script>
</div>

<style>
  .jf-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .jf-row { display: flex; flex-direction: column; gap: 0.4rem; }

  .jf-row label,
  .jf-row .jf-row-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .jf-row textarea {
    width: 100%;
    min-height: 160px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    line-height: 1.5;
    color: var(--color-text);
  }

  .jf-row textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .jf-row textarea.jf-input-error { border-color: var(--color-error, #c0392b); }

  /* Output pre block — matches textarea appearance */
  .jf-output {
    width: 100%;
    min-height: 160px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    line-height: 1.5;
    color: var(--color-text-secondary);
    overflow: auto;
    white-space: pre;
    margin: 0;
    box-sizing: border-box;
  }

  .jf-output code {
    font-family: inherit;
    font-size: inherit;
    background: none;
    padding: 0;
  }

  .jf-output-error { color: var(--color-error, #c0392b); }

  .jf-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .jf-status { font-size: 0.85rem; min-height: 1.2rem; }
  .jf-status.success { color: #057a55; }
  .jf-status.error { color: #c0392b; }

  /* Syntax highlight colours — light (use :global because spans are injected via innerHTML) */
  :global(.jv-key)  { color: #6366f1; }
  :global(.jv-str)  { color: #e67e22; }
  :global(.jv-num)  { color: #27ae60; }
  :global(.jv-bool) { color: #8e44ad; }
  :global(.jv-null) { color: #95a5a6; }

  /* Dark mode */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .jf-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .jf-status.error   { color: #f87171; }
    :global(:root:not([data-theme="light"]) .jv-key)  { color: #818cf8; }
    :global(:root:not([data-theme="light"]) .jv-str)  { color: #fb923c; }
    :global(:root:not([data-theme="light"]) .jv-num)  { color: #4ade80; }
    :global(:root:not([data-theme="light"]) .jv-bool) { color: #c084fc; }
    :global(:root:not([data-theme="light"]) .jv-null) { color: #94a3b8; }
  }
  [data-theme="dark"] .jf-status.success { color: #34d399; }
  [data-theme="dark"] .jf-status.error   { color: #f87171; }
  :global([data-theme="dark"] .jv-key)  { color: #818cf8; }
  :global([data-theme="dark"] .jv-str)  { color: #fb923c; }
  :global([data-theme="dark"] .jv-num)  { color: #4ade80; }
  :global([data-theme="dark"] .jv-bool) { color: #c084fc; }
  :global([data-theme="dark"] .jv-null) { color: #94a3b8; }
</style>
