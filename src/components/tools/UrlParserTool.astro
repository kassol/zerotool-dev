---
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: { label: 'Enter a URL', example: 'Load Example', clear: 'Clear' },
  zh: { label: '输入 URL', example: '加载示例', clear: '清空' },
  ja: { label: 'URLを入力', example: 'サンプルを読み込む', clear: 'クリア' },
  ko: { label: 'URL 입력', example: '예시 불러오기', clear: '지우기' },
};

const L = labels[lang];
---
<div>
  <div class="up-wrap" data-lang={lang}>
    <div class="up-input-section">
      <label for="up-input">{L.label}</label>
      <input
        id="up-input"
        type="text"
        placeholder="https://example.com:8080/path/to/page?key=value&foo=bar#section"
        spellcheck="false"
        autocomplete="off"
      />
      <div class="up-actions">
        <button id="up-example" class="btn-ghost">{L.example}</button>
        <button id="up-clear" class="btn-ghost">{L.clear}</button>
      </div>
    </div>

    <div id="up-status" class="up-status" aria-live="polite"></div>

    <div id="up-results" class="up-results"></div>
  </div>

  <script is:inline>
    (function () {
      var wrap = document.querySelector('.up-wrap');
      var lang = wrap ? (wrap.dataset.lang || 'en') : 'en';

      var i18n = {
        en: {
          invalidUrl: 'Invalid URL. Make sure it includes a scheme (e.g. https://).',
          parsedOk: 'Parsed successfully.',
          queryParams: 'Query Parameters',
          copy: 'Copy',
          copied: 'Copied!',
          thField: 'Field',
          thValue: 'Value',
          thKey: 'Key',
          fields: {
            protocol: 'Protocol',
            username: 'Username',
            password: 'Password',
            host: 'Host',
            hostname: 'Hostname',
            port: 'Port',
            pathname: 'Pathname',
            search: 'Search',
            hash: 'Hash',
            origin: 'Origin',
            href: 'Full URL',
          },
        },
        zh: {
          invalidUrl: 'URL 格式无效。请确保包含协议（如 https://）。',
          parsedOk: '解析成功。',
          queryParams: '查询参数',
          copy: '复制',
          copied: '已复制！',
          thField: '字段',
          thValue: '值',
          thKey: '键',
          fields: {
            protocol: '协议',
            username: '用户名',
            password: '密码',
            host: '主机',
            hostname: '主机名',
            port: '端口',
            pathname: '路径',
            search: '查询字符串',
            hash: '哈希',
            origin: '来源',
            href: '完整 URL',
          },
        },
        ja: {
          invalidUrl: 'URLが無効です。スキームを含めてください（例：https://）。',
          parsedOk: '解析しました。',
          queryParams: 'クエリパラメータ',
          copy: 'コピー',
          copied: 'コピーしました！',
          thField: 'フィールド',
          thValue: '値',
          thKey: 'キー',
          fields: {
            protocol: 'プロトコル',
            username: 'ユーザー名',
            password: 'パスワード',
            host: 'ホスト',
            hostname: 'ホスト名',
            port: 'ポート',
            pathname: 'パス',
            search: 'クエリ文字列',
            hash: 'ハッシュ',
            origin: 'オリジン',
            href: '完全なURL',
          },
        },
        ko: {
          invalidUrl: '잘못된 URL입니다. 스키마를 포함했는지 확인하세요 (예: https://).',
          parsedOk: '파싱 완료.',
          queryParams: '쿼리 파라미터',
          copy: '복사',
          copied: '복사됨!',
          thField: '필드',
          thValue: '값',
          thKey: '키',
          fields: {
            protocol: '프로토콜',
            username: '사용자명',
            password: '비밀번호',
            host: '호스트',
            hostname: '호스트명',
            port: '포트',
            pathname: '경로',
            search: '쿼리 문자열',
            hash: '해시',
            origin: '오리진',
            href: '전체 URL',
          },
        },
      };

      var T = i18n[lang] || i18n.en;

      var EXAMPLE_URL = 'https://user:pass@example.com:8080/path/to/page?key=value&foo=bar#section';

      var FIELD_KEYS = ['protocol','username','password','host','hostname','port','pathname','search','hash','origin','href'];

      function copyText(text, btn) {
        navigator.clipboard.writeText(text).then(function () {
          btn.textContent = T.copied;
          setTimeout(function () { btn.textContent = T.copy; }, 1500);
        });
      }

      function buildTable(parsed) {
        var table = document.createElement('table');
        table.className = 'up-table';

        var thead = document.createElement('thead');
        var thRow = document.createElement('tr');
        [T.thField, T.thValue, ''].forEach(function(h) {
          var th = document.createElement('th');
          th.textContent = h;
          thRow.appendChild(th);
        });
        thead.appendChild(thRow);
        table.appendChild(thead);

        var tbody = document.createElement('tbody');

        FIELD_KEYS.forEach(function (key) {
          var val = parsed[key] || '';
          var isEmpty = val === '' || val === null;

          var tr = document.createElement('tr');
          if (isEmpty) tr.className = 'up-row-empty';

          var tdLabel = document.createElement('td');
          tdLabel.className = 'up-field';
          tdLabel.textContent = T.fields[key] || key;
          tr.appendChild(tdLabel);

          var tdVal = document.createElement('td');
          tdVal.className = 'up-value' + (isEmpty ? ' up-empty' : '');
          tdVal.textContent = isEmpty ? '—' : val;
          tr.appendChild(tdVal);

          var tdCopy = document.createElement('td');
          tdCopy.className = 'up-copy-cell';
          if (!isEmpty) {
            var btn = document.createElement('button');
            btn.className = 'btn-copy';
            btn.textContent = T.copy;
            btn.addEventListener('click', function () { copyText(val, btn); });
            tdCopy.appendChild(btn);
          }
          tr.appendChild(tdCopy);

          tbody.appendChild(tr);
        });

        table.appendChild(tbody);
        return table;
      }

      function buildQueryTable(parsed) {
        var entries = [];
        parsed.searchParams.forEach(function (v, k) {
          entries.push([k, v]);
        });
        if (entries.length === 0) return null;

        var section = document.createElement('div');
        section.className = 'up-query-section';

        var h = document.createElement('div');
        h.className = 'up-section-title';
        h.textContent = T.queryParams + ' (' + entries.length + ')';
        section.appendChild(h);

        var table = document.createElement('table');
        table.className = 'up-table';

        var thead = document.createElement('thead');
        var thRow = document.createElement('tr');
        [T.thKey, T.thValue, ''].forEach(function(label) {
          var th = document.createElement('th');
          th.textContent = label;
          thRow.appendChild(th);
        });
        thead.appendChild(thRow);
        table.appendChild(thead);

        var tbody = document.createElement('tbody');
        entries.forEach(function (pair) {
          var tr = document.createElement('tr');

          var tdKey = document.createElement('td');
          tdKey.className = 'up-field';
          tdKey.textContent = pair[0];
          tr.appendChild(tdKey);

          var tdVal = document.createElement('td');
          tdVal.className = 'up-value';
          tdVal.textContent = pair[1];
          tr.appendChild(tdVal);

          var tdCopy = document.createElement('td');
          tdCopy.className = 'up-copy-cell';
          var btn = document.createElement('button');
          btn.className = 'btn-copy';
          btn.textContent = T.copy;
          btn.addEventListener('click', (function (v) {
            return function () { copyText(v, btn); };
          })(pair[1]));
          tdCopy.appendChild(btn);
          tr.appendChild(tdCopy);

          tbody.appendChild(tr);
        });

        table.appendChild(tbody);
        section.appendChild(table);
        return section;
      }

      function parse() {
        var raw = document.getElementById('up-input').value.trim();
        var statusEl = document.getElementById('up-status');
        var resultsEl = document.getElementById('up-results');
        resultsEl.innerHTML = '';

        if (!raw) {
          statusEl.textContent = '';
          statusEl.className = 'up-status';
          return;
        }

        var parsed;
        try {
          parsed = new URL(raw);
        } catch (e) {
          statusEl.textContent = T.invalidUrl;
          statusEl.className = 'up-status error';
          return;
        }

        statusEl.textContent = T.parsedOk;
        statusEl.className = 'up-status success';

        resultsEl.appendChild(buildTable(parsed));

        var querySection = buildQueryTable(parsed);
        if (querySection) resultsEl.appendChild(querySection);

        window.trackTool && window.trackTool('url-parser', 'parse');
      }

      document.getElementById('up-input').addEventListener('input', parse);

      document.getElementById('up-example').addEventListener('click', function () {
        document.getElementById('up-input').value = EXAMPLE_URL;
        parse();
      });

      document.getElementById('up-clear').addEventListener('click', function () {
        document.getElementById('up-input').value = '';
        document.getElementById('up-status').textContent = '';
        document.getElementById('up-status').className = 'up-status';
        document.getElementById('up-results').innerHTML = '';
      });
    })();
  </script>
</div>

<style>
  .up-wrap { display: flex; flex-direction: column; gap: 1rem; }

  .up-input-section { display: flex; flex-direction: column; gap: 0.4rem; }

  .up-input-section label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .up-input-section input {
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }
  .up-input-section input:focus { outline: none; border-color: #6366f1; background: var(--color-bg); }

  .up-actions { display: flex; gap: 0.5rem; margin-top: 0.25rem; }

  .up-status { font-size: 0.85rem; min-height: 1.2rem; }
  .up-status.success { color: #057a55; }
  .up-status.error { color: #c0392b; }

  .up-results { display: flex; flex-direction: column; gap: 1rem; }

  .up-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .up-table thead tr {
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
  }

  .up-table th {
    text-align: left;
    padding: 0.45rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .up-table td {
    padding: 0.4rem 0.75rem;
    border-top: 1px solid var(--color-border);
    vertical-align: middle;
  }

  .up-field {
    font-weight: 600;
    color: var(--color-text-secondary);
    width: 110px;
    white-space: nowrap;
  }

  .up-value {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-text);
    word-break: break-all;
  }

  .up-empty { color: var(--color-text-muted); font-family: inherit; font-size: 0.85rem; }

  .up-row-empty td { opacity: 0.55; }

  .up-copy-cell { width: 64px; text-align: right; }

  .up-section-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    margin-bottom: 0.4rem;
  }

  .up-query-section { display: flex; flex-direction: column; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .up-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .up-status.error { color: #f87171; }
  }
  [data-theme="dark"] .up-status.success { color: #34d399; }
  [data-theme="dark"] .up-status.error { color: #f87171; }
</style>
