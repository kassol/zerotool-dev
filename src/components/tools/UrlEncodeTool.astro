---
// No props needed — tool widget is language-independent
---

<div>
  <div class="url-wrap">
    <div class="url-mode">
      <label>
        <input type="radio" name="urlmode" value="encode" checked /> <span data-i18n="encode">Encode</span>
      </label>
      <label>
        <input type="radio" name="urlmode" value="decode" /> <span data-i18n="decode">Decode</span>
      </label>
    </div>

    <div class="url-row">
      <label for="url-input" id="url-input-label">Plain Text / URL</label>
      <textarea
        id="url-input"
        placeholder="Enter text or URL to encode..."
        spellcheck="false"
      ></textarea>
    </div>

    <div class="url-actions">
      <button id="url-run" class="btn-primary" data-i18n="encode">Encode</button>
      <button id="url-swap" class="btn-secondary" data-i18n="swap">Swap</button>
      <button id="url-clear" class="btn-ghost" data-i18n="clear">Clear</button>
    </div>

    <div id="url-status" class="url-status" aria-live="polite"></div>

    <div class="url-row">
      <label for="url-output" id="url-output-label">
        <span id="url-output-label-text">Encoded URL</span>
        <button id="url-copy" class="btn-copy" type="button" data-i18n="copy">Copy</button>
      </label>
      <textarea
        id="url-output"
        placeholder="Result appears here..."
        readonly
        spellcheck="false"
      ></textarea>
    </div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: { encode: 'Encode', decode: 'Decode', swap: 'Swap', clear: 'Clear', copy: 'Copy', copied: 'Copied!', plainUrlLabel: 'Plain Text / URL', encodedUrlLabel: 'Encoded URL', decodedUrlLabel: 'Decoded URL', encodedOk: 'Encoded.', decodedOk: 'Decoded.', encodePh: 'Enter text or URL to encode...', decodePh: 'Enter percent-encoded URL to decode...', encodedOutPh: 'Percent-encoded output appears here...', decodedOutPh: 'Decoded text appears here...' },
        zh: { encode: '编码', decode: '解码', swap: '交换', clear: '清除', copy: '复制', copied: '已复制！', plainUrlLabel: '纯文本 / URL', encodedUrlLabel: '编码后的 URL', decodedUrlLabel: '解码后的 URL', encodedOk: '已编码。', decodedOk: '已解码。', encodePh: '输入要编码的文本或 URL...', decodePh: '输入要解码的百分比编码 URL...', encodedOutPh: '百分比编码输出在这里...', decodedOutPh: '解码文本在这里...' },
        ja: { encode: 'エンコード', decode: 'デコード', swap: '入れ替え', clear: 'クリア', copy: 'コピー', copied: 'コピー済み！', plainUrlLabel: 'プレーンテキスト / URL', encodedUrlLabel: 'エンコードされた URL', decodedUrlLabel: 'デコードされた URL', encodedOk: 'エンコードしました。', decodedOk: 'デコードしました。', encodePh: 'エンコードするテキストまたは URL を入力...', decodePh: 'デコードするパーセントエンコード URL を入力...', encodedOutPh: 'パーセントエンコード出力がここに表示されます...', decodedOutPh: 'デコードされたテキストがここに表示されます...' },
        ko: { encode: '인코딩', decode: '디코딩', swap: '교체', clear: '지우기', copy: '복사', copied: '복사됨!', plainUrlLabel: '일반 텍스트 / URL', encodedUrlLabel: '인코딩된 URL', decodedUrlLabel: '디코딩된 URL', encodedOk: '인코딩 완료.', decodedOk: '디코딩 완료.', encodePh: '인코딩할 텍스트 또는 URL을 입력...', decodePh: '디코딩할 퍼센트 인코딩 URL을 입력...', encodedOutPh: '퍼센트 인코딩 출력이 여기에 표시됩니다...', decodedOutPh: '디코딩된 텍스트가 여기에 표시됩니다...' }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;

      document.querySelectorAll('.url-wrap [data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });

      var inputEl = document.getElementById('url-input');
      var outputEl = document.getElementById('url-output');
      var statusEl = document.getElementById('url-status');
      var runBtn = document.getElementById('url-run');
      var copyBtn = document.getElementById('url-copy');
      var mode = 'encode';
      var lastValidUrlOutput = '';

      function setStatus(msg, isError) {
        statusEl.textContent = msg;
        statusEl.className = 'url-status ' + (isError ? 'error' : 'success');
      }

      function clearStatus() {
        statusEl.textContent = '';
        statusEl.className = 'url-status';
      }

      function updateUI() {
        if (mode === 'encode') {
          document.getElementById('url-input-label').textContent = t.plainUrlLabel;
          document.getElementById('url-output-label-text').textContent = t.encodedUrlLabel;
          runBtn.textContent = t.encode;
          inputEl.placeholder = t.encodePh;
          outputEl.placeholder = t.encodedOutPh;
        } else {
          document.getElementById('url-input-label').textContent = t.encodedUrlLabel;
          document.getElementById('url-output-label-text').textContent = t.decodedUrlLabel;
          runBtn.textContent = t.decode;
          inputEl.placeholder = t.decodePh;
          outputEl.placeholder = t.decodedOutPh;
        }
      }

      // Sync mode from actual radio state (browser may restore form state)
      var checkedRadio = document.querySelector('input[name="urlmode"]:checked');
      if (checkedRadio) mode = checkedRadio.value;
      updateUI();

      // Restore saved input
      if (window.ztPersist) {
        var _urlSaved = window.ztPersist.load('url-encode')['input'];
        if (_urlSaved) inputEl.value = _urlSaved;
      }

      // Real-time encode/decode (debounced 300ms) + save at 500ms
      var _urlLiveTimer = null;
      var _urlSaveTimer = null;
      inputEl.addEventListener('input', function () {
        clearTimeout(_urlLiveTimer);
        clearTimeout(_urlSaveTimer);
        _urlLiveTimer = setTimeout(function () {
          var val = inputEl.value;
          if (!val) { clearStatus(); return; }
          try {
            var result = mode === 'encode'
              ? encodeURIComponent(val)
              : decodeURIComponent(val);
            outputEl.value = result;
            lastValidUrlOutput = result;
            setStatus(mode === 'encode' ? t.encodedOk : t.decodedOk, false);
          } catch (e) {
            setStatus('Error: ' + e.message, true);
          }
        }, 300);
        _urlSaveTimer = setTimeout(function () {
          if (window.ztPersist) window.ztPersist.save('url-encode', { input: inputEl.value });
        }, 500);
      });

      document.querySelectorAll('input[name="urlmode"]').forEach(function (r) {
        r.addEventListener('change', function () {
          mode = this.value;
          updateUI();
          clearStatus();
          outputEl.value = '';
          lastValidUrlOutput = '';
        });
      });

      runBtn.addEventListener('click', function () {
        var val = inputEl.value;
        if (!val) { clearStatus(); return; }
        try {
          outputEl.value = mode === 'encode'
            ? encodeURIComponent(val)
            : decodeURIComponent(val);
          lastValidUrlOutput = outputEl.value;
          setStatus(mode === 'encode' ? t.encodedOk : t.decodedOk, false);
          window.trackTool && window.trackTool('url_encode', mode);
        } catch (e) {
          setStatus('Error: ' + e.message, true);
        }
      });

      document.getElementById('url-swap').addEventListener('click', function () {
        var tmp = inputEl.value;
        inputEl.value = outputEl.value;
        outputEl.value = tmp;
        clearStatus();
      });

      document.getElementById('url-clear').addEventListener('click', function () {
        clearTimeout(_urlSaveTimer);
        inputEl.value = '';
        outputEl.value = '';
        clearStatus();
        if (window.ztPersist) window.ztPersist.clear('url-encode');
      });

      copyBtn.addEventListener('click', function () {
        if (!outputEl.value) return;
        navigator.clipboard.writeText(outputEl.value).then(function () {
          copyBtn.textContent = t.copied;
          setTimeout(function () { copyBtn.textContent = t.copy; }, 1500);
        });
      });
    })();
  </script>
</div>

<style>
  .url-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .url-mode { display: flex; gap: 1.5rem; font-size: 0.95rem; }
  .url-mode label { display: flex; align-items: center; gap: 0.4rem; cursor: pointer; }

  .url-row { display: flex; flex-direction: column; gap: 0.4rem; }

  .url-row label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .url-row textarea {
    width: 100%;
    min-height: 120px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .url-row textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .url-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .url-status { font-size: 0.85rem; min-height: 1.2rem; }
  .url-status.success { color: #057a55; }
  .url-status.error { color: #c0392b; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .url-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .url-status.error { color: #f87171; }
  }
  [data-theme="dark"] .url-status.success { color: #34d399; }
  [data-theme="dark"] .url-status.error { color: #f87171; }
</style>
