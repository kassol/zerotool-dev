---
// YamlValidatorTool — validate YAML syntax with detailed error messages and structure preview
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    inputLabel: 'YAML Input',
    clear: 'Clear',
    validate: 'Validate',
    parsedStructure: 'Parsed Structure',
    copyJson: 'Copy JSON',
    copied: 'Copied!',
    msgEmpty: 'Paste YAML above and click Validate.',
    msgLibMissing: 'YAML library not loaded. Please check your network connection.',
    msgValid: 'Valid YAML \u2014 no errors found.',
    msgInvalid: 'Invalid YAML \u2014 see error details below.',
  },
  zh: {
    inputLabel: 'YAML 输入',
    clear: '清除',
    validate: '验证',
    parsedStructure: '解析结构',
    copyJson: '复制 JSON',
    copied: '已复制！',
    msgEmpty: '在上方粘贴 YAML 内容，然后点击验证。',
    msgLibMissing: 'YAML 库未加载，请检查网络连接。',
    msgValid: 'YAML 有效 \u2014 未发现错误。',
    msgInvalid: 'YAML 无效 \u2014 请查看下方错误详情。',
  },
  ja: {
    inputLabel: 'YAML 入力',
    clear: 'クリア',
    validate: '検証',
    parsedStructure: '解析結果',
    copyJson: 'JSON をコピー',
    copied: 'コピーしました！',
    msgEmpty: '上に YAML を貼り付けて検証をクリックしてください。',
    msgLibMissing: 'YAML ライブラリが読み込まれていません。ネットワーク接続を確認してください。',
    msgValid: 'YAML は有効です \u2014 エラーなし。',
    msgInvalid: 'YAML は無効です \u2014 下のエラー詳細を確認してください。',
  },
  ko: {
    inputLabel: 'YAML 입력',
    clear: '지우기',
    validate: '검증',
    parsedStructure: '파싱 구조',
    copyJson: 'JSON 복사',
    copied: '복사됨!',
    msgEmpty: '위에 YAML을 붙여넣고 검증을 클릭하세요.',
    msgLibMissing: 'YAML 라이브러리가 로드되지 않았습니다. 네트워크 연결을 확인하세요.',
    msgValid: 'YAML 유효 \u2014 오류 없음.',
    msgInvalid: 'YAML 유효하지 않음 \u2014 아래 오류 세부사항을 확인하세요.',
  },
};

const L = labels[lang];
---

<div>
  <div
    class="yv-wrap"
    data-msg-empty={L.msgEmpty}
    data-msg-lib-missing={L.msgLibMissing}
    data-msg-valid={L.msgValid}
    data-msg-invalid={L.msgInvalid}
    data-copy-json={L.copyJson}
    data-copied={L.copied}
  >
    <div class="yv-input-section">
      <label for="yv-input">
        <span>{L.inputLabel}</span>
        <button id="yv-clear" class="btn-ghost" type="button">{L.clear}</button>
      </label>
      <textarea
        id="yv-input"
        placeholder={"name: Alice\nage: 30\naddress:\n  city: Wonderland\n  zip: '00000'\nhobbies:\n  - reading\n  - hiking"}
        spellcheck="false"
      ></textarea>
    </div>

    <div class="yv-actions">
      <button id="yv-validate" class="btn-primary" type="button">{L.validate}</button>
    </div>

    <div id="yv-status" class="yv-status" aria-live="polite"></div>

    <div id="yv-error-box" class="yv-error-box" style="display:none"></div>

    <div id="yv-preview" class="yv-preview" style="display:none">
      <div class="yv-preview-header">
        <span>{L.parsedStructure}</span>
        <button id="yv-copy-preview" class="btn-copy" type="button">{L.copyJson}</button>
      </div>
      <pre id="yv-preview-content" class="yv-preview-content"></pre>
    </div>
  </div>

  <script>
    import jsyaml from 'js-yaml';

    const inputEl   = document.getElementById('yv-input') as HTMLTextAreaElement;
    const statusEl  = document.getElementById('yv-status')!;
    const errorBox  = document.getElementById('yv-error-box')!;
    const previewEl = document.getElementById('yv-preview')!;
    const previewContent = document.getElementById('yv-preview-content')!;
    const validateBtn    = document.getElementById('yv-validate')!;
    const clearBtn       = document.getElementById('yv-clear')!;
    const copyPreviewBtn = document.getElementById('yv-copy-preview')!;
    const wrapEl = document.querySelector('.yv-wrap') as HTMLElement;

    const MSG_EMPTY   = wrapEl.dataset.msgEmpty!;
    const MSG_VALID   = wrapEl.dataset.msgValid!;
    const MSG_INVALID = wrapEl.dataset.msgInvalid!;
    const COPY_JSON   = wrapEl.dataset.copyJson!;
    const COPIED      = wrapEl.dataset.copied!;

    function setStatus(msg: string, type: string) {
      statusEl.textContent = msg;
      statusEl.className = 'yv-status ' + (type || '');
    }

    function clearAll() {
      setStatus('', '');
      errorBox.style.display = 'none';
      errorBox.innerHTML = '';
      previewEl.style.display = 'none';
      previewContent.textContent = '';
    }

    function parseYamlError(e: any) {
      const msg = e.message || String(e);
      const reasonMatch = msg.match(/^([^\n]+?)(?:\s+at line\s+(\d+),\s+column\s+(\d+))?[:\n]/);
      const reason = reasonMatch ? reasonMatch[1].trim() : msg.split('\n')[0].trim();
      const line   = e.mark && e.mark.line   != null ? e.mark.line + 1   : null;
      const col    = e.mark && e.mark.column != null ? e.mark.column + 1 : null;
      const nlIdx  = msg.indexOf('\n');
      const snippet = nlIdx !== -1 ? msg.slice(nlIdx + 1).trim() : null;
      return { reason, line, col, snippet };
    }

    function escapeHtml(str: string) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    function buildErrorHtml(info: { reason: string; line: number | null; col: number | null; snippet: string | null }) {
      let html = '<div class="yv-err-title">Syntax Error</div>';
      html += '<div class="yv-err-reason">' + escapeHtml(info.reason) + '</div>';
      if (info.line != null) {
        html += '<div class="yv-err-location">Line ' + info.line;
        if (info.col != null) html += ', Column ' + info.col;
        html += '</div>';
      }
      if (info.snippet) {
        html += '<pre class="yv-err-snippet">' + escapeHtml(info.snippet) + '</pre>';
      }
      return html;
    }

    function doValidate() {
      const text = inputEl.value;
      if (!text.trim()) {
        clearAll();
        setStatus(MSG_EMPTY, '');
        return;
      }
      try {
        const parsed = jsyaml.load(text);
        errorBox.style.display = 'none';
        errorBox.innerHTML = '';
        const jsonStr = JSON.stringify(parsed, null, 2);
        previewContent.textContent = jsonStr;
        previewEl.style.display = '';
        setStatus(MSG_VALID, 'success');
        (window as any).trackTool?.('yaml-validator', 'validate_success');
      } catch (e) {
        previewEl.style.display = 'none';
        previewContent.textContent = '';
        const info = parseYamlError(e);
        errorBox.innerHTML = buildErrorHtml(info);
        errorBox.style.display = '';
        setStatus(MSG_INVALID, 'error');
        (window as any).trackTool?.('yaml-validator', 'validate_error');
      }
    }

    /* Prevent textarea blur before click fires (eliminates first-click race) */
    validateBtn.addEventListener('mousedown', (e) => e.preventDefault());
    validateBtn.addEventListener('click', doValidate);

    clearBtn.addEventListener('click', () => {
      inputEl.value = '';
      clearAll();
    });

    copyPreviewBtn.addEventListener('click', () => {
      if (!previewContent.textContent) return;
      navigator.clipboard.writeText(previewContent.textContent).then(() => {
        copyPreviewBtn.textContent = COPIED;
        setTimeout(() => { copyPreviewBtn.textContent = COPY_JSON; }, 1500);
      });
    });

    /* Keyboard shortcut: Ctrl/Cmd+Enter */
    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) doValidate();
    });

    /* Auto-validate on load if pre-filled */
    if (inputEl.value.trim()) doValidate();
  </script>
</div>

<style>
  .yv-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .yv-input-section { display: flex; flex-direction: column; gap: 0.4rem; }

  .yv-input-section label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #yv-input {
    width: 100%;
    min-height: 200px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
    line-height: 1.5;
  }

  #yv-input:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .yv-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .yv-status { font-size: 0.85rem; min-height: 1.2rem; }
  .yv-status.success { color: #057a55; }
  .yv-status.error   { color: #c0392b; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .yv-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .yv-status.error   { color: #f87171; }
  }
  [data-theme="dark"] .yv-status.success { color: #34d399; }
  [data-theme="dark"] .yv-status.error   { color: #f87171; }

  /* Error box */
  .yv-error-box {
    border: 1px solid rgba(192, 57, 43, 0.4);
    border-left: 3px solid #c0392b;
    border-radius: var(--radius-sm);
    background: rgba(192, 57, 43, 0.05);
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .yv-error-box {
      border-color: rgba(248, 113, 113, 0.3);
      border-left-color: #f87171;
      background: rgba(248, 113, 113, 0.07);
    }
  }
  [data-theme="dark"] .yv-error-box {
    border-color: rgba(248, 113, 113, 0.3);
    border-left-color: #f87171;
    background: rgba(248, 113, 113, 0.07);
  }

  .yv-err-title {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #c0392b;
  }

  [data-theme="dark"] .yv-err-title { color: #f87171; }

  .yv-err-reason { font-size: 0.88rem; font-weight: 600; color: var(--color-text); }

  .yv-err-location {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }

  .yv-err-snippet {
    margin: 0.25rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    white-space: pre;
    overflow-x: auto;
    color: var(--color-text-secondary);
    background: transparent;
    padding: 0;
    border: none;
  }

  /* Preview */
  .yv-preview {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .yv-preview-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0.75rem;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .yv-preview-content {
    margin: 0;
    padding: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--color-text);
    background: var(--color-bg);
    overflow-x: auto;
    max-height: 320px;
    white-space: pre;
  }
</style>
