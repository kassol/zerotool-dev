---
// No props needed — tool widget is language-independent
---

<div>
  <div class="wc-wrap">
    <div class="wc-row">
      <label for="wc-input" data-i18n="inputText">Input Text</label>
      <textarea
        id="wc-input"
        class="tool-textarea"
        data-i18n-ph="inputPlaceholder"
        placeholder="Type or paste your text here..."
        rows="8"
        spellcheck="false"
      ></textarea>
    </div>

    <div class="wc-stats" id="wc-stats">
      <div class="wc-stat">
        <span class="wc-stat-value" id="wc-chars">0</span>
        <span class="wc-stat-label" data-i18n="characters">Characters</span>
      </div>
      <div class="wc-stat">
        <span class="wc-stat-value" id="wc-chars-no-spaces">0</span>
        <span class="wc-stat-label" data-i18n="charsNoSpaces">Characters (no spaces)</span>
      </div>
      <div class="wc-stat">
        <span class="wc-stat-value" id="wc-words">0</span>
        <span class="wc-stat-label" data-i18n="words">Words</span>
      </div>
      <div class="wc-stat">
        <span class="wc-stat-value" id="wc-sentences">0</span>
        <span class="wc-stat-label" data-i18n="sentences">Sentences</span>
      </div>
      <div class="wc-stat">
        <span class="wc-stat-value" id="wc-paragraphs">0</span>
        <span class="wc-stat-label" data-i18n="paragraphs">Paragraphs</span>
      </div>
      <div class="wc-stat">
        <span class="wc-stat-value" id="wc-read-time">0 min</span>
        <span class="wc-stat-label" data-i18n="readingTime">Reading Time</span>
      </div>
      <div class="wc-stat">
        <span class="wc-stat-value" id="wc-speak-time">0 min</span>
        <span class="wc-stat-label" data-i18n="speakingTime">Speaking Time</span>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: {
          inputText: 'Input Text', inputPlaceholder: 'Type or paste your text here...',
          characters: 'Characters', charsNoSpaces: 'Characters (no spaces)',
          words: 'Words', sentences: 'Sentences', paragraphs: 'Paragraphs',
          readingTime: 'Reading Time', speakingTime: 'Speaking Time'
        },
        zh: {
          inputText: '输入文本', inputPlaceholder: '在此输入或粘贴文本...',
          characters: '字符数', charsNoSpaces: '字符数（不含空格）',
          words: '单词数', sentences: '句子数', paragraphs: '段落数',
          readingTime: '阅读时间', speakingTime: '朗读时间'
        },
        ja: {
          inputText: '入力テキスト', inputPlaceholder: 'テキストを入力または貼り付け...',
          characters: '文字数', charsNoSpaces: '文字数（空白除く）',
          words: '単語数', sentences: '文の数', paragraphs: '段落数',
          readingTime: '読書時間', speakingTime: 'スピーキング時間'
        },
        ko: {
          inputText: '입력 텍스트', inputPlaceholder: '텍스트를 입력하거나 붙여넣으세요...',
          characters: '문자 수', charsNoSpaces: '문자 수 (공백 제외)',
          words: '단어 수', sentences: '문장 수', paragraphs: '단락 수',
          readingTime: '읽기 시간', speakingTime: '말하기 시간'
        }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });
      document.querySelectorAll('[data-i18n-ph]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-ph'); if (t[key]) el.placeholder = t[key];
      });

      var inputEl = document.getElementById('wc-input');

      var ids = {
        chars: document.getElementById('wc-chars'),
        charsNoSpaces: document.getElementById('wc-chars-no-spaces'),
        words: document.getElementById('wc-words'),
        sentences: document.getElementById('wc-sentences'),
        paragraphs: document.getElementById('wc-paragraphs'),
        readTime: document.getElementById('wc-read-time'),
        speakTime: document.getElementById('wc-speak-time'),
      };

      function formatTime(minutes) {
        if (minutes < 1) return '< 1 min';
        if (minutes < 60) return Math.ceil(minutes) + ' min';
        var h = Math.floor(minutes / 60);
        var m = Math.ceil(minutes % 60);
        return h + ' hr ' + m + ' min';
      }

      function countWords(text) {
        var trimmed = text.trim();
        if (!trimmed) return 0;
        return trimmed.split(/\s+/).length;
      }

      function countSentences(text) {
        var trimmed = text.trim();
        if (!trimmed) return 0;
        var matches = trimmed.match(/[.!?…]+[\s"'»）)]*(?=[A-Z\u4e00-\u9fff]|$)/g);
        return matches ? matches.length : (trimmed.length > 0 ? 1 : 0);
      }

      function countParagraphs(text) {
        var trimmed = text.trim();
        if (!trimmed) return 0;
        return trimmed.split(/\n\s*\n/).filter(function (p) {
          return p.trim().length > 0;
        }).length || (trimmed.length > 0 ? 1 : 0);
      }

      function update() {
        var text = inputEl.value;
        var words = countWords(text);

        ids.chars.textContent = text.length;
        ids.charsNoSpaces.textContent = text.replace(/\s/g, '').length;
        ids.words.textContent = words;
        ids.sentences.textContent = countSentences(text);
        ids.paragraphs.textContent = countParagraphs(text);
        ids.readTime.textContent = words === 0 ? '0 min' : formatTime(words / 200);
        ids.speakTime.textContent = words === 0 ? '0 min' : formatTime(words / 130);

        window.trackTool && window.trackTool('word_counter', 'count');
      }

      inputEl.addEventListener('input', update);
    })();
  </script>
</div>

<style>
  .wc-wrap { display: flex; flex-direction: column; gap: 1rem; }

  .wc-row { display: flex; flex-direction: column; gap: 0.4rem; }

  .wc-row label { font-size: 0.85rem; font-weight: 600; color: var(--color-text-secondary); }

  .wc-stats {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.75rem;
  }

  .wc-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 1rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    transition: border-color var(--transition-fast);
  }

  .wc-stat:hover { border-color: var(--color-primary); }

  .wc-stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    font-family: var(--font-mono);
  }

  .wc-stat-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-align: center;
  }

  @media (max-width: 500px) {
    .wc-stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>
