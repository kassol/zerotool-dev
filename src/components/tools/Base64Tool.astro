---
// No props needed — tool widget is language-independent
---

<div>
  <div class="b64-wrap">
    <!-- Mode + variant row -->
    <div class="b64-controls">
      <div class="b64-mode">
        <label>
          <input type="radio" name="b64mode" value="encode" checked /> Encode
        </label>
        <label>
          <input type="radio" name="b64mode" value="decode" /> Decode
        </label>
      </div>
      <div class="b64-variant">
        <label>
          <input type="radio" name="b64variant" value="standard" checked /> Standard
        </label>
        <label>
          <input type="radio" name="b64variant" value="urlsafe" /> URL-safe
        </label>
      </div>
    </div>

    <!-- File drop zone (encode mode only) -->
    <div id="b64-drop" class="b64-drop" role="button" tabindex="0" aria-label="Drop file here or click to select">
      <div class="b64-drop-inner">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
        </svg>
        <span>Drop any file here, or <strong>click to select</strong></span>
      </div>
      <input type="file" id="b64-file" class="b64-file-input" aria-label="Select file" />
    </div>

    <!-- File info (shown after file dropped) -->
    <div id="b64-file-info" class="b64-file-info" hidden></div>

    <!-- Data URI toggle (encode mode + file loaded only) -->
    <div id="b64-uri-row" class="b64-uri-row" hidden>
      <label>
        <input type="checkbox" id="b64-uri-toggle" />
        Include Data URI prefix (<code>data:&lt;mime&gt;;base64,…</code>)
      </label>
    </div>

    <div class="b64-row">
      <label for="b64-input" id="b64-input-label"><span>Plain Text</span></label>
      <textarea
        id="b64-input"
        placeholder="Enter text to encode..."
        spellcheck="false"
      ></textarea>
    </div>

    <div class="b64-actions">
      <button id="b64-run" class="btn-primary">Encode</button>
      <button id="b64-swap" class="btn-secondary">Swap</button>
      <button id="b64-clear" class="btn-ghost">Clear</button>
    </div>

    <div id="b64-status" class="b64-status" aria-live="polite"></div>

    <div class="b64-row">
      <label for="b64-output" id="b64-output-label">
        <span>Base64</span>
        <button id="b64-copy" class="btn-copy" type="button">Copy</button>
      </label>
      <textarea
        id="b64-output"
        placeholder="Result appears here..."
        readonly
        spellcheck="false"
      ></textarea>
    </div>
  </div>

  <script is:inline>
    (function () {
      var inputEl = document.getElementById('b64-input');
      var outputEl = document.getElementById('b64-output');
      var statusEl = document.getElementById('b64-status');
      var runBtn = document.getElementById('b64-run');
      var copyBtn = document.getElementById('b64-copy');
      var inputLabel = document.getElementById('b64-input-label');
      var outputLabel = document.getElementById('b64-output-label');
      var dropEl = document.getElementById('b64-drop');
      var fileInput = document.getElementById('b64-file');
      var fileInfoEl = document.getElementById('b64-file-info');
      var uriRowEl = document.getElementById('b64-uri-row');
      var uriToggle = document.getElementById('b64-uri-toggle');
      var mode = 'encode';
      var variant = 'standard';
      var rawB64 = '';
      var currentMime = '';

      function setStatus(msg, isError) {
        statusEl.textContent = msg;
        statusEl.className = 'b64-status ' + (isError ? 'error' : 'success');
      }

      function clearStatus() {
        statusEl.textContent = '';
        statusEl.className = 'b64-status';
      }

      function toUrlSafe(b64) {
        return b64.replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
      }

      function fromUrlSafe(b64url) {
        var b64 = b64url.replace(/-/g, '+').replace(/_/g, '/');
        // restore padding
        var pad = b64.length % 4;
        if (pad === 2) b64 += '==';
        else if (pad === 3) b64 += '=';
        return b64;
      }

      function encodeText(text) {
        var b64 = btoa(unescape(encodeURIComponent(text)));
        return variant === 'urlsafe' ? toUrlSafe(b64) : b64;
      }

      function decodeText(input) {
        var b64 = variant === 'urlsafe' ? fromUrlSafe(input.trim()) : input.trim();
        return decodeURIComponent(escape(atob(b64)));
      }

      function arrayBufferToBase64(buffer) {
        var bytes = new Uint8Array(buffer);
        var binary = '';
        var chunk = 8192;
        for (var i = 0; i < bytes.length; i += chunk) {
          binary += String.fromCharCode.apply(null, bytes.subarray(i, i + chunk));
        }
        return btoa(binary);
      }

      function formatBytes(n) {
        if (n < 1024) return n + ' B';
        if (n < 1048576) return (n / 1024).toFixed(1) + ' KB';
        return (n / 1048576).toFixed(2) + ' MB';
      }

      function esc(s) {
        var d = document.createElement('span');
        d.textContent = s;
        return d.innerHTML;
      }

      function updateLabels() {
        if (mode === 'encode') {
          inputLabel.querySelector('span').textContent = 'Plain Text';
          outputLabel.querySelector('span').textContent = 'Base64';
          inputEl.placeholder = 'Enter text to encode...';
          outputEl.placeholder = 'Base64 output appears here...';
          runBtn.textContent = 'Encode';
          dropEl.hidden = false;
        } else {
          inputLabel.querySelector('span').textContent = 'Base64';
          outputLabel.querySelector('span').textContent = 'Plain Text';
          inputEl.placeholder = 'Enter Base64 string to decode...';
          outputEl.placeholder = 'Decoded text appears here...';
          runBtn.textContent = 'Decode';
          dropEl.hidden = true;
          fileInfoEl.hidden = true;
        }
      }

      function applyUriPrefix(b64) {
        return uriToggle.checked && currentMime
          ? 'data:' + currentMime + ';base64,' + b64
          : b64;
      }

      function processFile(file) {
        if (file.size > 5 * 1024 * 1024) {
          setStatus('Large file — encoding may take a few seconds', false);
        }
        var reader = new FileReader();
        reader.onload = function (e) {
          var b64 = arrayBufferToBase64(e.target.result);
          if (variant === 'urlsafe') b64 = toUrlSafe(b64);
          rawB64 = b64;
          currentMime = file.type || 'application/octet-stream';
          outputEl.value = applyUriPrefix(b64);
          inputEl.value = '';
          inputEl.placeholder = 'File loaded — text input cleared';
          fileInfoEl.innerHTML =
            '<strong>' + esc(file.name) + '</strong> &mdash; ' +
            esc(currentMime) + ' &mdash; ' + formatBytes(file.size);
          fileInfoEl.hidden = false;
          uriRowEl.hidden = false;
          setStatus('File encoded.', false);
          window.trackTool && window.trackTool('base64', 'encode_file');
        };
        reader.onerror = function () {
          setStatus('Failed to read file.', true);
        };
        reader.readAsArrayBuffer(file);
      }

      uriToggle.addEventListener('change', function () {
        if (rawB64) outputEl.value = applyUriPrefix(rawB64);
      });

      // Restore saved input
      if (window.__ztLoadInput) {
        var _b64Saved = window.__ztLoadInput('base64', 'input');
        if (_b64Saved) inputEl.value = _b64Saved;
      }

      // Save input on change (debounced 500ms)
      var _b64SaveTimer = null;
      inputEl.addEventListener('input', function () {
        clearTimeout(_b64SaveTimer);
        _b64SaveTimer = setTimeout(function () {
          if (window.__ztSaveInput) window.__ztSaveInput('base64', 'input', inputEl.value);
        }, 500);
      });

      document.querySelectorAll('input[name="b64mode"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
          mode = this.value;
          updateLabels();
          clearStatus();
          outputEl.value = '';
          rawB64 = '';
          currentMime = '';
          uriRowEl.hidden = true;
          uriToggle.checked = false;
        });
      });

      document.querySelectorAll('input[name="b64variant"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
          variant = this.value;
        });
      });

      runBtn.addEventListener('click', function () {
        var val = inputEl.value;
        if (!val) { clearStatus(); outputEl.value = ''; return; }
        try {
          if (mode === 'encode') {
            outputEl.value = encodeText(val);
            setStatus('Encoded.', false);
            window.trackTool && window.trackTool('base64', 'encode');
          } else {
            outputEl.value = decodeText(val);
            setStatus('Decoded.', false);
            window.trackTool && window.trackTool('base64', 'decode');
          }
        } catch (e) {
          outputEl.value = '';
          setStatus('Error: ' + e.message, true);
        }
      });

      document.getElementById('b64-swap').addEventListener('click', function () {
        var tmp = inputEl.value;
        inputEl.value = outputEl.value;
        outputEl.value = tmp;
        fileInfoEl.hidden = true;
        uriRowEl.hidden = true;
        uriToggle.checked = false;
        rawB64 = '';
        currentMime = '';
        inputEl.placeholder = mode === 'encode' ? 'Enter text to encode...' : 'Enter Base64 string to decode...';
        clearStatus();
      });

      document.getElementById('b64-clear').addEventListener('click', function () {
        inputEl.value = '';
        outputEl.value = '';
        fileInput.value = '';
        fileInfoEl.hidden = true;
        uriRowEl.hidden = true;
        uriToggle.checked = false;
        rawB64 = '';
        currentMime = '';
        inputEl.placeholder = mode === 'encode' ? 'Enter text to encode...' : 'Enter Base64 string to decode...';
        clearStatus();
      });

      copyBtn.addEventListener('click', function () {
        if (!outputEl.value) return;
        navigator.clipboard.writeText(outputEl.value).then(function () {
          copyBtn.textContent = 'Copied!';
          setTimeout(function () { copyBtn.textContent = 'Copy'; }, 1500);
        });
      });

      /* ── Drop zone ── */
      dropEl.addEventListener('click', function (e) {
        if (e.target !== fileInput) fileInput.click();
      });

      dropEl.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
      });

      fileInput.addEventListener('change', function () {
        if (this.files && this.files[0]) processFile(this.files[0]);
      });

      dropEl.addEventListener('dragover', function (e) {
        e.preventDefault();
        dropEl.classList.add('drag-over');
      });

      dropEl.addEventListener('dragleave', function (e) {
        if (!dropEl.contains(e.relatedTarget)) dropEl.classList.remove('drag-over');
      });

      dropEl.addEventListener('drop', function (e) {
        e.preventDefault();
        dropEl.classList.remove('drag-over');
        var file = e.dataTransfer.files[0];
        if (file) processFile(file);
      });
    })();
  </script>
</div>

<style>
  .b64-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .b64-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .b64-mode,
  .b64-variant { display: flex; gap: 1.25rem; font-size: 0.95rem; }
  .b64-mode label,
  .b64-variant label { display: flex; align-items: center; gap: 0.4rem; cursor: pointer; }

  .b64-variant {
    font-size: 0.88rem;
    color: var(--color-text-secondary);
  }

  /* Drop zone */
  .b64-drop {
    position: relative;
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.65rem 1rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    background: var(--color-bg-secondary);
  }

  .b64-drop:hover,
  .b64-drop.drag-over {
    border-color: var(--color-primary);
    background: var(--color-bg);
  }

  .b64-drop-inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
    font-size: 0.88rem;
    pointer-events: none;
    user-select: none;
  }

  .b64-file-input {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
  }

  .b64-file-info {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    padding: 0.25rem 0;
  }

  .b64-uri-row {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .b64-uri-row label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
  }

  .b64-uri-row code {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .b64-row { display: flex; flex-direction: column; gap: 0.4rem; }

  .b64-row label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .b64-row textarea {
    width: 100%;
    min-height: 140px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .b64-row textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .b64-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .b64-status { font-size: 0.85rem; min-height: 1.2rem; }
  .b64-status.success { color: #057a55; }
  .b64-status.error { color: #c0392b; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .b64-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .b64-status.error { color: #f87171; }
  }
  [data-theme="dark"] .b64-status.success { color: #34d399; }
  [data-theme="dark"] .b64-status.error { color: #f87171; }
</style>
