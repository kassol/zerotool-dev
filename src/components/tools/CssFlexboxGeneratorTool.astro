---
// CssFlexboxGeneratorTool — visual Flexbox layout builder
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    direction: 'flex-direction',
    wrap: 'flex-wrap',
    justifyContent: 'justify-content',
    alignItems: 'align-items',
    alignContent: 'align-content',
    gap: 'gap',
    itemCount: 'Items',
    preview: 'Preview',
    outputLabel: 'Generated CSS',
    copy: 'Copy',
    copied: 'Copied!',
  },
  zh: {
    direction: 'flex-direction',
    wrap: 'flex-wrap',
    justifyContent: 'justify-content',
    alignItems: 'align-items',
    alignContent: 'align-content',
    gap: '间距',
    itemCount: '子项数量',
    preview: '预览',
    outputLabel: '生成的 CSS',
    copy: '复制',
    copied: '已复制！',
  },
  ja: {
    direction: 'flex-direction',
    wrap: 'flex-wrap',
    justifyContent: 'justify-content',
    alignItems: 'align-items',
    alignContent: 'align-content',
    gap: 'ギャップ',
    itemCount: 'アイテム数',
    preview: 'プレビュー',
    outputLabel: '生成された CSS',
    copy: 'コピー',
    copied: 'コピーしました！',
  },
  ko: {
    direction: 'flex-direction',
    wrap: 'flex-wrap',
    justifyContent: 'justify-content',
    alignItems: 'align-items',
    alignContent: 'align-content',
    gap: '간격',
    itemCount: '아이템 수',
    preview: '미리보기',
    outputLabel: '생성된 CSS',
    copy: '복사',
    copied: '복사됨!',
  },
};

const L = labels[lang] ?? labels['en'];
---

<div
  class="cfg-wrap"
  data-copy={L.copy}
  data-copied={L.copied}
>
  <!-- Controls -->
  <div class="cfg-controls">
    <!-- flex-direction -->
    <div class="cfg-field">
      <label class="cfg-label" for="cfg-direction">{L.direction}</label>
      <select id="cfg-direction" class="cfg-select">
        <option value="row" selected>row</option>
        <option value="row-reverse">row-reverse</option>
        <option value="column">column</option>
        <option value="column-reverse">column-reverse</option>
      </select>
    </div>
    <!-- flex-wrap -->
    <div class="cfg-field">
      <label class="cfg-label" for="cfg-wrap">{L.wrap}</label>
      <select id="cfg-wrap" class="cfg-select">
        <option value="nowrap" selected>nowrap</option>
        <option value="wrap">wrap</option>
        <option value="wrap-reverse">wrap-reverse</option>
      </select>
    </div>
    <!-- justify-content -->
    <div class="cfg-field">
      <label class="cfg-label" for="cfg-justify">{L.justifyContent}</label>
      <select id="cfg-justify" class="cfg-select">
        <option value="flex-start" selected>flex-start</option>
        <option value="flex-end">flex-end</option>
        <option value="center">center</option>
        <option value="space-between">space-between</option>
        <option value="space-around">space-around</option>
        <option value="space-evenly">space-evenly</option>
      </select>
    </div>
    <!-- align-items -->
    <div class="cfg-field">
      <label class="cfg-label" for="cfg-align-items">{L.alignItems}</label>
      <select id="cfg-align-items" class="cfg-select">
        <option value="flex-start" selected>flex-start</option>
        <option value="flex-end">flex-end</option>
        <option value="center">center</option>
        <option value="stretch">stretch</option>
        <option value="baseline">baseline</option>
      </select>
    </div>
    <!-- align-content -->
    <div class="cfg-field">
      <label class="cfg-label" for="cfg-align-content">{L.alignContent}</label>
      <select id="cfg-align-content" class="cfg-select">
        <option value="flex-start" selected>flex-start</option>
        <option value="flex-end">flex-end</option>
        <option value="center">center</option>
        <option value="stretch">stretch</option>
        <option value="space-between">space-between</option>
        <option value="space-around">space-around</option>
      </select>
    </div>
    <!-- gap -->
    <div class="cfg-field">
      <label class="cfg-label" for="cfg-gap">{L.gap}</label>
      <input id="cfg-gap" class="cfg-text-input" type="text" value="1rem" spellcheck="false" autocomplete="off" />
    </div>
    <!-- item count -->
    <div class="cfg-field">
      <label class="cfg-label" for="cfg-items">{L.itemCount}</label>
      <input id="cfg-items" class="cfg-num-input" type="number" min="1" max="8" value="4" />
    </div>
  </div>

  <!-- Preview -->
  <div class="cfg-section">
    <div class="cfg-section-label">{L.preview}</div>
    <div id="cfg-preview" class="cfg-preview"></div>
  </div>

  <!-- CSS Output -->
  <div class="cfg-section">
    <div class="cfg-output-header">
      <span class="cfg-section-label">{L.outputLabel}</span>
      <button id="cfg-copy" class="btn-copy" type="button">{L.copy}</button>
    </div>
    <pre id="cfg-pre" class="cfg-pre"><code id="cfg-code" class="cfg-code"></code></pre>
  </div>

  <script is:inline>
    (function () {
      var wrap = document.currentScript
        ? document.currentScript.closest('.cfg-wrap')
        : document.querySelector('.cfg-wrap');

      var COPY_LABEL   = wrap.dataset.copy;
      var COPIED_LABEL = wrap.dataset.copied;

      var dirEl     = document.getElementById('cfg-direction');
      var wrapEl    = document.getElementById('cfg-wrap');
      var justEl    = document.getElementById('cfg-justify');
      var aItemsEl  = document.getElementById('cfg-align-items');
      var aContEl   = document.getElementById('cfg-align-content');
      var gapEl     = document.getElementById('cfg-gap');
      var itemsEl   = document.getElementById('cfg-items');
      var previewEl = document.getElementById('cfg-preview');
      var codeEl    = document.getElementById('cfg-code');
      var copyBtn   = document.getElementById('cfg-copy');

      var CELL_COLORS = [
        '#bfdbfe','#bbf7d0','#fde68a','#fecaca',
        '#ddd6fe','#fed7aa','#a7f3d0','#e9d5ff',
      ];

      function update() {
        var dir        = dirEl.value;
        var flexWrap   = wrapEl.value;
        var justify    = justEl.value;
        var alignItems = aItemsEl.value;
        var alignCont  = aContEl.value;
        var gap        = gapEl.value.trim() || '1rem';
        var count      = Math.max(1, Math.min(8, parseInt(itemsEl.value) || 4));

        /* Update preview */
        previewEl.style.display        = 'flex';
        previewEl.style.flexDirection  = dir;
        previewEl.style.flexWrap       = flexWrap;
        previewEl.style.justifyContent = justify;
        previewEl.style.alignItems     = alignItems;
        previewEl.style.alignContent   = alignCont;
        previewEl.style.gap            = gap;

        /* Rebuild children */
        var existing = previewEl.querySelectorAll('.cfg-cell');
        while (existing.length > count) {
          previewEl.removeChild(previewEl.lastChild);
          existing = previewEl.querySelectorAll('.cfg-cell');
        }
        while (existing.length < count) {
          var cell = document.createElement('div');
          cell.className = 'cfg-cell';
          cell.style.background = CELL_COLORS[existing.length % CELL_COLORS.length];
          cell.textContent = existing.length + 1;
          previewEl.appendChild(cell);
          existing = previewEl.querySelectorAll('.cfg-cell');
        }

        /* Build CSS */
        var lines = [
          '.container {',
          '  display: flex;',
          '  flex-direction: ' + dir + ';',
          '  flex-wrap: ' + flexWrap + ';',
          '  justify-content: ' + justify + ';',
          '  align-items: ' + alignItems + ';',
          '  align-content: ' + alignCont + ';',
          '  gap: ' + gap + ';',
          '}',
        ];
        var raw = lines.join('\n');
        var highlighted = raw
          .replace(/(\{|\})/g,        '<span class="cfg-hl-brace">$1</span>')
          .replace(/(\.container)/g,  '<span class="cfg-hl-sel">$1</span>')
          .replace(/([\w-]+)(\s*:)/g, '<span class="cfg-hl-prop">$1</span>$2')
          .replace(/(:)(\s*)([^;{}\n]+)(;)/g, '$1$2<span class="cfg-hl-val">$3</span><span class="cfg-hl-semi">$4</span>');
        codeEl.innerHTML = highlighted;

        window.trackTool && window.trackTool('css-flexbox-generator', 'generate');
      }

      [dirEl, wrapEl, justEl, aItemsEl, aContEl].forEach(function (el) {
        el.addEventListener('change', update);
      });
      gapEl.addEventListener('input', update);
      itemsEl.addEventListener('input', update);

      copyBtn.addEventListener('click', function () {
        var text = codeEl.textContent;
        if (!text) return;
        navigator.clipboard.writeText(text).then(function () {
          copyBtn.textContent = COPIED_LABEL;
          setTimeout(function () { copyBtn.textContent = COPY_LABEL; }, 1500);
          window.trackTool && window.trackTool('css-flexbox-generator', 'copy');
        });
      });

      update();
    })();
  </script>
</div>

<style>
  .cfg-wrap { display: flex; flex-direction: column; gap: 1.25rem; }

  .cfg-controls {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.75rem;
  }

  .cfg-field { display: flex; flex-direction: column; gap: 0.3rem; }

  .cfg-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .cfg-select,
  .cfg-text-input,
  .cfg-num-input {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.3rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    width: 100%;
    box-sizing: border-box;
  }

  .cfg-select:focus,
  .cfg-text-input:focus,
  .cfg-num-input:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .cfg-section { display: flex; flex-direction: column; gap: 0.4rem; }

  .cfg-section-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .cfg-output-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Preview */
  .cfg-preview {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.75rem;
    background: var(--color-bg-secondary);
    min-height: 300px;
    max-height: 600px;
  }

  .cfg-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    min-width: 60px;
    min-height: 60px;
    padding: 0.3rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: #374151;
  }

  /* Code output */
  .cfg-pre {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    overflow-x: auto;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.6;
  }

  .cfg-code { font-family: inherit; }

  .cfg-hl-sel   { color: #7c3aed; font-weight: 600; }
  .cfg-hl-brace { color: var(--color-text-secondary); }
  .cfg-hl-prop  { color: #0369a1; }
  .cfg-hl-val   { color: #057a55; }
  .cfg-hl-semi  { color: var(--color-text-secondary); }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .cfg-hl-sel  { color: #a78bfa; }
    :root:not([data-theme="light"]) .cfg-hl-prop { color: #38bdf8; }
    :root:not([data-theme="light"]) .cfg-hl-val  { color: #34d399; }
    :root:not([data-theme="light"]) .cfg-cell { color: #e5e7eb; }
  }
  [data-theme="dark"] .cfg-hl-sel  { color: #a78bfa; }
  [data-theme="dark"] .cfg-hl-prop { color: #38bdf8; }
  [data-theme="dark"] .cfg-hl-val  { color: #34d399; }
  [data-theme="dark"] .cfg-cell { color: #e5e7eb; }

  @media (max-width: 480px) {
    .cfg-preview { min-height: 200px; }
  }
</style>
