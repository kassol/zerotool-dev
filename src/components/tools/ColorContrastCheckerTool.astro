---
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    foreground: 'Foreground',
    background: 'Background',
    swapAria: 'Swap foreground and background',
    contrastRatio: 'Contrast Ratio',
    bodyText: 'Body text',
    bodyHint: '< 18px, or < 14px bold',
    largeText: 'Large text',
    largeHint: '≥ 18.66px bold or ≥ 24px',
    uiComponent: 'UI components & graphics',
    uiHint: 'Borders, icons, focus rings (WCAG 1.4.11)',
    aa: 'AA',
    aaa: 'AAA',
    pass: 'Pass',
    fail: 'Fail',
    nA: '—',
    suggestionTitle: 'Suggested fix to pass body AA (4.5 : 1)',
    suggestionLine: 'Keep hue & chroma, adjust foreground lightness:',
    apply: 'Apply suggestion',
    copyFixed: 'Copy HEX',
    invalidHex: 'Invalid hex color',
    sampleText: 'The quick brown fox jumps over the lazy dog — 0123456789',
    copied: 'Copied!',
  },
  zh: {
    foreground: '前景色',
    background: '背景色',
    swapAria: '交换前景与背景色',
    contrastRatio: '对比度',
    bodyText: '正文',
    bodyHint: '< 18px 或 < 14px 粗体',
    largeText: '大号文字',
    largeHint: '≥ 18.66px 粗体或 ≥ 24px',
    uiComponent: 'UI 组件 & 图形',
    uiHint: '边框、图标、聚焦环（WCAG 1.4.11）',
    aa: 'AA',
    aaa: 'AAA',
    pass: '通过',
    fail: '不通过',
    nA: '—',
    suggestionTitle: '修正建议（满足正文 AA 4.5 : 1）',
    suggestionLine: '保留色相与饱和度，调整前景亮度：',
    apply: '应用修正',
    copyFixed: '复制 HEX',
    invalidHex: '无效的 HEX 颜色',
    sampleText: '永和九年岁在癸丑 The quick brown fox 0123456789',
    copied: '已复制！',
  },
  ja: {
    foreground: '前景色',
    background: '背景色',
    swapAria: '前景と背景を入れ替える',
    contrastRatio: 'コントラスト比',
    bodyText: '本文',
    bodyHint: '< 18px / < 14px 太字',
    largeText: '大きな文字',
    largeHint: '≥ 18.66px 太字 / ≥ 24px',
    uiComponent: 'UI コンポーネント・図形',
    uiHint: '枠線・アイコン・フォーカスリング（WCAG 1.4.11）',
    aa: 'AA',
    aaa: 'AAA',
    pass: '合格',
    fail: '不合格',
    nA: '—',
    suggestionTitle: '修正案（本文 AA 4.5 : 1 達成）',
    suggestionLine: '色相と彩度を保ち、前景の明度を調整：',
    apply: '修正案を適用',
    copyFixed: 'HEX をコピー',
    invalidHex: '不正な HEX カラー',
    sampleText: 'いろはにほへと The quick brown fox 0123456789',
    copied: 'コピーしました！',
  },
  ko: {
    foreground: '전경색',
    background: '배경색',
    swapAria: '전경과 배경 교환',
    contrastRatio: '대비비',
    bodyText: '본문',
    bodyHint: '< 18px 또는 < 14px 굵게',
    largeText: '큰 글자',
    largeHint: '≥ 18.66px 굵게 또는 ≥ 24px',
    uiComponent: 'UI 구성요소 · 그래픽',
    uiHint: '테두리, 아이콘, 포커스 링 (WCAG 1.4.11)',
    aa: 'AA',
    aaa: 'AAA',
    pass: '통과',
    fail: '실패',
    nA: '—',
    suggestionTitle: '수정 제안 (본문 AA 4.5 : 1 통과)',
    suggestionLine: '색상과 채도를 유지하고 전경 명도를 조정:',
    apply: '제안 적용',
    copyFixed: 'HEX 복사',
    invalidHex: '잘못된 HEX 색상',
    sampleText: '동해 물과 백두산이 The quick brown fox 0123456789',
    copied: '복사됨!',
  },
};

const L = labels[lang] ?? labels['en'];
---

<div
  class="ccc-wrap"
  data-copied={L.copied}
  data-invalid-hex={L.invalidHex}
  data-pass={L.pass}
  data-fail={L.fail}
>
  <div class="ccc-inputs">
    <div class="ccc-color-cell">
      <label class="ccc-label" for="ccc-fg-hex">{L.foreground}</label>
      <div class="ccc-color-input">
        <input id="ccc-fg-picker" class="ccc-picker" type="color" value="#1f2937" aria-label={L.foreground} />
        <div class="ccc-hex-wrap">
          <input
            id="ccc-fg-hex"
            class="ccc-hex-input"
            type="text"
            value="#1f2937"
            maxlength="7"
            autocomplete="off"
            spellcheck="false"
            aria-describedby="ccc-fg-error"
          />
          <span id="ccc-fg-error" class="ccc-hex-error" role="alert" aria-live="polite"></span>
        </div>
      </div>
    </div>

    <button id="ccc-swap" class="ccc-swap-btn" type="button" aria-label={L.swapAria}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M16 3l4 4-4 4"/>
        <path d="M20 7H4"/>
        <path d="M8 21l-4-4 4-4"/>
        <path d="M4 17h16"/>
      </svg>
    </button>

    <div class="ccc-color-cell">
      <label class="ccc-label" for="ccc-bg-hex">{L.background}</label>
      <div class="ccc-color-input">
        <input id="ccc-bg-picker" class="ccc-picker" type="color" value="#f9fafb" aria-label={L.background} />
        <div class="ccc-hex-wrap">
          <input
            id="ccc-bg-hex"
            class="ccc-hex-input"
            type="text"
            value="#f9fafb"
            maxlength="7"
            autocomplete="off"
            spellcheck="false"
            aria-describedby="ccc-bg-error"
          />
          <span id="ccc-bg-error" class="ccc-hex-error" role="alert" aria-live="polite"></span>
        </div>
      </div>
    </div>
  </div>

  <div id="ccc-preview" class="ccc-preview" aria-live="polite">
    <span class="ccc-preview-large">{L.sampleText}</span>
    <span class="ccc-preview-small">{L.sampleText}</span>
  </div>

  <div class="ccc-summary">
    <div class="ccc-ratio-card">
      <span class="ccc-ratio-label">{L.contrastRatio}</span>
      <div class="ccc-ratio-row">
        <span id="ccc-ratio-value" class="ccc-ratio-value">—</span>
        <span id="ccc-ratio-headline" class="ccc-ratio-headline"></span>
      </div>
    </div>

    <div class="ccc-status-grid">
      <div class="ccc-status-card">
        <div class="ccc-status-title">{L.bodyText}</div>
        <div class="ccc-status-hint">{L.bodyHint}</div>
        <div class="ccc-status-row">
          <span class="ccc-status-tag">{L.aa}</span>
          <span id="ccc-body-aa" class="ccc-status-result"></span>
        </div>
        <div class="ccc-status-row">
          <span class="ccc-status-tag">{L.aaa}</span>
          <span id="ccc-body-aaa" class="ccc-status-result"></span>
        </div>
      </div>

      <div class="ccc-status-card">
        <div class="ccc-status-title">{L.largeText}</div>
        <div class="ccc-status-hint">{L.largeHint}</div>
        <div class="ccc-status-row">
          <span class="ccc-status-tag">{L.aa}</span>
          <span id="ccc-large-aa" class="ccc-status-result"></span>
        </div>
        <div class="ccc-status-row">
          <span class="ccc-status-tag">{L.aaa}</span>
          <span id="ccc-large-aaa" class="ccc-status-result"></span>
        </div>
      </div>

      <div class="ccc-status-card">
        <div class="ccc-status-title">{L.uiComponent}</div>
        <div class="ccc-status-hint">{L.uiHint}</div>
        <div class="ccc-status-row">
          <span class="ccc-status-tag">{L.aa}</span>
          <span id="ccc-ui-aa" class="ccc-status-result"></span>
        </div>
        <div class="ccc-status-row">
          <span class="ccc-status-tag">{L.aaa}</span>
          <span class="ccc-status-result ccc-status-na">{L.nA}</span>
        </div>
      </div>
    </div>
  </div>

  <div id="ccc-suggestion" class="ccc-suggestion" hidden>
    <div class="ccc-suggestion-title">{L.suggestionTitle}</div>
    <div class="ccc-suggestion-body">
      <span class="ccc-suggestion-line">{L.suggestionLine}</span>
      <span id="ccc-suggestion-swatch" class="ccc-suggestion-swatch" aria-hidden="true"></span>
      <span id="ccc-suggestion-hex" class="ccc-suggestion-hex"></span>
      <span id="ccc-suggestion-ratio" class="ccc-suggestion-ratio"></span>
    </div>
    <div class="ccc-suggestion-actions">
      <button id="ccc-apply-btn" class="btn-primary" type="button">{L.apply}</button>
      <button id="ccc-copy-fixed" class="btn-copy" type="button">{L.copyFixed}</button>
    </div>
  </div>

  <script is:inline>
  (function () {
    var wrap = document.currentScript
      ? document.currentScript.closest('.ccc-wrap')
      : document.querySelector('.ccc-wrap');

    var COPIED  = wrap.dataset.copied;
    var INVALID = wrap.dataset.invalidHex;
    var PASS    = wrap.dataset.pass;
    var FAIL    = wrap.dataset.fail;

    var fgPicker = document.getElementById('ccc-fg-picker');
    var bgPicker = document.getElementById('ccc-bg-picker');
    var fgInput  = document.getElementById('ccc-fg-hex');
    var bgInput  = document.getElementById('ccc-bg-hex');
    var fgErr    = document.getElementById('ccc-fg-error');
    var bgErr    = document.getElementById('ccc-bg-error');
    var swapBtn  = document.getElementById('ccc-swap');
    var preview  = document.getElementById('ccc-preview');
    var ratioVal = document.getElementById('ccc-ratio-value');
    var ratioHL  = document.getElementById('ccc-ratio-headline');
    var bodyAA   = document.getElementById('ccc-body-aa');
    var bodyAAA  = document.getElementById('ccc-body-aaa');
    var largeAA  = document.getElementById('ccc-large-aa');
    var largeAAA = document.getElementById('ccc-large-aaa');
    var uiAA     = document.getElementById('ccc-ui-aa');
    var sugWrap  = document.getElementById('ccc-suggestion');
    var sugSw    = document.getElementById('ccc-suggestion-swatch');
    var sugHex   = document.getElementById('ccc-suggestion-hex');
    var sugRatio = document.getElementById('ccc-suggestion-ratio');
    var applyBtn = document.getElementById('ccc-apply-btn');
    var copyFix  = document.getElementById('ccc-copy-fixed');

    var fg = '#1f2937';
    var bg = '#f9fafb';

    /* ── Hex utilities ── */
    function normalizeHex(s) {
      s = (s || '').trim();
      if (!s) return '';
      if (!s.startsWith('#')) s = '#' + s;
      if (/^#[0-9a-fA-F]{3}$/.test(s)) {
        s = '#' + s[1] + s[1] + s[2] + s[2] + s[3] + s[3];
      }
      return s.toLowerCase();
    }
    function isValidHex(s) {
      return /^#[0-9a-fA-F]{6}$/.test(s);
    }
    function hexToRgb(hex) {
      return {
        r: parseInt(hex.slice(1, 3), 16),
        g: parseInt(hex.slice(3, 5), 16),
        b: parseInt(hex.slice(5, 7), 16),
      };
    }
    function rgbToHex(r, g, b) {
      function clamp(v) { return Math.max(0, Math.min(255, Math.round(v))); }
      return '#' + [clamp(r), clamp(g), clamp(b)].map(function (v) {
        return ('0' + v.toString(16)).slice(-2);
      }).join('');
    }

    /* ── WCAG 2 contrast ── */
    function srgbToLin(c) {
      c /= 255;
      return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
    }
    function linToSrgb(c) {
      var v = c <= 0.0031308 ? 12.92 * c : 1.055 * Math.pow(c, 1 / 2.4) - 0.055;
      return v * 255;
    }
    /* ITU-R BT.709 sRGB luminance weights (referenced by WCAG 2.x). */
    var R_LUM = 0.2126, G_LUM = 0.7152, B_LUM = 0.0722;
    function relLum(rgb) {
      return R_LUM * srgbToLin(rgb.r) + G_LUM * srgbToLin(rgb.g) + B_LUM * srgbToLin(rgb.b);
    }
    function contrast(c1, c2) {
      var l1 = relLum(c1), l2 = relLum(c2);
      var hi = Math.max(l1, l2), lo = Math.min(l1, l2);
      return (hi + 0.05) / (lo + 0.05);
    }

    /* ── OKLCH (CSS Color 4 / Björn Ottosson) for hue-preserving fix ── */
    function rgbToOklab(rgb) {
      var r = srgbToLin(rgb.r);
      var g = srgbToLin(rgb.g);
      var b = srgbToLin(rgb.b);
      var l_ = Math.cbrt(0.4122214708 * r + 0.5363325363 * g + 0.0514459929 * b);
      var m_ = Math.cbrt(0.2119034982 * r + 0.6806995451 * g + 0.1073969566 * b);
      var s_ = Math.cbrt(0.0883024619 * r + 0.2817188376 * g + 0.6299787005 * b);
      return {
        L: 0.2104542553 * l_ + 0.7936177850 * m_ - 0.0040720468 * s_,
        a: 1.9779984951 * l_ - 2.4285922050 * m_ + 0.4505937099 * s_,
        b: 0.0259040371 * l_ + 0.7827717662 * m_ - 0.8086757660 * s_,
      };
    }
    function oklabToRgb(lab) {
      var l_ = lab.L + 0.3963377774 * lab.a + 0.2158037573 * lab.b;
      var m_ = lab.L - 0.1055613458 * lab.a - 0.0638541728 * lab.b;
      var s_ = lab.L - 0.0894841775 * lab.a - 1.2914855480 * lab.b;
      var l = l_ * l_ * l_;
      var m = m_ * m_ * m_;
      var s = s_ * s_ * s_;
      return {
        r: linToSrgb( 4.0767416621 * l - 3.3077115913 * m + 0.2309699292 * s),
        g: linToSrgb(-1.2684380046 * l + 2.6097574011 * m - 0.3413193965 * s),
        b: linToSrgb(-0.0041960863 * l - 0.7034186147 * m + 1.7076147010 * s),
      };
    }
    function rgbToOklch(rgb) {
      var lab = rgbToOklab(rgb);
      return {
        L: lab.L,
        C: Math.sqrt(lab.a * lab.a + lab.b * lab.b),
        h: Math.atan2(lab.b, lab.a),
      };
    }
    function oklchToRgb(lch) {
      return oklabToRgb({ L: lch.L, a: lch.C * Math.cos(lch.h), b: lch.C * Math.sin(lch.h) });
    }
    function clampRgb(rgb) {
      return {
        r: Math.max(0, Math.min(255, rgb.r)),
        g: Math.max(0, Math.min(255, rgb.g)),
        b: Math.max(0, Math.min(255, rgb.b)),
      };
    }

    /* Suggestion: keep hue & chroma, search lightness for target ratio.
       Tries both directions (lower/raise L) and picks the one that succeeds.
       BISECTION_ITERS = 22: each iteration halves the L window, so 22 steps
       resolve to ~2.4e-7 in OKLCH L — well below the precision needed for
       8-bit sRGB output (≈ 1/255 ≈ 4e-3). 22 also caps the cost at well
       under 1ms per call so the suggestion runs synchronously on input. */
    var BISECTION_ITERS = 22;
    function suggestFix(fgRgb, bgRgb, target) {
      var fgLch = rgbToOklch(fgRgb);
      var directions = [-1, 1];
      var best = null;

      for (var d = 0; d < directions.length; d++) {
        var dir = directions[d];
        var startL = fgLch.L;
        var endL = dir < 0 ? 0 : 1;
        var lo = startL, hi = endL;

        // Bisect: find smallest L delta from start that meets target.
        for (var i = 0; i < BISECTION_ITERS; i++) {
          var mid = (lo + hi) / 2;
          var trial = clampRgb(oklchToRgb({ L: mid, C: fgLch.C, h: fgLch.h }));
          var r = contrast(trial, bgRgb);
          if (r >= target) {
            // Closer to start passes — narrow the window toward start.
            hi = mid;
          } else {
            lo = mid;
          }
        }

        var finalL = hi;
        var finalRgb = clampRgb(oklchToRgb({ L: finalL, C: fgLch.C, h: fgLch.h }));
        var actualRatio = contrast(finalRgb, bgRgb);
        if (actualRatio >= target * 0.99) {
          var deltaL = Math.abs(finalL - startL);
          if (!best || deltaL < best.deltaL) {
            best = { rgb: finalRgb, ratio: actualRatio, deltaL: deltaL };
          }
        }
      }

      if (!best) {
        var black = { r: 0, g: 0, b: 0 };
        var white = { r: 255, g: 255, b: 255 };
        var rb = contrast(black, bgRgb);
        var rw = contrast(white, bgRgb);
        best = rb > rw ? { rgb: black, ratio: rb } : { rgb: white, ratio: rw };
      }
      return best;
    }

    /* ── DOM update ── */
    function setStatus(el, ratio, threshold) {
      if (ratio >= threshold) {
        el.textContent = PASS;
        el.className = 'ccc-status-result ccc-pass';
      } else {
        el.textContent = FAIL;
        el.className = 'ccc-status-result ccc-fail';
      }
    }

    function update() {
      if (!isValidHex(fg) || !isValidHex(bg)) return;
      var fgRgb = hexToRgb(fg);
      var bgRgb = hexToRgb(bg);
      var ratio = contrast(fgRgb, bgRgb);

      preview.style.backgroundColor = bg;
      preview.style.color = fg;

      ratioVal.textContent = ratio.toFixed(2) + ' : 1';

      var headline = ratio >= 7 ? 'AAA' : ratio >= 4.5 ? 'AA' : null;
      if (headline) {
        ratioHL.textContent = headline;
        ratioHL.className = 'ccc-ratio-headline ccc-ratio-pass';
      } else {
        ratioHL.textContent = FAIL;
        ratioHL.className = 'ccc-ratio-headline ccc-ratio-fail';
      }

      setStatus(bodyAA,   ratio, 4.5);
      setStatus(bodyAAA,  ratio, 7);
      setStatus(largeAA,  ratio, 3);
      setStatus(largeAAA, ratio, 4.5);
      setStatus(uiAA,     ratio, 3);

      if (ratio < 4.5) {
        var fix = suggestFix(fgRgb, bgRgb, 4.5);
        var hex = rgbToHex(fix.rgb.r, fix.rgb.g, fix.rgb.b);
        sugSw.style.background = hex;
        sugHex.textContent = hex.toUpperCase();
        sugRatio.textContent = '→ ' + fix.ratio.toFixed(2) + ' : 1';
        sugWrap.hidden = false;
        applyBtn.dataset.hex = hex;
        copyFix.dataset.hex = hex;
      } else {
        sugWrap.hidden = true;
      }

      window.trackTool && window.trackTool('color-contrast-checker', 'check');
    }

    /* ── Wiring ── */
    function setSide(side, value, source) {
      var v = normalizeHex(value);
      var picker = side === 'fg' ? fgPicker : bgPicker;
      var input  = side === 'fg' ? fgInput  : bgInput;
      var errEl  = side === 'fg' ? fgErr    : bgErr;

      if (isValidHex(v)) {
        if (side === 'fg') fg = v; else bg = v;
        if (source !== 'picker') picker.value = v;
        if (source !== 'input')  input.value = v.toUpperCase();
        input.classList.remove('ccc-error');
        errEl.textContent = '';
        update();
      } else if (source === 'input' && (input.value || '').trim().replace(/^#/, '').length >= 3) {
        input.classList.add('ccc-error');
        errEl.textContent = INVALID;
      } else if (source === 'input') {
        input.classList.remove('ccc-error');
        errEl.textContent = '';
      }
    }

    fgPicker.addEventListener('input', function () { setSide('fg', fgPicker.value, 'picker'); });
    bgPicker.addEventListener('input', function () { setSide('bg', bgPicker.value, 'picker'); });
    fgInput.addEventListener('input',  function () { setSide('fg', fgInput.value,  'input');  });
    bgInput.addEventListener('input',  function () { setSide('bg', bgInput.value,  'input');  });

    swapBtn.addEventListener('click', function () {
      var oldFg = fg, oldBg = bg;
      fg = oldBg; bg = oldFg;
      fgPicker.value = fg; bgPicker.value = bg;
      fgInput.value  = fg.toUpperCase();
      bgInput.value  = bg.toUpperCase();
      fgInput.classList.remove('ccc-error');
      bgInput.classList.remove('ccc-error');
      fgErr.textContent = '';
      bgErr.textContent = '';
      update();
      window.trackTool && window.trackTool('color-contrast-checker', 'swap');
    });

    applyBtn.addEventListener('click', function () {
      var hex = applyBtn.dataset.hex;
      if (!hex) return;
      fg = hex.toLowerCase();
      fgPicker.value = fg;
      fgInput.value  = fg.toUpperCase();
      fgInput.classList.remove('ccc-error');
      fgErr.textContent = '';
      update();
      window.trackTool && window.trackTool('color-contrast-checker', 'apply');
    });

    copyFix.addEventListener('click', function () {
      var hex = copyFix.dataset.hex;
      if (!hex) return;
      navigator.clipboard.writeText(hex.toUpperCase()).then(function () {
        var orig = copyFix.textContent;
        copyFix.textContent = COPIED;
        copyFix.classList.add('copied');
        setTimeout(function () {
          copyFix.textContent = orig;
          copyFix.classList.remove('copied');
        }, 1400);
        window.trackTool && window.trackTool('color-contrast-checker', 'copy_fix');
      });
    });

    fgInput.value = fg.toUpperCase();
    bgInput.value = bg.toUpperCase();
    update();
  })();
  </script>
</div>

<style is:global>
  .ccc-wrap {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ccc-inputs {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 0.85rem;
    align-items: end;
    padding: 1rem;
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: inset 0 0 0 1px var(--color-border-soft), var(--shadow-card);
  }

  .ccc-color-cell {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .ccc-label {
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .ccc-color-input {
    display: flex;
    gap: 0.6rem;
    min-width: 0;
  }

  .ccc-picker {
    width: 50px;
    height: 50px;
    flex: 0 0 50px;
    padding: 3px;
    border: 0;
    border-radius: var(--radius-md);
    cursor: pointer;
    background: var(--color-bg-secondary);
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
  }

