---
// TextToAsciiArtTool — converts text to ASCII art using figlet.js fonts
---
<div class="taa-wrap">
  <div class="taa-inputs">
    <div class="taa-field">
      <label for="taa-input" data-i18n="inputLabel">Input Text</label>
      <input
        id="taa-input"
        type="text"
        maxlength="80"
        placeholder="Hello World"
        data-i18n-ph="placeholder"
        spellcheck="false"
        autocomplete="off"
      />
    </div>

    <div class="taa-field">
      <label for="taa-font" data-i18n="fontLabel">Font</label>
      <select id="taa-font">
        <option value="Standard">Standard</option>
        <option value="Banner">Banner</option>
        <option value="Big">Big</option>
        <option value="Block">Block</option>
        <option value="Doom">Doom</option>
        <option value="Lean">Lean</option>
        <option value="Mini">Mini</option>
        <option value="Script">Script</option>
        <option value="Shadow">Shadow</option>
        <option value="Slant">Slant</option>
        <option value="Small">Small</option>
        <option value="3D-ASCII">3D-ASCII</option>
      </select>
    </div>
  </div>

  <div class="taa-output-wrap">
    <div class="taa-output-header">
      <span class="taa-output-label" data-i18n="outputLabel">Output</span>
      <button id="taa-copy" class="btn-copy" disabled data-i18n="copy">Copy</button>
    </div>
    <div id="taa-loading" class="taa-loading" hidden>
      <span data-i18n="loading">Loading font…</span>
    </div>
    <pre id="taa-output" class="taa-output" aria-live="polite"></pre>
  </div>

  <div id="taa-status" class="taa-status" aria-live="polite"></div>

  <script>
    import figlet from 'figlet';

    figlet.defaults({ fontPath: '/figlet-fonts' });

    const STRINGS: Record<string, Record<string, string>> = {
      en: {
        inputLabel: 'Input Text',
        placeholder: 'Hello World',
        fontLabel: 'Font',
        outputLabel: 'Output',
        copy: 'Copy',
        copied: 'Copied!',
        loading: 'Loading font…',
        errorRender: 'Render error.',
        empty: 'Type something above to generate ASCII art.',
      },
      zh: {
        inputLabel: '输入文字',
        placeholder: 'Hello World',
        fontLabel: '字体',
        outputLabel: '输出',
        copy: '复制',
        copied: '已复制！',
        loading: '正在加载字体…',
        errorRender: '渲染错误。',
        empty: '在上方输入文字以生成 ASCII 艺术。',
      },
      ja: {
        inputLabel: '入力テキスト',
        placeholder: 'Hello World',
        fontLabel: 'フォント',
        outputLabel: '出力',
        copy: 'コピー',
        copied: 'コピー済み！',
        loading: 'フォント読み込み中…',
        errorRender: 'レンダリングエラー。',
        empty: '上にテキストを入力するとASCIIアートが生成されます。',
      },
      ko: {
        inputLabel: '입력 텍스트',
        placeholder: 'Hello World',
        fontLabel: '글꼴',
        outputLabel: '출력',
        copy: '복사',
        copied: '복사됨!',
        loading: '글꼴 로드 중…',
        errorRender: '렌더링 오류.',
        empty: '위에 텍스트를 입력하면 ASCII 아트가 생성됩니다.',
      },
    };

    const pageLang = (document.documentElement.lang || 'en').slice(0, 2);
    const t = STRINGS[pageLang] || STRINGS.en;

    // Apply i18n
    document.querySelectorAll('.taa-wrap [data-i18n]').forEach((el) => {
      const key = (el as HTMLElement).dataset.i18n!;
      if (t[key]) el.textContent = t[key];
    });
    document.querySelectorAll('.taa-wrap [data-i18n-ph]').forEach((el) => {
      const key = (el as HTMLElement).dataset.i18nPh!;
      if (t[key]) (el as HTMLInputElement).placeholder = t[key];
    });

    const inputEl   = document.getElementById('taa-input') as HTMLInputElement;
    const fontEl    = document.getElementById('taa-font') as HTMLSelectElement;
    const outputEl  = document.getElementById('taa-output') as HTMLElement;
    const copyBtn   = document.getElementById('taa-copy') as HTMLButtonElement;
    const statusEl  = document.getElementById('taa-status') as HTMLElement;
    const loadingEl = document.getElementById('taa-loading') as HTMLElement;

    function showStatus(msg: string, isError: boolean) {
      statusEl.textContent = msg;
      statusEl.className = 'taa-status' + (isError ? ' taa-error' : '');
    }

    function setLoading(on: boolean) {
      loadingEl.hidden = !on;
      outputEl.style.display = on ? 'none' : '';
    }

    function render() {
      const text = inputEl.value.trim();
      const font = fontEl.value;

      if (!text) {
        outputEl.textContent = '';
        copyBtn.disabled = true;
        showStatus(t.empty, false);
        return;
      }

      setLoading(true);
      showStatus('', false);

      figlet.text(text, { font: font as figlet.Fonts }, (err, result) => {
        setLoading(false);
        if (err) {
          showStatus(t.errorRender, true);
          outputEl.textContent = '';
          copyBtn.disabled = true;
          return;
        }
        outputEl.textContent = result ?? '';
        copyBtn.disabled = false;
        showStatus('', false);
      });
    }

    let _debounce: ReturnType<typeof setTimeout>;
    function scheduleRender() {
      clearTimeout(_debounce);
      _debounce = setTimeout(render, 300);
    }

    let tracked = false;
    function trackOnce() {
      if (!tracked) {
        tracked = true;
        (window as any).trackTool?.('text_to_ascii_art', 'generate');
      }
    }

    inputEl.addEventListener('input', () => {
      scheduleRender();
      trackOnce();
    });
    fontEl.addEventListener('change', () => { render(); });

    copyBtn.addEventListener('click', () => {
      const val = outputEl.textContent;
      if (!val) return;
      navigator.clipboard.writeText(val).then(() => {
        copyBtn.textContent = t.copied;
        setTimeout(() => { copyBtn.textContent = t.copy; }, 1500);
      });
    });

    showStatus(t.empty, false);
  </script>
</div>

<style>
  .taa-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .taa-inputs { display: flex; flex-wrap: wrap; gap: 0.75rem; }

  .taa-field { display: flex; flex-direction: column; gap: 0.3rem; flex: 1; min-width: 180px; }

  .taa-field label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .taa-field input,
  .taa-field select {
    width: 100%;
    font-size: 0.9rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .taa-field input:focus,
  .taa-field select:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .taa-output-wrap {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    overflow: hidden;
  }

  .taa-output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.45rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .taa-output-label {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .taa-loading {
    padding: 1.5rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .taa-output {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.2;
    padding: 0.75rem;
    margin: 0;
    white-space: pre;
    overflow-x: auto;
    min-height: 100px;
    color: var(--color-text);
  }

  .taa-status {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    min-height: 1.2rem;
  }

  .taa-status.taa-error { color: #b45309; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .taa-status.taa-error { color: #fbbf24; }
  }
  [data-theme="dark"] .taa-status.taa-error { color: #fbbf24; }
</style>
