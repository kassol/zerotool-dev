---
// JqPlaygroundTool — run jq filters against JSON via the official jq 1.7 WASM build.
// The engine (jq.js + jq.wasm, ~1MB gzipped) is loaded lazily on first filter focus.
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    jsonInput: 'JSON Input',
    filter: 'jq Filter',
    examples: 'Examples',
    result: 'Result',
    copy: 'Copy',
    copied: 'Copied!',
    clear: 'Clear',
    loadingEngine: 'Loading jq engine (~1MB, one-time download)…',
    loadFailed: 'Failed to load jq engine. Refresh and try again.',
    invalidJson: 'Invalid JSON',
    errorPrefix: 'jq error:',
    noOutput: '(no output)',
    matchCount: '{n} value',
    matchCountPlural: '{n} values',
    engineNote: 'Engine: jq 1.7 (WASM, cached after first load)',
  },
  zh: {
    jsonInput: 'JSON 输入',
    filter: 'jq 过滤器',
    examples: '示例',
    result: '结果',
    copy: '复制',
    copied: '已复制！',
    clear: '清空',
    loadingEngine: '正在加载 jq 引擎（约 1MB，仅首次下载）…',
    loadFailed: '加载 jq 引擎失败，请刷新页面重试。',
    invalidJson: 'JSON 格式无效',
    errorPrefix: 'jq 错误：',
    noOutput: '（无输出）',
    matchCount: '{n} 项结果',
    matchCountPlural: '{n} 项结果',
    engineNote: '引擎：jq 1.7（WASM，首次加载后浏览器缓存）',
  },
  ja: {
    jsonInput: 'JSON 入力',
    filter: 'jq フィルタ',
    examples: '例',
    result: '結果',
    copy: 'コピー',
    copied: 'コピーしました！',
    clear: 'クリア',
    loadingEngine: 'jq エンジンを読み込み中（約 1MB、初回のみ）…',
    loadFailed: 'jq エンジンの読み込みに失敗しました。再読み込みしてください。',
    invalidJson: '無効な JSON',
    errorPrefix: 'jq エラー：',
    noOutput: '（出力なし）',
    matchCount: '{n} 件',
    matchCountPlural: '{n} 件',
    engineNote: 'エンジン：jq 1.7（WASM、初回ロード後はキャッシュ）',
  },
  ko: {
    jsonInput: 'JSON 입력',
    filter: 'jq 필터',
    examples: '예시',
    result: '결과',
    copy: '복사',
    copied: '복사됨!',
    clear: '지우기',
    loadingEngine: 'jq 엔진 로드 중 (약 1MB, 최초 1회)…',
    loadFailed: 'jq 엔진 로드 실패. 페이지를 새로고침하세요.',
    invalidJson: '유효하지 않은 JSON',
    errorPrefix: 'jq 오류:',
    noOutput: '(출력 없음)',
    matchCount: '{n}개',
    matchCountPlural: '{n}개',
    engineNote: '엔진: jq 1.7 (WASM, 최초 로드 후 캐시)',
  },
};

const L = labels[lang] ?? labels.en;

const SAMPLE_JSON = `{
  "users": [
    {"name": "Alice", "age": 30, "dept": "eng",   "active": true},
    {"name": "Bob",   "age": 25, "dept": "eng",   "active": false},
    {"name": "Carol", "age": 35, "dept": "sales", "active": true},
    {"name": "Dan",   "age": 28, "dept": "sales", "active": true}
  ],
  "count": 4
}`;

const EXAMPLES: { label: string; filter: string }[] = [
  { label: '.',                                filter: '.' },
  { label: '.users',                           filter: '.users' },
  { label: '.users[]',                         filter: '.users[]' },
  { label: '.users | length',                  filter: '.users | length' },
  { label: 'keys',                             filter: 'keys' },
  { label: 'map(.name)',                       filter: '.users | map(.name)' },
  { label: 'select active',                    filter: '.users[] | select(.active)' },
  { label: 'group_by dept',                    filter: '.users | group_by(.dept) | map({dept: .[0].dept, n: length})' },
  { label: 'sort_by age',                      filter: '.users | sort_by(.age) | map(.name)' },
  { label: 'sum ages',                         filter: '[.users[].age] | add' },
];
---

<div
  class="jqp-wrap"
  data-slug="jq-playground"
  data-copy={L.copy}
  data-copied={L.copied}
  data-loading-engine={L.loadingEngine}
  data-load-failed={L.loadFailed}
  data-invalid-json={L.invalidJson}
  data-error-prefix={L.errorPrefix}
  data-no-output={L.noOutput}
  data-match-count={L.matchCount}
  data-match-count-plural={L.matchCountPlural}
>
  <div class="jqp-layout">
    <!-- Left: JSON input -->
    <div class="jqp-panel">
      <div class="jqp-input-header">
        <label class="tool-label" for="jqp-json">{L.jsonInput}</label>
        <button id="jqp-clear" class="btn-ghost jqp-clear" type="button">{L.clear}</button>
      </div>
      <textarea id="jqp-json" class="tool-textarea jqp-json" spellcheck="false" autocomplete="off">{SAMPLE_JSON}</textarea>
    </div>

    <!-- Right: filter + examples + result -->
    <div class="jqp-panel">
      <label class="tool-label" for="jqp-filter">{L.filter}</label>
      <input id="jqp-filter" class="tool-input jqp-filter" type="text" value=".users | map(.name)" spellcheck="false" autocomplete="off" />

      <div class="jqp-examples-label">{L.examples}</div>
      <div class="jqp-pills">
        {EXAMPLES.map(ex => (
          <button class="jqp-pill" type="button" data-filter={ex.filter}>{ex.label}</button>
        ))}
      </div>

      <div class="jqp-result-header">
        <span class="tool-label">{L.result}</span>
        <span id="jqp-count" class="jqp-count"></span>
        <button id="jqp-copy" class="btn-copy" type="button">{L.copy}</button>
      </div>

      <pre id="jqp-pre" class="jqp-pre"><code id="jqp-code" class="jqp-code"></code></pre>

      <div id="jqp-status" class="tool-status none jqp-engine-status"></div>
      <p class="jqp-engine-note">{L.engineNote}</p>
    </div>
  </div>

  <script is:inline>
    (function () {
      var wrap = document.querySelector('.jqp-wrap');
      if (!wrap) return;

      var SLUG = 'jq-playground';
      var L = {
        copy:          wrap.dataset.copy,
        copied:        wrap.dataset.copied,
        loadingEngine: wrap.dataset.loadingEngine,
        loadFailed:    wrap.dataset.loadFailed,
        invalidJson:   wrap.dataset.invalidJson,
        errorPrefix:   wrap.dataset.errorPrefix,
        noOutput:      wrap.dataset.noOutput,
        matchOne:      wrap.dataset.matchCount,
        matchMany:     wrap.dataset.matchCountPlural,
      };

      var jsonEl   = document.getElementById('jqp-json');
      var filterEl = document.getElementById('jqp-filter');
      var codeEl   = document.getElementById('jqp-code');
      var countEl  = document.getElementById('jqp-count');
      var statusEl = document.getElementById('jqp-status');
      var copyBtn  = document.getElementById('jqp-copy');

      /* ── ztPersist restore ── */
      try {
        var saved = window.ztPersist && window.ztPersist.load(SLUG);
        if (saved && typeof saved === 'object') {
          if (typeof saved.json === 'string')   jsonEl.value   = saved.json;
          if (typeof saved.filter === 'string') filterEl.value = saved.filter;
        }
      } catch (e) {}

      function persist() {
        try {
          window.ztPersist && window.ztPersist.save(SLUG, {
            json: jsonEl.value, filter: filterEl.value
          });
        } catch (e) {}
      }

      function setStatus(text, kind) {
        statusEl.textContent = text || '';
        statusEl.className = 'tool-status jqp-engine-status ' + (kind || 'none');
      }

      /* ── jq engine lazy loader ── */
      var jqInst = null;
      var jqLoading = null;
      function ensureJq() {
        if (jqInst) return Promise.resolve(jqInst);
        if (jqLoading) return jqLoading;
        setStatus(L.loadingEngine, 'info');

        // emscripten needs Module.locateFile set BEFORE jq.js evaluates,
        // because jq.js immediately calls the factory at end-of-file.
        try {
          window.Module = {
            locateFile: function (p) {
              return p && p.indexOf('.wasm') !== -1 ? '/jq-web/jq.wasm' : p;
            }
          };
        } catch (e) {}

        jqLoading = new Promise(function (resolve, reject) {
          var s = document.createElement('script');
          s.src = '/jq-web/jq.js';
          s.onload = function () {
            // window.jq is now Promise<{json, raw}> after jq.js runs the IIFE.
            Promise.resolve(window.jq).then(function (inst) {
              jqInst = inst;
              setStatus('', 'none');
              resolve(inst);
            }, function (err) {
              setStatus(L.loadFailed, 'error');
              reject(err);
            });
          };
          s.onerror = function () {
            setStatus(L.loadFailed, 'error');
            reject(new Error('script load failed'));
          };
          document.head.appendChild(s);
        });
        return jqLoading;
      }

      /* ── JSON syntax highlight ── */
      function escapeHtml(s) {
        return String(s).replace(/[&<>]/g, function (c) {
          return c === '&' ? '&amp;' : c === '<' ? '&lt;' : '&gt;';
        });
      }
      function highlightJson(str) {
        return escapeHtml(str).replace(
          /("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g,
          function (m) {
            if (/^"/.test(m)) {
              if (/:$/.test(m)) return '<span class="jqp-hl-key">' + m + '</span>';
              return '<span class="jqp-hl-str">' + m + '</span>';
            }
            if (/true|false/.test(m)) return '<span class="jqp-hl-bool">' + m + '</span>';
            if (/null/.test(m))       return '<span class="jqp-hl-null">' + m + '</span>';
            return '<span class="jqp-hl-num">' + m + '</span>';
          }
        );
      }

      function fmtCount(n) {
        var tmpl = n === 1 ? L.matchOne : L.matchMany;
        return tmpl ? tmpl.replace('{n}', String(n)) : '';
      }

      /* ── Run jq ── */
      function showError(msg) {
        codeEl.innerHTML = '<span class="jqp-error">' + escapeHtml(msg) + '</span>';
        countEl.textContent = '';
        copyBtn.disabled = true;
      }

      function showResult(value, count) {
        var out = JSON.stringify(value, null, 2);
        if (out === undefined) {
          codeEl.innerHTML = '<span class="jqp-no-output">' + L.noOutput + '</span>';
          countEl.textContent = '';
          copyBtn.disabled = true;
          return;
        }
        codeEl.innerHTML = highlightJson(out);
        countEl.textContent = count > 0 ? fmtCount(count) : '';
        copyBtn.disabled = false;
      }

      function run() {
        persist();
        var jsonText = jsonEl.value.trim();
        var filter   = filterEl.value.trim();

        if (!jsonText) {
          codeEl.innerHTML = '';
          countEl.textContent = '';
          copyBtn.disabled = true;
          return;
        }

        var data;
        try { data = JSON.parse(jsonText); }
        catch (e) { showError(L.invalidJson + ': ' + e.message); return; }

        if (!filter) {
          showResult(data, 1);
          return;
        }

        ensureJq().then(function (jq) {
          var result;
          try { result = jq.json(data, filter); }
          catch (e) {
            showError(L.errorPrefix + ' ' + (e && e.message ? e.message : String(e)));
            return;
          }
          // jq-web returns: single value for one output, array for multiple.
          // We can't distinguish 1-vs-many reliably from return type alone,
          // so we just count = Array.isArray(result) ? result.length : 1.
          var count = Array.isArray(result) ? result.length : 1;
          showResult(result, count);
          if (window.trackTool) window.trackTool(SLUG, 'run');
        }).catch(function () {
          // engine load failed; status already set
        });
      }

      var runTimer = null;
      function scheduleRun() {
        clearTimeout(runTimer);
        runTimer = setTimeout(run, 200);
      }

      jsonEl.addEventListener('input', scheduleRun);
      filterEl.addEventListener('input', scheduleRun);

      document.querySelectorAll('.jqp-pill').forEach(function (p) {
        p.addEventListener('click', function () {
          filterEl.value = p.dataset.filter || '';
          run();
          if (window.trackTool) window.trackTool(SLUG, 'example');
        });
      });

      copyBtn.addEventListener('click', function () {
        var txt = codeEl.textContent;
        if (!txt) return;
        navigator.clipboard.writeText(txt).then(function () {
          copyBtn.classList.add('copied');
          copyBtn.textContent = L.copied;
          setTimeout(function () {
            copyBtn.classList.remove('copied');
            copyBtn.textContent = L.copy;
          }, 1500);
          if (window.trackTool) window.trackTool(SLUG, 'copy');
        });
      });

      var clearBtn = document.getElementById('jqp-clear');
      clearBtn.addEventListener('click', function () {
        jsonEl.value = '';
        filterEl.value = '';
        codeEl.innerHTML = '';
        countEl.textContent = '';
        copyBtn.disabled = true;
        setStatus('', 'none');
        try { window.ztPersist && window.ztPersist.clear(SLUG); } catch (e) {}
        if (window.trackTool) window.trackTool(SLUG, 'clear');
      });

      // Pre-warm engine when user touches the filter field.
      filterEl.addEventListener('focus', function () { ensureJq(); }, { once: true });

      // Initial paint.
      run();
    })();
  </script>
</div>

<style is:global>
  .jqp-wrap { display: flex; flex-direction: column; gap: 1rem; }

  .jqp-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 760px) {
    .jqp-layout { grid-template-columns: 1fr; }
  }

  .jqp-panel { display: flex; flex-direction: column; gap: 0.55rem; min-width: 0; }

  .jqp-input-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }

  .jqp-clear {
    min-height: 30px;
    padding: 0.22rem 0.65rem;
    font-size: 0.78rem;
  }

  .jqp-wrap .jqp-json {
    min-height: 300px;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .jqp-wrap .jqp-filter {
    font-size: 0.92rem;
  }

  .jqp-examples-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 0.2rem;
  }

  .jqp-pills { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  .jqp-pill {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    padding: 0.28rem 0.7rem;
    border: 0;
    border-radius: var(--radius-pill);
    background: var(--color-surface-muted);
    color: var(--color-text-secondary);
    cursor: pointer;
    white-space: nowrap;
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
    transition: background-color var(--transition-fast), color var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
  }
  @media (hover: hover) {
    .jqp-pill:hover {
      color: var(--color-primary);
      background: var(--color-surface);
      box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--color-primary) 45%, transparent);
    }
  }
  .jqp-pill:active { transform: scale(0.96); }

  .jqp-result-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.2rem;
  }

  .jqp-count {
    font-size: 0.78rem;
    color: var(--color-primary);
    font-weight: 700;
    flex: 1;
  }

  .jqp-pre {
    background: var(--color-bg-secondary);
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
    border-radius: var(--radius-md);
    padding: 0.85rem 1rem;
    overflow: auto;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.55;
    flex: 1;
    min-height: 160px;
    max-height: 460px;
  }

  .jqp-code { font-family: inherit; }

  .jqp-engine-status:empty { display: none; }
  .jqp-engine-status { font-size: 0.8rem; }

  .jqp-engine-note {
    margin: 0;
    font-size: 0.74rem;
    color: var(--color-text-muted);
  }

  /* JSON syntax highlight — light */
  .jqp-hl-key  { color: oklch(46% 0.12 240); font-weight: 600; }
  .jqp-hl-str  { color: oklch(46% 0.11 145); }
  .jqp-hl-num  { color: oklch(50% 0.14 40);  }
  .jqp-hl-bool { color: oklch(48% 0.16 295); }
  .jqp-hl-null { color: var(--color-text-muted); font-style: italic; }

  .jqp-error    { color: var(--color-danger); white-space: pre-wrap; }
  .jqp-no-output { color: var(--color-text-muted); font-style: italic; }

  /* Dark mode highlight */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .jqp-hl-key  { color: oklch(74% 0.13 240); }
    :root:not([data-theme="light"]) .jqp-hl-str  { color: oklch(75% 0.13 150); }
    :root:not([data-theme="light"]) .jqp-hl-num  { color: oklch(76% 0.14 55);  }
    :root:not([data-theme="light"]) .jqp-hl-bool { color: oklch(76% 0.13 295); }
  }
  [data-theme="dark"] .jqp-hl-key  { color: oklch(74% 0.13 240); }
  [data-theme="dark"] .jqp-hl-str  { color: oklch(75% 0.13 150); }
  [data-theme="dark"] .jqp-hl-num  { color: oklch(76% 0.14 55);  }
  [data-theme="dark"] .jqp-hl-bool { color: oklch(76% 0.13 295); }
</style>
