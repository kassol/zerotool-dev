          phaseQueued: '대기', phaseDns: 'DNS', phaseConnect: '연결', phaseSend: '전송', phaseWait: '대기(TTFB)', phaseReceive: '수신',
          wfCapHint: '전체 {total} 중 처음 {shown} 표시', wfShowAll: '전체 보기',
          searchPh: 'URL 검색',
          filterStatus: '상태', filterTypes: '리소스 유형', filterDomains: '도메인',
          exportBtn: 'HAR 부분 내보내기', copyAllCurl: '전체 cURL 복사',
          parsedOk: '{n}개의 요청을 파싱했습니다.',
          parseFailed: 'HAR 1.2로 파싱할 수 없습니다 ({msg}).',
          notHar: '이 JSON은 HAR 아카이브가 아닙니다 — log.entries 누락.',
          empty: 'HAR에 요청 항목이 없습니다.',
          tooBig: '파일이 너무 큽니다 ({size}).',
          copied: '클립보드에 복사됨.',
          copyFailed: '복사 실패.',
          exported: '{n}개 요청을 내보냈습니다.',
          tabHeaders: '헤더', tabCookies: '쿠키', tabBody: '본문', tabTiming: '타이밍', tabCurl: 'cURL',
          requestHeaders: '요청 헤더', responseHeaders: '응답 헤더',
          requestCookies: '요청 쿠키', responseCookies: '응답 쿠키',
          requestBody: '요청 본문', responseBody: '응답 본문',
          noBody: '(없음)', noCookies: '(없음)', noHeaders: '(없음)',
          status: '상태', method: '메서드', size: '크기', time: '시간',
          selectRequest: '목록에서 요청을 선택하세요.',
          subsetSummary: '{total}개 중 {n}개 일치 · {size}',
          naLabel: 'N/A',
        },
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;

      function applyI18n(root) {
        (root || document).querySelectorAll('[data-i18n]').forEach(function (el) {
          var k = el.getAttribute('data-i18n');
          if (t[k]) el.textContent = t[k];
        });
        (root || document).querySelectorAll('[data-i18n-ph]').forEach(function (el) {
          var k = el.getAttribute('data-i18n-ph');
          if (t[k]) el.setAttribute('placeholder', t[k]);
        });
      }
      applyI18n();

      var MAX_BYTES = 50 * 1024 * 1024; // 50 MB
      var INITIAL_WF_ROWS = 200;

      var dropzone = document.getElementById('har-dropzone');
      var fileInput = document.getElementById('har-file-input');
      var meta = document.getElementById('har-meta');
      var statusEl = document.getElementById('har-status');
      var tabs = document.getElementById('har-tabs');
      var panel = document.getElementById('har-panel');
      var views = panel.querySelectorAll('.har-view');
      var resetBtn = document.getElementById('har-reset');

      var statCount = document.getElementById('har-stat-count');
      var statTime = document.getElementById('har-stat-time');
      var statSize = document.getElementById('har-stat-size');
      var statDomains = document.getElementById('har-stat-domains');
      var pieEl = document.getElementById('har-pie');
      var pieLegendEl = document.getElementById('har-pie-legend');
      var domainListEl = document.getElementById('har-domain-list');

      var waterfallEl = document.getElementById('har-waterfall');
      var wfCapEl = document.getElementById('har-wf-cap');
      var wfMoreBtn = document.getElementById('har-wf-more');

      var reqSearchEl = document.getElementById('har-req-search');
      var reqListEl = document.getElementById('har-req-list');
      var reqDetailEl = document.getElementById('har-req-detail');

      var filterTypesEl = document.getElementById('har-filter-types');
      var filterDomainsEl = document.getElementById('har-filter-domains');
      var exportSummaryEl = document.getElementById('har-export-summary');
      var exportBtn = document.getElementById('har-export-btn');
      var copyAllCurlBtn = document.getElementById('har-copy-curl-btn');

      var harData = null;     // parsed HAR object
      var entries = [];        // log.entries normalized
      var totalTime = 0;
      var totalSize = 0;
      var domainsCount = 0;
      var minStart = 0;
      var maxEnd = 0;
      var wfShowAllFlag = false;
      var selectedIdx = -1;
      var filterState = { status: new Set(['2xx', '3xx', '4xx', '5xx', 'other']), types: new Set(), domains: new Set() };

      function setStatus(msg, tone) {
        statusEl.textContent = msg || '';
        statusEl.setAttribute('data-tone', tone || '');
        statusEl.style.display = msg ? '' : 'none';
      }

      function fmt(n, suffix) {
        if (!isFinite(n)) return '—';
        if (n >= 1000) return (n / 1000).toFixed(2) + ' ' + (suffix === 'ms' ? 's' : 'k' + (suffix || ''));
        return Math.round(n * 100) / 100 + (suffix ? ' ' + suffix : '');
      }
      function fmtBytes(n) {
        if (!isFinite(n) || n <= 0) return '0 B';
        var u = ['B', 'KB', 'MB', 'GB']; var i = 0;
        while (n >= 1024 && i < u.length - 1) { n /= 1024; i++; }
        return (i === 0 ? n : n.toFixed(2)) + ' ' + u[i];
      }
      function escapeHtml(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      }

      function resourceTypeOf(entry) {
        var mt = (entry && entry.response && entry.response.content && entry.response.content.mimeType) || '';
        mt = mt.split(';')[0].trim().toLowerCase();
        if (!mt) return 'other';
        if (mt.indexOf('javascript') >= 0 || mt === 'application/x-javascript') return 'script';
        if (mt === 'text/css') return 'stylesheet';
        if (mt.indexOf('html') >= 0) return 'document';
        if (mt.indexOf('json') >= 0) return 'json';
        if (mt.indexOf('xml') >= 0) return 'xml';
        if (mt.indexOf('image/') === 0) return 'image';
        if (mt.indexOf('font/') === 0 || mt.indexOf('font-woff') >= 0) return 'font';
        if (mt.indexOf('video/') === 0 || mt.indexOf('audio/') === 0) return 'media';
        if (mt.indexOf('text/') === 0) return 'text';
        return 'other';
      }
      function statusBucket(code) {
        var c = Number(code);
        if (c >= 200 && c < 300) return '2xx';
        if (c >= 300 && c < 400) return '3xx';
        if (c >= 400 && c < 500) return '4xx';
        if (c >= 500) return '5xx';
        return 'other';
      }
      function domainOf(url) {
        try { return new URL(url).host; } catch (e) { return '(invalid)'; }
      }

      // ---------- parse + load ----------
      function loadFile(file) {
        if (!file) return;
        if (file.size > MAX_BYTES) {
          setStatus(t.tooBig.replace('{size}', fmtBytes(file.size)), 'error');
          return;
        }
        var fr = new FileReader();
        fr.onload = function () {
          try {
            var json = JSON.parse(fr.result);
            if (!json || !json.log || !Array.isArray(json.log.entries)) {
              setStatus(t.notHar, 'error');
              return;
            }
            if (json.log.entries.length === 0) {
              setStatus(t.empty, 'error');
              return;
            }
            ingest(file.name, json);
          } catch (e) {
            setStatus(t.parseFailed.replace('{msg}', String(e.message || e)), 'error');
          }
        };
        fr.onerror = function () {
          setStatus(t.parseFailed.replace('{msg}', 'read error'), 'error');
        };
        fr.readAsText(file);
      }

      function ingest(name, json) {
        harData = json;
        var raw = json.log.entries;
        entries = raw.map(function (e, idx) {
          var timings = e.timings || {};
          var phases = phaseSegments(timings);
          var startMs = Date.parse(e.startedDateTime) || 0;
          var size = (e.response && e.response._transferSize != null)
            ? Number(e.response._transferSize)
            : (e.response && e.response.content && e.response.content.size) || 0;
          var url = (e.request && e.request.url) || '';
          var entryTime = Number(e.time) || 0;
          var sum = phases.reduce(function (a, p) { return a + (p.dur > 0 ? p.dur : 0); }, 0);
          return {
            idx: idx,
            raw: e,
            url: url,
            host: domainOf(url),
            method: (e.request && e.request.method) || '—',
            status: (e.response && e.response.status) || 0,
            statusText: (e.response && e.response.statusText) || '',
            mime: (e.response && e.response.content && e.response.content.mimeType) || '',
            type: resourceTypeOf(e),
            size: size > 0 ? size : 0,
            time: entryTime,
            startMs: startMs,
            endMs: startMs + entryTime,
            phases: phases,
            timings: timings,
            invariantOk: Math.abs(entryTime - sum) < 1.5, // ms float tolerance
          };
        });

        totalTime = entries.reduce(function (a, e) { return a + (e.time > 0 ? e.time : 0); }, 0);
        totalSize = entries.reduce(function (a, e) { return a + e.size; }, 0);
        var seenHosts = {};
        entries.forEach(function (e) { seenHosts[e.host] = true; });
        domainsCount = Object.keys(seenHosts).length;
        minStart = Math.min.apply(Math, entries.map(function (e) { return e.startMs; }));
        maxEnd = Math.max.apply(Math, entries.map(function (e) { return e.endMs; }));

        // meta pills
        document.getElementById('har-meta-name').textContent = name || '—';
        document.getElementById('har-meta-name').setAttribute('title', name || '');
        document.getElementById('har-meta-version').textContent = 'HAR ' + ((json.log.version) || '1.2');
        document.getElementById('har-meta-count').textContent = entries.length + ' reqs';
        document.getElementById('har-meta-time').textContent = fmt(totalTime, 'ms');
        document.getElementById('har-meta-size').textContent = fmtBytes(totalSize);

        dropzone.hidden = true;
        meta.hidden = false;
        tabs.hidden = false;
        panel.hidden = false;

        wfShowAllFlag = false;
        selectedIdx = -1;
        renderOverview();
        renderWaterfall();
        renderRequestList('');
        renderRequestDetail(null);
        rebuildExportFilters();
        renderExportSummary();
        switchView('overview');
        setStatus(t.parsedOk.replace('{n}', entries.length).replace('{s}', entries.length === 1 ? '' : 's'), 'success');
        if (window.trackTool) window.trackTool('har-file-analyzer', 'parse');
      }

      function phaseSegments(timings) {
        // HAR 1.2 fields: blocked, dns, connect, ssl, send, wait, receive (-1 = N/A).
        // Per spec, when `ssl` is defined its time is also included in `connect`,
        // so entry.time = blocked + dns + connect + send + wait + receive (no ssl).
        function v(name) { var x = Number(timings[name]); return isFinite(x) ? x : -1; }
        var blocked = v('blocked'), dns = v('dns'), connect = v('connect'), ssl = v('ssl'), send = v('send'), wait = v('wait'), receive = v('receive');
        // Initial Connection: use connect (already covers ssl). Only fall back to ssl
        // when connect is -1 but ssl was reported (non-compliant exporter).
        var connectDur = connect >= 0 ? connect : (ssl >= 0 ? ssl : -1);
        return [
          { key: 'queued', dur: blocked, tokenVar: '--color-har-queued', i18nKey: 'phaseQueued' },
          { key: 'dns', dur: dns, tokenVar: '--color-har-dns', i18nKey: 'phaseDns' },
          { key: 'connect', dur: connectDur, tokenVar: '--color-har-connect', i18nKey: 'phaseConnect' },
          { key: 'send', dur: send, tokenVar: '--color-har-send', i18nKey: 'phaseSend' },
          { key: 'wait', dur: wait, tokenVar: '--color-har-wait', i18nKey: 'phaseWait' },
          { key: 'receive', dur: receive, tokenVar: '--color-har-receive', i18nKey: 'phaseReceive' },
        ];
      }

      // ---------- views ----------
      function switchView(name) {
        Array.prototype.forEach.call(tabs.querySelectorAll('.har-tab'), function (b) {
          var on = b.getAttribute('data-view') === name;
          b.classList.toggle('is-active', on);
          b.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        Array.prototype.forEach.call(views, function (sec) {
          sec.hidden = sec.getAttribute('data-view') !== name;
        });
      }
      Array.prototype.forEach.call(tabs.querySelectorAll('.har-tab'), function (b) {
        b.addEventListener('click', function () { switchView(b.getAttribute('data-view')); });
      });

      function renderOverview() {
        statCount.textContent = String(entries.length);
        statTime.textContent = fmt(totalTime, 'ms');
        statSize.textContent = fmtBytes(totalSize);
        statDomains.textContent = String(domainsCount);

        // status pie
        var buckets = { '2xx': 0, '3xx': 0, '4xx': 0, '5xx': 0, 'other': 0 };
        entries.forEach(function (e) { buckets[statusBucket(e.status)]++; });
        var colors = {
          '2xx': 'var(--color-success)',
          '3xx': 'var(--color-accent)',
          '4xx': 'color-mix(in oklch, var(--color-danger) 65%, var(--color-accent))',
          '5xx': 'var(--color-danger)',
          'other': 'var(--color-text-muted)',
        };
        var total = entries.length;
        var arc = 0;
        var segs = [];
        var legendHtml = '';
        Object.keys(buckets).forEach(function (k) {
          var v = buckets[k];
          if (v === 0) return;
          var pct = v / total;
          var dash = pct * 100;
          segs.push('<circle cx="50" cy="50" r="32" fill="none" stroke="' + colors[k] + '" stroke-width="20" stroke-dasharray="' + dash.toFixed(3) + ' ' + (100 - dash).toFixed(3) + '" stroke-dashoffset="' + (-arc).toFixed(3) + '" pathLength="100" transform="rotate(-90 50 50)" />');
          arc += dash;
          legendHtml += '<li><i class="har-swatch" style="background:' + colors[k] + '"></i><span>' + k + '</span><span class="har-pie-count">' + v + '</span></li>';
        });
        pieEl.innerHTML = segs.join('');
        pieLegendEl.innerHTML = legendHtml;

        // top domains
        var byHost = {};
        entries.forEach(function (e) {
          if (!byHost[e.host]) byHost[e.host] = { host: e.host, count: 0, size: 0 };
          byHost[e.host].count++;
          byHost[e.host].size += e.size;
        });
        var rows = Object.keys(byHost).map(function (h) { return byHost[h]; })
          .sort(function (a, b) { return b.count - a.count; })
          .slice(0, 5);
        domainListEl.innerHTML = rows.map(function (r) {
          return '<li><span class="har-domain-host">' + escapeHtml(r.host) + '</span><span class="har-domain-meta">' + r.count + ' · ' + fmtBytes(r.size) + '</span></li>';
        }).join('');
      }

      function renderWaterfall() {
        var range = Math.max(1, maxEnd - minStart);
        var cap = wfShowAllFlag ? entries.length : Math.min(INITIAL_WF_ROWS, entries.length);
        var rows = [];
        for (var i = 0; i < cap; i++) {
          var e = entries[i];
          var leftPct = ((e.startMs - minStart) / range) * 100;
          var widthPct = Math.max(0.1, (e.time / range) * 100);
          var phaseHtml = '';
          for (var p = 0; p < e.phases.length; p++) {
            var ph = e.phases[p];
            if (!(ph.dur > 0)) continue;
            var sw = (ph.dur / e.time) * 100;
            var phaseLabel = STRINGS[pageLang] && STRINGS[pageLang][ph.i18nKey] || STRINGS.en[ph.i18nKey];
            phaseHtml += '<span class="har-wf-seg" style="width:' + sw.toFixed(3) + '%;background:var(' + ph.tokenVar + ')" title="' + escapeHtml(phaseLabel + ': ' + fmt(ph.dur, 'ms')) + '"></span>';
          }
          var statusClass = 'har-wf-status-' + statusBucket(e.status);
          var displayUrl = e.url.length > 80 ? e.url.slice(0, 39) + '…' + e.url.slice(-40) : e.url;
          rows.push(
            '<div class="har-wf-row" role="row" data-idx="' + e.idx + '">' +
              '<div class="har-wf-url" title="' + escapeHtml(e.url) + '"><span class="har-wf-method">' + escapeHtml(e.method) + '</span><span class="har-wf-urltext">' + escapeHtml(displayUrl) + '</span></div>' +
              '<div class="har-wf-status ' + statusClass + '">' + escapeHtml(String(e.status || '—')) + '</div>' +
              '<div class="har-wf-size">' + fmtBytes(e.size) + '</div>' +
              '<div class="har-wf-time">' + fmt(e.time, 'ms') + '</div>' +
              '<div class="har-wf-bar" style="position:relative">' +
                '<div class="har-wf-bar-track" style="left:' + leftPct.toFixed(3) + '%;width:' + widthPct.toFixed(3) + '%">' + phaseHtml + '</div>' +
              '</div>' +
            '</div>'
          );
        }
        waterfallEl.innerHTML = rows.join('');
        wfCapEl.textContent = t.wfCapHint.replace('{shown}', cap).replace('{total}', entries.length);
        wfMoreBtn.hidden = entries.length <= INITIAL_WF_ROWS || wfShowAllFlag;
        // row click → jump to detail
        Array.prototype.forEach.call(waterfallEl.querySelectorAll('.har-wf-row'), function (row) {
          row.addEventListener('click', function () {
            selectedIdx = Number(row.getAttribute('data-idx'));
            switchView('detail');
            renderRequestList(reqSearchEl.value);
            renderRequestDetail(entries[selectedIdx]);
            var sel = reqListEl.querySelector('[data-idx="' + selectedIdx + '"]');
            if (sel) sel.scrollIntoView({ block: 'nearest' });
          });
        });
      }
      wfMoreBtn.addEventListener('click', function () { wfShowAllFlag = true; renderWaterfall(); });

      function renderRequestList(q) {
        var query = (q || '').toLowerCase();
        var items = entries
          .map(function (e) { return e; })
          .filter(function (e) { return !query || e.url.toLowerCase().indexOf(query) >= 0 || e.host.toLowerCase().indexOf(query) >= 0; })
          .slice(0, 500); // safety cap
        var html = items.map(function (e) {
          var sel = e.idx === selectedIdx ? ' is-selected' : '';
          return '<li class="har-req-item ' + 'har-wf-status-' + statusBucket(e.status) + sel + '" role="option" tabindex="0" data-idx="' + e.idx + '" aria-selected="' + (e.idx === selectedIdx ? 'true' : 'false') + '">' +
            '<span class="har-req-method">' + escapeHtml(e.method) + '</span>' +
            '<span class="har-req-status">' + escapeHtml(String(e.status || '—')) + '</span>' +
            '<span class="har-req-url" title="' + escapeHtml(e.url) + '">' + escapeHtml(e.url) + '</span>' +
            '</li>';
        }).join('');
        reqListEl.innerHTML = html;
        Array.prototype.forEach.call(reqListEl.querySelectorAll('.har-req-item'), function (li) {
          li.addEventListener('click', function () {
            selectedIdx = Number(li.getAttribute('data-idx'));
            Array.prototype.forEach.call(reqListEl.querySelectorAll('.har-req-item'), function (x) {
              x.classList.toggle('is-selected', x === li);
              x.setAttribute('aria-selected', x === li ? 'true' : 'false');
            });
            renderRequestDetail(entries[selectedIdx]);
          });
        });
      }
      reqSearchEl.addEventListener('input', function () { renderRequestList(reqSearchEl.value); });

      function kvRows(arr) {
        if (!arr || !arr.length) return '<div class="har-empty">' + escapeHtml(t.noHeaders) + '</div>';
        return '<dl class="har-kv">' + arr.map(function (h) {
          return '<dt>' + escapeHtml(h.name) + '</dt><dd>' + escapeHtml(h.value) + '</dd>';
        }).join('') + '</dl>';
      }
      function cookieRows(arr, emptyMsg) {
        if (!arr || !arr.length) return '<div class="har-empty">' + escapeHtml(emptyMsg) + '</div>';
        return '<table class="har-cookie-table"><thead><tr><th>name</th><th>value</th><th>domain</th><th>path</th><th>flags</th></tr></thead><tbody>' +
          arr.map(function (c) {
            var flags = [];
            if (c.httpOnly) flags.push('HttpOnly');
            if (c.secure) flags.push('Secure');
            if (c.sameSite) flags.push('SameSite=' + c.sameSite);
            if (c.expires) flags.push('Expires=' + c.expires);
            return '<tr><td><code>' + escapeHtml(c.name) + '</code></td><td><code>' + escapeHtml(c.value) + '</code></td><td>' + escapeHtml(c.domain || '') + '</td><td>' + escapeHtml(c.path || '') + '</td><td>' + escapeHtml(flags.join(' ')) + '</td></tr>';
          }).join('') +
          '</tbody></table>';
      }
      function bodyBlock(label, content, mime) {
        if (!content || (typeof content === 'object' && content.text == null)) {
          return '<h4>' + escapeHtml(label) + '</h4><div class="har-empty">' + escapeHtml(t.noBody) + '</div>';
        }
        var text = typeof content === 'string' ? content : (content.text || '');
        if (!text) return '<h4>' + escapeHtml(label) + '</h4><div class="har-empty">' + escapeHtml(t.noBody) + '</div>';
        if (text.length > 200000) text = text.slice(0, 200000) + '\n…(truncated)';
        var mt = (mime || (content && content.mimeType) || '');
        return '<h4>' + escapeHtml(label) + ' <span class="har-mime">' + escapeHtml(mt) + '</span></h4><pre class="har-pre"><code>' + escapeHtml(text) + '</code></pre>';
      }
      function curlOf(entry) {
        var r = entry.raw.request || {};
        var parts = ['curl', '-X', JSON.stringify(r.method || 'GET'), JSON.stringify(r.url || '')];
        (r.headers || []).forEach(function (h) {
          parts.push('-H', JSON.stringify(h.name + ': ' + h.value));
        });
        if (r.postData && r.postData.text) parts.push('--data-raw', JSON.stringify(r.postData.text));
        return parts.join(' ');
      }
      function timingTable(timings) {
        var fields = ['blocked', 'dns', 'connect', 'ssl', 'send', 'wait', 'receive'];
        var rows = fields.map(function (f) {
          var v = Number(timings[f]);
          var disp = isFinite(v) && v >= 0 ? fmt(v, 'ms') : t.naLabel;
          return '<tr><th>' + f + '</th><td>' + escapeHtml(disp) + '</td></tr>';
        }).join('');
        return '<table class="har-timing-table"><tbody>' + rows + '</tbody></table>';
      }

      function renderRequestDetail(entry) {
        if (!entry) {
          reqDetailEl.innerHTML = '<p class="har-detail-empty">' + escapeHtml(t.selectRequest) + '</p>';
          return;
        }
        var req = entry.raw.request || {};
        var res = entry.raw.response || {};
        var sections = [
          '<header class="har-detail-head">',
            '<div class="har-detail-url"><strong>' + escapeHtml(entry.method) + '</strong> <span>' + escapeHtml(entry.url) + '</span></div>',
            '<dl class="har-detail-meta">',
              '<div><dt>' + escapeHtml(t.status) + '</dt><dd>' + escapeHtml(String(entry.status)) + ' ' + escapeHtml(entry.statusText) + '</dd></div>',
              '<div><dt>' + escapeHtml(t.size) + '</dt><dd>' + escapeHtml(fmtBytes(entry.size)) + '</dd></div>',
              '<div><dt>' + escapeHtml(t.time) + '</dt><dd>' + escapeHtml(fmt(entry.time, 'ms')) + '</dd></div>',
            '</dl>',
          '</header>',
          '<section class="har-detail-section"><h3>' + escapeHtml(t.tabTiming) + '</h3>' + timingTable(entry.timings) + '</section>',
          '<section class="har-detail-section"><h3>' + escapeHtml(t.requestHeaders) + '</h3>' + kvRows(req.headers) + '</section>',
          '<section class="har-detail-section"><h3>' + escapeHtml(t.responseHeaders) + '</h3>' + kvRows(res.headers) + '</section>',
          '<section class="har-detail-section"><h3>' + escapeHtml(t.requestCookies) + '</h3>' + cookieRows(req.cookies, t.noCookies) + '</section>',
          '<section class="har-detail-section"><h3>' + escapeHtml(t.responseCookies) + '</h3>' + cookieRows(res.cookies, t.noCookies) + '</section>',
          '<section class="har-detail-section">' + bodyBlock(t.requestBody, req.postData) + '</section>',
          '<section class="har-detail-section">' + bodyBlock(t.responseBody, res.content) + '</section>',
          '<section class="har-detail-section"><h3>' + escapeHtml(t.tabCurl) + '</h3><div class="har-curl-row"><pre class="har-pre"><code>' + escapeHtml(curlOf(entry)) + '</code></pre><button class="btn-copy" data-curl-copy type="button">Copy</button></div></section>',
        ];
        reqDetailEl.innerHTML = sections.join('');
        var copyBtn = reqDetailEl.querySelector('[data-curl-copy]');
        if (copyBtn) copyBtn.addEventListener('click', function () { copyText(curlOf(entry)); });
      }

      function rebuildExportFilters() {
        // types
        var types = {};
        entries.forEach(function (e) { types[e.type] = (types[e.type] || 0) + 1; });
        var typeKeys = Object.keys(types).sort();
        filterState.types = new Set(typeKeys);
        filterTypesEl.innerHTML = '<legend>' + escapeHtml(t.filterTypes) + '</legend>' + typeKeys.map(function (k) {
          return '<label class="har-cb"><input type="checkbox" data-filter="type" value="' + escapeHtml(k) + '" checked /> ' + escapeHtml(k) + ' <span class="har-filter-count">(' + types[k] + ')</span></label>';
        }).join('');
        // domains (top 20)
        var hosts = {};
        entries.forEach(function (e) { hosts[e.host] = (hosts[e.host] || 0) + 1; });
        var hostKeys = Object.keys(hosts).sort(function (a, b) { return hosts[b] - hosts[a]; }).slice(0, 20);
        filterState.domains = new Set(hostKeys);
        filterDomainsEl.innerHTML = '<legend>' + escapeHtml(t.filterDomains) + '</legend>' + hostKeys.map(function (k) {
          return '<label class="har-cb"><input type="checkbox" data-filter="domain" value="' + escapeHtml(k) + '" checked /> ' + escapeHtml(k) + ' <span class="har-filter-count">(' + hosts[k] + ')</span></label>';
        }).join('');
        var allCb = panel.querySelectorAll('input[data-filter]');
        Array.prototype.forEach.call(allCb, function (cb) { cb.addEventListener('change', onFilterChange); });
      }
      function onFilterChange(ev) {
        var cb = ev.target;
        var group = cb.getAttribute('data-filter');
        var value = cb.value;
        var bag = group === 'status' ? filterState.status : group === 'type' ? filterState.types : filterState.domains;
        if (cb.checked) bag.add(value); else bag.delete(value);
        renderExportSummary();
      }
      function filteredEntries() {
        return entries.filter(function (e) {
          if (!filterState.status.has(statusBucket(e.status))) return false;
          if (!filterState.types.has(e.type)) return false;
          if (!filterState.domains.has(e.host)) return false;
          return true;
        });
      }
      function renderExportSummary() {
        var matched = filteredEntries();
        var size = matched.reduce(function (a, e) { return a + e.size; }, 0);
        exportSummaryEl.textContent = t.subsetSummary
          .replace('{n}', matched.length)
          .replace('{total}', entries.length)
          .replace('{size}', fmtBytes(size));
      }
      exportBtn.addEventListener('click', function () {
        if (!harData) return;
        var matched = filteredEntries();
        var subset = JSON.parse(JSON.stringify(harData));
        subset.log = subset.log || {};
        subset.log.entries = matched.map(function (m) { return m.raw; });
        var blob = new Blob([JSON.stringify(subset, null, 2)], { type: 'application/json' });
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url; a.download = 'subset.har';
        document.body.appendChild(a); a.click(); a.remove();
        setTimeout(function () { URL.revokeObjectURL(url); }, 0);
        setStatus(t.exported.replace('{n}', matched.length).replace('{s}', matched.length === 1 ? '' : 's'), 'success');
        if (window.trackTool) window.trackTool('har-file-analyzer', 'export_subset');
      });
      copyAllCurlBtn.addEventListener('click', function () {
        var matched = filteredEntries();
        var text = matched.map(curlOf).join('\n\n');
        copyText(text);
        if (window.trackTool) window.trackTool('har-file-analyzer', 'copy_all_curl');
      });

      function copyText(text) {
        if (navigator.clipboard) {
          navigator.clipboard.writeText(text)
            .then(function () { setStatus(t.copied, 'success'); })
            .catch(function () { setStatus(t.copyFailed, 'error'); });
        } else {
          var ta = document.createElement('textarea');
          ta.value = text; document.body.appendChild(ta); ta.select();
          try { document.execCommand('copy'); setStatus(t.copied, 'success'); }
          catch (e) { setStatus(t.copyFailed, 'error'); }
          document.body.removeChild(ta);
        }
      }

      // ---------- dropzone interactions ----------
      function openPicker() { fileInput.click(); }
      dropzone.addEventListener('click', openPicker);
      dropzone.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openPicker(); }
      });
      fileInput.addEventListener('change', function () {
        if (fileInput.files && fileInput.files[0]) loadFile(fileInput.files[0]);
        fileInput.value = '';
      });
      ['dragenter', 'dragover'].forEach(function (ev) {
        dropzone.addEventListener(ev, function (e) {
          e.preventDefault(); e.stopPropagation();
          dropzone.classList.add('is-dragover');
        });
      });
      ['dragleave', 'drop'].forEach(function (ev) {
        dropzone.addEventListener(ev, function (e) {
          e.preventDefault(); e.stopPropagation();
          if (ev === 'dragleave' && e.target !== dropzone) return;
          dropzone.classList.remove('is-dragover');
        });
      });
      dropzone.addEventListener('drop', function (e) {
        var f = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
        if (f) loadFile(f);
      });

      resetBtn.addEventListener('click', function () {
        harData = null; entries = []; selectedIdx = -1; wfShowAllFlag = false;
        dropzone.hidden = false;
        meta.hidden = true;
        tabs.hidden = true;
        panel.hidden = true;
        waterfallEl.innerHTML = '';
        pieEl.innerHTML = '';
        pieLegendEl.innerHTML = '';
        domainListEl.innerHTML = '';
        reqListEl.innerHTML = '';
        reqDetailEl.innerHTML = '';
        filterTypesEl.innerHTML = '<legend>' + escapeHtml(t.filterTypes) + '</legend>';
        filterDomainsEl.innerHTML = '<legend>' + escapeHtml(t.filterDomains) + '</legend>';
        exportSummaryEl.textContent = '';
        setStatus('', '');
      });
    })();
  </script>
</div>

<style is:global>
  .har-shell { display: flex; flex-direction: column; gap: 0.85rem; min-width: 0; }

  .har-dropzone {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.4rem; padding: 2.5rem 1rem; border-radius: var(--radius-lg);
    background: var(--color-surface-muted);
    outline: 1px dashed var(--color-border);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: background var(--transition-fast), outline-color var(--transition-fast);
    min-height: 200px;
  }
  .har-dropzone:hover, .har-dropzone:focus-visible, .har-dropzone.is-dragover {
    background: color-mix(in oklch, var(--color-primary) 6%, var(--color-surface-muted));
    outline-color: var(--color-primary);
    outline-style: solid;
    color: var(--color-text);
  }
  .har-dropzone-icon { color: var(--color-primary); }
  .har-dropzone-title { font-weight: 600; font-size: 1rem; margin: 0; }
  .har-dropzone-hint { font-size: 0.82rem; margin: 0; color: var(--color-text-muted); }

  .har-meta { display: none; }
  .har-meta:not([hidden]) {
    display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center;
    padding: 0.4rem 0.55rem; border-radius: var(--radius-md);
    background: var(--color-surface);
    outline: 1px solid var(--color-border-soft);
    outline-offset: -1px;
  }
  .har-pill {
    display: inline-flex; align-items: center;
    padding: 0.2rem 0.6rem; border-radius: var(--radius-pill);
    background: var(--color-surface-muted);
    color: var(--color-text-secondary);
    font-size: 0.78rem; font-family: var(--font-mono);
    max-width: 24ch; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .har-reset { margin-left: auto; font-size: 0.78rem; }

  .har-status { font-size: 0.85rem; }
  .har-status:empty { display: none; }
  .har-status[data-tone="success"] { color: var(--color-success); }
  .har-status[data-tone="error"] { color: var(--color-danger); }

  .har-tabs { display: none; }
  .har-tabs:not([hidden]) {
    display: flex; flex-wrap: wrap; gap: 0;
    border-bottom: 1px solid var(--color-border);
  }
  .har-tab {
    appearance: none; background: none; border: none;
    padding: 0.5rem 0.95rem; font-size: 0.88rem; font-weight: 600;
    color: var(--color-text-secondary);
    border-bottom: 2px solid transparent;
    cursor: pointer; transition: color var(--transition-fast), border-color var(--transition-fast);
  }
  .har-tab:hover { color: var(--color-text); }
  .har-tab.is-active { color: var(--color-primary); border-bottom-color: var(--color-primary); }
  .har-tab:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; border-radius: var(--radius-sm); }

