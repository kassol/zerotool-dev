---
// HarFileAnalyzerTool — drops a HAR file (DevTools export) and visualizes
// request waterfall, headers/cookies, status pie, domain breakdown, and a
// filterable export. Pure browser, no upload, no persistence.
---

<div>
  <div class="har-shell">
    <div class="har-dropzone" id="har-dropzone" tabindex="0" role="button" aria-label="Choose HAR file">
      <input type="file" id="har-file-input" accept=".har,application/json,application/octet-stream" hidden />
      <svg class="har-dropzone-icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      <p class="har-dropzone-title" data-i18n="dropTitle">Drop a .har file here</p>
      <p class="har-dropzone-hint" data-i18n="dropHint">or click to choose · 100% local, never uploaded</p>
    </div>

    <div class="har-meta" id="har-meta" hidden>
      <span class="har-pill" id="har-meta-name" title="">—</span>
      <span class="har-pill" id="har-meta-version">v—</span>
      <span class="har-pill" id="har-meta-count">0 reqs</span>
      <span class="har-pill" id="har-meta-time">0 ms</span>
      <span class="har-pill" id="har-meta-size">0 B</span>
      <button class="btn-ghost har-reset" id="har-reset" type="button" data-i18n="reset">Reset</button>
    </div>

    <div class="tool-status har-status" id="har-status" aria-live="polite"></div>

    <div class="har-tabs" id="har-tabs" role="tablist" aria-label="HAR view" hidden>
      <button class="har-tab is-active" role="tab" aria-selected="true" data-view="overview" type="button" data-i18n="tabOverview">Overview</button>
      <button class="har-tab" role="tab" aria-selected="false" data-view="waterfall" type="button" data-i18n="tabWaterfall">Waterfall</button>
      <button class="har-tab" role="tab" aria-selected="false" data-view="detail" type="button" data-i18n="tabDetail">Detail</button>
      <button class="har-tab" role="tab" aria-selected="false" data-view="export" type="button" data-i18n="tabExport">Filter &amp; Export</button>
    </div>

    <div class="har-panel" id="har-panel" role="tabpanel" aria-live="polite" hidden>
      <!-- Overview -->
      <section class="har-view" data-view="overview" hidden>
        <div class="har-stat-grid">
          <div class="har-stat"><span class="har-stat-label" data-i18n="statRequests">Requests</span><span class="har-stat-value" id="har-stat-count">—</span></div>
          <div class="har-stat"><span class="har-stat-label" data-i18n="statTotalTime">Total time</span><span class="har-stat-value" id="har-stat-time">—</span></div>
          <div class="har-stat"><span class="har-stat-label" data-i18n="statTotalSize">Transferred</span><span class="har-stat-value" id="har-stat-size">—</span></div>
          <div class="har-stat"><span class="har-stat-label" data-i18n="statDomains">Domains</span><span class="har-stat-value" id="har-stat-domains">—</span></div>
        </div>
        <div class="har-overview-grid">
          <div class="har-overview-card">
            <h3 class="har-card-title" data-i18n="cardStatusCodes">Status codes</h3>
            <div class="har-pie-wrap"><svg class="har-pie" id="har-pie" viewBox="0 0 100 100" aria-label="Status code distribution"></svg></div>
            <ul class="har-pie-legend" id="har-pie-legend"></ul>
          </div>
          <div class="har-overview-card">
            <h3 class="har-card-title" data-i18n="cardTopDomains">Top domains</h3>
            <ol class="har-domain-list" id="har-domain-list"></ol>
          </div>
        </div>
      </section>

      <!-- Waterfall -->
      <section class="har-view" data-view="waterfall" hidden>
        <div class="har-legend" role="list">
          <span class="har-legend-item" role="listitem"><i class="har-swatch" style="background:var(--color-har-queued)"></i><span data-i18n="phaseQueued">Queued / Stalled</span></span>
          <span class="har-legend-item" role="listitem"><i class="har-swatch" style="background:var(--color-har-dns)"></i><span data-i18n="phaseDns">DNS</span></span>
          <span class="har-legend-item" role="listitem"><i class="har-swatch" style="background:var(--color-har-connect)"></i><span data-i18n="phaseConnect">Connect</span></span>
          <span class="har-legend-item" role="listitem"><i class="har-swatch" style="background:var(--color-har-send)"></i><span data-i18n="phaseSend">Send</span></span>
          <span class="har-legend-item" role="listitem"><i class="har-swatch" style="background:var(--color-har-wait)"></i><span data-i18n="phaseWait">Wait (TTFB)</span></span>
          <span class="har-legend-item" role="listitem"><i class="har-swatch" style="background:var(--color-har-receive)"></i><span data-i18n="phaseReceive">Receive</span></span>
        </div>
        <div class="har-wf-controls">
          <span class="har-wf-cap" id="har-wf-cap" data-i18n="wfCapHint">Showing first 200 of 0</span>
          <button class="btn-ghost har-wf-more" id="har-wf-more" type="button" hidden data-i18n="wfShowAll">Show all</button>
        </div>
        <div class="har-waterfall" id="har-waterfall" role="table"></div>
      </section>

      <!-- Detail -->
      <section class="har-view" data-view="detail" hidden>
        <div class="har-detail-grid">
          <div class="har-req-list-wrap">
            <input id="har-req-search" class="tool-input har-req-search" type="search" data-i18n-ph="searchPh" placeholder="Search URL" autocomplete="off" />
            <ol class="har-req-list" id="har-req-list" role="listbox" aria-label="Requests"></ol>
          </div>
          <div class="har-req-detail" id="har-req-detail"></div>
        </div>
      </section>

      <!-- Filter & Export -->
      <section class="har-view" data-view="export" hidden>
        <div class="har-filter">
          <fieldset class="har-filter-group">
            <legend data-i18n="filterStatus">Status</legend>
            <label class="har-cb"><input type="checkbox" data-filter="status" value="2xx" checked /> 2xx</label>
            <label class="har-cb"><input type="checkbox" data-filter="status" value="3xx" checked /> 3xx</label>
            <label class="har-cb"><input type="checkbox" data-filter="status" value="4xx" checked /> 4xx</label>
            <label class="har-cb"><input type="checkbox" data-filter="status" value="5xx" checked /> 5xx</label>
            <label class="har-cb"><input type="checkbox" data-filter="status" value="other" checked /> 1xx / 0</label>
          </fieldset>
          <fieldset class="har-filter-group" id="har-filter-types">
            <legend data-i18n="filterTypes">Resource type</legend>
          </fieldset>
          <fieldset class="har-filter-group" id="har-filter-domains">
            <legend data-i18n="filterDomains">Domain</legend>
          </fieldset>
        </div>
        <div class="har-export-summary" id="har-export-summary"></div>
        <div class="har-export-actions">
          <button class="btn-primary" id="har-export-btn" type="button" data-i18n="exportBtn">Export HAR subset</button>
          <button class="btn-ghost" id="har-copy-curl-btn" type="button" data-i18n="copyAllCurl">Copy all as cURL</button>
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
