          dropHint: '또는 클릭으로 선택 · 100% 로컬, 업로드 없음',
          reset: '초기화',
          tabOverview: '개요', tabWaterfall: '워터폴', tabDetail: '상세', tabExport: '필터 및 내보내기',
          statRequests: '요청 수', statTotalTime: '총 시간', statTotalSize: '전송량', statDomains: '도메인',
