---
// HtaccessGeneratorTool — generates .htaccess configuration
---
<div>
  <div class="hta-wrap">

    <!-- Section: HTTPS Redirect -->
    <div class="hta-section">
      <label class="hta-toggle">
        <input type="checkbox" id="hta-https" checked />
        <span class="hta-toggle-label" data-i18n="forceHttps">Force HTTPS</span>
        <span class="hta-toggle-desc" data-i18n="forceHttpsDesc">Redirect all HTTP traffic to HTTPS</span>
      </label>
    </div>

    <!-- Section: WWW -->
    <div class="hta-section">
      <label class="hta-toggle">
        <input type="checkbox" id="hta-www-enable" />
        <span class="hta-toggle-label" data-i18n="wwwRedirect">WWW Redirect</span>
        <span class="hta-toggle-desc" data-i18n="wwwRedirectDesc">Enforce consistent www / non-www domain</span>
      </label>
      <div class="hta-sub" id="hta-www-sub">
        <label class="hta-radio">
          <input type="radio" name="hta-www" value="add" checked /> <span data-i18n="forceWww">Force www</span>
        </label>
        <label class="hta-radio">
          <input type="radio" name="hta-www" value="remove" /> <span data-i18n="removeWww">Remove www</span>
        </label>
      </div>
    </div>

    <!-- Section: Directory Index -->
    <div class="hta-section">
      <label class="hta-toggle">
        <input type="checkbox" id="hta-index-enable" checked />
        <span class="hta-toggle-label" data-i18n="dirIndex">Directory Index</span>
        <span class="hta-toggle-desc" data-i18n="dirIndexDesc">Set default files served for a directory</span>
      </label>
      <div class="hta-sub" id="hta-index-sub">
        <label class="hta-field-label" for="hta-index-files" data-i18n="defaultFiles">Default files (space-separated)</label>
        <input
          type="text"
          id="hta-index-files"
          value="index.php index.html index.htm"
          spellcheck="false"
          class="hta-input"
        />
      </div>
    </div>

    <!-- Section: Caching -->
    <div class="hta-section">
      <label class="hta-toggle">
        <input type="checkbox" id="hta-cache-enable" checked />
        <span class="hta-toggle-label" data-i18n="browserCaching">Browser Caching</span>
        <span class="hta-toggle-desc" data-i18n="browserCachingDesc">Set cache expiry for common file types</span>
      </label>
      <div class="hta-sub hta-cache-grid" id="hta-cache-sub">
        <div class="hta-cache-row">
          <span class="hta-cache-type">Images (jpg, png, gif, svg, webp)</span>
          <select id="hta-cache-images" class="hta-select">
            <option value="1 month">1 month</option>
            <option value="3 months">3 months</option>
            <option value="6 months">6 months</option>
            <option value="1 year" selected>1 year</option>
          </select>
        </div>
        <div class="hta-cache-row">
          <span class="hta-cache-type">CSS &amp; JavaScript</span>
          <select id="hta-cache-css" class="hta-select">
            <option value="1 week">1 week</option>
            <option value="1 month" selected>1 month</option>
            <option value="3 months">3 months</option>
            <option value="1 year">1 year</option>
          </select>
        </div>
        <div class="hta-cache-row">
          <span class="hta-cache-type">Fonts (woff, woff2, ttf, eot)</span>
          <select id="hta-cache-fonts" class="hta-select">
            <option value="1 month">1 month</option>
            <option value="3 months">3 months</option>
            <option value="1 year" selected>1 year</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Section: Security -->
    <div class="hta-section">
      <label class="hta-toggle">
        <input type="checkbox" id="hta-security-enable" checked />
        <span class="hta-toggle-label" data-i18n="security">Security</span>
        <span class="hta-toggle-desc" data-i18n="securityDesc">Disable directory listing and protect sensitive files</span>
      </label>
      <div class="hta-sub" id="hta-security-sub">
        <label class="hta-check">
          <input type="checkbox" id="hta-sec-dirlisting" checked /> <span data-i18n="disableDirBrowse">Disable directory browsing</span>
        </label>
        <label class="hta-check">
          <input type="checkbox" id="hta-sec-htaccess" checked /> <span data-i18n="hideHtaccess">Hide .htaccess file</span>
        </label>
        <label class="hta-check">
          <input type="checkbox" id="hta-sec-envfiles" checked /> <span data-i18n="hideEnvFiles">Hide .env files</span>
        </label>
        <label class="hta-check">
          <input type="checkbox" id="hta-sec-xss" /> <span data-i18n="addXssHeaders">Add XSS &amp; clickjacking headers</span>
        </label>
      </div>
    </div>

    <!-- Section: Custom Redirect -->
    <div class="hta-section">
      <label class="hta-toggle">
        <input type="checkbox" id="hta-redir-enable" />
        <span class="hta-toggle-label" data-i18n="customRedirect">Custom Redirect</span>
        <span class="hta-toggle-desc" data-i18n="customRedirectDesc">Redirect a specific path to another URL</span>
      </label>
      <div class="hta-sub hta-redir-fields" id="hta-redir-sub">
        <div class="hta-redir-row">
          <div class="hta-field">
            <label class="hta-field-label" for="hta-redir-from" data-i18n="fromPath">From path</label>
            <input type="text" id="hta-redir-from" placeholder="/old-page" class="hta-input" spellcheck="false" />
          </div>
          <div class="hta-field">
            <label class="hta-field-label" for="hta-redir-to" data-i18n="toUrl">To URL</label>
            <input type="text" id="hta-redir-to" placeholder="https://example.com/new-page" class="hta-input" spellcheck="false" />
          </div>
          <div class="hta-field hta-field-sm">
            <label class="hta-field-label" for="hta-redir-type" data-i18n="type">Type</label>
            <select id="hta-redir-type" class="hta-select">
              <option value="301" selected>301 Permanent</option>
              <option value="302">302 Temporary</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <!-- Output -->
    <div class="hta-output-wrap">
      <div class="hta-output-header">
        <span class="hta-output-title">.htaccess</span>
        <button id="hta-copy" class="btn-copy" data-i18n="copy">Copy</button>
      </div>
      <pre id="hta-output" class="hta-output"></pre>
    </div>

    <div id="hta-status" class="hta-status" aria-live="polite"></div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: { forceHttps: 'Force HTTPS', forceHttpsDesc: 'Redirect all HTTP traffic to HTTPS', wwwRedirect: 'WWW Redirect', wwwRedirectDesc: 'Enforce consistent www / non-www domain', forceWww: 'Force www', removeWww: 'Remove www', dirIndex: 'Directory Index', dirIndexDesc: 'Set default files served for a directory', defaultFiles: 'Default files (space-separated)', browserCaching: 'Browser Caching', browserCachingDesc: 'Set cache expiry for common file types', security: 'Security', securityDesc: 'Disable directory listing and protect sensitive files', disableDirBrowse: 'Disable directory browsing', hideHtaccess: 'Hide .htaccess file', hideEnvFiles: 'Hide .env files', addXssHeaders: 'Add XSS & clickjacking headers', customRedirect: 'Custom Redirect', customRedirectDesc: 'Redirect a specific path to another URL', fromPath: 'From path', toUrl: 'To URL', type: 'Type', copy: 'Copy', copied: 'Copied!' },
        zh: { forceHttps: '强制 HTTPS', forceHttpsDesc: '将所有 HTTP 流量重定向到 HTTPS', wwwRedirect: 'WWW 重定向', wwwRedirectDesc: '强制统一 www / 非 www 域名', forceWww: '强制 www', removeWww: '去除 www', dirIndex: '目录索引', dirIndexDesc: '设置目录默认文件', defaultFiles: '默认文件（空格分隔）', browserCaching: '浏览器缓存', browserCachingDesc: '设置常见文件类型的缓存过期时间', security: '安全', securityDesc: '禁用目录列表并保护敏感文件', disableDirBrowse: '禁用目录浏览', hideHtaccess: '隐藏 .htaccess 文件', hideEnvFiles: '隐藏 .env 文件', addXssHeaders: '添加 XSS 和点击劫持防护头', customRedirect: '自定义重定向', customRedirectDesc: '将特定路径重定向到另一个 URL', fromPath: '来源路径', toUrl: '目标 URL', type: '类型', copy: '复制', copied: '已复制！' },
        ja: { forceHttps: 'HTTPS 強制', forceHttpsDesc: 'すべての HTTP トラフィックを HTTPS にリダイレクト', wwwRedirect: 'WWW リダイレクト', wwwRedirectDesc: 'www / 非 www ドメインを統一', forceWww: 'www を強制', removeWww: 'www を削除', dirIndex: 'ディレクトリインデックス', dirIndexDesc: 'ディレクトリのデフォルトファイルを設定', defaultFiles: 'デフォルトファイル（スペース区切り）', browserCaching: 'ブラウザキャッシュ', browserCachingDesc: '一般的なファイルタイプのキャッシュ有効期限を設定', security: 'セキュリティ', securityDesc: 'ディレクトリ一覧を無効化し機密ファイルを保護', disableDirBrowse: 'ディレクトリ閲覧を無効化', hideHtaccess: '.htaccess ファイルを隠す', hideEnvFiles: '.env ファイルを隠す', addXssHeaders: 'XSS・クリックジャッキング防止ヘッダーを追加', customRedirect: 'カスタムリダイレクト', customRedirectDesc: '特定のパスを別の URL にリダイレクト', fromPath: 'リダイレクト元', toUrl: 'リダイレクト先 URL', type: '種類', copy: 'コピー', copied: 'コピー済み！' },
        ko: { forceHttps: 'HTTPS 강제', forceHttpsDesc: '모든 HTTP 트래픽을 HTTPS로 리다이렉트', wwwRedirect: 'WWW 리다이렉트', wwwRedirectDesc: 'www / 비 www 도메인 통일', forceWww: 'www 강제', removeWww: 'www 제거', dirIndex: '디렉토리 인덱스', dirIndexDesc: '디렉토리 기본 파일 설정', defaultFiles: '기본 파일 (공백 구분)', browserCaching: '브라우저 캐싱', browserCachingDesc: '일반적인 파일 형식의 캐시 만료 설정', security: '보안', securityDesc: '디렉토리 목록 비활성화 및 민감한 파일 보호', disableDirBrowse: '디렉토리 탐색 비활성화', hideHtaccess: '.htaccess 파일 숨기기', hideEnvFiles: '.env 파일 숨기기', addXssHeaders: 'XSS 및 클릭재킹 방지 헤더 추가', customRedirect: '사용자 정의 리다이렉트', customRedirectDesc: '특정 경로를 다른 URL로 리다이렉트', fromPath: '원본 경로', toUrl: '대상 URL', type: '유형', copy: '복사', copied: '복사됨!' }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });
      document.querySelectorAll('[data-i18n-ph]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-ph'); if (t[key]) el.placeholder = t[key];
      });

      var els = {
        https:         document.getElementById('hta-https'),
        wwwEnable:     document.getElementById('hta-www-enable'),
        wwwSub:        document.getElementById('hta-www-sub'),
        indexEnable:   document.getElementById('hta-index-enable'),
        indexSub:      document.getElementById('hta-index-sub'),
        indexFiles:    document.getElementById('hta-index-files'),
        cacheEnable:   document.getElementById('hta-cache-enable'),
        cacheSub:      document.getElementById('hta-cache-sub'),
        cacheImages:   document.getElementById('hta-cache-images'),
        cacheCss:      document.getElementById('hta-cache-css'),
        cacheFonts:    document.getElementById('hta-cache-fonts'),
        secEnable:     document.getElementById('hta-security-enable'),
        secSub:        document.getElementById('hta-security-sub'),
        secDirListing: document.getElementById('hta-sec-dirlisting'),
        secHtaccess:   document.getElementById('hta-sec-htaccess'),
        secEnvFiles:   document.getElementById('hta-sec-envfiles'),
        secXss:        document.getElementById('hta-sec-xss'),
        redirEnable:   document.getElementById('hta-redir-enable'),
        redirSub:      document.getElementById('hta-redir-sub'),
        redirFrom:     document.getElementById('hta-redir-from'),
        redirTo:       document.getElementById('hta-redir-to'),
        redirType:     document.getElementById('hta-redir-type'),
        output:        document.getElementById('hta-output'),
        copyBtn:       document.getElementById('hta-copy'),
        status:        document.getElementById('hta-status'),
      };

      function wwwMode() {
        var radios = document.querySelectorAll('input[name="hta-www"]');
        for (var i = 0; i < radios.length; i++) {
          if (radios[i].checked) return radios[i].value;
        }
        return 'add';
      }

      function lines() {
        var out = [];

        // HTTPS redirect
        if (els.https.checked) {
          out.push('# Force HTTPS');
          out.push('<IfModule mod_rewrite.c>');
          out.push('  RewriteEngine On');
          out.push('  RewriteCond %{HTTPS} off');
          out.push('  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]');
          out.push('</IfModule>');
        }

        // WWW
        if (els.wwwEnable.checked) {
          var mode = wwwMode();
          out.push('');
          if (mode === 'add') {
            out.push('# Force www');
            out.push('<IfModule mod_rewrite.c>');
            out.push('  RewriteEngine On');
            out.push('  RewriteCond %{HTTP_HOST} !^www\\. [NC]');
            out.push('  RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]');
            out.push('</IfModule>');
          } else {
            out.push('# Remove www');
            out.push('<IfModule mod_rewrite.c>');
            out.push('  RewriteEngine On');
            out.push('  RewriteCond %{HTTP_HOST} ^www\\.(.+)$ [NC]');
            out.push('  RewriteRule ^(.*)$ https://%1%{REQUEST_URI} [L,R=301]');
            out.push('</IfModule>');
          }
        }

        // Directory Index
        if (els.indexEnable.checked) {
          var files = (els.indexFiles.value || 'index.php index.html').trim();
          out.push('');
          out.push('# Directory Index');
          out.push('DirectoryIndex ' + files);
        }

        // Caching
        if (els.cacheEnable.checked) {
          out.push('');
          out.push('# Browser Caching');
          out.push('<IfModule mod_expires.c>');
          out.push('  ExpiresActive On');
          out.push('  ExpiresByType image/jpeg "access plus ' + els.cacheImages.value + '"');
          out.push('  ExpiresByType image/png "access plus ' + els.cacheImages.value + '"');
          out.push('  ExpiresByType image/gif "access plus ' + els.cacheImages.value + '"');
          out.push('  ExpiresByType image/svg+xml "access plus ' + els.cacheImages.value + '"');
          out.push('  ExpiresByType image/webp "access plus ' + els.cacheImages.value + '"');
          out.push('  ExpiresByType text/css "access plus ' + els.cacheCss.value + '"');
          out.push('  ExpiresByType application/javascript "access plus ' + els.cacheCss.value + '"');
          out.push('  ExpiresByType text/javascript "access plus ' + els.cacheCss.value + '"');
          out.push('  ExpiresByType font/woff "access plus ' + els.cacheFonts.value + '"');
          out.push('  ExpiresByType font/woff2 "access plus ' + els.cacheFonts.value + '"');
          out.push('  ExpiresByType application/x-font-ttf "access plus ' + els.cacheFonts.value + '"');
          out.push('  ExpiresByType application/vnd.ms-fontobject "access plus ' + els.cacheFonts.value + '"');
          out.push('</IfModule>');
        }

        // Security
        if (els.secEnable.checked) {
          var hasAny = els.secDirListing.checked || els.secHtaccess.checked ||
                       els.secEnvFiles.checked || els.secXss.checked;
          if (hasAny) {
            out.push('');
            out.push('# Security');
          }
          if (els.secDirListing.checked) {
            out.push('Options -Indexes');
          }
          if (els.secHtaccess.checked) {
            out.push('<Files ".htaccess">');
            out.push('  Order allow,deny');
            out.push('  Deny from all');
            out.push('</Files>');
          }
          if (els.secEnvFiles.checked) {
            out.push('<Files ".env">');
            out.push('  Order allow,deny');
            out.push('  Deny from all');
            out.push('</Files>');
          }
          if (els.secXss.checked) {
            out.push('<IfModule mod_headers.c>');
            out.push('  Header always set X-Content-Type-Options "nosniff"');
            out.push('  Header always set X-Frame-Options "SAMEORIGIN"');
            out.push('  Header always set X-XSS-Protection "1; mode=block"');
            out.push('  Header always set Referrer-Policy "strict-origin-when-cross-origin"');
            out.push('</IfModule>');
          }
        }

        // Custom Redirect
        if (els.redirEnable.checked) {
          var from = (els.redirFrom.value || '').trim();
          var to   = (els.redirTo.value   || '').trim();
          if (from && to) {
            out.push('');
            out.push('# Custom Redirect');
            out.push('Redirect ' + els.redirType.value + ' ' + from + ' ' + to);
          }
        }

        // Trim leading blank line
        if (out.length && out[0] === '') out.shift();

        return out.join('\n');
      }

      function generate() {
        var result = lines();
        els.output.textContent = result || '# (no options selected)';
        els.copyBtn.disabled = !result;
      }

      function onToggleChange(enableEl, subEl) {
        enableEl.addEventListener('change', function () {
          subEl.style.display = enableEl.checked ? '' : 'none';
          generate();
        });
        // init
        subEl.style.display = enableEl.checked ? '' : 'none';
      }

      onToggleChange(els.wwwEnable,   els.wwwSub);
      onToggleChange(els.indexEnable, els.indexSub);
      onToggleChange(els.cacheEnable, els.cacheSub);
      onToggleChange(els.secEnable,   els.secSub);
      onToggleChange(els.redirEnable, els.redirSub);

      // Attach all change listeners
      var inputs = document.querySelectorAll(
        '#hta-https, #hta-www-enable, input[name="hta-www"], ' +
        '#hta-index-enable, #hta-index-files, ' +
        '#hta-cache-enable, #hta-cache-images, #hta-cache-css, #hta-cache-fonts, ' +
        '#hta-security-enable, #hta-sec-dirlisting, #hta-sec-htaccess, #hta-sec-envfiles, #hta-sec-xss, ' +
        '#hta-redir-enable, #hta-redir-from, #hta-redir-to, #hta-redir-type'
      );
      inputs.forEach(function (el) {
        el.addEventListener('change', generate);
        if (el.tagName === 'INPUT' && (el.type === 'text' || el.type === 'url')) {
          el.addEventListener('input', generate);
        }
      });

      els.copyBtn.addEventListener('click', function () {
        var text = els.output.textContent;
        if (!text || text === '# (no options selected)') return;
        function showCopied() {
          els.copyBtn.textContent = t.copied;
          els.copyBtn.classList.add('copied');
          setTimeout(function () {
            els.copyBtn.textContent = t.copy;
            els.copyBtn.classList.remove('copied');
          }, 1500);
        }
        navigator.clipboard.writeText(text).then(showCopied).catch(showCopied);
        window.trackTool && window.trackTool('htaccess-generator', 'generate');
      });

      // Initial render
      generate();
    })();
  </script>
</div>

<style>
  .hta-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  /* Section card */
  .hta-section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    background: var(--color-bg-secondary);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  /* Toggle header row */
  .hta-toggle {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    user-select: none;
  }

  .hta-toggle input[type="checkbox"] {
    width: 1.1rem;
    height: 1.1rem;
    accent-color: var(--color-primary);
    flex-shrink: 0;
    cursor: pointer;
  }

  .hta-toggle-label {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .hta-toggle-desc {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  /* Sub-options */
  .hta-sub {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-left: 1.7rem;
  }

  .hta-radio, .hta-check {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    cursor: pointer;
  }

  .hta-radio input, .hta-check input {
    accent-color: var(--color-primary);
    cursor: pointer;
  }

  /* Cache grid */
  .hta-cache-grid { gap: 0.4rem; }

  .hta-cache-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .hta-cache-type {
    font-size: 0.83rem;
    color: var(--color-text-secondary);
    flex: 1;
    min-width: 180px;
  }

  /* Custom redirect fields */
  .hta-redir-fields { gap: 0.5rem; }

  .hta-redir-row {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    align-items: flex-end;
  }

  .hta-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    min-width: 140px;
  }

  .hta-field-sm { flex: 0 0 auto; min-width: 130px; }

  .hta-field-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  /* Inputs */
  .hta-input {
    width: 100%;
    padding: 0.35rem 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.83rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
    box-sizing: border-box;
  }

  .hta-input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .hta-select {
    padding: 0.3rem 0.5rem;
    font-size: 0.83rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .hta-select:focus { outline: none; border-color: var(--color-primary); }

  /* Output block */
  .hta-output-wrap {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .hta-output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.45rem 0.75rem;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
  }

  .hta-output-title {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .hta-output {
    margin: 0;
    padding: 0.75rem 1rem;
