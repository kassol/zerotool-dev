<script>
  const SLUG = 'svg-optimizer';

  // SVGO preset-default plugin list (33 entries) — see svgo.dev/docs/preset-default.
  // The 4 we expose as primary toggles (cleanupIds, convertColors, removeComments,
  // mergePaths) are excluded from the advanced grid to avoid double controls.
  const PRESET_DEFAULT_OTHER = [
    'removeDoctype',
    'removeXMLProcInst',
    'removeMetadata',
    'removeEditorsNSData',
    'cleanupAttrs',
    'mergeStyles',
    'inlineStyles',
    'minifyStyles',
    'removeUselessDefs',
    'cleanupNumericValues',
    'removeUnknownsAndDefaults',
    'removeNonInheritableGroupAttrs',
    'removeUselessStrokeAndFill',
    'cleanupEnableBackground',
    'removeHiddenElems',
    'removeEmptyText',
    'convertShapeToPath',
    'convertEllipseToCircle',
    'moveElemsAttrsToGroup',
    'moveGroupAttrsToElems',
    'collapseGroups',
    'convertPathData',
    'convertTransform',
    'removeEmptyAttrs',
    'removeEmptyContainers',
    'removeUnusedNS',
    'sortAttrs',
    'sortDefsChildren',
    'removeDesc'
  ];

  type State = {
    cleanupIds: boolean;
    convertColors: boolean;
    removeComments: boolean;
    removeViewBox: boolean;
    removeDimensions: boolean;
    mergePaths: boolean;
    multipass: boolean;
    precision: number;
    advanced: Record<string, boolean>;
  };

  function defaultState(): State {
    const advanced: Record<string, boolean> = {};
    PRESET_DEFAULT_OTHER.forEach((p) => { advanced[p] = true; });
    return {
      cleanupIds: true,
      convertColors: true,
      removeComments: true,
      removeViewBox: false,
      removeDimensions: false,
      mergePaths: true,
      multipass: true,
      precision: 3,
      advanced,
    };
  }

  const wrap = document.querySelector('.svgo-wrap') as HTMLElement | null;
  if (!wrap) throw new Error('svgo wrap missing');

  const T = {
    statusReady: wrap.dataset.msgStatusReady || 'Ready',
    statusOptimizing: wrap.dataset.msgStatusOptimizing || 'Optimizing…',
    statusEmpty: wrap.dataset.msgStatusEmpty || 'Paste or upload an SVG.',
    statusInvalid: wrap.dataset.msgStatusInvalid || 'Does not look like valid SVG.',
    statusFileError: wrap.dataset.msgStatusFileError || 'Please drop a .svg file.',
    statusOptimized: wrap.dataset.msgStatusOptimized || 'Optimized: {before} → {after} ({delta})',
    statusLarger: wrap.dataset.msgStatusLarger || 'Result is larger: {before} → {after} ({delta})',
    statusError: wrap.dataset.msgStatusError || 'Optimization failed: {msg}',
    savedLabel: wrap.dataset.msgSavedLabel || 'saved',
    largerLabel: wrap.dataset.msgLargerLabel || 'larger',
    copied: wrap.dataset.msgCopied || 'Copied!',
    showAll: wrap.dataset.msgShowAllPlugins || 'Show all 33 plugins',
    hideAll: wrap.dataset.msgHideAllPlugins || 'Hide advanced plugins',
  };

  // Refs
  const tabPaste = document.getElementById('svgo-tab-paste') as HTMLButtonElement;
  const tabUpload = document.getElementById('svgo-tab-upload') as HTMLButtonElement;
  const panelPaste = document.getElementById('svgo-panel-paste') as HTMLElement;
  const panelUpload = document.getElementById('svgo-panel-upload') as HTMLElement;
  const inputEl = document.getElementById('svgo-input') as HTMLTextAreaElement;
  const dropEl = document.getElementById('svgo-drop') as HTMLElement;
  const fileEl = document.getElementById('svgo-file') as HTMLInputElement;
  const optimizeBtn = document.getElementById('svgo-optimize') as HTMLButtonElement;
  const resetBtn = document.getElementById('svgo-reset') as HTMLButtonElement;
  const statusEl = document.getElementById('svgo-status') as HTMLElement;
  const precisionEl = document.getElementById('svgo-precision') as HTMLInputElement;
  const precisionVal = document.getElementById('svgo-precision-val') as HTMLElement;
  const advancedBtn = document.getElementById('svgo-toggle-advanced') as HTMLButtonElement;
  const advancedBody = document.getElementById('svgo-advanced-body') as HTMLElement;
  const advancedGrid = document.getElementById('svgo-advanced-grid') as HTMLElement;
  const resultEl = document.getElementById('svgo-result') as HTMLElement;
  const bytesBeforeEl = document.getElementById('svgo-bytes-before') as HTMLElement;
  const bytesAfterEl = document.getElementById('svgo-bytes-after') as HTMLElement;
  const savedEl = document.getElementById('svgo-saved') as HTMLElement;
  const previewBeforeEl = document.getElementById('svgo-preview-before') as HTMLElement;
  const previewAfterEl = document.getElementById('svgo-preview-after') as HTMLElement;
  const outputCodeEl = document.getElementById('svgo-output-code') as HTMLElement;
  const copyBtn = document.getElementById('svgo-copy') as HTMLButtonElement;
  const downloadBtn = document.getElementById('svgo-download') as HTMLButtonElement;
  const primaryToggles = Array.from(
    document.querySelectorAll<HTMLInputElement>('.svgo-toggle input[type="checkbox"][data-plugin]')
  );

  let state: State = defaultState();
  let lastOutput = '';

  // Build advanced grid
  PRESET_DEFAULT_OTHER.forEach((name) => {
    const wrapEl = document.createElement('label');
    wrapEl.className = 'svgo-adv-toggle';
    wrapEl.innerHTML =
      '<input type="checkbox" data-adv-plugin="' + name + '" checked />' +
      '<code>' + name + '</code>';
    advancedGrid.appendChild(wrapEl);
  });

  // Persistence (preference policy — plugin config survives Clear)
  function loadPersisted(): void {
    if (window.ztPersist && window.ztPersist.load) {
      const saved = window.ztPersist.load(SLUG) as Partial<State> | null;
      if (saved && typeof saved === 'object') {
        state = { ...defaultState(), ...saved, advanced: { ...defaultState().advanced, ...(saved.advanced || {}) } };
      }
    }
    // Reflect into UI
    primaryToggles.forEach((cb) => {
      const key = cb.getAttribute('data-plugin') as keyof State;
      if (key && typeof state[key] === 'boolean') cb.checked = state[key] as boolean;
    });
    precisionEl.value = String(state.precision);
    precisionVal.textContent = String(state.precision);
    Object.keys(state.advanced).forEach((p) => {
      const cb = advancedGrid.querySelector<HTMLInputElement>('[data-adv-plugin="' + p + '"]');
      if (cb) cb.checked = state.advanced[p];
    });
  }

  function persist(): void {
    if (window.ztPersist && window.ztPersist.save) {
      window.ztPersist.save(SLUG, state);
    }
  }

  // Tab switching
  function setTab(which: 'paste' | 'upload'): void {
    const isPaste = which === 'paste';
    tabPaste.classList.toggle('svgo-tab--active', isPaste);
    tabUpload.classList.toggle('svgo-tab--active', !isPaste);
    tabPaste.setAttribute('aria-selected', isPaste ? 'true' : 'false');
    tabUpload.setAttribute('aria-selected', isPaste ? 'false' : 'true');
    panelPaste.hidden = !isPaste;
    panelUpload.hidden = isPaste;
  }
  tabPaste.addEventListener('click', () => setTab('paste'));
  tabUpload.addEventListener('click', () => setTab('upload'));

  // File / drag-drop
  dropEl.addEventListener('click', (e) => { if (e.target !== fileEl) fileEl.click(); });
  dropEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileEl.click(); }
  });
  fileEl.addEventListener('change', () => {
    if (fileEl.files && fileEl.files[0]) readFile(fileEl.files[0]);
  });
  dropEl.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropEl.classList.add('svgo-drop--over');
  });
  dropEl.addEventListener('dragleave', () => dropEl.classList.remove('svgo-drop--over'));
  dropEl.addEventListener('drop', (e) => {
    e.preventDefault();
    dropEl.classList.remove('svgo-drop--over');
    const f = e.dataTransfer && e.dataTransfer.files[0];
    if (f) readFile(f);
  });

  function readFile(file: File): void {
    if (!file.name.toLowerCase().endsWith('.svg') && file.type !== 'image/svg+xml') {
      setStatus(T.statusFileError, 'error');
      return;
    }
    const reader = new FileReader();
    reader.onload = (ev) => {
      const text = String(ev.target && ev.target.result || '');
      inputEl.value = text;
      setTab('paste');
      setStatus(T.statusReady, 'none');
    };
    reader.onerror = () => setStatus(T.statusFileError, 'error');
    reader.readAsText(file);
  }

  // Toggles
  primaryToggles.forEach((cb) => {
    cb.addEventListener('change', () => {
      const key = cb.getAttribute('data-plugin') as keyof State;
      if (!key) return;
      (state as any)[key] = cb.checked;
      persist();
    });
  });
  precisionEl.addEventListener('input', () => {
    state.precision = Number(precisionEl.value);
    precisionVal.textContent = String(state.precision);
    persist();
  });
  advancedGrid.addEventListener('change', (e) => {
    const tgt = e.target as HTMLInputElement;
    if (tgt && tgt.dataset.advPlugin) {
      state.advanced[tgt.dataset.advPlugin] = tgt.checked;
      persist();
    }
  });

  resetBtn.addEventListener('click', () => {
    state = defaultState();
    loadPersisted(); // also re-renders UI
    persist();
    setStatus(T.statusReady, 'none');
  });

  advancedBtn.addEventListener('click', () => {
    const open = advancedBody.hidden;
    advancedBody.hidden = !open;
    advancedBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    const labelEl = advancedBtn.querySelector('span');
    if (labelEl) labelEl.textContent = open ? T.hideAll : T.showAll;
  });

  // Status
  function setStatus(msg: string, kind: 'success' | 'error' | 'info' | 'none'): void {
    statusEl.textContent = msg;
    statusEl.className = 'tool-status ' + kind;
  }

  function formatBytes(n: number): string {
    if (n < 1024) return n + ' B';
    if (n < 1024 * 1024) return (n / 1024).toFixed(2) + ' KB';
    return (n / (1024 * 1024)).toFixed(2) + ' MB';
  }

  function formatDelta(before: number, after: number): { delta: string; isLarger: boolean } {
    const ratio = before === 0 ? 0 : (before - after) / before;
    const isLarger = after > before;
    const sign = isLarger ? '+' : '↓';
    const pct = Math.abs(ratio * 100).toFixed(1);
    const label = isLarger ? T.largerLabel : T.savedLabel;
    return { delta: sign + pct + '% ' + label, isLarger };
  }

  // Lazy SVGO loader
  let svgoMod: any = null;
  let svgoLoading: Promise<any> | null = null;
  async function getSvgo(): Promise<any> {
    if (svgoMod) return svgoMod;
    if (svgoLoading) return svgoLoading;
    svgoLoading = import('svgo/browser').then((mod) => {
      svgoMod = mod;
      return mod;
    });
    return svgoLoading;
  }

  function buildConfig(): any {
    const overrides: Record<string, any> = {
      cleanupIds: state.cleanupIds ? {} : false,
      convertColors: state.convertColors ? {} : false,
      removeComments: state.removeComments ? {} : false,
      mergePaths: state.mergePaths ? {} : false,
    };
    Object.keys(state.advanced).forEach((p) => {
      if (!state.advanced[p]) overrides[p] = false;
    });
    const plugins: any[] = [{ name: 'preset-default', params: { overrides } }];
    if (state.removeViewBox) plugins.push('removeViewBox');
    if (state.removeDimensions) plugins.push('removeDimensions');
    return {
      multipass: state.multipass,
      floatPrecision: state.precision,
      plugins,
    };
  }

  function isSvgish(text: string): boolean {
    return /<svg[\s>]/i.test(text);
  }

  async function optimize(): Promise<void> {
    const input = inputEl.value.trim();
    if (!input) {
      setStatus(T.statusEmpty, 'error');
      return;
    }
    if (!isSvgish(input)) {
      setStatus(T.statusInvalid, 'error');
      return;
    }

    setStatus(T.statusOptimizing, 'info');
    optimizeBtn.disabled = true;

    let mod: any;
    try {
      mod = await getSvgo();
    } catch (err: any) {
      setStatus(T.statusError.replace('{msg}', String(err && err.message || err)), 'error');
      optimizeBtn.disabled = false;
      return;
    }

    let output = input;
    try {
      const result = mod.optimize(input, buildConfig());
      output = result.data || input;
    } catch (err: any) {
      setStatus(T.statusError.replace('{msg}', String(err && err.message || err)), 'error');
      optimizeBtn.disabled = false;
      return;
    }

    optimizeBtn.disabled = false;
    lastOutput = output;

    const beforeBytes = new Blob([input]).size;
    const afterBytes = new Blob([output]).size;
    const beforeFmt = formatBytes(beforeBytes);
    const afterFmt = formatBytes(afterBytes);
    const { delta, isLarger } = formatDelta(beforeBytes, afterBytes);

    bytesBeforeEl.textContent = beforeFmt;
    bytesAfterEl.textContent = afterFmt;
    savedEl.textContent = delta;
    savedEl.className = 'svgo-saved' + (isLarger ? ' svgo-saved--larger' : '');
    previewBeforeEl.innerHTML = input;
    previewAfterEl.innerHTML = output;
    outputCodeEl.textContent = output;

    resultEl.hidden = false;

    const tpl = isLarger ? T.statusLarger : T.statusOptimized;
    const msg = tpl
      .replace('{before}', beforeFmt)
      .replace('{after}', afterFmt)
      .replace('{delta}', delta);
    setStatus(msg, isLarger ? 'info' : 'success');

    if (window.trackTool) window.trackTool('svg-optimizer', 'optimize');
  }
  optimizeBtn.addEventListener('click', () => { void optimize(); });

  // Copy / Download
  copyBtn.addEventListener('click', async () => {
    if (!lastOutput) return;
    try {
      await navigator.clipboard.writeText(lastOutput);
      const original = copyBtn.textContent;
      copyBtn.classList.add('copied');
      copyBtn.textContent = T.copied;
      setTimeout(() => {
        copyBtn.classList.remove('copied');
        copyBtn.textContent = original;
      }, 1400);
      if (window.trackTool) window.trackTool('svg-optimizer', 'copy');
    } catch (_) {}
  });

  downloadBtn.addEventListener('click', () => {
    if (!lastOutput) return;
    const blob = new Blob([lastOutput], { type: 'image/svg+xml;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'optimized.svg';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 4000);
    if (window.trackTool) window.trackTool('svg-optimizer', 'download');
  });

  // Boot
  loadPersisted();
  setStatus(T.statusReady, 'none');
</script>

