---
// SvgOptimizerTool — minify SVG markup with SVGO v4 in the browser.
// SVGO is loaded lazily on first Optimize click (~190KB gzipped browser bundle),
// so the tool page itself stays light. All processing is local.
---

<div class="svgo-wrap">
  <div class="svgo-tabs" role="tablist">
    <button
      id="svgo-tab-paste"
      class="svgo-tab svgo-tab--active"
      role="tab"
      aria-selected="true"
      aria-controls="svgo-panel-paste"
      type="button"
      data-i18n="tabPaste"
    >Paste SVG</button>
    <button
      id="svgo-tab-upload"
      class="svgo-tab"
      role="tab"
      aria-selected="false"
      aria-controls="svgo-panel-upload"
      type="button"
      data-i18n="tabUpload"
    >Upload File</button>
  </div>

  <div id="svgo-panel-paste" class="svgo-panel" role="tabpanel">
    <label for="svgo-input" class="tool-label" data-i18n="inputLabel">SVG markup</label>
    <textarea
      id="svgo-input"
      class="tool-textarea svgo-input"
      rows="7"
      spellcheck="false"
      autocapitalize="off"
      autocorrect="off"
      placeholder="Paste your SVG markup here…"
      data-i18n-attr="placeholder|inputPlaceholder"
    ></textarea>
  </div>

  <div id="svgo-panel-upload" class="svgo-panel" hidden role="tabpanel">
    <div id="svgo-drop" class="svgo-drop" role="button" tabindex="0" aria-label="Drop or select SVG">
      <div class="svgo-drop-inner">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="17 8 12 3 7 8"/>
          <line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
        <p data-i18n="dropHint">Drop an SVG file here, or click to select</p>
        <p class="svgo-drop-hint" data-i18n="dropHint2">.svg files only</p>
      </div>
      <input id="svgo-file" type="file" accept=".svg,image/svg+xml" class="svgo-file-input" aria-label="Select SVG file" />
    </div>
  </div>

  <div class="svgo-controls">
    <div class="svgo-controls-head">
      <h3 class="svgo-controls-heading" data-i18n="pluginsHeading">Plugins</h3>
      <button id="svgo-reset" class="btn-ghost svgo-reset" type="button" data-i18n="resetBtn">Reset</button>
    </div>
    <div class="svgo-toggle-grid">
      <label class="svgo-toggle">
        <input type="checkbox" data-plugin="cleanupIds" checked />
        <span class="svgo-toggle-text" data-i18n="pluginCleanupIds">Clean unused IDs</span>
      </label>
      <label class="svgo-toggle">
        <input type="checkbox" data-plugin="convertColors" checked />
        <span class="svgo-toggle-text" data-i18n="pluginConvertColors">Shorten colors</span>
      </label>
      <label class="svgo-toggle">
        <input type="checkbox" data-plugin="removeComments" checked />
        <span class="svgo-toggle-text" data-i18n="pluginRemoveComments">Remove comments</span>
      </label>
      <label class="svgo-toggle">
        <input type="checkbox" data-plugin="removeViewBox" />
        <span class="svgo-toggle-text" data-i18n="pluginRemoveViewBox">Remove viewBox</span>
        <span class="svgo-warn" aria-hidden="true">!</span>
      </label>
      <label class="svgo-toggle">
        <input type="checkbox" data-plugin="removeDimensions" />
        <span class="svgo-toggle-text" data-i18n="pluginRemoveDimensions">Remove width/height</span>
      </label>
      <label class="svgo-toggle">
        <input type="checkbox" data-plugin="mergePaths" checked />
        <span class="svgo-toggle-text" data-i18n="pluginMergePaths">Merge paths</span>
      </label>
      <label class="svgo-toggle">
        <input type="checkbox" data-plugin="multipass" checked />
        <span class="svgo-toggle-text" data-i18n="pluginMultipass">Multipass</span>
      </label>
      <label class="svgo-toggle svgo-toggle--slider">
        <span class="svgo-toggle-text">
          <span data-i18n="pluginPrecision">Precision</span>
          <span class="svgo-precision-val" id="svgo-precision-val">3</span>
        </span>
        <input type="range" id="svgo-precision" min="0" max="5" step="1" value="3" />
      </label>
    </div>

    <button
      id="svgo-toggle-advanced"
      class="btn-ghost svgo-advanced-btn"
      type="button"
      aria-expanded="false"
      aria-controls="svgo-advanced-body"
    >
      <span data-i18n="showAllPlugins">Show all 33 plugins</span>
    </button>
    <div id="svgo-advanced-body" class="svgo-advanced-body" hidden>
      <p class="svgo-advanced-hint">Advanced — raw SVGO plugin names. Defaults match SVGO preset-default.</p>
      <div id="svgo-advanced-grid" class="svgo-advanced-grid"></div>
    </div>
  </div>

  <div class="svgo-actions">
    <button id="svgo-optimize" class="btn-primary" type="button" data-i18n="optimizeBtn">Optimize SVG</button>
    <span id="svgo-status" class="tool-status none" aria-live="polite" data-i18n="statusReady">Ready</span>
  </div>

  <div id="svgo-result" class="svgo-result" hidden>
    <div class="svgo-result-grid">
      <article class="svgo-result-card">
        <header class="svgo-result-head">
          <span class="svgo-result-label" data-i18n="previewBefore">Before</span>
          <span id="svgo-bytes-before" class="svgo-result-bytes">—</span>
        </header>
        <div id="svgo-preview-before" class="svgo-preview"></div>
      </article>
      <article class="svgo-result-card">
        <header class="svgo-result-head">
          <span class="svgo-result-label" data-i18n="previewAfter">After</span>
          <span id="svgo-bytes-after" class="svgo-result-bytes">—</span>
          <span id="svgo-saved" class="svgo-saved"></span>
        </header>
        <div id="svgo-preview-after" class="svgo-preview"></div>
      </article>
    </div>

    <div class="svgo-output-actions">
      <button id="svgo-copy" class="btn-copy" type="button" data-i18n="copyOutput">Copy output</button>
      <button id="svgo-download" class="btn-secondary" type="button" data-i18n="downloadSvg">Download .svg</button>
    </div>

    <details class="svgo-output-details">
      <summary data-i18n="showOutputCode">Show optimized code</summary>
      <pre class="svgo-output-pre"><code id="svgo-output-code"></code></pre>
    </details>
  </div>
</div>

