---
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    colorTab: 'Color', imageTab: 'Image',
    colorLabel: 'Color',
    uploadTitle: 'Drop an image here, or click to browse',
    uploadHint: 'PNG, JPG, WebP — processed locally, never uploaded',
    original: 'Original',
    protanopia: 'Protanopia', deuteranopia: 'Deuteranopia', tritanopia: 'Tritanopia',
    protanomaly: 'Protanomaly', deuteranomaly: 'Deuteranomaly', tritanomaly: 'Tritanomaly',
    achromatopsia: 'Achromatopsia', achromatomaly: 'Achromatomaly',
    protanopiaSub: 'Red-blind', deuteranopiaSub: 'Green-blind', tritanopiaSub: 'Blue-blind',
    protanomalySub: 'Red-weak', deuteranomalySub: 'Green-weak', tritanomalySub: 'Blue-weak',
    achromatopsiaSub: 'No color', achromatomalySub: 'Low color',
    copied: 'Copied!', changeImage: 'Change image',
  },
  zh: {
    colorTab: '颜色', imageTab: '图片',
    colorLabel: '颜色',
    uploadTitle: '拖放图片到此处，或点击浏览',
    uploadHint: '支持 PNG、JPG、WebP — 本地处理，不上传',
    original: '原色',
    protanopia: '红色盲', deuteranopia: '绿色盲', tritanopia: '蓝色盲',
    protanomaly: '红色弱', deuteranomaly: '绿色弱', tritanomaly: '蓝色弱',
    achromatopsia: '全色盲', achromatomaly: '全色弱',
    protanopiaSub: '缺少红锥细胞', deuteranopiaSub: '缺少绿锥细胞', tritanopiaSub: '缺少蓝锥细胞',
    protanomalySub: '红锥细胞异常', deuteranomalySub: '绿锥细胞异常', tritanomalySub: '蓝锥细胞异常',
    achromatopsiaSub: '无色彩视觉', achromatomalySub: '色彩视觉减弱',
    copied: '已复制！', changeImage: '更换图片',
  },
  ja: {
    colorTab: 'カラー', imageTab: '画像',
    colorLabel: 'カラー',
    uploadTitle: '画像をドロップ、またはクリックして選択',
    uploadHint: 'PNG、JPG、WebP — ローカル処理、アップロードなし',
    original: '元の色',
    protanopia: '1型色覚', deuteranopia: '2型色覚', tritanopia: '3型色覚',
    protanomaly: '1型色弱', deuteranomaly: '2型色弱', tritanomaly: '3型色弱',
    achromatopsia: '全色盲', achromatomaly: '色弱',
    protanopiaSub: '赤不感', deuteranopiaSub: '緑不感', tritanopiaSub: '青不感',
    protanomalySub: '赤弱感', deuteranomalySub: '緑弱感', tritanomalySub: '青弱感',
    achromatopsiaSub: '色覚なし', achromatomalySub: '低色覚',
    copied: 'コピー済み', changeImage: '画像を変更',
  },
  ko: {
    colorTab: '색상', imageTab: '이미지',
    colorLabel: '색상',
    uploadTitle: '이미지를 드래그하거나 클릭하여 선택',
    uploadHint: 'PNG, JPG, WebP — 로컬 처리, 업로드 없음',
    original: '원본',
    protanopia: '적색맹', deuteranopia: '녹색맹', tritanopia: '청색맹',
    protanomaly: '적색약', deuteranomaly: '녹색약', tritanomaly: '청색약',
    achromatopsia: '전색맹', achromatomaly: '부분색약',
    protanopiaSub: '적추체 결여', deuteranopiaSub: '녹추체 결여', tritanopiaSub: '청추체 결여',
    protanomalySub: '적추체 이상', deuteranomalySub: '녹추체 이상', tritanomalySub: '청추체 이상',
    achromatopsiaSub: '무색각', achromatomalySub: '저색각',
    copied: '복사됨!', changeImage: '이미지 변경',
  },
};

const L = labels[lang] ?? labels['en'];

const types = [
  { key: 'original', label: L.original, sub: '' },
  { key: 'protanopia', label: L.protanopia, sub: L.protanopiaSub },
  { key: 'deuteranopia', label: L.deuteranopia, sub: L.deuteranopiaSub },
  { key: 'tritanopia', label: L.tritanopia, sub: L.tritanopiaSub },
  { key: 'protanomaly', label: L.protanomaly, sub: L.protanomalySub },
  { key: 'deuteranomaly', label: L.deuteranomaly, sub: L.deuteranomalySub },
  { key: 'tritanomaly', label: L.tritanomaly, sub: L.tritanomalySub },
  { key: 'achromatopsia', label: L.achromatopsia, sub: L.achromatopsiaSub },
  { key: 'achromatomaly', label: L.achromatomaly, sub: L.achromatomalySub },
];
---

<div class="cbs-wrap" data-copied={L.copied}>
  <div class="cbs-tabs">
    <button class="cbs-tab cbs-tab-active" id="cbs-tab-color" type="button">{L.colorTab}</button>
    <button class="cbs-tab" id="cbs-tab-image" type="button">{L.imageTab}</button>
  </div>

  <div class="cbs-panel" id="cbs-color-panel">
    <div class="cbs-color-row">
      <input id="cbs-picker" type="color" value="#e74c3c" class="cbs-picker" aria-label={L.colorLabel} />
      <input id="cbs-hex" type="text" value="#E74C3C" class="tool-input cbs-hex" maxlength="7" autocomplete="off" spellcheck="false" />
    </div>
  </div>

  <div class="cbs-panel" id="cbs-image-panel" hidden>
    <div class="cbs-dropzone" id="cbs-dropzone">
      <svg class="cbs-dropzone-icon" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <circle cx="8.5" cy="8.5" r="1.5" />
        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
      </svg>
      <span class="cbs-dropzone-title">{L.uploadTitle}</span>
      <span class="cbs-dropzone-hint">{L.uploadHint}</span>
      <input id="cbs-file" type="file" accept="image/*" class="cbs-file-input" />
    </div>
    <button id="cbs-change-image" class="btn-secondary cbs-change-btn" type="button" hidden>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
      {L.changeImage}
    </button>
  </div>

  <div class="cbs-grid" id="cbs-grid">
    {types.map(t => (
      <div class={`cbs-card ${t.key === 'original' ? 'cbs-card-original' : ''}`} data-type={t.key}>
        <div class="cbs-card-head">
          <span class="cbs-card-label">{t.label}</span>
          {t.sub && <span class="cbs-card-sub">{t.sub}</span>}
        </div>
        <div class="cbs-card-swatch" id={`cbs-swatch-${t.key}`}></div>
        <img class="cbs-card-img" id={`cbs-img-${t.key}`} alt={t.label} hidden />
        <button class="btn-copy cbs-card-copy" id={`cbs-copy-${t.key}`} type="button" hidden></button>
      </div>
    ))}
  </div>

<script is:inline>
(function () {
  var wrap = document.currentScript
    ? document.currentScript.closest('.cbs-wrap')
    : document.querySelector('.cbs-wrap');

  var COPIED = wrap.dataset.copied;

  var tabColor = document.getElementById('cbs-tab-color');
  var tabImage = document.getElementById('cbs-tab-image');
  var colorPanel = document.getElementById('cbs-color-panel');
  var imagePanel = document.getElementById('cbs-image-panel');
  var picker = document.getElementById('cbs-picker');
  var hexInput = document.getElementById('cbs-hex');
  var dropzone = document.getElementById('cbs-dropzone');
  var fileInput = document.getElementById('cbs-file');
  var changeBtn = document.getElementById('cbs-change-image');
  var grid = document.getElementById('cbs-grid');

  var currentHex = '#e74c3c';

  /* ── CVD simulation matrices (Viénot 1999 / Brettel 1997) ── */
  var P = [0.567,0.433,0, 0.558,0.442,0, 0,0.242,0.758];
  var D = [0.625,0.375,0, 0.700,0.300,0, 0,0.300,0.700];
  var T = [0.950,0.050,0, 0,0.433,0.567, 0,0.475,0.525];
  var A = [0.2126,0.7152,0.0722, 0.2126,0.7152,0.0722, 0.2126,0.7152,0.0722];
  var I = [1,0,0, 0,1,0, 0,0,1];

  function lerp(a, b, t) {
    return a.map(function (v, i) { return v * (1 - t) + b[i] * t; });
  }

  var TYPES = {
    protanopia: P, deuteranopia: D, tritanopia: T,
    protanomaly: lerp(I, P, 0.6), deuteranomaly: lerp(I, D, 0.6), tritanomaly: lerp(I, T, 0.6),
    achromatopsia: A, achromatomaly: lerp(I, A, 0.5),
  };
  var TYPE_KEYS = Object.keys(TYPES);

  /* ── Color utilities ── */
  function hexToRgb(hex) {
    return [parseInt(hex.slice(1, 3), 16), parseInt(hex.slice(3, 5), 16), parseInt(hex.slice(5, 7), 16)];
  }

  function rgbToHex(r, g, b) {
    function c(v) { return ('0' + Math.round(Math.max(0, Math.min(255, v))).toString(16)).slice(-2); }
    return '#' + c(r) + c(g) + c(b);
  }

  function simColor(rgb, m) {
    return [
      m[0] * rgb[0] + m[1] * rgb[1] + m[2] * rgb[2],
      m[3] * rgb[0] + m[4] * rgb[1] + m[5] * rgb[2],
      m[6] * rgb[0] + m[7] * rgb[1] + m[8] * rgb[2],
    ];
  }

  function normalizeHex(s) {
    s = (s || '').trim();
    if (!s.startsWith('#')) s = '#' + s;
    if (/^#[0-9a-fA-F]{3}$/.test(s)) s = '#' + s[1] + s[1] + s[2] + s[2] + s[3] + s[3];
    return s.toLowerCase();
  }

  function isValidHex(s) { return /^#[0-9a-fA-F]{6}$/.test(s); }

  /* ── Color mode ── */
  function updateColor() {
    if (!isValidHex(currentHex)) return;
    var rgb = hexToRgb(currentHex);

    setCard('original', currentHex, null);
    TYPE_KEYS.forEach(function (key) {
      var sim = simColor(rgb, TYPES[key]);
      setCard(key, rgbToHex(sim[0], sim[1], sim[2]), null);
    });

    window.trackTool && window.trackTool('color-blindness-simulator', 'simulate_color');
  }

  function setCard(key, hex, imgSrc) {
    var swatch = document.getElementById('cbs-swatch-' + key);
    var img = document.getElementById('cbs-img-' + key);
    var copy = document.getElementById('cbs-copy-' + key);

    if (imgSrc) {
      swatch.hidden = true;
      img.src = imgSrc;
      img.hidden = false;
      copy.hidden = true;
    } else {
      swatch.style.background = hex;
      swatch.hidden = false;
      img.hidden = true;
      copy.textContent = hex.toUpperCase();
      copy.dataset.hex = hex.toUpperCase();
      copy.hidden = false;
    }
  }

  /* ── Image mode ── */
  var srcCanvas = document.createElement('canvas');
  var srcCtx = srcCanvas.getContext('2d');
  var MAX_DIM = 600;

  function processImage(file) {
    var reader = new FileReader();
    reader.onload = function (e) {
      var image = new Image();
      image.onload = function () {
        var w = image.width, h = image.height;
        if (w > MAX_DIM || h > MAX_DIM) {
          var ratio = Math.min(MAX_DIM / w, MAX_DIM / h);
          w = Math.round(w * ratio);
          h = Math.round(h * ratio);
        }
        srcCanvas.width = w;
        srcCanvas.height = h;
        srcCtx.drawImage(image, 0, 0, w, h);

        setCard('original', null, srcCanvas.toDataURL());

        var srcData = srcCtx.getImageData(0, 0, w, h);
        var tc = document.createElement('canvas');
        tc.width = w; tc.height = h;
        var tctx = tc.getContext('2d');
        TYPE_KEYS.forEach(function (key) {
          var d = new ImageData(new Uint8ClampedArray(srcData.data), w, h);
          var px = d.data;
          var m = TYPES[key];
          for (var i = 0; i < px.length; i += 4) {
            var r = px[i], g = px[i + 1], b = px[i + 2];
            px[i]     = m[0] * r + m[1] * g + m[2] * b;
            px[i + 1] = m[3] * r + m[4] * g + m[5] * b;
            px[i + 2] = m[6] * r + m[7] * g + m[8] * b;
          }
          tctx.putImageData(d, 0, 0);
          setCard(key, null, tc.toDataURL());
        });

        dropzone.hidden = true;
        changeBtn.hidden = false;
        window.trackTool && window.trackTool('color-blindness-simulator', 'simulate_image');
      };
      image.src = e.target.result;
    };
    reader.readAsDataURL(file);
  }

  /* ── Tab switching ── */
  function setMode(mode) {
    tabColor.classList.toggle('cbs-tab-active', mode === 'color');
    tabImage.classList.toggle('cbs-tab-active', mode === 'image');
    colorPanel.hidden = mode !== 'color';
    imagePanel.hidden = mode !== 'image';
    if (mode === 'color') updateColor();
  }

  tabColor.addEventListener('click', function () { setMode('color'); });
  tabImage.addEventListener('click', function () { setMode('image'); });

  /* ── Color input wiring ── */
  picker.addEventListener('input', function () {
    currentHex = picker.value.toLowerCase();
    hexInput.value = currentHex.toUpperCase();
    updateColor();
  });

  hexInput.addEventListener('input', function () {
    var v = normalizeHex(hexInput.value);
    if (isValidHex(v)) {
      currentHex = v;
      picker.value = v;
      updateColor();
    }
  });

  /* ── File input wiring ── */
  dropzone.addEventListener('click', function () { fileInput.click(); });

  fileInput.addEventListener('change', function () {
    if (fileInput.files && fileInput.files[0]) processImage(fileInput.files[0]);
  });

  dropzone.addEventListener('dragover', function (e) {
    e.preventDefault();
    dropzone.classList.add('cbs-dropzone-active');
  });

  dropzone.addEventListener('dragleave', function () {
    dropzone.classList.remove('cbs-dropzone-active');
  });

  dropzone.addEventListener('drop', function (e) {
    e.preventDefault();
    dropzone.classList.remove('cbs-dropzone-active');
    if (e.dataTransfer.files && e.dataTransfer.files[0]) processImage(e.dataTransfer.files[0]);
  });

  changeBtn.addEventListener('click', function () {
    fileInput.value = '';
    dropzone.hidden = false;
    changeBtn.hidden = true;
    fileInput.click();
  });

  /* ── Copy wiring (delegation) ── */
  grid.addEventListener('click', function (e) {
    var btn = e.target.closest('.cbs-card-copy');
    if (!btn || !btn.dataset.hex) return;
    navigator.clipboard.writeText(btn.dataset.hex).then(function () {
      var orig = btn.textContent;
      btn.textContent = COPIED;
      btn.classList.add('copied');
      setTimeout(function () {
        btn.textContent = orig;
        btn.classList.remove('copied');
      }, 1400);
      window.trackTool && window.trackTool('color-blindness-simulator', 'copy');
    });
  });

  /* ── Init ── */
  hexInput.value = currentHex.toUpperCase();
  updateColor();
})();
</script>
</div>

<style is:global>
  .cbs-wrap {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Tabs ── */
  .cbs-tabs {
    display: flex;
    gap: 0.35rem;
    padding: 0.3rem;
    background: var(--color-surface-muted);
    border-radius: var(--radius-pill);
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
    width: fit-content;
  }

  .cbs-tab {
    padding: 0.42rem 1.1rem;
    border: 0;
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .cbs-tab-active {
    background: var(--color-surface);
    color: var(--color-text);
    box-shadow: var(--shadow-subtle);
  }

  @media (hover: hover) {
    .cbs-tab:not(.cbs-tab-active):hover {
      color: var(--color-text-secondary);
    }
  }

  /* ── Panels ── */
  .cbs-panel { display: flex; flex-direction: column; gap: 0.75rem; }
  .cbs-panel[hidden] { display: none; }

  .cbs-color-row {
    display: flex;
    gap: 0.6rem;
    align-items: center;
  }

  .cbs-picker {
    width: 50px;
    height: 50px;
    flex: 0 0 50px;
    padding: 3px;
    border: 0;
    border-radius: var(--radius-md);
    cursor: pointer;
    background: var(--color-bg-secondary);
    box-shadow: inset 0 0 0 1px var(--color-border-soft);
  }

  .cbs-picker::-webkit-color-swatch-wrapper { padding: 0; }
  .cbs-picker::-webkit-color-swatch { border: 0; border-radius: var(--radius-sm); }
  .cbs-picker::-moz-color-swatch { border: 0; border-radius: var(--radius-sm); }

  .cbs-hex {
    width: 130px;
    text-transform: uppercase;
    font-weight: 700;
  }

  /* ── Dropzone ── */
  .cbs-dropzone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 2.2rem 1.5rem;
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: inset 0 0 0 2px var(--color-border-soft);
    cursor: pointer;
    transition: background-color var(--transition-fast), box-shadow var(--transition-fast);
    position: relative;
  }

  .cbs-dropzone[hidden] { display: none; }

  .cbs-dropzone-active,
  .cbs-dropzone:hover {
    background: var(--color-bg-secondary);
    box-shadow: inset 0 0 0 2px color-mix(in oklch, var(--color-primary) 55%, transparent);
  }

  .cbs-dropzone-icon { color: var(--color-text-muted); }

  .cbs-dropzone-title {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    text-align: center;
  }

  .cbs-dropzone-hint {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  .cbs-file-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }

  .cbs-change-btn { align-self: flex-start; }
  .cbs-change-btn[hidden] { display: none; }

  /* ── Grid ── */
  .cbs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
    gap: 0.85rem;
  }

  /* ── Card ── */
  .cbs-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: inset 0 0 0 1px var(--color-border-soft), var(--shadow-card);
    overflow: hidden;
  }

  .cbs-card-original {
    box-shadow: inset 0 0 0 2px color-mix(in oklch, var(--color-primary) 50%, transparent), var(--shadow-card);
  }

  .cbs-card-head {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
    padding: 0.6rem 0.75rem 0.4rem;
    flex-wrap: wrap;
  }

  .cbs-card-label {
    font-size: 0.82rem;
    font-weight: 800;
    color: var(--color-text);
    line-height: 1.2;
  }

  .cbs-card-sub {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.2;
  }

  .cbs-card-swatch {
    aspect-ratio: 4 / 3;
    width: 100%;
    transition: background-color var(--transition-fast);
  }

  .cbs-card-swatch[hidden] { display: none; }

  .cbs-card-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .cbs-card-img[hidden] { display: none; }

  .cbs-card-copy {
    margin: 0.45rem 0.6rem 0.55rem;
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
  }

  .cbs-card-copy[hidden] { display: none; }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .cbs-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .cbs-card-original {
      grid-column: 1 / -1;
    }

    .cbs-picker {
      width: 44px;
      height: 44px;
      flex: 0 0 44px;
    }
  }

  @media (max-width: 400px) {
    .cbs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
