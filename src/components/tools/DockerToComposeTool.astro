---
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    inputLabel: 'docker run Command',
    outputLabel: 'docker-compose.yml',
    example: 'Example',
    clear: 'Clear',
    copy: 'Copy',
    copied: 'Copied!',
    convert: 'Convert',
    msgInvalidCmd: 'Not a valid docker run command',
    msgConverted: 'Converted.',
  },
  zh: {
    inputLabel: 'docker run 命令',
    outputLabel: 'docker-compose.yml',
    example: '示例',
    clear: '清空',
    copy: '复制',
    copied: '已复制！',
    convert: '转换',
    msgInvalidCmd: '无效的 docker run 命令',
    msgConverted: '已转换。',
  },
  ja: {
    inputLabel: 'docker run コマンド',
    outputLabel: 'docker-compose.yml',
    example: 'サンプル',
    clear: 'クリア',
    copy: 'コピー',
    copied: 'コピーしました！',
    convert: '変換',
    msgInvalidCmd: '無効なdocker runコマンド',
    msgConverted: '変換しました。',
  },
  ko: {
    inputLabel: 'docker run 명령어',
    outputLabel: 'docker-compose.yml',
    example: '예시',
    clear: '지우기',
    copy: '복사',
    copied: '복사됨!',
    convert: '변환',
    msgInvalidCmd: '잘못된 docker run 명령어',
    msgConverted: '변환 완료.',
  },
};

const L = labels[lang];
---

<div
  class="dtc-wrap"
  data-copy={L.copy}
  data-copied={L.copied}
  data-msg-invalid-cmd={L.msgInvalidCmd}
  data-msg-converted={L.msgConverted}
>
  <div class="dtc-panels">
    <div class="dtc-panel">
      <div class="dtc-panel-header">
        <span>{L.inputLabel}</span>
        <div class="dtc-panel-actions">
          <button id="dtc-example" class="btn-ghost btn-sm" type="button">{L.example}</button>
          <button id="dtc-clear" class="btn-ghost btn-sm" type="button">{L.clear}</button>
        </div>
      </div>
      <textarea
        id="dtc-input"
        placeholder="docker run -d --name myapp -p 8080:80 nginx:latest"
        spellcheck="false"
      ></textarea>
    </div>

    <div class="dtc-panel">
      <div class="dtc-panel-header">
        <span>{L.outputLabel}</span>
        <button id="dtc-copy" class="btn-ghost btn-sm" type="button">{L.copy}</button>
      </div>
      <pre id="dtc-output" class="dtc-output"><code id="dtc-output-code"></code></pre>
    </div>
  </div>

  <div class="dtc-actions">
    <button id="dtc-convert" class="btn-primary" type="button">{L.convert}</button>
  </div>

  <div id="dtc-status" class="dtc-status" aria-live="polite"></div>

  <script is:inline>
    (function () {
      var wrap = document.currentScript
        ? document.currentScript.closest('.dtc-wrap')
        : document.querySelector('.dtc-wrap');

      var COPY = wrap ? wrap.dataset.copy : 'Copy';
      var COPIED = wrap ? wrap.dataset.copied : 'Copied!';
      var MSG_INVALID = wrap ? wrap.dataset.msgInvalidCmd : 'Not a valid docker run command';
      var MSG_CONVERTED = wrap ? wrap.dataset.msgConverted : 'Converted.';

      var inputEl = document.getElementById('dtc-input');
      var outputCodeEl = document.getElementById('dtc-output-code');
      var statusEl = document.getElementById('dtc-status');

      var EXAMPLE = 'docker run -d \\\n' +
        '  --name myapp \\\n' +
        '  -p 8080:80 \\\n' +
        '  -v ./data:/var/www/html \\\n' +
        '  -e NODE_ENV=production \\\n' +
        '  --restart unless-stopped \\\n' +
        '  nginx:latest';

      function setStatus(msg, isError) {
        statusEl.textContent = msg;
        statusEl.className = 'dtc-status ' + (isError ? 'error' : 'success');
      }
      function clearStatus() {
        statusEl.textContent = '';
        statusEl.className = 'dtc-status';
      }

      /* ── Tokenizer (same as curl tool) ── */
      function tokenize(cmd) {
        var tokens = [];
        var i = 0;
        cmd = cmd.replace(/\\\n/g, ' ');
        while (i < cmd.length) {
          while (i < cmd.length && /\s/.test(cmd[i])) i++;
          if (i >= cmd.length) break;

          var ch = cmd[i];
          if (ch === '"' || ch === "'") {
            var quote = ch;
            i++;
            var buf = '';
            while (i < cmd.length && cmd[i] !== quote) {
              if (cmd[i] === '\\' && quote === '"') {
                i++;
                if (i < cmd.length) { buf += cmd[i]; i++; }
              } else {
                buf += cmd[i++];
              }
            }
            i++;
            tokens.push(buf);
          } else {
            var start = i;
            while (i < cmd.length && !/\s/.test(cmd[i])) i++;
            tokens.push(cmd.slice(start, i));
          }
        }
        return tokens;
      }

      /* ── Service name derivation ── */
      function deriveServiceName(image) {
        // Strip registry prefix (contains a dot or colon before first slash)
        var parts = image.split('/');
        var name;
        if (parts.length >= 2 && (parts[0].indexOf('.') >= 0 || parts[0].indexOf(':') >= 0)) {
          parts = parts.slice(1);
        }
        name = parts.join('/');
        // Strip tag
        var colonIdx = name.lastIndexOf(':');
        if (colonIdx >= 0) name = name.slice(0, colonIdx);
        // Replace slashes with underscores
        name = name.replace(/\//g, '_');
        // Replace non-alphanumeric (except _ and -) with _
        name = name.replace(/[^a-zA-Z0-9_-]/g, '_');
        return name || 'app';
      }

      /* ── Parser ── */
      function parseDockerRun(cmd) {
        var tokens = tokenize(cmd.trim());
        if (!tokens.length) return null;

        // Skip 'docker' and 'run'
        var i = 0;
        if (tokens[i] === 'docker') i++;
        if (i >= tokens.length || tokens[i] !== 'run') return null;
        i++;

        var result = {
          name: null,
          ports: [],
          volumes: [],
          envs: [],
          network: null,
          restart: null,
          capAdd: [],
          memory: null,
          cpus: null,
          image: null,
          command: [],
        };

        while (i < tokens.length) {
          var t = tokens[i];

          if (t === '--name') {
            i++;
            result.name = tokens[i] || null;
          } else if (t === '-p' || t === '--publish') {
            i++;
            if (tokens[i]) result.ports.push(tokens[i]);
          } else if (t === '-v' || t === '--volume') {
            i++;
            if (tokens[i]) result.volumes.push(tokens[i]);
          } else if (t === '-e' || t === '--env') {
            i++;
            if (tokens[i]) result.envs.push(tokens[i]);
          } else if (t === '--network') {
            i++;
            result.network = tokens[i] || null;
          } else if (t === '--restart') {
            i++;
            result.restart = tokens[i] || null;
          } else if (t === '-d' || t === '--detach') {
            // ignore
          } else if (t === '--cap-add') {
            i++;
            if (tokens[i]) result.capAdd.push(tokens[i]);
          } else if (t === '--memory' || t === '-m') {
            i++;
            result.memory = tokens[i] || null;
          } else if (t === '--cpus') {
            i++;
            result.cpus = tokens[i] || null;
          } else if (t === '--rm' || t === '-i' || t === '-t' || t === '-it' || t === '-ti') {
            // ignore
          } else if (t.startsWith('--env=')) {
            result.envs.push(t.slice('--env='.length));
          } else if (t.startsWith('-e=')) {
            result.envs.push(t.slice('-e='.length));
          } else if (t.startsWith('--name=')) {
            result.name = t.slice('--name='.length);
          } else if (t.startsWith('--network=')) {
            result.network = t.slice('--network='.length);
          } else if (t.startsWith('--restart=')) {
            result.restart = t.slice('--restart='.length);
          } else if (t.startsWith('--memory=') || t.startsWith('-m=')) {
            result.memory = t.slice(t.indexOf('=') + 1);
          } else if (t.startsWith('--cpus=')) {
            result.cpus = t.slice('--cpus='.length);
          } else if (t.startsWith('--cap-add=')) {
            result.capAdd.push(t.slice('--cap-add='.length));
          } else if (t.startsWith('-p=') || t.startsWith('--publish=')) {
            result.ports.push(t.slice(t.indexOf('=') + 1));
          } else if (t.startsWith('-v=') || t.startsWith('--volume=')) {
            result.volumes.push(t.slice(t.indexOf('=') + 1));
          } else if (!t.startsWith('-')) {
            // First non-flag = image, rest = command
            result.image = t;
            i++;
            while (i < tokens.length) {
              result.command.push(tokens[i]);
              i++;
            }
            break;
          }
          // unknown flags: skip with their value if they look like --flag value
          i++;
        }

        if (!result.image) return null;
        return result;
      }

      /* ── YAML helpers ── */
      function yamlStr(s) {
        // Quote if needed
        if (/[:#\[\]{},&*?|<>=!%@`]/.test(s) || s.indexOf('"') >= 0 || s === '' || /^\s|\s$/.test(s)) {
          return '"' + s.replace(/\\/g, '\\\\').replace(/"/g, '\\"') + '"';
        }
        return s;
      }

      /* ── YAML generator ── */
      function generateCompose(p) {
        var serviceName = p.name || deriveServiceName(p.image);
        var lines = [];

        lines.push("version: '3.8'");
        lines.push('');
        lines.push('services:');
        lines.push('  ' + yamlStr(serviceName) + ':');
        lines.push('    image: ' + yamlStr(p.image));

        if (p.ports.length) {
          lines.push('    ports:');
          p.ports.forEach(function (port) {
            lines.push('      - ' + yamlStr(port));
          });
        }

        if (p.volumes.length) {
          lines.push('    volumes:');
          p.volumes.forEach(function (vol) {
            lines.push('      - ' + yamlStr(vol));
          });
        }

        if (p.envs.length) {
          lines.push('    environment:');
          p.envs.forEach(function (env) {
            lines.push('      - ' + yamlStr(env));
          });
        }

        if (p.network) {
          lines.push('    networks:');
          lines.push('      - ' + yamlStr(p.network));
        }

        if (p.restart) {
          lines.push('    restart: ' + yamlStr(p.restart));
        }

        if (p.capAdd.length) {
          lines.push('    cap_add:');
          p.capAdd.forEach(function (cap) {
            lines.push('      - ' + yamlStr(cap));
          });
        }

        if (p.memory || p.cpus) {
          lines.push('    deploy:');
          lines.push('      resources:');
          lines.push('        limits:');
          if (p.memory) lines.push('          memory: ' + yamlStr(p.memory));
          if (p.cpus) lines.push("          cpus: '" + p.cpus + "'");
        }

        if (p.command.length) {
          lines.push('    command: [' + p.command.map(function (c) {
            return '"' + c.replace(/\\/g, '\\\\').replace(/"/g, '\\"') + '"';
          }).join(', ') + ']');
        }

        if (p.network) {
          lines.push('');
          lines.push('networks:');
          lines.push('  ' + yamlStr(p.network) + ':');
          lines.push('    external: true');
        }

        return lines.join('\n');
      }

      /* ── Main convert ── */
      function convert() {
        var raw = inputEl.value.trim();
        if (!raw) { clearStatus(); outputCodeEl.textContent = ''; return; }

        var parsed = parseDockerRun(raw);
        if (!parsed) {
          outputCodeEl.textContent = '';
          setStatus(MSG_INVALID, true);
          return;
        }

        outputCodeEl.textContent = generateCompose(parsed);
        setStatus(MSG_CONVERTED, false);
        window.trackTool && window.trackTool('docker-to-compose', 'convert');
      }

      /* ── Events ── */
      document.getElementById('dtc-convert').addEventListener('click', convert);

      document.getElementById('dtc-example').addEventListener('click', function () {
        inputEl.value = EXAMPLE;
        clearStatus();
        convert();
      });

      document.getElementById('dtc-clear').addEventListener('click', function () {
        inputEl.value = '';
        outputCodeEl.textContent = '';
        clearStatus();
      });

      document.getElementById('dtc-copy').addEventListener('click', function () {
        var text = outputCodeEl.textContent;
        if (!text) return;
        var btn = document.getElementById('dtc-copy');
        navigator.clipboard.writeText(text).then(function () {
          btn.textContent = COPIED;
          setTimeout(function () { btn.textContent = COPY; }, 1500);
        });
      });
    })();
  </script>
</div>

<style>
  .dtc-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .dtc-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .dtc-panels { grid-template-columns: 1fr; }
  }

  .dtc-panel { display: flex; flex-direction: column; gap: 0.4rem; }

  .dtc-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .dtc-panel-actions { display: flex; gap: 0.3rem; }

  .dtc-panel textarea {
    width: 100%;
    min-height: 260px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
    line-height: 1.5;
    transition: border-color 0.15s;
  }

  .dtc-panel textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .dtc-output {
    min-height: 260px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    line-height: 1.5;
    margin: 0;
    overflow: auto;
    white-space: pre;
  }

  .btn-sm {
    padding: 0.2rem 0.5rem;
    font-size: 0.78rem;
  }

  .dtc-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .dtc-status { font-size: 0.85rem; min-height: 1.2rem; }
  .dtc-status.success { color: #057a55; }
  .dtc-status.error { color: #c0392b; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .dtc-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .dtc-status.error { color: #f87171; }
  }
  [data-theme="dark"] .dtc-status.success { color: #34d399; }
  [data-theme="dark"] .dtc-status.error { color: #f87171; }
</style>
