---
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    jsonInput: 'JSON Input',
    csvOutput: 'CSV Output',
    example: 'Example',
    clear: 'Clear',
    copy: 'Copy',
    copied: 'Copied!',
    download: 'Download .csv',
    convert: 'Convert to CSV',
    delimiter: 'Delimiter',
    delComma: 'Comma (,)',
    delSemicolon: 'Semicolon (;)',
    delTab: 'Tab',
    flatten: 'Flatten nested objects',
    header: 'Include header',
    on: 'On',
    off: 'Off',
    msgRows: '{n} rows converted',
    msgOneRow: '1 row converted',
    msgEmptyArray: 'Empty array — nothing to convert',
    msgNotArray: 'Input must be a JSON array of objects',
    msgInvalidJson: 'Invalid JSON: ',
  },
  zh: {
    jsonInput: 'JSON 输入',
    csvOutput: 'CSV 输出',
    example: '示例',
    clear: '清空',
    copy: '复制',
    copied: '已复制！',
    download: '下载 .csv',
    convert: '转换为 CSV',
    delimiter: '分隔符',
    delComma: '逗号 (,)',
    delSemicolon: '分号 (;)',
    delTab: 'Tab',
    flatten: '展开嵌套对象',
    header: '包含表头',
    on: '开启',
    off: '关闭',
    msgRows: '已转换 {n} 行',
    msgOneRow: '已转换 1 行',
    msgEmptyArray: '空数组——无内容可转换',
    msgNotArray: '输入必须是 JSON 对象数组',
    msgInvalidJson: 'JSON 格式错误：',
  },
  ja: {
    jsonInput: 'JSON 入力',
    csvOutput: 'CSV 出力',
    example: 'サンプル',
    clear: 'クリア',
    copy: 'コピー',
    copied: 'コピーしました！',
    download: '.csv をダウンロード',
    convert: 'CSV に変換',
    delimiter: '区切り文字',
    delComma: 'カンマ (,)',
    delSemicolon: 'セミコロン (;)',
    delTab: 'タブ',
    flatten: 'ネストオブジェクトを展開',
    header: 'ヘッダーを含める',
    on: 'オン',
    off: 'オフ',
    msgRows: '{n} 行を変換しました',
    msgOneRow: '1 行を変換しました',
    msgEmptyArray: '空の配列 — 変換するデータがありません',
    msgNotArray: '入力はオブジェクトの JSON 配列である必要があります',
    msgInvalidJson: '無効なJSON：',
  },
  ko: {
    jsonInput: 'JSON 입력',
    csvOutput: 'CSV 출력',
    example: '예시',
    clear: '지우기',
    copy: '복사',
    copied: '복사됨!',
    download: '.csv 다운로드',
    convert: 'CSV로 변환',
    delimiter: '구분자',
    delComma: '쉼표 (,)',
    delSemicolon: '세미콜론 (;)',
    delTab: '탭',
    flatten: '중첩 객체 펼치기',
    header: '헤더 포함',
    on: '켜짐',
    off: '꺼짐',
    msgRows: '{n}행 변환됨',
    msgOneRow: '1행 변환됨',
    msgEmptyArray: '빈 배열 — 변환할 데이터가 없습니다',
    msgNotArray: '입력은 객체의 JSON 배열이어야 합니다',
    msgInvalidJson: '잘못된 JSON: ',
  },
};

const L = labels[lang];
---

<div
  class="jtc-wrap"
  data-copy={L.copy}
  data-copied={L.copied}
  data-msg-rows={L.msgRows}
  data-msg-one-row={L.msgOneRow}
  data-msg-empty-array={L.msgEmptyArray}
  data-msg-not-array={L.msgNotArray}
  data-msg-invalid-json={L.msgInvalidJson}
>
  <div class="jtc-config">
    <div class="jtc-config-row">
      <span class="jtc-label">{L.delimiter}</span>
      <div class="jtc-tabs" id="jtc-del-tabs">
        <button type="button" class="jtc-tab active" data-del=",">{L.delComma}</button>
        <button type="button" class="jtc-tab" data-del=";">{L.delSemicolon}</button>
        <button type="button" class="jtc-tab" data-del={'\t'}>{L.delTab}</button>
      </div>
    </div>
    <div class="jtc-config-row">
      <span class="jtc-label">{L.flatten}</span>
      <div class="jtc-tabs" id="jtc-flatten-tabs">
        <button type="button" class="jtc-tab active" data-flatten="true">{L.on}</button>
        <button type="button" class="jtc-tab" data-flatten="false">{L.off}</button>
      </div>
    </div>
    <div class="jtc-config-row">
      <span class="jtc-label">{L.header}</span>
      <div class="jtc-tabs" id="jtc-header-tabs">
        <button type="button" class="jtc-tab active" data-header="true">{L.on}</button>
        <button type="button" class="jtc-tab" data-header="false">{L.off}</button>
      </div>
    </div>
  </div>

  <div class="jtc-panels">
    <div class="jtc-panel">
      <div class="jtc-panel-header">
        <span>{L.jsonInput}</span>
        <div class="jtc-panel-actions">
          <button id="jtc-example" class="btn-ghost btn-sm" type="button">{L.example}</button>
          <button id="jtc-clear" class="btn-ghost btn-sm" type="button">{L.clear}</button>
        </div>
      </div>
      <textarea id="jtc-input" spellcheck="false" placeholder='[{"id": 1, "name": "Alice"}]'></textarea>
    </div>

    <div class="jtc-panel">
      <div class="jtc-panel-header">
        <span>{L.csvOutput}</span>
        <div class="jtc-panel-actions">
          <button id="jtc-download" class="btn-ghost btn-sm" type="button">{L.download}</button>
          <button id="jtc-copy" class="btn-ghost btn-sm" type="button">{L.copy}</button>
        </div>
      </div>
      <textarea id="jtc-output" spellcheck="false" readonly></textarea>
    </div>
  </div>

  <div class="jtc-actions">
    <button id="jtc-convert" class="btn-primary" type="button">{L.convert}</button>
  </div>

  <div id="jtc-status" class="jtc-status" aria-live="polite"></div>

  <script>
    (function () {
      var wrap = document.querySelector('.jtc-wrap');
      if (!wrap) return;

      var COPY = wrap.dataset.copy || 'Copy';
      var COPIED = wrap.dataset.copied || 'Copied!';
      var MSG_ROWS = wrap.dataset.msgRows || '{n} rows converted';
      var MSG_ONE_ROW = wrap.dataset.msgOneRow || '1 row converted';
      var MSG_EMPTY = wrap.dataset.msgEmptyArray || 'Empty array — nothing to convert';
      var MSG_NOT_ARRAY = wrap.dataset.msgNotArray || 'Input must be a JSON array of objects';
      var MSG_INVALID = wrap.dataset.msgInvalidJson || 'Invalid JSON: ';

      var inputEl = document.getElementById('jtc-input') as HTMLTextAreaElement;
      var outputEl = document.getElementById('jtc-output') as HTMLTextAreaElement;
      var statusEl = document.getElementById('jtc-status');

      var delimiter = ',';
      var flatten = true;
      var includeHeader = true;

      var EXAMPLE = JSON.stringify([
        { id: 1, name: 'Alice', address: { city: 'NY', zip: '10001' } },
        { id: 2, name: 'Bob', address: { city: 'LA', zip: '90001' } },
      ], null, 2);

      function wireTabs(containerId: string, prop: string, setter: (v: string) => void) {
        var tabs = wrap!.querySelectorAll('#' + containerId + ' .jtc-tab');
        for (var i = 0; i < tabs.length; i++) {
          (function (tab) {
            tab.addEventListener('click', function () {
              for (var j = 0; j < tabs.length; j++) tabs[j].classList.remove('active');
              tab.classList.add('active');
              setter((tab as HTMLElement).dataset[prop] || '');
              convert();
            });
          })(tabs[i]);
        }
      }

      wireTabs('jtc-del-tabs', 'del', function (v) { delimiter = v; });
      wireTabs('jtc-flatten-tabs', 'flatten', function (v) { flatten = v === 'true'; });
      wireTabs('jtc-header-tabs', 'header', function (v) { includeHeader = v === 'true'; });

      function setStatus(msg: string, isError: boolean) {
        statusEl!.textContent = msg;
        statusEl!.className = 'jtc-status ' + (isError ? 'error' : 'success');
      }

      function flattenObject(obj: Record<string, unknown>, prefix: string): Record<string, unknown> {
        var result: Record<string, unknown> = {};
        var keys = Object.keys(obj);
        for (var i = 0; i < keys.length; i++) {
          var k = keys[i];
          var val = obj[k];
          var fullKey = prefix ? prefix + '.' + k : k;
          if (val !== null && typeof val === 'object' && !Array.isArray(val)) {
            var sub = flattenObject(val as Record<string, unknown>, fullKey);
            var subKeys = Object.keys(sub);
            for (var j = 0; j < subKeys.length; j++) result[subKeys[j]] = sub[subKeys[j]];
          } else {
            result[fullKey] = val;
          }
        }
        return result;
      }

      function csvField(val: unknown, del: string): string {
        if (val === null || val === undefined) return '';
        var s = typeof val === 'object' ? JSON.stringify(val) : String(val);
        if (s.indexOf(del) !== -1 || s.indexOf('"') !== -1 || s.indexOf('\n') !== -1 || s.indexOf('\r') !== -1) {
          return '"' + s.replace(/"/g, '""') + '"';
        }
        return s;
      }

      function buildCsv(rows: Record<string, unknown>[], del: string, withHeader: boolean): string {
        var headers: string[] = [];
        for (var i = 0; i < rows.length; i++) {
          var keys = Object.keys(rows[i]);
          for (var j = 0; j < keys.length; j++) {
            if (headers.indexOf(keys[j]) === -1) headers.push(keys[j]);
          }
        }

        var lines: string[] = [];
        if (withHeader) lines.push(headers.map(function (h) { return csvField(h, del); }).join(del));

        for (var i = 0; i < rows.length; i++) {
          var row = rows[i];
          lines.push(headers.map(function (h) { return csvField(row[h], del); }).join(del));
        }

        return lines.join('\n');
      }

      function convert() {
        var raw = inputEl.value.trim();
        if (!raw) {
          outputEl.value = '';
          statusEl!.textContent = '';
          statusEl!.className = 'jtc-status';
          return;
        }

        var parsed: unknown;
        try {
          parsed = JSON.parse(raw);
        } catch (e: unknown) {
          inputEl.classList.add('error');
          outputEl.value = '';
          setStatus(MSG_INVALID + (e instanceof Error ? e.message : String(e)), true);
          return;
        }

        inputEl.classList.remove('error');

        if (!Array.isArray(parsed)) {
          outputEl.value = '';
          setStatus(MSG_NOT_ARRAY, true);
          return;
        }

        if (parsed.length === 0) {
          outputEl.value = '';
          setStatus(MSG_EMPTY, true);
          return;
        }

        var rows = parsed.map(function (item: unknown) {
          if (item === null || typeof item !== 'object' || Array.isArray(item)) {
            return { value: item };
          }
          if (flatten) return flattenObject(item as Record<string, unknown>, '');
          return item as Record<string, unknown>;
        });

        var csv = buildCsv(rows, delimiter, includeHeader);
        outputEl.value = csv;
        var dataRows = includeHeader ? rows.length : rows.length;
        var msg = dataRows === 1 ? MSG_ONE_ROW : MSG_ROWS.replace('{n}', String(dataRows));
        setStatus(msg, false);
        window.trackTool && window.trackTool('json-to-csv', 'convert');
      }

      var _liveTimer: ReturnType<typeof setTimeout> | null = null;
      inputEl.addEventListener('input', function () {
        clearTimeout(_liveTimer!);
        _liveTimer = setTimeout(convert, 300);
      });

      document.getElementById('jtc-convert')!.addEventListener('click', convert);

      document.getElementById('jtc-example')!.addEventListener('click', function () {
        inputEl.value = EXAMPLE;
        inputEl.classList.remove('error');
        convert();
      });

      document.getElementById('jtc-clear')!.addEventListener('click', function () {
        inputEl.value = '';
        outputEl.value = '';
        inputEl.classList.remove('error');
        statusEl!.textContent = '';
        statusEl!.className = 'jtc-status';
      });

      document.getElementById('jtc-copy')!.addEventListener('click', function () {
        var text = outputEl.value;
        if (!text) return;
        var btn = document.getElementById('jtc-copy')!;
        navigator.clipboard.writeText(text).then(function () {
          btn.textContent = COPIED;
          setTimeout(function () { btn.textContent = COPY; }, 1500);
        });
      });

      document.getElementById('jtc-download')!.addEventListener('click', function () {
        var text = outputEl.value;
        if (!text) return;
        var blob = new Blob([text], { type: 'text/csv;charset=utf-8;' });
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = 'export.csv';
        a.click();
        URL.revokeObjectURL(url);
      });

      inputEl.value = EXAMPLE;
      convert();
    })();
  </script>
</div>

<style>
  .jtc-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .jtc-config {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .jtc-config-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .jtc-label {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
    min-width: 9rem;
  }

  .jtc-tabs { display: flex; gap: 0.25rem; flex-wrap: wrap; }

  .jtc-tab {
    padding: 0.2rem 0.6rem;
    font-size: 0.78rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: background 0.1s, color 0.1s, border-color 0.1s;
  }

  .jtc-tab:hover { border-color: var(--color-primary); color: var(--color-text); }
  .jtc-tab.active {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  .jtc-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .jtc-panels { grid-template-columns: 1fr; }
  }

  .jtc-panel { display: flex; flex-direction: column; gap: 0.4rem; }

  .jtc-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .jtc-panel-actions { display: flex; gap: 0.3rem; }

  .jtc-panel textarea {
    width: 100%;
    min-height: 280px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
    line-height: 1.5;
    transition: border-color 0.15s;
  }

  .jtc-panel textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }
  .jtc-panel textarea.error { border-color: #c0392b; }
  .jtc-panel textarea[readonly] { cursor: default; }

  .btn-sm { padding: 0.2rem 0.5rem; font-size: 0.78rem; }
  .jtc-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .jtc-status { font-size: 0.85rem; min-height: 1.2rem; }
  .jtc-status.success { color: #057a55; }
  .jtc-status.error { color: #c0392b; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .jtc-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .jtc-status.error { color: #f87171; }
    :root:not([data-theme="light"]) .jtc-panel textarea.error { border-color: #f87171; }
  }
  [data-theme="dark"] .jtc-status.success { color: #34d399; }
  [data-theme="dark"] .jtc-status.error { color: #f87171; }
  [data-theme="dark"] .jtc-panel textarea.error { border-color: #f87171; }
</style>
