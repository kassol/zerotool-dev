---
// AiTokenCounterTool — count tokens and estimate cost across major LLMs.
// All BPE tokenization runs in the browser via js-tiktoken; vocabularies
// are dynamically imported so initial JS payload stays small.
---

<div class="atc-wrap"
  data-msg-paste=""
  data-msg-empty=""
  data-msg-tokens-shown=""
  data-msg-chars=""
  data-msg-words=""
  data-msg-loading=""
  data-msg-copied=""
  data-msg-copy-stats=""
  data-msg-show-viz=""
  data-msg-hide-viz=""
  data-msg-viz-hint=""
>
  <section class="atc-input-section">
    <label for="atc-input" class="tool-label" data-i18n="inputLabel">Prompt or context</label>
    <textarea
      id="atc-input"
      class="tool-textarea"
      rows="6"
      spellcheck="false"
      autocapitalize="off"
      autocorrect="off"
      placeholder="Paste your prompt or context here…"
      data-i18n-attr="placeholder|inputPlaceholder"
    ></textarea>
    <div class="atc-input-meta">
      <div class="atc-input-actions">
        <button id="atc-clear" class="btn-ghost" type="button" data-i18n="clear">Clear</button>
        <button id="atc-sample" class="btn-ghost" type="button" data-i18n="loadSample">Load sample</button>
        <button id="atc-copy-stats" class="btn-secondary" type="button" data-i18n="copyStats">Copy stats</button>
      </div>
      <span class="atc-input-stats" aria-live="polite">
        <span data-i18n="charsLabel">chars</span>:&nbsp;<span id="atc-chars" class="atc-stat-num">0</span>
        <span class="atc-stat-sep">·</span>
        <span data-i18n="wordsLabel">words</span>:&nbsp;<span id="atc-words" class="atc-stat-num">0</span>
      </span>
    </div>
  </section>

  <section class="atc-cards-section">
    <h2 class="atc-section-heading" data-i18n="resultsHeading">Token counts &amp; cost</h2>
    <div id="atc-cards" class="atc-cards-grid"></div>
    <p class="atc-pricing-note" data-i18n="pricingNote">
      Prices are reference values reviewed in May 2026. Verify on each provider's pricing page.
    </p>
  </section>

  <section class="atc-viz-section">
    <button id="atc-viz-toggle" class="btn-secondary" type="button" aria-expanded="false" aria-controls="atc-viz-body">
      <span data-i18n="showViz">Show token visualization</span>
    </button>
    <div id="atc-viz-body" class="atc-viz-body" hidden>
      <p class="atc-viz-meta" id="atc-viz-meta"></p>
      <div id="atc-viz-chips" class="atc-viz-chips" role="list"></div>
    </div>
  </section>
</div>

<script is:inline>
  (function () {
    var STRINGS = {
      en: {
        inputLabel: 'Prompt or context',
        inputPlaceholder: 'Paste your prompt or context here…',
        clear: 'Clear',
        loadSample: 'Load sample',
        copyStats: 'Copy stats',
