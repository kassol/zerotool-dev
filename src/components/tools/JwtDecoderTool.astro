---
// JwtDecoderTool — JWT token decoder widget
---
<div>
  <div class="jwt-wrap">
    <div class="jwt-input-section">
      <label for="jwt-input" data-i18n="pasteLabel">Paste JWT Token</label>
      <textarea
        id="jwt-input"
        placeholder="Paste your JWT here..."
        data-i18n-placeholder="pastePlaceholder"
        spellcheck="false"
        autocomplete="off"
      ></textarea>
      <div class="jwt-actions">
        <button id="jwt-decode" class="btn-primary" data-i18n="decode">Decode</button>
        <button id="jwt-example" class="btn-ghost" data-i18n="loadExample">Load Example</button>
        <button id="jwt-clear" class="btn-ghost" data-i18n="clear">Clear</button>
      </div>
    </div>

    <div id="jwt-status" class="jwt-status" aria-live="polite"></div>

    <div id="jwt-results" class="jwt-results"></div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: { pasteLabel: 'Paste JWT Token', decode: 'Decode', loadExample: 'Load Example', clear: 'Clear', copy: 'Copy', copied: 'Copied!', decodedOk: 'Decoded successfully.', errPaste: 'Please paste a JWT token.', errInvalid: 'Invalid JWT: expected 3 dot-separated parts, got ', errDecode: 'Failed to Base64URL-decode token parts.', pastePlaceholder: 'Paste your JWT here...' },
        zh: { pasteLabel: '粘贴 JWT Token', decode: '解码', loadExample: '加载示例', clear: '清除', copy: '复制', copied: '已复制！', decodedOk: '解码成功。', errPaste: '请粘贴 JWT Token。', errInvalid: 'JWT 无效：应有 3 段，实际为 ', errDecode: 'Base64URL 解码失败。', pastePlaceholder: '在此粘贴 JWT Token...' },
        ja: { pasteLabel: 'JWT トークンを貼り付け', decode: 'デコード', loadExample: 'サンプルを読み込む', clear: 'クリア', copy: 'コピー', copied: 'コピー済み！', decodedOk: 'デコードしました。', errPaste: 'JWT トークンを貼り付けてください。', errInvalid: '無効な JWT：3 つのパートが必要です。実際: ', errDecode: 'Base64URL デコードに失敗しました。', pastePlaceholder: 'ここに JWT トークンを貼り付け...' },
        ko: { pasteLabel: 'JWT 토큰 붙여넣기', decode: '디코드', loadExample: '예시 불러오기', clear: '지우기', copy: '복사', copied: '복사됨!', decodedOk: '디코딩 완료.', errPaste: 'JWT 토큰을 붙여넣어 주세요.', errInvalid: '유효하지 않은 JWT: 3개 파트가 필요합니다. 실제: ', errDecode: 'Base64URL 디코드에 실패했습니다.', pastePlaceholder: '여기에 JWT 토큰을 붙여넣기...' }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;

      document.querySelectorAll('.jwt-wrap [data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });
      document.querySelectorAll('.jwt-wrap [data-i18n-placeholder]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-placeholder'); if (t[key]) el.setAttribute('placeholder', t[key]);
      });

      var JWT_REGEX = /^[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]*$/;
      var EXAMPLE_JWT = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyLCJleHAiOjE4OTM0NTYwMDB9.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c';
      var debounceTimer = null;

      function b64urlDecode(str) {
        str = str.replace(/-/g, '+').replace(/_/g, '/');
        while (str.length % 4) str += '=';
        try {
          return atob(str);
        } catch (e) {
          return null;
        }
      }

      function parseJSON(str) {
        try { return JSON.parse(str); } catch (e) { return null; }
      }

      function syntaxHighlight(obj) {
        var json = JSON.stringify(obj, null, 2);
        return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+-]?\d+)?)/g, function (match) {
          var cls = 'jv-num';
          if (/^"/.test(match)) {
            if (/:$/.test(match)) {
              cls = 'jv-key';
            } else {
              cls = 'jv-str';
            }
          } else if (/true|false/.test(match)) {
            cls = 'jv-bool';
          } else if (/null/.test(match)) {
            cls = 'jv-null';
          }
          return '<span class="' + cls + '">' + match + '</span>';
        });
      }

      function formatTimeClaim(key, val) {
        if (['exp', 'iat', 'nbf'].indexOf(key) !== -1 && typeof val === 'number') {
          var d = new Date(val * 1000);
          var now = Date.now();
          var extra = ' <span class="jwt-time-hint">(' + d.toUTCString();
          if (key === 'exp') {
            extra += val * 1000 < now ? ' — <span class="jwt-expired">EXPIRED</span>' : ' — <span class="jwt-valid">valid</span>';
          }
          extra += ')</span>';
          return extra;
        }
        return '';
      }

      function buildSection(label, color, obj) {
        var div = document.createElement('div');
        div.className = 'jwt-section';

        var header = document.createElement('div');
        header.className = 'jwt-section-header';
        header.innerHTML = '<span class="jwt-section-dot" style="background:' + color + '"></span><strong>' + label + '</strong>';
        div.appendChild(header);

        var pre = document.createElement('pre');
        pre.className = 'jwt-json';
        if (label === 'Payload' && obj) {
          var json = JSON.stringify(obj, null, 2);
          var highlighted = syntaxHighlight(obj);
          highlighted = highlighted.replace(/"(exp|iat|nbf)": (<span[^>]*>(\d+)<\/span>)/g, function(match, key, spanHtml, val) {
            return '"' + key + '": ' + spanHtml + formatTimeClaim(key, parseInt(val));
          });
          pre.innerHTML = highlighted;
        } else if (obj) {
          pre.innerHTML = syntaxHighlight(obj);
        } else {
          pre.textContent = '(unable to parse)';
        }
        div.appendChild(pre);

        var copyBtn = document.createElement('button');
        copyBtn.className = 'btn-copy';
        copyBtn.textContent = t.copy;
        copyBtn.addEventListener('click', function () {
          navigator.clipboard.writeText(JSON.stringify(obj, null, 2)).then(function () {
            copyBtn.textContent = t.copied;
            setTimeout(function () { copyBtn.textContent = t.copy; }, 1500);
          });
        });
        div.appendChild(copyBtn);

        return div;
      }

      function buildSigSection(sigRaw) {
        var div = document.createElement('div');
        div.className = 'jwt-section';
        var header = document.createElement('div');
        header.className = 'jwt-section-header';
        header.innerHTML = '<span class="jwt-section-dot" style="background:#f59e0b"></span><strong>Signature</strong> <span class="jwt-sig-note">(raw Base64URL — not verified)</span>';
        div.appendChild(header);
        var code = document.createElement('code');
        code.className = 'jwt-sig';
        code.textContent = sigRaw;
        div.appendChild(code);
        return div;
      }

      function decode() {
        var raw = document.getElementById('jwt-input').value.trim();
        var statusEl = document.getElementById('jwt-status');
        var resultsEl = document.getElementById('jwt-results');
        resultsEl.innerHTML = '';

        if (!raw) {
          statusEl.textContent = t.errPaste;
          statusEl.className = 'jwt-status error';
          return;
        }

        var parts = raw.split('.');
        if (parts.length !== 3) {
          statusEl.textContent = t.errInvalid + parts.length + '.';
          statusEl.className = 'jwt-status error';
          return;
        }

        var headerStr = b64urlDecode(parts[0]);
        var payloadStr = b64urlDecode(parts[1]);

        if (!headerStr || !payloadStr) {
          statusEl.textContent = t.errDecode;
          statusEl.className = 'jwt-status error';
          return;
        }

        var header = parseJSON(headerStr);
        var payload = parseJSON(payloadStr);

        resultsEl.appendChild(buildSection('Header', '#6366f1', header));
        resultsEl.appendChild(buildSection('Payload', '#10b981', payload));
        resultsEl.appendChild(buildSigSection(parts[2]));

        statusEl.textContent = t.decodedOk;
        statusEl.className = 'jwt-status success';
        window.trackTool && window.trackTool('jwt_decoder', 'decode');
      }

      function clearOutput() {
        document.getElementById('jwt-results').innerHTML = '';
        document.getElementById('jwt-status').textContent = '';
        document.getElementById('jwt-status').className = 'jwt-status';
      }

      // Restore saved input
      var jwtInputEl = document.getElementById('jwt-input');
      if (window.ztPersist) {
        var _jwtSaved = window.ztPersist.load('jwt-decoder')['input'];
        if (_jwtSaved) {
          jwtInputEl.value = _jwtSaved;
          if (JWT_REGEX.test(_jwtSaved.trim())) decode();
        }
      }

      document.getElementById('jwt-decode').addEventListener('click', decode);

      document.getElementById('jwt-input').addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) decode();
      });

      var _jwtSaveTimer = null;
      document.getElementById('jwt-input').addEventListener('input', function () {
        clearTimeout(debounceTimer);
        clearTimeout(_jwtSaveTimer);
        var val = this.value.trim();
        _jwtSaveTimer = setTimeout(function () {
          if (window.ztPersist) window.ztPersist.save('jwt-decoder', { input: jwtInputEl.value });
        }, 500);
        if (!val || !JWT_REGEX.test(val)) {
          clearOutput();
          return;
        }
        debounceTimer = setTimeout(decode, 300);
      });

      document.getElementById('jwt-example').addEventListener('click', function () {
        document.getElementById('jwt-input').value = EXAMPLE_JWT;
        clearTimeout(debounceTimer);
        decode();
      });

      document.getElementById('jwt-clear').addEventListener('click', function () {
        clearTimeout(debounceTimer);
        document.getElementById('jwt-input').value = '';
        clearOutput();
      });
    })();
  </script>
</div>

<style>
  .jwt-wrap { display: flex; flex-direction: column; gap: 1rem; }

  .jwt-input-section { display: flex; flex-direction: column; gap: 0.4rem; }

  .jwt-input-section label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .jwt-input-section textarea {
    width: 100%;
    min-height: 90px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
    word-break: break-all;
  }
  .jwt-input-section textarea:focus { outline: none; border-color: #6366f1; background: var(--color-bg); }

  .jwt-actions { display: flex; gap: 0.5rem; margin-top: 0.25rem; }

  .jwt-status { font-size: 0.85rem; min-height: 1.2rem; }
  .jwt-status.success { color: #057a55; }
  .jwt-status.error { color: #c0392b; }

  .jwt-results { display: flex; flex-direction: column; gap: 1rem; }

  .jwt-section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .jwt-section-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    font-size: 0.88rem;
  }

  .jwt-section-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .jwt-sig-note {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .jwt-json {
    margin: 0;
    padding: 0.75rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.55;
    overflow-x: auto;
    background: var(--color-bg);
    color: var(--color-text);
    white-space: pre;
  }

  .jwt-sig {
    display: block;
    padding: 0.75rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    word-break: break-all;
    background: var(--color-bg);
  }

  .jv-key { color: #6366f1; }
  .jv-str { color: #e67e22; }
  .jv-num { color: #27ae60; }
  .jv-bool { color: #8e44ad; }
  .jv-null { color: #95a5a6; }

  .jwt-time-hint { font-size: 0.78rem; color: var(--color-text-muted); }
  .jwt-expired { color: #e00; font-weight: 700; }
  .jwt-valid { color: #057a55; font-weight: 700; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .jwt-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .jwt-status.error { color: #f87171; }
    :root:not([data-theme="light"]) .jv-key { color: #818cf8; }
    :root:not([data-theme="light"]) .jv-str { color: #fb923c; }
    :root:not([data-theme="light"]) .jv-num { color: #4ade80; }
    :root:not([data-theme="light"]) .jv-bool { color: #c084fc; }
    :root:not([data-theme="light"]) .jv-null { color: #94a3b8; }
    :root:not([data-theme="light"]) .jwt-expired { color: #f87171; }
    :root:not([data-theme="light"]) .jwt-valid { color: #34d399; }
  }
  [data-theme="dark"] .jwt-status.success { color: #34d399; }
  [data-theme="dark"] .jwt-status.error { color: #f87171; }
  [data-theme="dark"] .jv-key { color: #818cf8; }
  [data-theme="dark"] .jv-str { color: #fb923c; }
  [data-theme="dark"] .jv-num { color: #4ade80; }
  [data-theme="dark"] .jv-bool { color: #c084fc; }
  [data-theme="dark"] .jv-null { color: #94a3b8; }
  [data-theme="dark"] .jwt-expired { color: #f87171; }
  [data-theme="dark"] .jwt-valid { color: #34d399; }
</style>
