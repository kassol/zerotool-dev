---
// CssGradientGeneratorTool — Linear / Radial / Conic gradient generator
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    type: 'Type',
    linear: 'Linear',
    radial: 'Radial',
    conic: 'Conic',
    angle: 'Angle (deg)',
    direction: 'Direction',
    shape: 'Shape',
    circle: 'Circle',
    ellipse: 'Ellipse',
    position: 'Position',
    fromAngle: 'From (deg)',
    atPosition: 'At Position',
    colorStops: 'Color Stops',
    addStop: '+ Add Stop',
    removeStop: '×',
    preview: 'Preview',
    outputLabel: 'Generated CSS',
    copy: 'Copy',
    copied: 'Copied!',
  },
  zh: {
    type: '类型',
    linear: '线性',
    radial: '径向',
    conic: '锥形',
    angle: '角度 (deg)',
    direction: '方向',
    shape: '形状',
    circle: '圆形',
    ellipse: '椭圆',
    position: '位置',
    fromAngle: '起始角度 (deg)',
    atPosition: '中心位置',
    colorStops: '颜色节点',
    addStop: '+ 添加',
    removeStop: '×',
    preview: '预览',
    outputLabel: '生成的 CSS',
    copy: '复制',
    copied: '已复制！',
  },
  ja: {
    type: 'タイプ',
    linear: 'リニア',
    radial: 'ラジアル',
    conic: 'コニック',
    angle: '角度 (deg)',
    direction: '方向',
    shape: '形状',
    circle: '円形',
    ellipse: '楕円',
    position: '位置',
    fromAngle: '開始角度 (deg)',
    atPosition: '中心位置',
    colorStops: 'カラーストップ',
    addStop: '+ 追加',
    removeStop: '×',
    preview: 'プレビュー',
    outputLabel: '生成された CSS',
    copy: 'コピー',
    copied: 'コピーしました！',
  },
  ko: {
    type: '유형',
    linear: '선형',
    radial: '방사형',
    conic: '원뿔형',
    angle: '각도 (deg)',
    direction: '방향',
    shape: '모양',
    circle: '원형',
    ellipse: '타원',
    position: '위치',
    fromAngle: '시작 각도 (deg)',
    atPosition: '중심 위치',
    colorStops: '색상 정지점',
    addStop: '+ 추가',
    removeStop: '×',
    preview: '미리보기',
    outputLabel: '생성된 CSS',
    copy: '복사',
    copied: '복사됨!',
  },
};

const L = labels[lang] ?? labels['en'];
---

<div
  class="cgg-wrap"
  data-copy={L.copy}
  data-copied={L.copied}
>
  <!-- Type tabs -->
  <div class="cgg-tabs">
    <button class="cgg-tab cgg-tab--active" data-type="linear" type="button">{L.linear}</button>
    <button class="cgg-tab" data-type="radial" type="button">{L.radial}</button>
    <button class="cgg-tab" data-type="conic" type="button">{L.conic}</button>
  </div>

  <!-- Controls -->
  <div class="cgg-controls">
    <!-- Linear controls -->
    <div id="cgg-panel-linear" class="cgg-panel">
      <div class="cgg-field">
        <label class="cgg-label" for="cgg-angle">{L.angle}</label>
        <div class="cgg-angle-row">
          <input id="cgg-angle-range" class="cgg-range" type="range" min="0" max="360" value="90" />
          <input id="cgg-angle" class="cgg-num-input" type="number" min="0" max="360" value="90" />
        </div>
      </div>
      <div class="cgg-field">
        <label class="cgg-label">{L.direction}</label>
        <div class="cgg-dir-btns">
          <button class="cgg-dir-btn" data-deg="0" type="button">Top</button>
          <button class="cgg-dir-btn cgg-dir-btn--active" data-deg="90" type="button">Right</button>
          <button class="cgg-dir-btn" data-deg="180" type="button">Bottom</button>
          <button class="cgg-dir-btn" data-deg="270" type="button">Left</button>
        </div>
      </div>
    </div>

    <!-- Radial controls -->
    <div id="cgg-panel-radial" class="cgg-panel cgg-panel--hidden">
      <div class="cgg-field">
        <label class="cgg-label" for="cgg-radial-shape">{L.shape}</label>
        <select id="cgg-radial-shape" class="cgg-select">
          <option value="ellipse">{L.ellipse}</option>
          <option value="circle">{L.circle}</option>
        </select>
      </div>
      <div class="cgg-field">
        <label class="cgg-label" for="cgg-radial-pos">{L.position}</label>
        <select id="cgg-radial-pos" class="cgg-select">
          <option value="center">center</option>
          <option value="top">top</option>
          <option value="bottom">bottom</option>
          <option value="left">left</option>
          <option value="right">right</option>
          <option value="top left">top left</option>
          <option value="top right">top right</option>
          <option value="bottom left">bottom left</option>
          <option value="bottom right">bottom right</option>
        </select>
      </div>
    </div>

    <!-- Conic controls -->
    <div id="cgg-panel-conic" class="cgg-panel cgg-panel--hidden">
      <div class="cgg-field">
        <label class="cgg-label" for="cgg-conic-from">{L.fromAngle}</label>
        <div class="cgg-angle-row">
          <input id="cgg-conic-from-range" class="cgg-range" type="range" min="0" max="360" value="0" />
          <input id="cgg-conic-from" class="cgg-num-input" type="number" min="0" max="360" value="0" />
        </div>
      </div>
      <div class="cgg-field">
        <label class="cgg-label" for="cgg-conic-pos">{L.atPosition}</label>
        <select id="cgg-conic-pos" class="cgg-select">
          <option value="center">center</option>
          <option value="top">top</option>
          <option value="bottom">bottom</option>
          <option value="left">left</option>
          <option value="right">right</option>
          <option value="top left">top left</option>
          <option value="top right">top right</option>
          <option value="bottom left">bottom left</option>
          <option value="bottom right">bottom right</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Color stops -->
  <div class="cgg-section">
    <div class="cgg-stops-header">
      <span class="cgg-label">{L.colorStops}</span>
      <button id="cgg-add-stop" class="cgg-add-btn" type="button">{L.addStop}</button>
    </div>
    <div id="cgg-stops" class="cgg-stops">
      <div class="cgg-stop" data-idx="0">
        <input class="cgg-stop-picker" type="color" value="#3b82f6" />
        <input class="cgg-stop-hex" type="text" value="#3b82f6" maxlength="7" spellcheck="false" autocomplete="off" />
        <input class="cgg-stop-pos" type="number" min="0" max="100" value="0" />
        <span class="cgg-stop-pct">%</span>
        <button class="cgg-stop-remove" type="button" aria-label="remove">{L.removeStop}</button>
      </div>
      <div class="cgg-stop" data-idx="1">
        <input class="cgg-stop-picker" type="color" value="#8b5cf6" />
        <input class="cgg-stop-hex" type="text" value="#8b5cf6" maxlength="7" spellcheck="false" autocomplete="off" />
        <input class="cgg-stop-pos" type="number" min="0" max="100" value="100" />
        <span class="cgg-stop-pct">%</span>
        <button class="cgg-stop-remove" type="button" aria-label="remove">{L.removeStop}</button>
      </div>
    </div>
  </div>

  <!-- Preview -->
  <div class="cgg-section">
    <div class="cgg-label">{L.preview}</div>
    <div id="cgg-preview" class="cgg-preview"></div>
  </div>

  <!-- CSS Output -->
  <div class="cgg-section">
    <div class="cgg-output-header">
      <span class="cgg-label">{L.outputLabel}</span>
      <button id="cgg-copy" class="btn-copy" type="button" aria-label={L.copy}>{L.copy}</button>
    </div>
    <pre id="cgg-pre" class="cgg-pre"><code id="cgg-code" class="cgg-code"></code></pre>
  </div>

  <script is:inline>
    (function () {
      var wrap = document.currentScript
        ? document.currentScript.closest('.cgg-wrap')
        : document.querySelector('.cgg-wrap');

      var COPY_LABEL   = wrap.dataset.copy;
      var COPIED_LABEL = wrap.dataset.copied;

      var currentType = 'linear';

      /* Tab switching */
      var tabs = wrap.querySelectorAll('.cgg-tab');
      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          tabs.forEach(function (t) { t.classList.remove('cgg-tab--active'); });
          tab.classList.add('cgg-tab--active');
          currentType = tab.dataset.type;
          wrap.querySelectorAll('.cgg-panel').forEach(function (p) { p.classList.add('cgg-panel--hidden'); });
          wrap.querySelector('#cgg-panel-' + currentType).classList.remove('cgg-panel--hidden');
          update();
        });
      });

      /* Linear: angle slider + number sync */
      var angleRangeEl = wrap.querySelector('#cgg-angle-range');
      var angleNumEl   = wrap.querySelector('#cgg-angle');
      angleRangeEl.addEventListener('input', function () {
        angleNumEl.value = angleRangeEl.value;
        updateDirButtons(parseInt(angleRangeEl.value));
        update();
      });
      angleNumEl.addEventListener('input', function () {
        var v = Math.min(360, Math.max(0, parseInt(angleNumEl.value) || 0));
        angleRangeEl.value = v;
        updateDirButtons(v);
        update();
      });

      /* Direction quick buttons */
      var dirBtns = wrap.querySelectorAll('.cgg-dir-btn');
      dirBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var deg = parseInt(btn.dataset.deg);
          angleRangeEl.value = deg;
          angleNumEl.value   = deg;
          updateDirButtons(deg);
          update();
        });
      });

      function updateDirButtons(deg) {
        dirBtns.forEach(function (btn) {
          btn.classList.toggle('cgg-dir-btn--active', parseInt(btn.dataset.deg) === deg);
        });
      }

      /* Radial controls */
      var radialShapeEl = wrap.querySelector('#cgg-radial-shape');
      var radialPosEl   = wrap.querySelector('#cgg-radial-pos');
      radialShapeEl.addEventListener('change', update);
      radialPosEl.addEventListener('change', update);

      /* Conic controls */
      var conicFromRangeEl = wrap.querySelector('#cgg-conic-from-range');
      var conicFromNumEl   = wrap.querySelector('#cgg-conic-from');
      var conicPosEl       = wrap.querySelector('#cgg-conic-pos');
      conicFromRangeEl.addEventListener('input', function () {
        conicFromNumEl.value = conicFromRangeEl.value;
        update();
      });
      conicFromNumEl.addEventListener('input', function () {
        var v = Math.min(360, Math.max(0, parseInt(conicFromNumEl.value) || 0));
        conicFromRangeEl.value = v;
        update();
      });
      conicPosEl.addEventListener('change', update);

      /* Color stops */
      var stopsEl  = wrap.querySelector('#cgg-stops');
      var addBtn   = wrap.querySelector('#cgg-add-stop');

      function getStopCount() { return stopsEl.querySelectorAll('.cgg-stop').length; }

      function bindStop(stopEl) {
        var picker = stopEl.querySelector('.cgg-stop-picker');
        var hex    = stopEl.querySelector('.cgg-stop-hex');
        var pos    = stopEl.querySelector('.cgg-stop-pos');
        var remove = stopEl.querySelector('.cgg-stop-remove');

        picker.addEventListener('input', function () {
          hex.value = picker.value;
          update();
        });
        hex.addEventListener('input', function () {
          var v = hex.value.trim();
          if (/^#[0-9a-fA-F]{6}$/.test(v)) {
            picker.value = v;
            update();
          }
        });
        pos.addEventListener('input', update);
        remove.addEventListener('click', function () {
          if (getStopCount() <= 2) return;
          stopEl.remove();
          updateRemoveButtons();
          update();
        });
      }

      function updateRemoveButtons() {
        var stops = stopsEl.querySelectorAll('.cgg-stop');
        stops.forEach(function (s) {
          s.querySelector('.cgg-stop-remove').disabled = stops.length <= 2;
        });
        addBtn.disabled = stops.length >= 6;
      }

      /* Bind initial stops */
      stopsEl.querySelectorAll('.cgg-stop').forEach(bindStop);
      updateRemoveButtons();

      addBtn.addEventListener('click', function () {
        if (getStopCount() >= 6) return;
        var stopEl = document.createElement('div');
        stopEl.className = 'cgg-stop';
        stopEl.innerHTML =
          '<input class="cgg-stop-picker" type="color" value="#f59e0b" />' +
          '<input class="cgg-stop-hex" type="text" value="#f59e0b" maxlength="7" spellcheck="false" autocomplete="off" />' +
          '<input class="cgg-stop-pos" type="number" min="0" max="100" value="50" />' +
          '<span class="cgg-stop-pct">%</span>' +
          '<button class="cgg-stop-remove" type="button" aria-label="remove">' + COPY_LABEL.replace(COPY_LABEL, '×') + '</button>';
        /* set remove label correctly */
        stopEl.querySelector('.cgg-stop-remove').textContent = '×';
        stopsEl.appendChild(stopEl);
        bindStop(stopEl);
        updateRemoveButtons();
        update();
      });

      /* Build gradient CSS */
      function buildStopList() {
        var stops = stopsEl.querySelectorAll('.cgg-stop');
        var parts = [];
        stops.forEach(function (s) {
          var color = s.querySelector('.cgg-stop-picker').value;
          var pos   = parseInt(s.querySelector('.cgg-stop-pos').value) || 0;
          parts.push(color + ' ' + pos + '%');
        });
        return parts;
      }

      function buildGradient() {
        var stops = buildStopList().join(', ');
        if (currentType === 'linear') {
          var deg = parseInt(angleRangeEl.value) || 90;
          return 'linear-gradient(' + deg + 'deg, ' + stops + ')';
        }
        if (currentType === 'radial') {
          var shape = radialShapeEl.value;
          var pos   = radialPosEl.value;
          return 'radial-gradient(' + shape + ' at ' + pos + ', ' + stops + ')';
        }
        /* conic */
        var from = parseInt(conicFromRangeEl.value) || 0;
        var at   = conicPosEl.value;
        return 'conic-gradient(from ' + from + 'deg at ' + at + ', ' + stops + ')';
      }

      /* Syntax highlight */
      function highlight(raw) {
        return raw
          .replace(/(\{|\})/g,       '<span class="cgg-hl-brace">$1</span>')
          .replace(/(\.gradient)/g,   '<span class="cgg-hl-sel">$1</span>')
          .replace(/([\w-]+)(\s*:)/g, '<span class="cgg-hl-prop">$1</span>$2')
          .replace(/(:)(\s*)([^;{}\n]+)(;)/g, '$1$2<span class="cgg-hl-val">$3</span><span class="cgg-hl-semi">$4</span>');
      }

      var previewEl = wrap.querySelector('#cgg-preview');
      var codeEl    = wrap.querySelector('#cgg-code');
      var copyBtn   = wrap.querySelector('#cgg-copy');

      function update() {
        var grad = buildGradient();
        previewEl.style.background = grad;
        var raw = '.gradient {\n  background: ' + grad + ';\n}';
        codeEl.innerHTML = highlight(raw);
        window.trackTool && window.trackTool('css-gradient-generator', 'generate');
      }

      copyBtn.addEventListener('click', function () {
        var text = codeEl.textContent;
        if (!text) return;
        navigator.clipboard.writeText(text).then(function () {
          copyBtn.textContent = COPIED_LABEL;
          copyBtn.setAttribute('aria-label', COPIED_LABEL);
          setTimeout(function () {
            copyBtn.textContent = COPY_LABEL;
            copyBtn.setAttribute('aria-label', COPY_LABEL);
          }, 1500);
        });
      });

      update();
    })();
  </script>
</div>

<style>
  .cgg-wrap { display: flex; flex-direction: column; gap: 1.25rem; }

  /* Tabs */
  .cgg-tabs {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0;
  }

  .cgg-tab {
    padding: 0.45rem 1rem;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1px solid transparent;
    border-bottom: none;
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: background 0.1s, color 0.1s, border-color 0.1s;
    margin-bottom: -1px;
  }

  .cgg-tab:hover { color: var(--color-text); background: var(--color-bg-secondary); }

  .cgg-tab--active {
    background: var(--color-bg);
    border-color: var(--color-border);
    color: var(--color-primary);
    font-weight: 600;
  }

  /* Controls */
  .cgg-controls { min-height: 5rem; }
  .cgg-panel { display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-start; }
  .cgg-panel--hidden { display: none; }

  .cgg-field { display: flex; flex-direction: column; gap: 0.3rem; }

  .cgg-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .cgg-angle-row { display: flex; align-items: center; gap: 0.5rem; }

  .cgg-range {
    width: 140px;
    accent-color: var(--color-primary);
    cursor: pointer;
  }

  .cgg-num-input {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.3rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    width: 72px;
    box-sizing: border-box;
  }

  .cgg-num-input:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .cgg-select {
    font-size: 0.82rem;
    padding: 0.3rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    cursor: pointer;
  }

  .cgg-select:focus { outline: none; border-color: var(--color-primary); }

  /* Direction quick buttons */
  .cgg-dir-btns { display: flex; gap: 0.3rem; flex-wrap: wrap; }

  .cgg-dir-btn {
    font-size: 0.78rem;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: background 0.1s, border-color 0.1s, color 0.1s;
  }

  .cgg-dir-btn:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .cgg-dir-btn--active { background: var(--color-primary); border-color: var(--color-primary); color: #fff; }

  /* Color stops */
  .cgg-section { display: flex; flex-direction: column; gap: 0.5rem; }

  .cgg-stops-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cgg-add-btn {
    font-size: 0.78rem;
    padding: 0.25rem 0.65rem;
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-primary);
    cursor: pointer;
    transition: background 0.1s, color 0.1s;
  }

  .cgg-add-btn:hover { background: var(--color-primary); color: #fff; }
  .cgg-add-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .cgg-stops { display: flex; flex-direction: column; gap: 0.4rem; }

  .cgg-stop {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .cgg-stop-picker {
    width: 36px;
    height: 32px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 2px;
    background: var(--color-bg-secondary);
    cursor: pointer;
    flex-shrink: 0;
  }

  .cgg-stop-hex {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    width: 88px;
    box-sizing: border-box;
  }

  .cgg-stop-hex:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .cgg-stop-pos {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.3rem 0.4rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    width: 60px;
    box-sizing: border-box;
    text-align: right;
  }

  .cgg-stop-pos:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .cgg-stop-pct {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }

  .cgg-stop-remove {
    font-size: 0.85rem;
    width: 28px;
    height: 28px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.1s, color 0.1s, border-color 0.1s;
    flex-shrink: 0;
  }

  .cgg-stop-remove:hover { background: #ef4444; border-color: #ef4444; color: #fff; }
  .cgg-stop-remove:disabled { opacity: 0.3; cursor: not-allowed; }

  /* Preview */
  .cgg-preview {
    width: 100%;
    height: 120px;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%);
  }

  /* Output */
  .cgg-output-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cgg-pre {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    overflow-x: auto;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.6;
  }

  .cgg-code { font-family: inherit; }

  .cgg-hl-sel   { color: #7c3aed; font-weight: 600; }
  .cgg-hl-brace { color: var(--color-text-secondary); }
  .cgg-hl-prop  { color: #0369a1; }
  .cgg-hl-val   { color: #057a55; }
  .cgg-hl-semi  { color: var(--color-text-secondary); }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .cgg-hl-sel  { color: #a78bfa; }
    :root:not([data-theme="light"]) .cgg-hl-prop { color: #38bdf8; }
    :root:not([data-theme="light"]) .cgg-hl-val  { color: #34d399; }
  }
