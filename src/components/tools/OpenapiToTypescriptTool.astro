---
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    rootName: 'Root namespace',
    makeOptional: 'Make properties optional',
    includePaths: 'Include path types',
    includeZod: 'Include Zod schemas',
    inputLabel: 'OpenAPI Spec (YAML or JSON)',
    outputLabel: 'TypeScript Output',
    example: 'Example',
    clear: 'Clear',
    copy: 'Copy',
    copied: 'Copied!',
    generate: 'Generate TypeScript',
    msgParseError: 'YAML/JSON parse error: ',
    msgNotOpenApi: 'Document is not an OpenAPI 3.x object.',
    msgUnsupportedVersion: 'Only OpenAPI 3.0+ is supported. Got: ',
    msgSwagger2: 'Swagger 2.0 is not supported. Migrate to OpenAPI 3.x first using editor.swagger.io.',
    msgEmpty: 'Nothing to generate. Add components/schemas or paths to the spec.',
    msgGenerated: 'Generated {n} interface(s).',
  },
  zh: {
    rootName: '根命名空间',
    makeOptional: '所有属性设为可选',
    includePaths: '包含 path 类型',
    includeZod: '包含 Zod schema',
    inputLabel: 'OpenAPI 规范（YAML 或 JSON）',
    outputLabel: 'TypeScript 输出',
    example: '示例',
    clear: '清空',
    copy: '复制',
    copied: '已复制！',
    generate: '生成 TypeScript',
    msgParseError: 'YAML/JSON 解析错误：',
    msgNotOpenApi: '文档不是 OpenAPI 3.x 对象。',
    msgUnsupportedVersion: '仅支持 OpenAPI 3.0+，当前版本：',
    msgSwagger2: '不支持 Swagger 2.0，请先用 editor.swagger.io 迁移到 OpenAPI 3.x。',
    msgEmpty: '无内容可生成。请在规范中添加 components/schemas 或 paths。',
    msgGenerated: '已生成 {n} 个接口。',
  },
  ja: {
    rootName: 'ルート名前空間',
    makeOptional: 'プロパティをオプションに',
    includePaths: 'path 型を含める',
    includeZod: 'Zod スキーマを含める',
    inputLabel: 'OpenAPI 仕様（YAML / JSON）',
    outputLabel: 'TypeScript 出力',
    example: 'サンプル',
    clear: 'クリア',
    copy: 'コピー',
    copied: 'コピーしました！',
    generate: 'TypeScript を生成',
    msgParseError: 'YAML/JSON パースエラー：',
    msgNotOpenApi: 'ドキュメントが OpenAPI 3.x オブジェクトではありません。',
    msgUnsupportedVersion: 'OpenAPI 3.0+ のみ対応。現在のバージョン：',
    msgSwagger2: 'Swagger 2.0 は非対応。editor.swagger.io で OpenAPI 3.x に移行してください。',
    msgEmpty: '生成対象がありません。仕様に components/schemas または paths を追加してください。',
    msgGenerated: '{n} 個のインターフェースを生成しました。',
  },
  ko: {
    rootName: '루트 네임스페이스',
    makeOptional: '속성을 모두 선택적으로',
    includePaths: 'path 타입 포함',
    includeZod: 'Zod 스키마 포함',
    inputLabel: 'OpenAPI 스펙 (YAML 또는 JSON)',
    outputLabel: 'TypeScript 출력',
    example: '예시',
    clear: '지우기',
    copy: '복사',
    copied: '복사됨!',
    generate: 'TypeScript 생성',
    msgParseError: 'YAML/JSON 파싱 오류: ',
    msgNotOpenApi: '문서가 OpenAPI 3.x 객체가 아닙니다.',
    msgUnsupportedVersion: 'OpenAPI 3.0+ 만 지원합니다. 현재 버전: ',
    msgSwagger2: 'Swagger 2.0은 지원하지 않습니다. editor.swagger.io에서 OpenAPI 3.x로 마이그레이션 후 사용하세요.',
    msgEmpty: '생성할 항목이 없습니다. 스펙에 components/schemas 또는 paths를 추가하세요.',
    msgGenerated: '{n}개 인터페이스 생성 완료.',
  },
};
const L = labels[lang];
---

<div
  class="opts-wrap"
  data-copy={L.copy}
  data-copied={L.copied}
  data-msg-parse-error={L.msgParseError}
  data-msg-not-openapi={L.msgNotOpenApi}
  data-msg-unsupported-version={L.msgUnsupportedVersion}
  data-msg-swagger2={L.msgSwagger2}
  data-msg-empty={L.msgEmpty}
  data-msg-generated={L.msgGenerated}
>
  <div class="opts-config">
    <div class="opts-config-row">
      <label class="tool-label" for="opts-root">{L.rootName}</label>
      <input id="opts-root" class="tool-input opts-root-input" type="text" value="Components" spellcheck="false" />
    </div>
    <div class="opts-config-row opts-config-row--checks">
      <label class="opts-check">
        <input id="opts-optional" type="checkbox" />
        <span>{L.makeOptional}</span>
      </label>
      <label class="opts-check">
        <input id="opts-paths" type="checkbox" />
        <span>{L.includePaths}</span>
      </label>
      <label class="opts-check">
        <input id="opts-zod" type="checkbox" />
        <span>{L.includeZod}</span>
      </label>
    </div>
  </div>

  <div class="opts-panels">
    <div class="opts-panel">
      <div class="opts-panel-header">
        <span class="tool-label">{L.inputLabel}</span>
        <div class="opts-panel-actions">
          <button id="opts-example" class="btn-ghost btn-sm" type="button">{L.example}</button>
          <button id="opts-clear" class="btn-ghost btn-sm" type="button">{L.clear}</button>
        </div>
      </div>
      <textarea
        id="opts-input"
        class="tool-textarea opts-input"
        spellcheck="false"
        autocomplete="off"
        placeholder={`openapi: 3.0.3
info:
  title: Pets
  version: 1.0.0
components:
  schemas:
    Pet:
      type: object
      required: [id, name]
      properties:
        id: { type: integer }
        name: { type: string }`}
      ></textarea>
    </div>

    <div class="opts-panel">
      <div class="opts-panel-header">
        <span class="tool-label">{L.outputLabel}</span>
        <button id="opts-copy" class="btn-copy" type="button">{L.copy}</button>
      </div>
      <pre id="opts-output" class="opts-output"><code id="opts-output-code"></code></pre>
    </div>
  </div>

  <div class="opts-actions">
    <button id="opts-generate" class="btn-primary" type="button">{L.generate}</button>
  </div>

  <div id="opts-status" class="tool-status" aria-live="polite"></div>
</div>

<script>
  import jsyaml from 'js-yaml';

  const wrap = document.querySelector<HTMLElement>('.opts-wrap');
  if (!wrap) throw new Error('opts-wrap missing');

  const COPY = wrap.dataset.copy || 'Copy';
  const COPIED = wrap.dataset.copied || 'Copied!';
  const MSG_PARSE_ERROR = wrap.dataset.msgParseError || 'Parse error: ';
  const MSG_NOT_OPENAPI = wrap.dataset.msgNotOpenapi || 'Not an OpenAPI 3.x object.';
  const MSG_UNSUPPORTED = wrap.dataset.msgUnsupportedVersion || 'Unsupported version: ';
  const MSG_SWAGGER2 = wrap.dataset.msgSwagger2 || 'Swagger 2.0 is not supported.';
  const MSG_EMPTY = wrap.dataset.msgEmpty || 'Nothing to generate.';
  const MSG_GENERATED = wrap.dataset.msgGenerated || 'Generated {n}.';

  const inputEl = document.getElementById('opts-input') as HTMLTextAreaElement;
  const outputCodeEl = document.getElementById('opts-output-code')!;
  const statusEl = document.getElementById('opts-status')!;
  const rootEl = document.getElementById('opts-root') as HTMLInputElement;
  const optionalEl = document.getElementById('opts-optional') as HTMLInputElement;
  const pathsEl = document.getElementById('opts-paths') as HTMLInputElement;
  const zodEl = document.getElementById('opts-zod') as HTMLInputElement;
  const generateBtn = document.getElementById('opts-generate')!;
  const exampleBtn = document.getElementById('opts-example')!;
  const clearBtn = document.getElementById('opts-clear')!;
  const copyBtn = document.getElementById('opts-copy')!;

  const EXAMPLE = `openapi: 3.0.3
info:
  title: Pet Store
  version: 1.0.0
paths:
  /pets:
    get:
      operationId: listPets
      parameters:
        - name: limit
          in: query
          schema: { type: integer }
      responses:
        '200':
          description: A list of pets
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/Pet'
    post:
      operationId: createPet
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/NewPet'
      responses:
        '201':
          description: Created
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Pet'
  /pets/{id}:
    get:
      operationId: getPetById
      parameters:
        - name: id
          in: path
          required: true
          schema: { type: integer }
      responses:
        '200':
          description: A pet
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Pet'
components:
  schemas:
    Pet:
      type: object
      required: [id, name, status]
      properties:
        id: { type: integer, format: int64 }
        name: { type: string }
        tag: { type: string, nullable: true }
        status:
          type: string
          enum: [available, pending, sold]
        photo: { type: string, format: binary }
    NewPet:
      type: object
      required: [name]
      properties:
        name: { type: string }
        tag: { type: string }
`;

  function setStatus(msg: string, kind: 'success' | 'error' | 'info' | 'none' = 'info'): void {
    statusEl.textContent = msg;
    statusEl.className = `tool-status ${kind === 'none' ? '' : kind}`;
  }

  function pascalCase(s: string): string {
    return s
      .replace(/[^a-zA-Z0-9]+(.)/g, (_, ch) => ch.toUpperCase())
      .replace(/^(.)/, (_, ch) => ch.toUpperCase());
  }

  function safeIdent(s: string): string {
    // Keep ref/operationId-like names; sanitize illegal chars
    return s.replace(/[^a-zA-Z0-9_$]/g, '_');
  }

  function safeKey(k: string): string {
    return /^[a-zA-Z_$][a-zA-Z0-9_$]*$/.test(k) ? k : JSON.stringify(k);
  }

  function formatHint(schema: any): string {
    if (!schema.format) return '';
    const f = schema.format;
    if (f === 'date-time') return '/** ISO 8601 date-time */ ';
    if (f === 'date') return '/** ISO 8601 date (YYYY-MM-DD) */ ';
    if (f === 'uuid') return '/** UUID */ ';
    if (f === 'email') return '/** email address */ ';
    if (f === 'uri' || f === 'url') return '/** URI */ ';
    return '';
  }

  type Ctx = {
    doc: any;
    declared: Map<string, string>;   // name -> body (interface { ... })
    declarationOrder: string[];
    rootName: string;
    optional: boolean;
  };

  function refToName(ref: string): string {
    const m = /^#\/components\/schemas\/(.+)$/.exec(ref);
    if (!m) return 'unknown';
    return safeIdent(m[1]);
  }

  function isNullable(schema: any): boolean {
    if (schema && schema.nullable === true) return true;
    if (Array.isArray(schema.type) && schema.type.includes('null')) return true;
    return false;
  }

  function getBaseType(schema: any): string | undefined {
    if (Array.isArray(schema.type)) {
      const nonNull = schema.type.filter((t: string) => t !== 'null');
      return nonNull[0];
    }
    return schema.type;
  }

  function schemaToTs(schema: any, nameHint: string, ctx: Ctx, indent = 0): string {
    if (!schema || typeof schema !== 'object') return 'unknown';

    if (schema.$ref) {
      const refName = refToName(schema.$ref);
      ensureDeclared(refName, ctx);
      return refName;
    }

    if (Array.isArray(schema.enum)) {
      const lits = schema.enum.map((v: any) => {
        if (v === null) return 'null';
        if (typeof v === 'string') return JSON.stringify(v);
        return JSON.stringify(v);
      });
      const ts = lits.join(' | ');
      return isNullable(schema) ? `${ts} | null` : ts;
    }

    if (Array.isArray(schema.oneOf)) {
      const parts = schema.oneOf.map((s: any, i: number) => schemaToTs(s, `${nameHint}Variant${i + 1}`, ctx, indent));
      const ts = parts.join(' | ');
      return isNullable(schema) ? `(${ts}) | null` : ts;
    }

    if (Array.isArray(schema.anyOf)) {
      const parts = schema.anyOf.map((s: any, i: number) => schemaToTs(s, `${nameHint}Variant${i + 1}`, ctx, indent));
      const ts = parts.join(' | ');
      return isNullable(schema) ? `(${ts}) | null` : ts;
    }

    if (Array.isArray(schema.allOf)) {
      const parts = schema.allOf.map((s: any, i: number) => schemaToTs(s, `${nameHint}Part${i + 1}`, ctx, indent));
      const ts = parts.join(' & ');
      return isNullable(schema) ? `(${ts}) | null` : ts;
    }

    const baseType = getBaseType(schema);
    const nullable = isNullable(schema);
    let ts: string;

    switch (baseType) {
      case 'string':
        if (schema.format === 'binary') ts = 'Blob';
        else ts = 'string';
        break;
      case 'integer':
      case 'number':
        ts = 'number';
        break;
      case 'boolean':
        ts = 'boolean';
        break;
      case 'array': {
        const itemTs = schemaToTs(schema.items || {}, `${nameHint}Item`, ctx, indent);
        ts = itemTs.includes(' ') ? `(${itemTs})[]` : `${itemTs}[]`;
        break;
      }
      case 'object':
      case undefined: {
        if (schema.properties || schema.additionalProperties) {
          ts = inlineObject(schema, nameHint, ctx, indent);
        } else {
          ts = 'Record<string, unknown>';
        }
        break;
      }
      default:
        ts = 'unknown';
    }

    return nullable ? `${ts} | null` : ts;
  }

  function inlineObject(schema: any, nameHint: string, ctx: Ctx, indent: number): string {
    const pad = '  '.repeat(indent + 1);
    const closePad = '  '.repeat(indent);
    const required = new Set<string>(Array.isArray(schema.required) ? schema.required : []);
    const lines: string[] = [];

    if (schema.properties && typeof schema.properties === 'object') {
      for (const [k, v] of Object.entries(schema.properties)) {
        const opt = ctx.optional || !required.has(k) ? '?' : '';
        const propTs = schemaToTs(v, `${nameHint}${pascalCase(k)}`, ctx, indent + 1);
        const hint = formatHint(v as any);
        lines.push(`${pad}${hint}${safeKey(k)}${opt}: ${propTs};`);
      }
    }

    if (schema.additionalProperties === true) {
      lines.push(`${pad}[key: string]: unknown;`);
    } else if (schema.additionalProperties && typeof schema.additionalProperties === 'object') {
      const apTs = schemaToTs(schema.additionalProperties, `${nameHint}Extra`, ctx, indent + 1);
      lines.push(`${pad}[key: string]: ${apTs};`);
    }

    if (lines.length === 0) return 'Record<string, unknown>';
    return `{\n${lines.join('\n')}\n${closePad}}`;
  }

  function ensureDeclared(name: string, ctx: Ctx): void {
    if (ctx.declared.has(name)) return;
    const schema = ctx.doc?.components?.schemas?.[name];
    if (!schema) {
      ctx.declared.set(name, `export type ${name} = unknown;`);
      ctx.declarationOrder.push(name);
      return;
    }
    // Reserve to break recursion
    ctx.declared.set(name, '');
    ctx.declarationOrder.push(name);

    const body = renderSchemaDeclaration(name, schema, ctx);
    ctx.declared.set(name, body);
  }

  function renderSchemaDeclaration(name: string, schema: any, ctx: Ctx): string {
    // If schema is an object with properties, render as interface; otherwise type alias.
    const isObjectInterface =
      !schema.$ref &&
      !schema.enum &&
      !schema.oneOf &&
      !schema.anyOf &&
      !schema.allOf &&
      (getBaseType(schema) === 'object' || (!getBaseType(schema) && schema.properties));

    if (isObjectInterface && (schema.properties || schema.additionalProperties)) {
      const body = inlineObject(schema, name, ctx, 0);
      // body is `{ ... }` from inlineObject; emit it as an interface block
      return `export interface ${name} ${body}`;
    }

    const ts = schemaToTs(schema, name, ctx, 0);
    return `export type ${name} = ${ts};`;
  }

  function generateSchemas(doc: any, optional: boolean): string {
    const schemas = doc?.components?.schemas;
    if (!schemas || typeof schemas !== 'object') return '';

    const ctx: Ctx = {
      doc,
      declared: new Map(),
      declarationOrder: [],
      rootName: '',
      optional,
    };

    for (const name of Object.keys(schemas)) {
      ensureDeclared(safeIdent(name), ctx);
    }

    return ctx.declarationOrder.map(n => ctx.declared.get(n)).filter(Boolean).join('\n\n');
  }

  function generatePathTypes(doc: any, optional: boolean, namespace: string): string {
    const paths = doc?.paths;
    if (!paths || typeof paths !== 'object') return '';

    const HTTP_METHODS = ['get', 'put', 'post', 'delete', 'options', 'head', 'patch'];
    const ctx: Ctx = {
      doc,
      declared: new Map(),
      declarationOrder: [],
      rootName: '',
      optional,
    };

    const operationBlocks: string[] = [];

    for (const [p, pathItem] of Object.entries(paths)) {
      if (!pathItem || typeof pathItem !== 'object') continue;
      for (const method of HTTP_METHODS) {
        const op = (pathItem as any)[method];
        if (!op || typeof op !== 'object') continue;

        const opId = op.operationId
          ? pascalCase(safeIdent(op.operationId))
          : pascalCase(`${method}${p.replace(/[{}\/]/g, '_').replace(/_+/g, '_')}`);

        const lines: string[] = [`  export namespace ${opId} {`];

        // Combine path-level and op-level parameters
        const pathLevelParams = Array.isArray((pathItem as any).parameters) ? (pathItem as any).parameters : [];
        const opParams = Array.isArray(op.parameters) ? op.parameters : [];
        const allParams = [...pathLevelParams, ...opParams].map((param: any) => {
          if (param.$ref) {
            const m = /^#\/components\/parameters\/(.+)$/.exec(param.$ref);
            if (m) {
              const ref = doc?.components?.parameters?.[m[1]];
              return ref || param;
            }
          }
          return param;
        });

        const groups: Record<string, any[]> = { path: [], query: [], header: [], cookie: [] };
        for (const param of allParams) {
          if (param && param.in && groups[param.in]) groups[param.in].push(param);
        }

        for (const [groupName, list] of Object.entries(groups)) {
          if (list.length === 0) continue;
          const fields = list.map((param: any) => {
            const opt = param.required ? '' : '?';
            const ts = schemaToTs(param.schema || {}, `${opId}${pascalCase(groupName)}${pascalCase(param.name || 'Param')}`, ctx, 2);
            return `      ${safeKey(param.name)}${opt}: ${ts};`;
          });
          const groupTypeName = `${pascalCase(groupName)}Parameters`;
          lines.push(`    export interface ${groupTypeName} {`);
          lines.push(...fields);
          lines.push(`    }`);
        }

        // Request body
        const rb = op.requestBody;
        if (rb && typeof rb === 'object') {
          const json = rb.content?.['application/json']?.schema;
          if (json) {
            const ts = schemaToTs(json, `${opId}RequestBody`, ctx, 2);
            lines.push(`    export type RequestBody = ${ts};`);
          }
        }

        // Responses
        if (op.responses && typeof op.responses === 'object') {
          for (const [code, resp] of Object.entries(op.responses)) {
            if (!resp || typeof resp !== 'object') continue;
            const json = (resp as any).content?.['application/json']?.schema;
            if (!json) continue;
            const ts = schemaToTs(json, `${opId}Response${code}`, ctx, 2);
            const respName = `Response${String(code).replace(/[^A-Za-z0-9]/g, '')}`;
            lines.push(`    export type ${respName} = ${ts};`);
          }
        }

        lines.push(`  }`);
        operationBlocks.push(lines.join('\n'));
      }
    }

    if (operationBlocks.length === 0) return '';
    return `export namespace ${namespace} {\n${operationBlocks.join('\n\n')}\n}`;
  }

  // ── Zod schema generation ──
  function schemaToZod(schema: any, ctx: Ctx, depth = 0): string {
    if (!schema || typeof schema !== 'object') return 'z.unknown()';

    if (schema.$ref) {
      const refName = refToName(schema.$ref);
      return `${refName}Schema`;
    }

    if (Array.isArray(schema.enum)) {
      const allStrings = schema.enum.every((v: any) => typeof v === 'string');
      if (allStrings) {
        const lits = schema.enum.map((v: string) => JSON.stringify(v)).join(', ');
        return wrapNullable(`z.enum([${lits}])`, schema);
      }
      const lits = schema.enum.map((v: any) => `z.literal(${JSON.stringify(v)})`);
      return wrapNullable(lits.length === 1 ? lits[0] : `z.union([${lits.join(', ')}])`, schema);
    }

    if (Array.isArray(schema.oneOf) || Array.isArray(schema.anyOf)) {
      const arr = schema.oneOf || schema.anyOf;
      const parts = arr.map((s: any) => schemaToZod(s, ctx, depth + 1));
      return wrapNullable(parts.length === 1 ? parts[0] : `z.union([${parts.join(', ')}])`, schema);
    }

    if (Array.isArray(schema.allOf)) {
      const parts = schema.allOf.map((s: any) => schemaToZod(s, ctx, depth + 1));
      if (parts.length === 1) return wrapNullable(parts[0], schema);
      let acc = parts[0];
      for (let i = 1; i < parts.length; i++) acc = `z.intersection(${acc}, ${parts[i]})`;
      return wrapNullable(acc, schema);
    }

    const baseType = getBaseType(schema);
    let z: string;

    switch (baseType) {
      case 'string':
        if (schema.format === 'email') z = 'z.string().email()';
        else if (schema.format === 'uri' || schema.format === 'url') z = 'z.string().url()';
        else if (schema.format === 'uuid') z = 'z.string().uuid()';
        else if (schema.format === 'date-time') z = 'z.string().datetime()';
        else if (schema.format === 'binary') z = 'z.instanceof(Blob)';
        else z = 'z.string()';
        break;
      case 'integer':
        z = 'z.number().int()';
        break;
      case 'number':
        z = 'z.number()';
        break;
      case 'boolean':
        z = 'z.boolean()';
        break;
      case 'array': {
        z = `z.array(${schemaToZod(schema.items || {}, ctx, depth + 1)})`;
        break;
      }
      case 'object':
      case undefined: {
        if (schema.properties && typeof schema.properties === 'object') {
          const required = new Set<string>(Array.isArray(schema.required) ? schema.required : []);
          const pad = '  '.repeat(depth + 1);
          const closePad = '  '.repeat(depth);
          const props = Object.entries(schema.properties).map(([k, v]) => {
            const zv = schemaToZod(v, ctx, depth + 1);
            const opt = ctx.optional || !required.has(k) ? '.optional()' : '';
            return `${pad}${safeKey(k)}: ${zv}${opt},`;
          });
          z = `z.object({\n${props.join('\n')}\n${closePad}})`;
        } else if (schema.additionalProperties) {
          const ap = schema.additionalProperties === true ? 'z.unknown()' : schemaToZod(schema.additionalProperties, ctx, depth + 1);
          z = `z.record(z.string(), ${ap})`;
        } else {
          z = 'z.record(z.string(), z.unknown())';
        }
        break;
      }
      default:
        z = 'z.unknown()';
    }

    return wrapNullable(z, schema);
  }

  function wrapNullable(expr: string, schema: any): string {
    return isNullable(schema) ? `${expr}.nullable()` : expr;
  }

  function generateZodSchemas(doc: any, optional: boolean): string {
    const schemas = doc?.components?.schemas;
    if (!schemas || typeof schemas !== 'object') return '';
    const ctx: Ctx = { doc, declared: new Map(), declarationOrder: [], rootName: '', optional };
    const lines = ['import { z } from \'zod\';\n'];
    for (const [name, schema] of Object.entries(schemas)) {
      const safeName = safeIdent(name);
      lines.push(`export const ${safeName}Schema = ${schemaToZod(schema, ctx)};`);
    }
    return lines.join('\n');
  }

  // ── Main generate ──
  function generate(): void {
    const raw = inputEl.value.trim();
    if (!raw) {
      outputCodeEl.textContent = '';
      setStatus('', 'none');
      return;
    }

    let doc: any;
    try {
      doc = jsyaml.load(raw, { schema: jsyaml.JSON_SCHEMA });
    } catch (e: any) {
      outputCodeEl.textContent = '';
      setStatus(MSG_PARSE_ERROR + (e?.message || String(e)), 'error');
      return;
    }

    if (!doc || typeof doc !== 'object') {
      outputCodeEl.textContent = '';
      setStatus(MSG_NOT_OPENAPI, 'error');
      return;
    }

    if (doc.swagger) {
      outputCodeEl.textContent = '';
      setStatus(MSG_SWAGGER2, 'error');
      return;
    }

    const ver = String(doc.openapi || '');
    if (!/^3\.\d+\.\d+/.test(ver)) {
      outputCodeEl.textContent = '';
      setStatus(MSG_UNSUPPORTED + (ver || '(missing)'), 'error');
      return;
    }

    const optional = optionalEl.checked;
    const includePaths = pathsEl.checked;
    const includeZod = zodEl.checked;
    const rawNamespace = (rootEl.value || 'Components').trim() || 'Components';
    const namespace = safeIdent(pascalCase(rawNamespace));

    const sections: string[] = [];

    const schemasBlock = generateSchemas(doc, optional);
    if (schemasBlock) {
      sections.push(`// ── components/schemas ──\n${schemasBlock}`);
    }

    if (includePaths) {
      const pathsBlock = generatePathTypes(doc, optional, namespace || 'Paths');
      if (pathsBlock) {
        sections.push(`// ── paths ──\n${pathsBlock}`);
      }
    }

    if (includeZod) {
      const zodBlock = generateZodSchemas(doc, optional);
      if (zodBlock) {
        sections.push(`// ── Zod schemas ──\n${zodBlock}`);
      }
    }

    if (sections.length === 0) {
      outputCodeEl.textContent = '';
      setStatus(MSG_EMPTY, 'info');
      return;
    }

    const interfaceCount = (schemasBlock.match(/^export (interface|type) /gm) || []).length;
    outputCodeEl.textContent = sections.join('\n\n');
    setStatus(MSG_GENERATED.replace('{n}', String(interfaceCount)), 'success');
    (window as any).trackTool?.('openapi-to-typescript', 'generate');
  }

  // Debounced live preview
  let liveTimer: number | null = null;
  function scheduleGenerate(): void {
    if (liveTimer !== null) window.clearTimeout(liveTimer);
    liveTimer = window.setTimeout(generate, 300);
  }

  inputEl.addEventListener('input', scheduleGenerate);
  rootEl.addEventListener('input', scheduleGenerate);
  optionalEl.addEventListener('change', generate);
  pathsEl.addEventListener('change', generate);
  zodEl.addEventListener('change', generate);

  generateBtn.addEventListener('mousedown', (e) => e.preventDefault());
  generateBtn.addEventListener('click', generate);

  exampleBtn.addEventListener('click', () => {
    inputEl.value = EXAMPLE;
    generate();
    (window as any).trackTool?.('openapi-to-typescript', 'example_load');
  });

  clearBtn.addEventListener('click', () => {
    inputEl.value = '';
    outputCodeEl.textContent = '';
    setStatus('', 'none');
  });

  copyBtn.addEventListener('click', () => {
    const text = outputCodeEl.textContent || '';
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      copyBtn.classList.add('copied');
      copyBtn.textContent = COPIED;
      window.setTimeout(() => {
        copyBtn.classList.remove('copied');
        copyBtn.textContent = COPY;
      }, 1500);
    });
  });

  inputEl.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
      e.preventDefault();
      generate();
    }
  });
</script>

