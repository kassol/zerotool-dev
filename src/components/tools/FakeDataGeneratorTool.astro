---
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    dataFields: 'Data Fields',
    fullName: 'Full Name',
    firstName: 'First Name',
    lastName: 'Last Name',
    email: 'Email',
    phone: 'Phone',
    company: 'Company',
    street: 'Street',
    city: 'City',
    state: 'State',
    zip: 'Zip Code',
    country: 'Country',
    uuid: 'UUID',
    date: 'Date',
    ip: 'IP Address',
    url: 'URL',
    color: 'Color (Hex)',
    lorem: 'Lorem Sentence',
    count: 'Count',
    format: 'Format',
    generate: 'Generate',
    copy: 'Copy',
    download: 'Download',
    copied: 'Copied!',
    downloaded: 'Downloaded!',
    noField: '⚠ Select at least one field.',
    placeholder: 'Select fields and click Generate…',
  },
  zh: {
    dataFields: '数据字段',
    fullName: '全名',
    firstName: '名',
    lastName: '姓',
    email: '邮箱',
    phone: '电话',
    company: '公司',
    street: '街道',
    city: '城市',
    state: '州/省',
    zip: '邮编',
    country: '国家',
    uuid: 'UUID',
    date: '日期',
    ip: 'IP 地址',
    url: 'URL',
    color: '颜色 (Hex)',
    lorem: '示例句子',
    count: '数量',
    format: '格式',
    generate: '生成',
    copy: '复制',
    download: '下载',
    copied: '已复制！',
    downloaded: '已下载！',
    noField: '⚠ 请至少选择一个字段。',
    placeholder: '选择字段后点击生成…',
  },
  ja: {
    dataFields: 'データフィールド',
    fullName: 'フルネーム',
    firstName: '名',
    lastName: '姓',
    email: 'メール',
    phone: '電話',
    company: '会社',
    street: '番地',
    city: '市区町村',
    state: '都道府県',
    zip: '郵便番号',
    country: '国',
    uuid: 'UUID',
    date: '日付',
    ip: 'IPアドレス',
    url: 'URL',
    color: 'カラー (Hex)',
    lorem: 'サンプル文章',
    count: '件数',
    format: 'フォーマット',
    generate: '生成',
    copy: 'コピー',
    download: 'ダウンロード',
    copied: 'コピーしました！',
    downloaded: 'ダウンロードしました！',
    noField: '⚠ フィールドを1つ以上選択してください。',
    placeholder: 'フィールドを選択して生成をクリック…',
  },
  ko: {
    dataFields: '데이터 필드',
    fullName: '전체 이름',
    firstName: '이름',
    lastName: '성',
    email: '이메일',
    phone: '전화',
    company: '회사',
    street: '거리',
    city: '도시',
    state: '주/도',
    zip: '우편번호',
    country: '국가',
    uuid: 'UUID',
    date: '날짜',
    ip: 'IP 주소',
    url: 'URL',
    color: '색상 (Hex)',
    lorem: '예시 문장',
    count: '개수',
    format: '형식',
    generate: '생성',
    copy: '복사',
    download: '다운로드',
    copied: '복사됨!',
    downloaded: '다운로드됨!',
    noField: '⚠ 필드를 하나 이상 선택하세요.',
    placeholder: '필드를 선택하고 생성을 클릭하세요…',
  },
};

const L = labels[lang];
---

<div
  class="fdg-wrap"
  data-copy={L.copy}
  data-copied={L.copied}
  data-download={L.download}
  data-downloaded={L.downloaded}
  data-no-field={L.noField}
>
  <div class="fdg-controls">
    <div class="fdg-section">
      <div class="fdg-section-title">{L.dataFields}</div>
      <div class="fdg-checkboxes" id="fdg-fields">
        <label class="fdg-cb"><input type="checkbox" value="fullName" checked /> {L.fullName}</label>
        <label class="fdg-cb"><input type="checkbox" value="firstName" /> {L.firstName}</label>
        <label class="fdg-cb"><input type="checkbox" value="lastName" /> {L.lastName}</label>
        <label class="fdg-cb"><input type="checkbox" value="email" checked /> {L.email}</label>
        <label class="fdg-cb"><input type="checkbox" value="phone" /> {L.phone}</label>
        <label class="fdg-cb"><input type="checkbox" value="company" /> {L.company}</label>
        <label class="fdg-cb"><input type="checkbox" value="street" /> {L.street}</label>
        <label class="fdg-cb"><input type="checkbox" value="city" /> {L.city}</label>
        <label class="fdg-cb"><input type="checkbox" value="state" /> {L.state}</label>
        <label class="fdg-cb"><input type="checkbox" value="zip" /> {L.zip}</label>
        <label class="fdg-cb"><input type="checkbox" value="country" /> {L.country}</label>
        <label class="fdg-cb"><input type="checkbox" value="uuid" /> {L.uuid}</label>
        <label class="fdg-cb"><input type="checkbox" value="date" /> {L.date}</label>
        <label class="fdg-cb"><input type="checkbox" value="ip" /> {L.ip}</label>
        <label class="fdg-cb"><input type="checkbox" value="url" /> {L.url}</label>
        <label class="fdg-cb"><input type="checkbox" value="color" /> {L.color}</label>
        <label class="fdg-cb"><input type="checkbox" value="lorem" /> {L.lorem}</label>
      </div>
    </div>

    <div class="fdg-row">
      <div class="fdg-field">
        <label class="fdg-label" for="fdg-count">{L.count}</label>
        <input type="number" id="fdg-count" value="10" min="1" max="100" />
      </div>
      <div class="fdg-field">
        <label class="fdg-label">{L.format}</label>
        <div class="fdg-format-btns">
          <button class="fdg-fmt active" data-fmt="json">JSON</button>
          <button class="fdg-fmt" data-fmt="csv">CSV</button>
        </div>
      </div>
    </div>

    <div class="fdg-actions">
      <button id="fdg-generate" class="btn-primary">{L.generate}</button>
      <button id="fdg-copy" class="btn-secondary">{L.copy}</button>
      <button id="fdg-download" class="btn-ghost">{L.download}</button>
    </div>
  </div>

  <textarea id="fdg-output" readonly spellcheck="false" placeholder={L.placeholder}></textarea>
</div>

<script is:inline>
(function () {
  var wrap = document.currentScript
    ? document.currentScript.closest('.fdg-wrap')
    : document.querySelector('.fdg-wrap');

  var COPY = wrap ? wrap.dataset.copy : 'Copy';
  var COPIED = wrap ? wrap.dataset.copied : 'Copied!';
  var DOWNLOAD = wrap ? wrap.dataset.download : 'Download';
  var DOWNLOADED = wrap ? wrap.dataset.downloaded : 'Downloaded!';
  var NO_FIELD = wrap ? wrap.dataset.noField : '⚠ Select at least one field.';

  var FIRST = ['James','John','Robert','Michael','William','David','Richard','Joseph','Thomas','Charles','Mary','Patricia','Jennifer','Linda','Barbara','Susan','Jessica','Sarah','Karen','Lisa','Daniel','Matthew','Anthony','Mark','Donald','Steven','Paul','Andrew','Kenneth','Joshua','Emma','Olivia','Sophia','Ava','Isabella','Mia','Charlotte','Amelia','Harper','Evelyn'];
  var LAST = ['Smith','Johnson','Williams','Brown','Jones','Garcia','Miller','Davis','Rodriguez','Martinez','Hernandez','Lopez','Gonzalez','Wilson','Anderson','Thomas','Taylor','Moore','Jackson','Martin','Lee','Perez','Thompson','White','Harris','Sanchez','Clark','Ramirez','Lewis','Robinson'];
  var DOMAINS = ['gmail.com','yahoo.com','outlook.com','example.com','mail.com','proton.me','icloud.com','hotmail.com'];
  var COMPANIES = ['Acme Corp','Globex','Initech','Umbrella Ltd','Hooli','Pied Piper','Wayne Enterprises','Stark Industries','Cyberdyne Systems','Weyland-Yutani','Oscorp','Soylent Corp','Aperture Science','Black Mesa','InGen','Massive Dynamic','Veridian Dynamics'];
  var STREETS = ['Oak St','Maple Ave','Pine Rd','Elm Dr','Cedar Blvd','Birch Ln','Walnut Way','Spruce Ct','Ash St','Willow Ave','Main St','First Ave','Park Blvd','Lakeview Dr','Riverside Rd','Sunset Blvd','Highland Ave'];
  var CITIES = ['Springfield','Shelbyville','Riverside','Lakewood','Fairview','Greenville','Centerville','Georgetown','Franklin','Bristol','Arlington','Burlington','Clinton','Durham','Florence'];
  var STATES = ['AL','AK','AZ','AR','CA','CO','CT','DE','FL','GA','HI','ID','IL','IN','IA','KS','KY','LA','ME','MD','MA','MI','MN','MS','MO','MT','NE','NV','NH','NJ','NM','NY','NC','ND','OH','OK','OR','PA','RI','SC','SD','TN','TX','UT','VT','VA','WA','WV','WI','WY'];
  var COUNTRIES = ['United States','Canada','United Kingdom','Australia','Germany','France','Japan','Brazil','India','Mexico','Italy','Spain','Netherlands','Sweden','Norway','Denmark','Finland','Switzerland','Austria','Belgium'];
  var TLDS = ['com','org','net','io','dev','app','co'];
  var PATHS = ['dashboard','profile','settings','api','data','report','analytics','docs','blog','about','contact','signup','login'];
  var LOREM_WORDS = 'lorem ipsum dolor sit amet consectetur adipiscing elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua ut enim ad minim veniam quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat duis aute irure dolor in reprehenderit voluptate velit esse cillum dolore eu fugiat nulla pariatur excepteur sint occaecat cupidatat non proident sunt in culpa qui officia deserunt mollit anim id est laborum'.split(' ');

  function rand(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
  function randInt(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }
  function pad(n, len) { return String(n).padStart(len, '0'); }

  function genUUID() {
    if (crypto.randomUUID) return crypto.randomUUID();
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      var r = Math.random() * 16 | 0;
      return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
    });
  }

  var generators = {
    fullName:  function() { return rand(FIRST) + ' ' + rand(LAST); },
    firstName: function() { return rand(FIRST); },
    lastName:  function() { return rand(LAST); },
    email:     function() { return (rand(FIRST) + '.' + rand(LAST) + randInt(10,99)).toLowerCase() + '@' + rand(DOMAINS); },
    phone:     function() { return '(' + randInt(200,999) + ') ' + randInt(200,999) + '-' + pad(randInt(0,9999), 4); },
    company:   function() { return rand(COMPANIES); },
    street:    function() { return randInt(1, 9999) + ' ' + rand(STREETS); },
    city:      function() { return rand(CITIES); },
    state:     function() { return rand(STATES); },
    zip:       function() { return pad(randInt(10000, 99999), 5); },
    country:   function() { return rand(COUNTRIES); },
    uuid:      function() { return genUUID(); },
    date:      function() {
      var y = randInt(2020, 2026), m = randInt(1,12), d = randInt(1,28);
      return y + '-' + pad(m, 2) + '-' + pad(d, 2);
    },
    ip:        function() { return randInt(1,254)+'.'+randInt(0,255)+'.'+randInt(0,255)+'.'+randInt(1,254); },
    url:       function() { return 'https://' + (rand(FIRST)+rand(LAST)).toLowerCase() + '.' + rand(TLDS) + '/' + rand(PATHS); },
    color:     function() { return '#' + pad(randInt(0, 0xFFFFFF).toString(16), 6); },
    lorem:     function() {
      var len = randInt(6, 14);
      var words = [];
      for (var i = 0; i < len; i++) words.push(rand(LOREM_WORDS));
      return words[0].charAt(0).toUpperCase() + words[0].slice(1) + ' ' + words.slice(1).join(' ') + '.';
    }
  };

  var currentFmt = 'json';
  var currentOutput = '';

  function getSelectedFields() {
    var checkboxes = document.querySelectorAll('#fdg-fields input[type=checkbox]:checked');
    var fields = [];
    checkboxes.forEach(function(cb) { fields.push(cb.value); });
    return fields;
  }

  function generateData(fields, count) {
    var rows = [];
    for (var i = 0; i < count; i++) {
      var row = {};
      fields.forEach(function(f) { row[f] = generators[f](); });
      rows.push(row);
    }
    return rows;
  }

  function toCSV(rows, fields) {
    if (!rows.length) return '';
    var lines = [fields.join(',')];
    rows.forEach(function(row) {
      var vals = fields.map(function(f) {
        var v = String(row[f]);
        if (v.indexOf(',') >= 0 || v.indexOf('"') >= 0) v = '"' + v.replace(/"/g, '""') + '"';
        return v;
      });
      lines.push(vals.join(','));
    });
    return lines.join('\n');
  }

  document.querySelectorAll('.fdg-fmt').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.fdg-fmt').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentFmt = btn.getAttribute('data-fmt');
    });
  });

  document.getElementById('fdg-generate').addEventListener('click', function() {
    var fields = getSelectedFields();
    if (!fields.length) {
      document.getElementById('fdg-output').value = NO_FIELD;
      return;
    }
    var count = Math.min(100, Math.max(1, parseInt(document.getElementById('fdg-count').value) || 10));
    var rows = generateData(fields, count);
    if (currentFmt === 'json') {
      currentOutput = JSON.stringify(rows, null, 2);
    } else {
      currentOutput = toCSV(rows, fields);
    }
    document.getElementById('fdg-output').value = currentOutput;
    window.trackTool && window.trackTool('fake-data-generator', 'generate');
  });

  document.getElementById('fdg-copy').addEventListener('click', function() {
    if (!currentOutput) return;
    navigator.clipboard.writeText(currentOutput).then(function() {
      var btn = document.getElementById('fdg-copy');
      btn.textContent = COPIED;
      setTimeout(function() { btn.textContent = COPY; }, 1500);
    });
  });

  document.getElementById('fdg-download').addEventListener('click', function() {
    if (!currentOutput) return;
    var ext = currentFmt === 'json' ? 'json' : 'csv';
    var mime = currentFmt === 'json' ? 'application/json' : 'text/csv';
    var blob = new Blob([currentOutput], { type: mime });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'fake-data.' + ext;
    a.click();
    URL.revokeObjectURL(url);
    var dlBtn = document.getElementById('fdg-download');
    dlBtn.textContent = DOWNLOADED;
    setTimeout(function() { dlBtn.textContent = DOWNLOAD; }, 1500);
  });
})();
</script>

<style>
  .fdg-wrap { display: flex; flex-direction: column; gap: 1rem; }

  .fdg-controls { display: flex; flex-direction: column; gap: 0.875rem; }

  .fdg-section-title {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .fdg-checkboxes {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.35rem 0.75rem;
  }

  .fdg-cb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    cursor: pointer;
    user-select: none;
  }

  .fdg-cb input[type=checkbox] { cursor: pointer; accent-color: var(--color-accent, #6366f1); }

  .fdg-row {
    display: flex;
    gap: 1.25rem;
    align-items: flex-end;
    flex-wrap: wrap;
  }

  .fdg-field { display: flex; flex-direction: column; gap: 0.35rem; }

  .fdg-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .fdg-field input[type=number] {
    width: 80px;
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.9rem;
    text-align: center;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .fdg-format-btns { display: flex; gap: 0.35rem; }

  .fdg-fmt {
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    background: var(--color-bg);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.15s;
  }

  .fdg-fmt.active,
  .fdg-fmt:hover {
    background: var(--color-accent, #6366f1);
    color: #fff;
    border-color: var(--color-accent, #6366f1);
  }

  .fdg-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  #fdg-output {
    width: 100%;
    min-height: 200px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    resize: vertical;
    line-height: 1.5;
  }
</style>
