---
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;

const labels = {
  en: {
    dropHint: 'Drop image here, click to select, or paste (Ctrl+V)',
    dropSub: 'JPG · PNG · WebP · GIF · SVG · BMP',
    loadAnother: 'Load another image',
    colors: 'Colors',
    sort: 'Sort by',
    sortFreq: 'Frequency',
    sortHue: 'Hue',
    sortLight: 'Lightness',
    skipNearWhite: 'Skip near-white',
    skipTransparent: 'Skip transparent',
    extractAgain: 'Re-extract',
    weightLabel: 'Weight',
    copyCss: 'Copy CSS variables',
    copyJson: 'Copy JSON',
    copyTailwind: 'Copy Tailwind',
    privacy: '100% client-side — image never leaves your browser',
    errNotImage: 'Selected file is not an image.',
    errDecode: 'Browser could not decode this image format.',
    errNoPixels: 'No visible pixels remained after the filters were applied.',
    extracting: 'Extracting palette…',
    copied: 'Copied!',
    a11yCopy: 'Click to copy',
  },
  zh: {
    dropHint: '把图片拖到此处，点击选择，或粘贴 (Ctrl+V)',
    dropSub: 'JPG · PNG · WebP · GIF · SVG · BMP',
    loadAnother: '加载其他图片',
    colors: '颜色数量',
    sort: '排序方式',
    sortFreq: '出现频率',
    sortHue: '色相',
    sortLight: '亮度',
    skipNearWhite: '跳过接近白色',
    skipTransparent: '跳过透明像素',
    extractAgain: '重新提取',
    weightLabel: '占比',
    copyCss: '复制 CSS 变量',
    copyJson: '复制 JSON',
    copyTailwind: '复制 Tailwind',
    privacy: '纯浏览器端运行 — 图片不会离开你的设备',
    errNotImage: '所选文件不是图片。',
    errDecode: '浏览器无法解码该图像格式。',
    errNoPixels: '应用过滤后没有剩余可见像素。',
    extracting: '正在提取调色板…',
    copied: '已复制！',
    a11yCopy: '点击复制',
  },
  ja: {
    dropHint: '画像をここにドロップ、クリックで選択、またはペースト (Ctrl+V)',
    dropSub: 'JPG · PNG · WebP · GIF · SVG · BMP',
    loadAnother: '別の画像を読み込む',
    colors: '色数',
    sort: '並べ替え',
    sortFreq: '頻度',
    sortHue: '色相',
    sortLight: '明度',
    skipNearWhite: '白に近い色を除外',
    skipTransparent: '透明ピクセルを除外',
    extractAgain: '再抽出',
    weightLabel: '占有率',
    copyCss: 'CSS 変数をコピー',
    copyJson: 'JSON をコピー',
    copyTailwind: 'Tailwind をコピー',
    privacy: '完全ブラウザ完結 — 画像はデバイスから出ません',
    errNotImage: '選択したファイルは画像ではありません。',
    errDecode: 'ブラウザがこの画像フォーマットをデコードできませんでした。',
    errNoPixels: 'フィルター適用後、可視ピクセルが残っていません。',
    extracting: 'パレットを抽出中…',
    copied: 'コピーしました！',
    a11yCopy: 'クリックでコピー',
  },
  ko: {
    dropHint: '이미지를 끌어다 놓거나 클릭, 또는 붙여넣기 (Ctrl+V)',
    dropSub: 'JPG · PNG · WebP · GIF · SVG · BMP',
    loadAnother: '다른 이미지 불러오기',
    colors: '색상 수',
    sort: '정렬 기준',
    sortFreq: '빈도',
    sortHue: '색상',
    sortLight: '명도',
    skipNearWhite: '거의 흰색 제외',
    skipTransparent: '투명 픽셀 제외',
    extractAgain: '다시 추출',
    weightLabel: '비중',
    copyCss: 'CSS 변수 복사',
    copyJson: 'JSON 복사',
    copyTailwind: 'Tailwind 복사',
    privacy: '100% 클라이언트사이드 — 이미지는 기기를 떠나지 않습니다',
    errNotImage: '선택한 파일이 이미지가 아닙니다.',
    errDecode: '브라우저가 이 이미지 포맷을 디코딩할 수 없습니다.',
    errNoPixels: '필터 적용 후 표시 가능한 픽셀이 없습니다.',
    extracting: '팔레트 추출 중…',
    copied: '복사됨!',
    a11yCopy: '클릭하여 복사',
  },
};
const L = labels[lang] ?? labels.en;
---

<div
  class="icp-wrap"
  data-err-not-image={L.errNotImage}
  data-err-decode={L.errDecode}
  data-err-no-pixels={L.errNoPixels}
  data-extracting={L.extracting}
  data-copied={L.copied}
  data-weight-label={L.weightLabel}
  data-a11y-copy={L.a11yCopy}
>
  <!-- Drop zone -->
  <div id="icp-drop" class="icp-drop" tabindex="0" role="button" aria-label={L.dropHint}>
    <svg class="icp-drop-icon" xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="3" width="18" height="13" rx="2"/>
      <circle cx="8" cy="8" r="1.4"/>
      <path d="m3 13 4-4 4 4 3-3 7 7"/>
      <circle cx="6" cy="20" r="1.4"/>
      <circle cx="12" cy="20" r="1.4"/>
      <circle cx="18" cy="20" r="1.4"/>
    </svg>
    <p class="icp-drop-hint">{L.dropHint}</p>
    <p class="icp-drop-sub">{L.dropSub}</p>
    <input type="file" id="icp-file" accept="image/*" class="icp-file-input" aria-label="Select image" />
  </div>

  <!-- Result area -->
  <div id="icp-result" class="icp-result" hidden>
    <div class="icp-preview-col">
      <div class="icp-preview-frame">
        <img id="icp-preview-img" class="icp-preview-img" alt="" />
      </div>
      <div class="icp-file-info">
        <p id="icp-filename" class="icp-filename"></p>
        <p id="icp-dimensions" class="icp-dimensions"></p>
      </div>
      <button id="icp-reset" class="btn-secondary" type="button">{L.loadAnother}</button>
    </div>

    <div class="icp-controls">
      <div class="icp-control-row">
        <label class="tool-label" for="icp-k">{L.colors}: <span id="icp-k-value">8</span></label>
        <input id="icp-k" type="range" min="3" max="16" step="1" value="8" />
      </div>
      <div class="icp-control-row">
        <label class="tool-label" for="icp-sort">{L.sort}</label>
        <select id="icp-sort" class="icp-select">
          <option value="freq">{L.sortFreq}</option>
          <option value="hue">{L.sortHue}</option>
          <option value="light">{L.sortLight}</option>
        </select>
      </div>
      <label class="icp-checkbox">
        <input id="icp-skip-trans" type="checkbox" checked />
        <span>{L.skipTransparent}</span>
      </label>
      <label class="icp-checkbox">
        <input id="icp-skip-white" type="checkbox" />
        <span>{L.skipNearWhite}</span>
      </label>
      <button id="icp-extract" class="btn-primary" type="button">{L.extractAgain}</button>
    </div>
  </div>

  <div id="icp-status" class="tool-status" aria-live="polite"></div>

  <div id="icp-palette" class="icp-palette" hidden></div>

  <div id="icp-bulk" class="icp-bulk" hidden>
    <button id="icp-copy-css" class="btn-secondary" type="button">{L.copyCss}</button>
    <button id="icp-copy-json" class="btn-secondary" type="button">{L.copyJson}</button>
    <button id="icp-copy-tw" class="btn-secondary" type="button">{L.copyTailwind}</button>
  </div>

  <p class="icp-privacy">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align:-2px"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    <span>{L.privacy}</span>
  </p>
</div>

<script is:inline>
  (function () {
    var wrap = document.querySelector('.icp-wrap');
    if (!wrap) return;

    var ERR_NOT_IMAGE = wrap.dataset.errNotImage;
    var ERR_DECODE    = wrap.dataset.errDecode;
    var ERR_NO_PIXELS = wrap.dataset.errNoPixels;
    var EXTRACTING    = wrap.dataset.extracting;
    var COPIED        = wrap.dataset.copied;
    var WEIGHT_LABEL  = wrap.dataset.weightLabel;
    var A11Y_COPY     = wrap.dataset.a11yCopy;

    var dropEl       = document.getElementById('icp-drop');
    var fileInput    = document.getElementById('icp-file');
    var resultEl     = document.getElementById('icp-result');
    var previewImg   = document.getElementById('icp-preview-img');
    var filenameEl   = document.getElementById('icp-filename');
    var dimensionsEl = document.getElementById('icp-dimensions');
    var resetBtn     = document.getElementById('icp-reset');
    var kInput       = document.getElementById('icp-k');
    var kValueEl     = document.getElementById('icp-k-value');
    var sortSelect   = document.getElementById('icp-sort');
    var skipWhiteCb  = document.getElementById('icp-skip-white');
    var skipTransCb  = document.getElementById('icp-skip-trans');
    var extractBtn   = document.getElementById('icp-extract');
    var statusEl     = document.getElementById('icp-status');
    var paletteEl    = document.getElementById('icp-palette');
    var bulkEl       = document.getElementById('icp-bulk');
    var copyCssBtn   = document.getElementById('icp-copy-css');
    var copyJsonBtn  = document.getElementById('icp-copy-json');
    var copyTwBtn    = document.getElementById('icp-copy-tw');

    var currentImage = null;
    var currentColors = [];

    function setStatus(msg, kind) {
      statusEl.textContent = msg || '';
      statusEl.className = 'tool-status' + (kind ? ' ' + kind : ' none');
    }

    /* --- Color math --- */
    function clamp255(v) { return Math.max(0, Math.min(255, Math.round(v))); }
    function toHex2(v) { return ('0' + clamp255(v).toString(16)).slice(-2); }
    function rgbToHex(r, g, b) { return '#' + toHex2(r) + toHex2(g) + toHex2(b); }

    function rgbToHsl(r, g, b) {
      r /= 255; g /= 255; b /= 255;
      var max = Math.max(r, g, b), min = Math.min(r, g, b);
      var h = 0, s = 0, l = (max + min) / 2;
      if (max !== min) {
        var d = max - min;
        s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
        if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) / 6;
        else if (max === g) h = ((b - r) / d + 2) / 6;
        else h = ((r - g) / d + 4) / 6;
      }
      return { h: h * 360, s: s * 100, l: l * 100 };
    }

    function srgbToLinear(c) {
      c = c / 255;
      return c <= 0.04045 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
    }

    function rgbToOklch(r, g, b) {
      var lr = srgbToLinear(r), lg = srgbToLinear(g), lb = srgbToLinear(b);
      var l_lin = 0.4122214708 * lr + 0.5363325363 * lg + 0.0514459929 * lb;
      var m_lin = 0.2119034982 * lr + 0.6806995451 * lg + 0.1073969566 * lb;
      var s_lin = 0.0883024619 * lr + 0.2817188376 * lg + 0.6299787005 * lb;
      var l_ = Math.cbrt(l_lin), m_ = Math.cbrt(m_lin), s_ = Math.cbrt(s_lin);
      var L = 0.2104542553 * l_ + 0.7936177850 * m_ - 0.0040720468 * s_;
      var A = 1.9779984951 * l_ - 2.4285922050 * m_ + 0.4505937099 * s_;
      var B = 0.0259040371 * l_ + 0.7827717662 * m_ - 0.8086757660 * s_;
      var C = Math.sqrt(A * A + B * B);
      var H = Math.atan2(B, A) * 180 / Math.PI;
      if (H < 0) H += 360;
      return { l: L, c: C, h: H };
    }

    function fmtRgb(rgb) { return 'rgb(' + Math.round(rgb.r) + ' ' + Math.round(rgb.g) + ' ' + Math.round(rgb.b) + ')'; }
    function fmtHsl(hsl) { return 'hsl(' + Math.round(hsl.h) + ' ' + Math.round(hsl.s) + '% ' + Math.round(hsl.l) + '%)'; }
    function fmtOklch(o) { return 'oklch(' + (o.l * 100).toFixed(1) + '% ' + o.c.toFixed(3) + ' ' + o.h.toFixed(1) + ')'; }
    function fmtPercent(w) { return (w * 100).toFixed(1) + '%'; }

    function textColorFor(r, g, b) {
      return (0.299 * r + 0.587 * g + 0.114 * b) > 145 ? '#1f2937' : '#f9fafb';
    }

    /* --- K-means clustering --- */
    function kmeans(pixels, k) {
      var n = pixels.length / 3;
      if (n === 0) return [];
      k = Math.min(k, Math.max(1, n));

      var centroids = [];
      var seen = {};
      var attempts = 0;
      while (centroids.length < k && attempts < n * 4 && attempts < 800) {
        var idx = Math.floor(Math.random() * n);
        var key = pixels[idx * 3] + '_' + pixels[idx * 3 + 1] + '_' + pixels[idx * 3 + 2];
        if (!seen[key]) {
          seen[key] = true;
          centroids.push([pixels[idx * 3], pixels[idx * 3 + 1], pixels[idx * 3 + 2]]);
        }
        attempts++;
      }
      while (centroids.length < k) {
        // monochrome fallback: clone last centroid with a sub-unit jitter
        // so subsequent k-means iterations can actually separate the pair.
        var last = centroids[centroids.length - 1] || [128, 128, 128];
        centroids.push([
          last[0] + (Math.random() - 0.5),
          last[1] + (Math.random() - 0.5),
          last[2] + (Math.random() - 0.5),
        ]);
      }

      var assignments = new Int32Array(n);
      var maxIter = 24;
      // Allocate the per-iteration accumulator once (4 lanes per centroid:
      // r, g, b, count) so the inner loop only needs fill(0) per pass.
      var sums = new Float64Array(k * 4);

      for (var iter = 0; iter < maxIter; iter++) {
        var changed = 0;
        for (var i = 0; i < n; i++) {
          var r = pixels[i * 3], g = pixels[i * 3 + 1], b = pixels[i * 3 + 2];
          var best = 0, bestD = Infinity;
          for (var j = 0; j < k; j++) {
            var dr = r - centroids[j][0], dg = g - centroids[j][1], db = b - centroids[j][2];
            var d = dr * dr + dg * dg + db * db;
            if (d < bestD) { bestD = d; best = j; }
          }
          if (assignments[i] !== best) { assignments[i] = best; changed++; }
        }
        if (changed === 0 && iter > 0) break;

        sums.fill(0);
        for (var i2 = 0; i2 < n; i2++) {
          var bi = assignments[i2] * 4;
          sums[bi]     += pixels[i2 * 3];
          sums[bi + 1] += pixels[i2 * 3 + 1];
          sums[bi + 2] += pixels[i2 * 3 + 2];
          sums[bi + 3]++;
        }
        var maxShift = 0;
        for (var j3 = 0; j3 < k; j3++) {
          var bj = j3 * 4;
          if (sums[bj + 3] === 0) continue;
          var nr = sums[bj]     / sums[bj + 3];
          var ng = sums[bj + 1] / sums[bj + 3];
          var nb = sums[bj + 2] / sums[bj + 3];
          var shift = Math.abs(nr - centroids[j3][0]) + Math.abs(ng - centroids[j3][1]) + Math.abs(nb - centroids[j3][2]);
          if (shift > maxShift) maxShift = shift;
          centroids[j3] = [nr, ng, nb];
        }
        if (maxShift < 1.5) break;
      }

      var counts = new Array(k);
      for (var jc = 0; jc < k; jc++) counts[jc] = 0;
      for (var i3 = 0; i3 < n; i3++) counts[assignments[i3]]++;

      var raw = [];
      for (var j4 = 0; j4 < k; j4++) {
        if (counts[j4] === 0) continue;
        raw.push({
          rgb: { r: Math.round(centroids[j4][0]), g: Math.round(centroids[j4][1]), b: Math.round(centroids[j4][2]) },
          weight: counts[j4] / n,
        });
      }

      // Dedupe near-duplicate centroids
      var deduped = [];
      for (var c = 0; c < raw.length; c++) {
        var dup = false;
        for (var d2 = 0; d2 < deduped.length; d2++) {
          var rgbA = raw[c].rgb, rgbB = deduped[d2].rgb;
          if (Math.abs(rgbA.r - rgbB.r) + Math.abs(rgbA.g - rgbB.g) + Math.abs(rgbA.b - rgbB.b) < 6) {
            deduped[d2].weight += raw[c].weight;
            dup = true;
            break;
          }
        }
        if (!dup) deduped.push(raw[c]);
      }
      return deduped;
    }

    /* --- Image processing --- */
    function processImage() {
      if (!currentImage) return;
      setStatus(EXTRACTING, 'info');

      setTimeout(function () {
        try {
          var maxDim = 200;
          var w = currentImage.naturalWidth || currentImage.width;
          var h = currentImage.naturalHeight || currentImage.height;
          if (!w || !h) {
            setStatus(ERR_NO_PIXELS, 'error');
            return;
          }
          var scale = Math.min(maxDim / w, maxDim / h, 1);
          var sw = Math.max(1, Math.round(w * scale));
          var sh = Math.max(1, Math.round(h * scale));

          var canvas = document.createElement('canvas');
          canvas.width = sw;
          canvas.height = sh;
          var ctx = canvas.getContext('2d', { willReadFrequently: true });
          ctx.drawImage(currentImage, 0, 0, sw, sh);

          var imgData;
          try { imgData = ctx.getImageData(0, 0, sw, sh); }
          catch (e) { setStatus(ERR_DECODE, 'error'); return; }

          var rgba = imgData.data;
          var skipTrans = skipTransCb.checked;
          var skipWhite = skipWhiteCb.checked;
          // Pre-allocate the full-size byte buffer (3 bytes per pixel after
          // dropping alpha) and slice once at the end — avoids the repeated
          // realloc that Array.push triggers on large images.
          var filtered = new Uint8Array((rgba.length >> 2) * 3);
          var fIdx = 0;
          for (var p = 0; p < rgba.length; p += 4) {
            var a = rgba[p + 3];
            if (skipTrans && a < 128) continue;
            var r = rgba[p], g = rgba[p + 1], b = rgba[p + 2];
            if (skipWhite) {
              var lum = 0.2126 * (r / 255) + 0.7152 * (g / 255) + 0.0722 * (b / 255);
              if (lum > 0.95) continue;
            }
            filtered[fIdx++] = r;
            filtered[fIdx++] = g;
            filtered[fIdx++] = b;
          }
          filtered = filtered.subarray(0, fIdx);
          if (filtered.length === 0) {
            setStatus(ERR_NO_PIXELS, 'error');
            paletteEl.hidden = true;
            bulkEl.hidden = true;
            return;
          }

          var k = parseInt(kInput.value, 10) || 8;
          var clusters = kmeans(filtered, k);

          var sortMode = sortSelect.value;
          if (sortMode === 'freq') {
            clusters.sort(function (a, b) { return b.weight - a.weight; });
          } else if (sortMode === 'hue') {
            clusters.forEach(function (c) {
              var hsl = rgbToHsl(c.rgb.r, c.rgb.g, c.rgb.b);
              c._sort = hsl.h;
            });
            clusters.sort(function (a, b) { return a._sort - b._sort; });
          } else if (sortMode === 'light') {
            clusters.forEach(function (c) {
              var hsl = rgbToHsl(c.rgb.r, c.rgb.g, c.rgb.b);
              c._sort = hsl.l;
            });
            clusters.sort(function (a, b) { return b._sort - a._sort; });
          }

          currentColors = clusters;
          renderPalette();
          setStatus('', 'none');
          if (typeof window.trackTool === 'function') {
            window.trackTool('image-color-palette', 'extract');
          }
        } catch (err) {
          setStatus(ERR_DECODE, 'error');
        }
      }, 16);
    }

    function makeRow(label, value, copyable) {
      var el = document.createElement(copyable ? 'button' : 'div');
      el.className = 'icp-swatch-row' + (copyable ? '' : ' is-readonly');
      if (copyable) {
        el.type = 'button';
        el.dataset.copyValue = value;
        el.setAttribute('aria-label', A11Y_COPY + ' ' + value);
      }
      var lbl = document.createElement('span');
      lbl.className = 'icp-swatch-row-label';
      lbl.textContent = label;
      var val = document.createElement('span');
      val.className = 'icp-swatch-row-value';
      val.textContent = value;
      el.appendChild(lbl);
      el.appendChild(val);
      return el;
    }

    function renderPalette() {
      paletteEl.innerHTML = '';
      currentColors.forEach(function (cluster) {
        var rgb = cluster.rgb;
        var hex = rgbToHex(rgb.r, rgb.g, rgb.b);
        var hsl = rgbToHsl(rgb.r, rgb.g, rgb.b);
        var oklch = rgbToOklch(rgb.r, rgb.g, rgb.b);

        var card = document.createElement('div');
        card.className = 'icp-swatch';

        var topBox = document.createElement('button');
        topBox.type = 'button';
        topBox.className = 'icp-swatch-top';
        topBox.style.backgroundColor = hex;
        topBox.style.color = textColorFor(rgb.r, rgb.g, rgb.b);
        topBox.dataset.copyValue = hex;
        topBox.setAttribute('aria-label', A11Y_COPY + ' ' + hex);
        var hexLabel = document.createElement('span');
        hexLabel.className = 'icp-swatch-hex';
        hexLabel.textContent = hex.toUpperCase();
        topBox.appendChild(hexLabel);
        card.appendChild(topBox);

        var meta = document.createElement('div');
        meta.className = 'icp-swatch-meta';
        meta.appendChild(makeRow('RGB', fmtRgb(rgb), true));
        meta.appendChild(makeRow('HSL', fmtHsl(hsl), true));
        meta.appendChild(makeRow('OKLCH', fmtOklch(oklch), true));
        meta.appendChild(makeRow(WEIGHT_LABEL, fmtPercent(cluster.weight), false));
        card.appendChild(meta);

        paletteEl.appendChild(card);
      });
      paletteEl.hidden = false;
      bulkEl.hidden = false;
    }

    /* Click-to-copy delegation */
    paletteEl.addEventListener('click', function (e) {
      var t = e.target;
      while (t && t !== paletteEl) {
        if (t.dataset && t.dataset.copyValue) {
          var val = t.dataset.copyValue;
          navigator.clipboard.writeText(val).then(function () {
            var hexEl = t.querySelector('.icp-swatch-hex');
            if (hexEl) {
              var orig1 = hexEl.textContent;
              hexEl.textContent = COPIED;
              setTimeout(function () { hexEl.textContent = orig1; }, 1100);
            } else {
              var valEl = t.querySelector('.icp-swatch-row-value');
              if (valEl) {
                var orig2 = valEl.textContent;
                valEl.textContent = COPIED;
                setTimeout(function () { valEl.textContent = orig2; }, 1100);
              }
            }
            if (typeof window.trackTool === 'function') {
              window.trackTool('image-color-palette', 'copy_swatch');
            }
          });
          return;
        }
        t = t.parentElement;
      }
    });

    /* Bulk copy */
    function copyText(btn, text, eventName) {
      navigator.clipboard.writeText(text).then(function () {
        var orig = btn.textContent;
        btn.textContent = COPIED;
        setTimeout(function () { btn.textContent = orig; }, 1200);
        if (typeof window.trackTool === 'function') {
          window.trackTool('image-color-palette', eventName);
        }
      });
    }
    copyCssBtn.addEventListener('click', function () {
      var lines = currentColors.map(function (c, i) {
        return '  --color-' + (i + 1) + ': ' + rgbToHex(c.rgb.r, c.rgb.g, c.rgb.b) + ';';
      });
      copyText(copyCssBtn, ':root {\n' + lines.join('\n') + '\n}\n', 'copy_css');
    });
    copyJsonBtn.addEventListener('click', function () {
      var arr = currentColors.map(function (c) {
        return {
          hex: rgbToHex(c.rgb.r, c.rgb.g, c.rgb.b),
          rgb: c.rgb,
          weight: parseFloat((c.weight * 100).toFixed(2)),
        };
      });
      copyText(copyJsonBtn, JSON.stringify(arr, null, 2), 'copy_json');
    });
    copyTwBtn.addEventListener('click', function () {
      var entries = currentColors.map(function (c, i) {
        return "        c" + (i + 1) + ": '" + rgbToHex(c.rgb.r, c.rgb.g, c.rgb.b) + "',";
      });
      var conf = "module.exports = {\n  theme: {\n    extend: {\n      colors: {\n        palette: {\n" + entries.join('\n') + "\n        },\n      },\n    },\n  },\n};\n";
      copyText(copyTwBtn, conf, 'copy_tailwind');
    });

    /* File loading */
    function handleFile(file) {
      if (!file || !file.type || file.type.indexOf('image') !== 0) {
        setStatus(ERR_NOT_IMAGE, 'error');
        return;
      }
      var reader = new FileReader();
      reader.onerror = function () { setStatus(ERR_DECODE, 'error'); };
      reader.onload = function (e) {
        var img = new Image();
        img.onload = function () {
          currentImage = img;
          previewImg.src = e.target.result;
          filenameEl.textContent = file.name;
          dimensionsEl.textContent = (img.naturalWidth || img.width) + ' × ' + (img.naturalHeight || img.height) + ' · ' + Math.round(file.size / 1024) + ' KB';
          dropEl.hidden = true;
          resultEl.hidden = false;
          processImage();
        };
        img.onerror = function () { setStatus(ERR_DECODE, 'error'); };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
    }

    /* Drop zone interactions */
    dropEl.addEventListener('click', function () { fileInput.click(); });
    dropEl.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        fileInput.click();
      }
    });
    fileInput.addEventListener('change', function (e) {
      var f = e.target.files[0];
      if (f) handleFile(f);
    });

    function preventDefaults(e) { e.preventDefault(); e.stopPropagation(); }
    ['dragenter', 'dragover'].forEach(function (ev) {
      dropEl.addEventListener(ev, function (e) {
        preventDefaults(e);
        dropEl.classList.add('icp-drop-active');
      });
    });
    ['dragleave', 'dragend'].forEach(function (ev) {
      dropEl.addEventListener(ev, function (e) {
        preventDefaults(e);
        dropEl.classList.remove('icp-drop-active');
      });
    });
    dropEl.addEventListener('drop', function (e) {
      preventDefaults(e);
      dropEl.classList.remove('icp-drop-active');
      var f = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
      if (f) handleFile(f);
    });

    /* Paste handler — global, scoped to wrap visibility */
    document.addEventListener('paste', function (e) {
      if (!wrap.isConnected) return;
      var items = e.clipboardData && e.clipboardData.items;
      if (!items) return;
      for (var i = 0; i < items.length; i++) {
        if (items[i].type && items[i].type.indexOf('image') === 0) {
          var f = items[i].getAsFile();
          if (f) {
            handleFile(f);
            e.preventDefault();
            return;
          }
        }
      }
    });

    /* Reset */
    resetBtn.addEventListener('click', function () {
      currentImage = null;
      currentColors = [];
      previewImg.src = '';
      paletteEl.innerHTML = '';
      paletteEl.hidden = true;
      bulkEl.hidden = true;
      resultEl.hidden = true;
      dropEl.hidden = false;
      fileInput.value = '';
      setStatus('', 'none');
    });

    /* Controls */
    kInput.addEventListener('input', function () {
      kValueEl.textContent = kInput.value;
    });
    kInput.addEventListener('change', function () {
      if (currentImage) processImage();
    });
    extractBtn.addEventListener('click', function () {
      if (currentImage) processImage();
    });
    sortSelect.addEventListener('change', function () {
      if (currentImage) processImage();
    });
    skipWhiteCb.addEventListener('change', function () {
      if (currentImage) processImage();
    });
    skipTransCb.addEventListener('change', function () {
      if (currentImage) processImage();
    });
  })();
</script>

