---
// BasicAuthHeaderGeneratorTool - UTF-8 safe HTTP Basic Authorization header generator and decoder.
---

<div class="bahg-wrap">
  <section class="bahg-card" aria-labelledby="bahg-generate-title">
    <div class="bahg-card-head">
      <div>
        <h2 id="bahg-generate-title" data-i18n="generateTitle">Generate Basic Auth Header</h2>
        <p data-i18n="generateHint">Create an Authorization header from a username and password.</p>
      </div>
    </div>

    <div class="bahg-grid">
      <label class="bahg-field" for="bahg-username">
        <span class="tool-label" data-i18n="username">Username</span>
        <input id="bahg-username" class="tool-input" type="text" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" placeholder="Aladdin" />
      </label>

      <label class="bahg-field" for="bahg-password">
        <span class="tool-label" data-i18n="password">Password</span>
        <span class="bahg-password-row">
          <input id="bahg-password" class="tool-input" type="password" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" placeholder="open sesame" />
          <button id="bahg-toggle-password" class="btn-secondary" type="button" data-i18n="show">Show</button>
        </span>
      </label>
    </div>

    <div class="bahg-actions">
      <button id="bahg-generate" class="btn-primary" type="button" data-i18n="generate">Generate</button>
      <button id="bahg-load-generate-example" class="btn-secondary" type="button" data-i18n="loadExample">Load Example</button>
      <button id="bahg-clear-generate" class="btn-ghost" type="button" data-i18n="clear">Clear</button>
    </div>

    <div id="bahg-generate-status" class="tool-status none" aria-live="polite"></div>

    <div id="bahg-generate-output" class="bahg-output" hidden>
      <div class="tool-result-row">
        <span class="tool-result-label" data-i18n="fullHeader">Full header</span>
        <code id="bahg-full-header" class="tool-result-value"></code>
        <button class="btn-copy" type="button" data-copy-target="bahg-full-header" data-i18n="copy">Copy</button>
      </div>
      <div class="tool-result-row">
        <span class="tool-result-label" data-i18n="token">Token</span>
        <code id="bahg-token" class="tool-result-value"></code>
        <button class="btn-copy" type="button" data-copy-target="bahg-token" data-i18n="copy">Copy</button>
      </div>
      <div class="bahg-snippet-grid">
        <div class="bahg-snippet">
          <div class="bahg-snippet-head">
            <span class="tool-result-label">cURL</span>
            <button class="btn-copy" type="button" data-copy-target="bahg-curl" data-i18n="copy">Copy</button>
          </div>
          <pre><code id="bahg-curl"></code></pre>
        </div>
        <div class="bahg-snippet">
          <div class="bahg-snippet-head">
            <span class="tool-result-label">Fetch</span>
            <button class="btn-copy" type="button" data-copy-target="bahg-fetch" data-i18n="copy">Copy</button>
          </div>
          <pre><code id="bahg-fetch"></code></pre>
        </div>
      </div>
    </div>
  </section>

  <section class="bahg-card" aria-labelledby="bahg-decode-title">
    <div class="bahg-card-head">
      <div>
        <h2 id="bahg-decode-title" data-i18n="decodeTitle">Decode Basic Auth Header</h2>
        <p data-i18n="decodeHint">Paste a full Authorization header, a Basic token, or a raw token.</p>
      </div>
    </div>

    <label class="bahg-field" for="bahg-decode-input">
      <span class="tool-label" data-i18n="decodeInput">Header or token</span>
      <textarea id="bahg-decode-input" class="tool-textarea" rows="4" spellcheck="false" placeholder="Basic dXNlcjpwOmE6c3M="></textarea>
    </label>

    <div class="bahg-actions">
      <button id="bahg-decode" class="btn-primary" type="button" data-i18n="decode">Decode</button>
      <button id="bahg-load-decode-example" class="btn-secondary" type="button" data-i18n="loadExample">Load Example</button>
      <button id="bahg-clear-decode" class="btn-ghost" type="button" data-i18n="clear">Clear</button>
    </div>

    <div id="bahg-decode-status" class="tool-status none" aria-live="polite"></div>

    <div id="bahg-decode-output" class="bahg-output" hidden>
      <div class="tool-result-row">
        <span class="tool-result-label" data-i18n="decodedUsername">Username</span>
        <code id="bahg-decoded-username" class="tool-result-value"></code>
        <button class="btn-copy" type="button" data-copy-target="bahg-decoded-username" data-i18n="copy">Copy</button>
      </div>
      <div class="tool-result-row">
        <span class="tool-result-label" data-i18n="decodedPassword">Password</span>
        <code id="bahg-decoded-password" class="tool-result-value"></code>
        <button class="btn-copy" type="button" data-copy-target="bahg-decoded-password" data-i18n="copy">Copy</button>
      </div>
    </div>
  </section>

  <p class="bahg-privacy" data-i18n="privacy">Basic auth is Base64 encoding, not encryption. Use HTTPS when sending it.</p>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: {
          generateTitle: 'Generate Basic Auth Header',
          generateHint: 'Create an Authorization header from a username and password.',
          decodeTitle: 'Decode Basic Auth Header',
          decodeHint: 'Paste a full Authorization header, a Basic token, or a raw token.',
          username: 'Username',
          password: 'Password',
          show: 'Show',
          hide: 'Hide',
          generate: 'Generate',
          decode: 'Decode',
          loadExample: 'Load Example',
          clear: 'Clear',
          copy: 'Copy',
          copied: 'Copied!',
          fullHeader: 'Full header',
          token: 'Token',
          decodeInput: 'Header or token',
          decodedUsername: 'Username',
          decodedPassword: 'Password',
          generated: 'Header generated.',
          decoded: 'Credentials decoded.',
          cleared: 'Cleared.',
          missingGenerate: 'Enter a username or password first.',
          usernameColon: 'Username cannot contain a colon.',
          missingDecode: 'Paste a Basic auth header or token first.',
          invalidScheme: 'Only the Basic authorization scheme is supported.',
          invalidBase64: 'Invalid Base64 token.',
          missingColon: 'Decoded credentials must contain a colon.',
          copyFailed: 'Copy failed. Select and copy manually.',
          privacy: 'Basic auth is Base64 encoding, not encryption. Use HTTPS when sending it.',
        },
        zh: {
          generateTitle: '生成 Basic Auth 请求头',
          generateHint: '用用户名和密码创建 Authorization 请求头。',
          decodeTitle: '解码 Basic Auth 请求头',
          decodeHint: '粘贴完整 Authorization 请求头、Basic token 或纯 token。',
          username: '用户名',
          password: '密码',
          show: '显示',
          hide: '隐藏',
          generate: '生成',
          decode: '解码',
          loadExample: '加载示例',
          clear: '清除',
          copy: '复制',
          copied: '已复制！',
          fullHeader: '完整请求头',
          token: 'Token',
          decodeInput: '请求头或 token',
          decodedUsername: '用户名',
          decodedPassword: '密码',
          generated: '请求头已生成。',
          decoded: '凭据已解码。',
          cleared: '已清除。',
          missingGenerate: '请先输入用户名或密码。',
          usernameColon: '用户名不能包含冒号。',
          missingDecode: '请先粘贴 Basic auth 请求头或 token。',
          invalidScheme: '仅支持 Basic 授权方案。',
          invalidBase64: 'Base64 token 无效。',
          missingColon: '解码后的凭据必须包含冒号。',
          copyFailed: '复制失败，请手动选择复制。',
          privacy: 'Basic auth 是 Base64 编码，不是加密。发送时请使用 HTTPS。',
        },
        ja: {
          generateTitle: 'Basic Auth ヘッダーを生成',
          generateHint: 'ユーザー名とパスワードから Authorization ヘッダーを作成します。',
          decodeTitle: 'Basic Auth ヘッダーをデコード',
          decodeHint: '完全な Authorization ヘッダー、Basic トークン、または生トークンを貼り付けます。',
          username: 'ユーザー名',
          password: 'パスワード',
          show: '表示',
          hide: '非表示',
          generate: '生成',
          decode: 'デコード',
          loadExample: '例を読み込む',
          clear: 'クリア',
          copy: 'コピー',
          copied: 'コピー済み！',
          fullHeader: '完全なヘッダー',
          token: 'トークン',
          decodeInput: 'ヘッダーまたはトークン',
          decodedUsername: 'ユーザー名',
          decodedPassword: 'パスワード',
          generated: 'ヘッダーを生成しました。',
          decoded: '認証情報をデコードしました。',
          cleared: 'クリアしました。',
          missingGenerate: 'まずユーザー名またはパスワードを入力してください。',
          usernameColon: 'ユーザー名にコロンは使用できません。',
          missingDecode: 'まず Basic auth ヘッダーまたはトークンを貼り付けてください。',
          invalidScheme: 'Basic 認証スキームのみ対応しています。',
          invalidBase64: 'Base64 トークンが無効です。',
          missingColon: 'デコード後の認証情報にはコロンが必要です。',
          copyFailed: 'コピーに失敗しました。手動で選択してコピーしてください。',
          privacy: 'Basic auth は Base64 エンコードであり、暗号化ではありません。送信時は HTTPS を使用してください。',
        },
        ko: {
          generateTitle: 'Basic Auth 헤더 생성',
          generateHint: '사용자 이름과 비밀번호로 Authorization 헤더를 만듭니다.',
          decodeTitle: 'Basic Auth 헤더 디코딩',
          decodeHint: '전체 Authorization 헤더, Basic 토큰 또는 원본 토큰을 붙여넣으세요.',
          username: '사용자 이름',
          password: '비밀번호',
          show: '보기',
          hide: '숨기기',
          generate: '생성',
          decode: '디코딩',
          loadExample: '예제 불러오기',
          clear: '지우기',
          copy: '복사',
          copied: '복사됨!',
          fullHeader: '전체 헤더',
          token: '토큰',
          decodeInput: '헤더 또는 토큰',
          decodedUsername: '사용자 이름',
          decodedPassword: '비밀번호',
          generated: '헤더가 생성되었습니다.',
          decoded: '자격 증명이 디코딩되었습니다.',
          cleared: '지웠습니다.',
          missingGenerate: '먼저 사용자 이름 또는 비밀번호를 입력하세요.',
          usernameColon: '사용자 이름에는 콜론을 포함할 수 없습니다.',
          missingDecode: '먼저 Basic auth 헤더 또는 토큰을 붙여넣으세요.',
          invalidScheme: 'Basic 인증 스킴만 지원합니다.',
          invalidBase64: 'Base64 토큰이 유효하지 않습니다.',
          missingColon: '디코딩된 자격 증명에는 콜론이 필요합니다.',
          copyFailed: '복사에 실패했습니다. 직접 선택해서 복사하세요.',
          privacy: 'Basic auth는 Base64 인코딩이며 암호화가 아닙니다. 전송할 때 HTTPS를 사용하세요.',
        },
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;
      var encoder = new TextEncoder();
      var decoder = new TextDecoder('utf-8', { fatal: true });

      function byId(id) {
        return document.getElementById(id);
      }

      document.querySelectorAll('.bahg-wrap [data-i18n]').forEach(function (el) {
        var key = el.getAttribute('data-i18n');
        if (t[key]) el.textContent = t[key];
      });

      var usernameEl = byId('bahg-username');
      var passwordEl = byId('bahg-password');
      var togglePasswordBtn = byId('bahg-toggle-password');
      var generateBtn = byId('bahg-generate');
      var loadGenerateExampleBtn = byId('bahg-load-generate-example');
      var clearGenerateBtn = byId('bahg-clear-generate');
      var generateStatusEl = byId('bahg-generate-status');
      var generateOutputEl = byId('bahg-generate-output');
      var fullHeaderEl = byId('bahg-full-header');
      var tokenEl = byId('bahg-token');
      var curlEl = byId('bahg-curl');
      var fetchEl = byId('bahg-fetch');
      var decodeInputEl = byId('bahg-decode-input');
      var decodeBtn = byId('bahg-decode');
      var loadDecodeExampleBtn = byId('bahg-load-decode-example');
      var clearDecodeBtn = byId('bahg-clear-decode');
      var decodeStatusEl = byId('bahg-decode-status');
      var decodeOutputEl = byId('bahg-decode-output');
      var decodedUsernameEl = byId('bahg-decoded-username');
      var decodedPasswordEl = byId('bahg-decoded-password');

      function setStatus(el, message, type) {
        el.textContent = message || '';
        el.className = 'tool-status ' + (type || 'none');
      }

      function bytesToBase64(bytes) {
        var binary = '';
        var chunkSize = 8192;
        for (var i = 0; i < bytes.length; i += chunkSize) {
          binary += String.fromCharCode.apply(null, bytes.subarray(i, i + chunkSize));
        }
        return btoa(binary);
      }

      function base64ToBytes(token) {
        var normalized = token.replace(/\s+/g, '');
        if (!normalized) throw new Error('invalidBase64');
        if (!/^[A-Za-z0-9+/]*={0,2}$/.test(normalized)) throw new Error('invalidBase64');
        var pad = normalized.length % 4;
        if (pad === 1) throw new Error('invalidBase64');
        if (pad === 2) normalized += '==';
        if (pad === 3) normalized += '=';
        try {
          var binary = atob(normalized);
          var bytes = new Uint8Array(binary.length);
          for (var i = 0; i < binary.length; i += 1) {
            bytes[i] = binary.charCodeAt(i);
          }
          return bytes;
        } catch (err) {
          throw new Error('invalidBase64');
        }
      }

      function extractBasicToken(input) {
        var value = input.trim();
        var authorizationMatch;
        if (!value) throw new Error('missingDecode');

        authorizationMatch = value.match(/^authorization\s*:\s*(.+)$/i);
        if (authorizationMatch) value = authorizationMatch[1].trim();

        var schemeMatch = value.match(/^([A-Za-z][A-Za-z0-9+.-]*)\s+(.+)$/);
        if (schemeMatch) {
          if (schemeMatch[1].toLowerCase() !== 'basic') throw new Error('invalidScheme');
          value = schemeMatch[2].trim();
        }
        return value;
      }

      function generateHeader() {
        var username = usernameEl.value;
        var password = passwordEl.value;
        var token;
        var header;
        if (!username && !password) {
          generateOutputEl.hidden = true;
          setStatus(generateStatusEl, t.missingGenerate, 'error');
          return;
        }
        if (username.indexOf(':') !== -1) {
          generateOutputEl.hidden = true;
          setStatus(generateStatusEl, t.usernameColon, 'error');
          return;
        }
        token = bytesToBase64(encoder.encode(username + ':' + password));
        header = 'Authorization: Basic ' + token;
        fullHeaderEl.textContent = header;
        tokenEl.textContent = token;
        curlEl.textContent = 'curl -H "' + header + '" https://example.com/api';
        fetchEl.textContent = "fetch('https://example.com/api', {\n  headers: {\n    Authorization: 'Basic " + token + "'\n  }\n});";
        generateOutputEl.hidden = false;
        setStatus(generateStatusEl, t.generated, 'success');
      }

      function decodeHeader() {
        var token;
        var decoded;
        var colonIndex;
        try {
          token = extractBasicToken(decodeInputEl.value);
          decoded = decoder.decode(base64ToBytes(token));
          colonIndex = decoded.indexOf(':');
          if (colonIndex === -1) throw new Error('missingColon');
          decodedUsernameEl.textContent = decoded.slice(0, colonIndex);
          decodedPasswordEl.textContent = decoded.slice(colonIndex + 1);
          decodeOutputEl.hidden = false;
          setStatus(decodeStatusEl, t.decoded, 'success');
        } catch (err) {
          decodeOutputEl.hidden = true;
          setStatus(decodeStatusEl, t[err.message] || t.invalidBase64, 'error');
        }
      }

      function resetCopyButton(button) {
        window.setTimeout(function () {
          button.classList.remove('copied');
          button.textContent = t.copy;
        }, 1200);
      }

      function copyText(button, statusEl) {
        var target = byId(button.getAttribute('data-copy-target'));
        var text = target ? target.textContent : '';
        if (!text) return;
        navigator.clipboard.writeText(text).then(function () {
          button.classList.add('copied');
          button.textContent = t.copied;
          resetCopyButton(button);
        }).catch(function () {
          setStatus(statusEl, t.copyFailed, 'error');
        });
      }

      togglePasswordBtn.addEventListener('click', function () {
        var showing = passwordEl.type === 'text';
        passwordEl.type = showing ? 'password' : 'text';
        togglePasswordBtn.textContent = showing ? t.show : t.hide;
      });

      generateBtn.addEventListener('click', generateHeader);
      loadGenerateExampleBtn.addEventListener('click', function () {
        usernameEl.value = 'Aladdin';
        passwordEl.value = 'open sesame';
        generateHeader();
      });
      clearGenerateBtn.addEventListener('click', function () {
        usernameEl.value = '';
        passwordEl.value = '';
        fullHeaderEl.textContent = '';
        tokenEl.textContent = '';
        curlEl.textContent = '';
        fetchEl.textContent = '';
        generateOutputEl.hidden = true;
        setStatus(generateStatusEl, '', 'none');
      });

      decodeBtn.addEventListener('click', decodeHeader);
      loadDecodeExampleBtn.addEventListener('click', function () {
        decodeInputEl.value = 'Basic dXNlcjpwOmE6c3M=';
        decodeHeader();
      });
      clearDecodeBtn.addEventListener('click', function () {
        decodeInputEl.value = '';
        decodedUsernameEl.textContent = '';
        decodedPasswordEl.textContent = '';
        decodeOutputEl.hidden = true;
        setStatus(decodeStatusEl, '', 'none');
      });

      document.querySelectorAll('.bahg-wrap [data-copy-target]').forEach(function (button) {
        button.addEventListener('click', function () {
          var statusEl = button.closest('#bahg-decode-output') ? decodeStatusEl : generateStatusEl;
          copyText(button, statusEl);
        });
      });
    })();
  </script>

  <style is:global>
    .bahg-wrap {
      display: grid;
      gap: 1rem;
    }

    .bahg-card {
      display: grid;
      gap: 1rem;
      padding: 1rem;
      border-radius: var(--radius-lg);
      background: var(--color-surface);
      box-shadow: var(--shadow-card);
      outline: 1px solid var(--color-border-soft);
      outline-offset: -1px;
    }

    .bahg-card-head {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: flex-start;
    }

    .bahg-card h2 {
      margin: 0;
      color: var(--color-text);
      font-family: var(--font-display);
      font-size: clamp(1.2rem, 2vw, 1.55rem);
      line-height: 1.15;
    }

    .bahg-card p {
      margin: 0.35rem 0 0;
      color: var(--color-text-secondary);
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .bahg-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .bahg-field {
      display: grid;
      gap: 0.35rem;
      min-width: 0;
    }

    .bahg-password-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.5rem;
      min-width: 0;
    }

    .bahg-actions {
      display: flex;
      gap: 0.6rem;
      flex-wrap: wrap;
    }

    .bahg-output {
      display: grid;
      gap: 0.75rem;
    }

    .bahg-output[hidden] {
      display: none;
    }

    .bahg-snippet-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .bahg-snippet {
      display: grid;
      gap: 0.55rem;
      min-width: 0;
      padding: 0.75rem;
      border-radius: var(--radius-md);
      background: var(--color-bg-secondary);
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
    }

    .bahg-snippet-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .bahg-snippet pre {
      margin: 0;
      overflow: auto;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .bahg-snippet code {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      line-height: 1.55;
      color: var(--color-text);
    }

    .bahg-privacy {
      margin: 0;
      padding: 0.8rem 0.9rem;
      border-radius: var(--radius-md);
      background: var(--color-surface-muted);
      color: var(--color-text-secondary);
      font-size: 0.9rem;
      line-height: 1.5;
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
    }

    @media (max-width: 720px) {
      .bahg-grid,
      .bahg-snippet-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 420px) {
      .bahg-card {
        padding: 0.85rem;
      }

      .bahg-password-row {
        grid-template-columns: 1fr;
      }

      .bahg-actions > button,
      .bahg-password-row > button {
        width: 100%;
      }

      .bahg-snippet-head,
      .bahg-wrap .tool-result-row {
        align-items: flex-start;
      }
    }
  </style>
</div>
