      var KU_NAMES = ['digitalSignature','nonRepudiation','keyEncipherment','dataEncipherment','keyAgreement','keyCertSign','cRLSign','encipherOnly','decipherOnly'];

      // ── ASN.1 parser ─────────────────────────────────────────────────
      function asnRead(buf, off) {
        var first = buf[off];
        var cls = (first >> 6) & 0x3;
        var constructed = (first & 0x20) !== 0;
        var tag = first & 0x1F;
        var p = off + 1;
        if (tag === 0x1F) {
          tag = 0;
          while (buf[p] & 0x80) { tag = (tag << 7) | (buf[p] & 0x7F); p++; }
          tag = (tag << 7) | buf[p]; p++;
        }
        var lenByte = buf[p++];
        var len;
        if ((lenByte & 0x80) === 0) {
          len = lenByte;
        } else {
          var n = lenByte & 0x7F;
          if (n === 0) throw new Error('indefinite length not supported');
          if (n > 4) throw new Error('length too large');
          len = 0;
          for (var i = 0; i < n; i++) len = (len << 8) | buf[p++];
        }
        return { cls: cls, constructed: constructed, tag: tag, length: len, valueOffset: p, end: p + len };
      }

      function asnChildren(buf, node) {
        var out = [];
        var p = node.valueOffset;
        while (p < node.end) {
          var c = asnRead(buf, p);
          out.push(c);
          p = c.end;
        }
        return out;
      }

      function bytesToLatin1(buf, s, e) {
        var out = '';
        for (var i = s; i < e; i++) out += String.fromCharCode(buf[i]);
        return out;
      }

      function bytesToUtf8(buf, s, e) {
        try { return new TextDecoder('utf-8').decode(buf.subarray(s, e)); }
        catch (err) { return bytesToLatin1(buf, s, e); }
      }

      function bytesToBmp(buf, s, e) {
        var out = '';
        for (var i = s; i < e; i += 2) out += String.fromCharCode((buf[i] << 8) | buf[i + 1]);
        return out;
      }

      function decodeOid(buf, s, e) {
        var oid = '', v = 0, first = true;
        for (var i = s; i < e; i++) {
          v = (v * 128) + (buf[i] & 0x7F);
          if ((buf[i] & 0x80) === 0) {
            if (first) {
              var a = v >= 80 ? 2 : Math.floor(v / 40);
              oid = a + '.' + (v - a * 40);
              first = false;
            } else {
              oid += '.' + v;
            }
            v = 0;
          }
        }
        return oid;
      }

      function decodeInteger(buf, s, e) {
        if (e - s === 0) return 0n;
        var hex = '';
        for (var i = s; i < e; i++) hex += (buf[i] < 16 ? '0' : '') + buf[i].toString(16);
        var n = BigInt('0x' + hex);
        if ((buf[s] & 0x80) !== 0 && e - s > 0) n -= (1n << BigInt((e - s) * 8));
        return n;
      }

      function decodeUtcTime(buf, s, e) {
        var str = bytesToLatin1(buf, s, e);
        var yy = parseInt(str.slice(0, 2), 10);
        var year = yy < 50 ? 2000 + yy : 1900 + yy;
        return new Date(Date.UTC(year, parseInt(str.slice(2, 4), 10) - 1, parseInt(str.slice(4, 6), 10),
          parseInt(str.slice(6, 8), 10), parseInt(str.slice(8, 10), 10), parseInt(str.slice(10, 12), 10)));
      }

      function decodeGenTime(buf, s, e) {
        var str = bytesToLatin1(buf, s, e);
        return new Date(Date.UTC(parseInt(str.slice(0, 4), 10), parseInt(str.slice(4, 6), 10) - 1,
          parseInt(str.slice(6, 8), 10), parseInt(str.slice(8, 10), 10),
          parseInt(str.slice(10, 12), 10), parseInt(str.slice(12, 14), 10)));
        }

      function valueOf(buf, node) {
        if (node.cls !== 0) return null;
        switch (node.tag) {
          case 0x01: return buf[node.valueOffset] !== 0;
          case 0x02: return decodeInteger(buf, node.valueOffset, node.end);
          case 0x03: {
            var unused = buf[node.valueOffset];
            return { unusedBits: unused, data: buf.subarray(node.valueOffset + 1, node.end) };
          }
          case 0x04: return buf.subarray(node.valueOffset, node.end);
          case 0x05: return null;
          case 0x06: return decodeOid(buf, node.valueOffset, node.end);
