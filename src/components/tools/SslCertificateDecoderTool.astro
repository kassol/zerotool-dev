---
// SslCertificateDecoderTool — X.509 PEM certificate decoder
// 100% client-side: ASN.1 DER parser + Web Crypto fingerprints, no dependencies.
interface Props { lang?: 'en' | 'zh' | 'ja' | 'ko' }
const { lang = 'en' } = Astro.props;
---

<div>
  <div class="scd-wrap">
    <div class="scd-input-section">
      <label for="scd-input" class="tool-label">
        <span data-i18n="pasteLabel">Paste PEM Certificate</span>
      </label>
      <textarea
        id="scd-input"
        class="tool-textarea scd-input"
        rows="9"
        placeholder="-----BEGIN CERTIFICATE-----&#10;MIIFazCCA1OgAwIBAgIRAIIQ...&#10;-----END CERTIFICATE-----"
        data-i18n-placeholder="placeholder"
        spellcheck="false"
        autocomplete="off"
      ></textarea>
    </div>

    <div class="scd-actions">
      <button id="scd-decode" class="btn-primary" type="button" data-i18n="decode">Decode</button>
      <button id="scd-example" class="btn-ghost" type="button" data-i18n="loadExample">Load Example</button>
      <button id="scd-clear" class="btn-ghost" type="button" data-i18n="clear">Clear</button>
    </div>

    <div id="scd-status" class="tool-status none" aria-live="polite"></div>

    <div id="scd-results" class="scd-results" hidden></div>
  </div>

