        if (kuExt) {
          try {
            var flags = parseKeyUsage(kuExt.raw);
            usageHtml += renderCard(t.sectionUsage,
              flags.length
                ? flags.map(function (f) { return '<span class="scd-chip">' + escapeHtml(f) + '</span>'; }).join('')
                : '<span class="scd-row--muted">—</span>'
            );
          } catch (e) {}
        }
        if (ekuExt) {
          try {
            var ekus = parseEku(ekuExt.raw);
            usageHtml += renderCard(t.sectionEku,
              ekus.length
                ? ekus.map(function (f) { return '<span class="scd-chip">' + escapeHtml(f) + '</span>'; }).join('')
                : '<span class="scd-row--muted">—</span>'
            );
          } catch (e) {}
        }
        if (usageHtml) html += '<div class="scd-grid-2">' + usageHtml + '</div>';

        var bcExt = findExtension(cert.extensions, '2.5.29.19');
        var bcBody = '';
        if (bcExt) {
          try {
            var bc = parseBasicConstraints(bcExt.raw);
            bcBody += renderRow(t.labelCa, escapeHtml(bc.ca ? t.statusYes : t.statusNo));
            if (bc.pathLen !== null) bcBody += renderRow(t.labelPathLen, escapeHtml(String(bc.pathLen)));
          } catch (e) {}
        }
        var skiExt = findExtension(cert.extensions, '2.5.29.14');
        var akiExt = findExtension(cert.extensions, '2.5.29.35');
        var idBody = '';
        if (skiExt) {
          try { idBody += renderRow(t.labelSki, '<span class="scd-mono">' + escapeHtml(parseOctetIdentifier(skiExt.raw)) + '</span>'); } catch (e) {}
        }
        if (akiExt) {
          try {
            var aki = parseAki(akiExt.raw);
            if (aki) idBody += renderRow(t.labelAki, '<span class="scd-mono">' + escapeHtml(aki) + '</span>');
          } catch (e) {}
        }

        var rightHtml = '';
        if (bcBody) rightHtml += renderCard(t.sectionConstraints, bcBody);
        if (idBody) rightHtml += renderCard(t.sectionIdentity, idBody);
        if (rightHtml) html += '<div class="scd-grid-2">' + rightHtml + '</div>';

        var crlExt = findExtension(cert.extensions, '2.5.29.31');
        if (crlExt) {
          try {
            var urls = parseCrlDistribution(crlExt.raw);
            if (urls.length) {
              var crlBody = urls.map(function (u) { return renderRow('URL', '<span class="scd-mono">' + escapeHtml(u) + '</span>', u); }).join('');
              html += renderCard(t.sectionCrl, crlBody);
            }
          } catch (e) {}
        }

        var aiaExt = findExtension(cert.extensions, '1.3.6.1.5.5.7.1.1');
        if (aiaExt) {
          try {
            var aia = parseAia(aiaExt.raw);
            if (aia.length) {
              var aiaBody = aia.map(function (a) {
                return renderRow(a.method, '<span class="scd-mono">' + escapeHtml(a.location || '') + '</span>', a.location || '');
              }).join('');
              html += renderCard(t.sectionAia, aiaBody);
            }
          } catch (e) {}
        }

        var fpBody =
          renderRow('SHA-256', '<span class="scd-mono">' + escapeHtml(fps.sha256) + '</span>', fps.sha256) +
          renderRow('SHA-1', '<span class="scd-mono">' + escapeHtml(fps.sha1) + '</span>', fps.sha1) +
          renderRow('MD5', '<span class="scd-mono">' + escapeHtml(fps.md5) + '</span>', fps.md5);
        html += renderCard(t.sectionFingerprints, fpBody);

        var serialHex = cert.serial.toString(16).toUpperCase();
        if (serialHex.length % 2 !== 0) serialHex = '0' + serialHex;
        var serialFormatted = serialHex.match(/.{1,2}/g).join(':');
        var metaBody =
          renderRow(t.labelSerial, '<span class="scd-mono">' + escapeHtml(serialFormatted) + '</span>', serialFormatted) +
          renderRow(t.labelVersion, escapeHtml('v' + cert.version));
        html += renderCard('Metadata', metaBody);

        return html;
      }

      // ── State & wiring ──────────────────────────────────────────────
      var inputEl = document.getElementById('scd-input');
      var statusEl = document.getElementById('scd-status');
      var resultsEl = document.getElementById('scd-results');
      var btnDecode = document.getElementById('scd-decode');
      var btnExample = document.getElementById('scd-example');
      var btnClear = document.getElementById('scd-clear');

      function setStatus(msg, type) {
        statusEl.textContent = msg || '';
        statusEl.className = 'tool-status ' + (type || 'none');
      }

      async function runDecode() {
        var input = inputEl.value.trim();
        resultsEl.hidden = true;
        resultsEl.innerHTML = '';
        if (!input) { setStatus(t.errEmpty, 'error'); return; }
        if (input.indexOf('-----BEGIN CERTIFICATE-----') === -1) {
          setStatus(t.errNoMarkers, 'error');
          return;
        }
        var pems = extractPemCerts(input);
        if (!pems.length) { setStatus(t.errNoMarkers, 'error'); return; }
        var b64 = pems[0];
        var der;
        try { der = base64ToBytes(b64); }
        catch (e) { setStatus(t.errBase64, 'error'); return; }
        var cert;
        try { cert = decodeCertificate(der); }
        catch (e) { setStatus(t.errAsn1 + (e && e.message ? e.message : String(e)), 'error'); return; }
        try {
          var sha256, sha1;
          if (crypto && crypto.subtle) {
            sha256 = await digest('SHA-256', der);
            sha1 = await digest('SHA-1', der);
          } else {
            sha256 = '—';
            sha1 = '—';
          }
          var md = md5(der);
          var fps = { sha256: sha256, sha1: sha1, md5: md };
          resultsEl.innerHTML = render(cert, fps);
          resultsEl.hidden = false;
          if (pems.length > 1) {
            setStatus(t.bundleNotice.replace('{n}', pems.length), 'info');
          } else {
            setStatus(t.decoded, 'success');
          }
          wireCopyButtons();
        } catch (e) {
          setStatus(t.errUnexpected + (e && e.message ? e.message : String(e)), 'error');
        }
      }

      function wireCopyButtons() {
        resultsEl.querySelectorAll('.scd-copy').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var v = btn.getAttribute('data-copy') || '';
            if (!v) return;
            try {
              navigator.clipboard.writeText(v).then(function () {
                var original = btn.textContent;
                btn.classList.add('copied');
                btn.textContent = t.copied;
                setTimeout(function () { btn.classList.remove('copied'); btn.textContent = original; }, 1400);
              });
            } catch (e) {}
          });
        });
      }

      btnDecode.addEventListener('click', runDecode);
      btnExample.addEventListener('click', function () {
        inputEl.value = EXAMPLE_PEM;
        setStatus('', 'none');
      });
      btnClear.addEventListener('click', function () {
        inputEl.value = '';
        resultsEl.hidden = true;
        resultsEl.innerHTML = '';
        setStatus('', 'none');
        if (window.ztPersist) {
          try { window.ztPersist.clear('ssl-certificate-decoder'); } catch (e) {}
        }
      });

      inputEl.addEventListener('keydown', function (e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); runDecode(); }
      });

      // Persist input via global ztPersist API (policy: input, default).
      if (window.ztPersist) {
        try {
          var saved = window.ztPersist.load('ssl-certificate-decoder');
          if (saved && typeof saved === 'string') inputEl.value = saved;
        } catch (e) {}
        inputEl.addEventListener('input', function () {
          try { window.ztPersist.save('ssl-certificate-decoder', inputEl.value); } catch (e) {}
        });
      }
    })();
  </script>

  <style is:global>
    .scd-wrap {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .scd-input-section {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .scd-input {
      min-height: 200px;
    }
    .scd-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .scd-results {
      display: grid;
      gap: 0.75rem;
    }
    .scd-grid-2 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    @media (min-width: 720px) {
      .scd-grid-2 {
        grid-template-columns: 1fr 1fr;
      }
    }
    .scd-card {
      background: var(--color-surface);
      border-radius: var(--radius-lg);
      padding: 0.9rem 1rem;
      box-shadow: inset 0 0 0 1px var(--color-border-soft), var(--shadow-card);
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      min-width: 0;
    }
    .scd-card-title {
      margin: 0;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-primary);
    }
    .scd-card-body {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      min-width: 0;
    }
    .scd-row {
      display: flex;
      gap: 0.7rem;
      align-items: center;
      flex-wrap: wrap;
      padding: 0.4rem 0.6rem;
      border-radius: var(--radius-md);
      background: var(--color-bg-secondary);
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
      min-width: 0;
    }
    .scd-row--muted {
      color: var(--color-text-muted);
      font-style: italic;
    }
    .scd-row-label {
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--color-text-secondary);
      flex: 0 0 auto;
      min-width: 7rem;
    }
    .scd-row-value {
      flex: 1 1 auto;
      min-width: 0;
      font-size: 0.88rem;
      color: var(--color-text);
      word-break: break-all;
      overflow-wrap: anywhere;
    }
    .scd-mono {
      font-family: var(--font-mono);
      font-size: 0.82rem;
    }
    .scd-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.18rem 0.6rem;
      border-radius: var(--radius-pill);
      font-size: 0.78rem;
      font-weight: 700;
      box-shadow: inset 0 0 0 1px color-mix(in oklch, currentColor 35%, transparent);
      background: color-mix(in oklch, currentColor 12%, transparent);
    }
    .scd-status-valid { color: var(--color-success); }
    .scd-status-expired { color: var(--color-danger); }
    .scd-status-soon { color: var(--color-accent); }
    .scd-status-future { color: var(--color-text-muted); }
    .scd-chip {
      display: inline-flex;
      align-items: center;
      padding: 0.2rem 0.65rem;
      border-radius: var(--radius-pill);
      background: var(--color-bg-secondary);
      color: var(--color-text-secondary);
      font-size: 0.82rem;
      font-weight: 600;
      margin-right: 0.35rem;
      margin-bottom: 0.3rem;
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
    }
    .scd-copy {
      flex: 0 0 auto;
    }
    @media (max-width: 640px) {
      .scd-row-label {
        min-width: 0;
        flex: 0 0 100%;
      }
    }
  </style>
</div>
