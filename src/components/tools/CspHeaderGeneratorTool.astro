          copy: 'コピー', copied: 'コピーしました！',
          removeDirective: 'ディレクティブを削除', removeSource: 'ソースを削除',
          poolKeywords: 'キーワード', poolSchemes: 'スキーム', poolHosts: 'ホスト・nonce',
