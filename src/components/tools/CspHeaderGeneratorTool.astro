          modeLabel: '모드', modeEnforce: '강제 Enforce', modeReport: '보고만 Report-Only',
          resetBtn: '프리셋으로 재설정', addDirectiveLabel: '지시문 추가', addDirectiveBtn: '+ 추가',
          upgradeInsecure: 'upgrade-insecure-requests', blockAllMixed: 'block-all-mixed-content',
          hashCalcTitle: '인라인 스크립트 / 스타일 해시 계산기',
          hashInputPh: '<script>...<\/script> 또는 <style>...<\/style> 안의 내용을 붙여넣으세요',
          hashAlgoLabel: '알고리즘', hashTargetLabel: '추가 대상', hashAddBtn: '계산 후 추가',
          hashEmpty: '해시가 여기에 표시됩니다',
          formatHeader: 'HTTP 헤더', formatMeta: 'HTML <meta>', formatExpress: 'Express (helmet)', formatNginx: 'Nginx',
          copy: '복사', copied: '복사됨!',
          removeDirective: '지시문 제거', removeSource: '소스 제거',
          poolKeywords: '키워드', poolSchemes: '스킴', poolHosts: '호스트 및 nonce',
          inputPlaceholder: 'https://cdn.example.com',
          addBtn: '추가', addNonceBtn: '+ nonce',
          warnNoneAlone: "'none'은 단독 사용만 유효합니다. 다른 소스가 있으면 무시됩니다.",
          warnInlineHash: "해시 또는 nonce가 있으면 최신 브라우저는 'unsafe-inline'을 무시합니다.",
          warnFrameAncestorsMeta: 'frame-ancestors는 <meta>에서 무시되므로 HTTP 헤더로 전송해야 합니다.',
          warnReportMeta: 'report-uri / report-to는 <meta>에서 무시됩니다. HTTP 헤더에서만 유효합니다.',
          warnSandboxMeta: 'sandbox는 <meta>에서 무시됩니다. HTTP 헤더에서만 유효합니다.',
          warnNoDefault: 'default-src가 없으면 누락된 fetch 지시문에 대한 폴백이 적용되지 않습니다.',
          warnHttpScheme: 'http:는 비보안 리소스를 허용합니다. 프로덕션에서는 https:를 권장합니다.',
          warnUnsafeEval: "'unsafe-eval'은 eval(), Function(), setTimeout('string')을 허용합니다. 꼭 필요한 경우에만.",
          warnUnsafeInlineScript: "script-src의 'unsafe-inline'은 CSP의 핵심 XSS 방어를 무효화합니다. 해시 또는 nonce를 사용하세요.",
          warnEmpty: '정책을 생성하려면 최소 한 개의 지시문이 필요합니다.'
        }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var T = STRINGS[pageLang] || STRINGS.en;
      document.querySelectorAll('[data-i18n]').forEach(function (el) {
        var key = el.getAttribute('data-i18n');
        if (T[key]) el.textContent = T[key];
      });
      document.querySelectorAll('[data-i18n-ph]').forEach(function (el) {
        var key = el.getAttribute('data-i18n-ph');
        if (T[key]) el.placeholder = T[key];
      });

      var DIRECTIVE_DEFS = [
        { name: 'default-src', kind: 'fetch' },
        { name: 'script-src', kind: 'fetch' },
        { name: 'script-src-elem', kind: 'fetch' },
        { name: 'script-src-attr', kind: 'fetch' },
        { name: 'style-src', kind: 'fetch' },
        { name: 'style-src-elem', kind: 'fetch' },
        { name: 'style-src-attr', kind: 'fetch' },
        { name: 'img-src', kind: 'fetch' },
        { name: 'font-src', kind: 'fetch' },
        { name: 'connect-src', kind: 'fetch' },
        { name: 'media-src', kind: 'fetch' },
        { name: 'object-src', kind: 'fetch' },
        { name: 'frame-src', kind: 'fetch' },
        { name: 'child-src', kind: 'fetch' },
        { name: 'worker-src', kind: 'fetch' },
        { name: 'manifest-src', kind: 'fetch' },
        { name: 'prefetch-src', kind: 'fetch' },
        { name: 'frame-ancestors', kind: 'navigation' },
        { name: 'form-action', kind: 'navigation' },
        { name: 'base-uri', kind: 'document' },
        { name: 'navigate-to', kind: 'navigation' },
        { name: 'sandbox', kind: 'sandbox' },
        { name: 'report-uri', kind: 'report' },
        { name: 'report-to', kind: 'report' },
        { name: 'require-trusted-types-for', kind: 'tt' },
        { name: 'trusted-types', kind: 'tt' }
      ];

      var DIRECTIVE_INDEX = {};
      DIRECTIVE_DEFS.forEach(function (d) { DIRECTIVE_INDEX[d.name] = d; });

      var KEYWORDS_BY_KIND = {
        fetch: ["'self'", "'none'", "'unsafe-inline'", "'unsafe-eval'", "'strict-dynamic'", "'unsafe-hashes'", "'wasm-unsafe-eval'", "'report-sample'"],
        navigation: ["'self'", "'none'"],
        document: ["'self'", "'none'"],
        sandbox: ['allow-forms', 'allow-scripts', 'allow-same-origin', 'allow-popups', 'allow-modals', 'allow-downloads', 'allow-top-navigation', 'allow-orientation-lock'],
        report: [],
        tt: ["'none'", "'allow-duplicates'", "'script'"]
      };

      var SCHEMES = ['https:', 'http:', 'data:', 'blob:', 'mediastream:', 'filesystem:', 'wss:', 'ws:'];

      var PRESETS = {
        strict: {
          'default-src': ["'self'"],
          'script-src': ["'self'", "'strict-dynamic'"],
          'style-src': ["'self'"],
          'img-src': ["'self'", 'data:'],
          'font-src': ["'self'"],
          'connect-src': ["'self'"],
          'object-src': ["'none'"],
          'base-uri': ["'self'"],
          'form-action': ["'self'"],
          'frame-ancestors': ["'none'"]
        },
        moderate: {
          'default-src': ["'self'"],
          'script-src': ["'self'"],
          'style-src': ["'self'", "'unsafe-inline'"],
          'img-src': ["'self'", 'data:', 'https:'],
          'font-src': ["'self'", 'data:'],
          'connect-src': ["'self'"],
          'object-src': ["'none'"],
          'base-uri': ["'self'"],
          'frame-ancestors': ["'self'"]
        },
        basic: {
          'default-src': ["'self'"]
        },
        empty: {}
      };

      var PRESET_FLAGS = {
        strict: { upgrade: true, block: false },
        moderate: { upgrade: true, block: false },
        basic: { upgrade: false, block: false },
        empty: { upgrade: false, block: false }
      };

      // ── State ─────────────────────────────────────────────────────────
      var state = {
        preset: 'strict',
        mode: 'enforce',
        format: 'header',
        upgrade: true,
        block: false,
        directives: cloneDirectives(PRESETS.strict)
      };

      function cloneDirectives(src) {
        var out = {};
        Object.keys(src).forEach(function (k) { out[k] = src[k].slice(); });
        return out;
      }

      function applyPreset(name) {
        state.preset = name;
        state.directives = cloneDirectives(PRESETS[name] || {});
        state.upgrade = !!(PRESET_FLAGS[name] && PRESET_FLAGS[name].upgrade);
        state.block = !!(PRESET_FLAGS[name] && PRESET_FLAGS[name].block);
      }

      // ── Persistence ──────────────────────────────────────────────────
      function persist() {
        if (window.ztPersist && window.ztPersist.save) {
          window.ztPersist.save(SLUG, {
            preset: state.preset,
            mode: state.mode,
            upgrade: state.upgrade,
            block: state.block,
            directives: state.directives
          });
        }
      }
      function loadPersisted() {
        if (window.ztPersist && window.ztPersist.load) {
          var data = window.ztPersist.load(SLUG) || {};
          if (data && data.directives && typeof data.directives === 'object') {
            state.directives = {};
            Object.keys(data.directives).forEach(function (k) {
              if (Array.isArray(data.directives[k])) {
                state.directives[k] = data.directives[k].slice();
              }
            });
          }
          if (typeof data.preset === 'string' && PRESETS[data.preset]) state.preset = data.preset;
          if (data.mode === 'enforce' || data.mode === 'report-only') state.mode = data.mode;
          state.upgrade = !!data.upgrade;
          state.block = !!data.block;
        }
      }

      // ── DOM refs ─────────────────────────────────────────────────────
      var presetSel = document.getElementById('csp-preset');
      var modeBtns = document.querySelectorAll('.csp-mode-btn');
      var resetBtn = document.getElementById('csp-reset');
      var directivesEl = document.getElementById('csp-directives');
      var addSelect = document.getElementById('csp-add-select');
      var addBtn = document.getElementById('csp-add-btn');
      var flagUpgrade = document.getElementById('csp-flag-upgrade');
      var flagBlock = document.getElementById('csp-flag-block');
      var hashInput = document.getElementById('csp-hash-input');
      var hashAlgo = document.getElementById('csp-hash-algo');
      var hashTarget = document.getElementById('csp-hash-target');
      var hashAddBtn = document.getElementById('csp-hash-add');
      var hashValueEl = document.getElementById('csp-hash-value');
      var hashCopyBtn = document.getElementById('csp-hash-copy');
      var tabBtns = document.querySelectorAll('.csp-tab');
      var outputEl = document.getElementById('csp-output');
      var copyBtn = document.getElementById('csp-copy');
      var validationEl = document.getElementById('csp-validation');

      // ── Renderers ────────────────────────────────────────────────────
      function renderAddSelect() {
        addSelect.innerHTML = '';
        DIRECTIVE_DEFS.forEach(function (d) {
          if (state.directives[d.name]) return;
          var opt = document.createElement('option');
          opt.value = d.name;
          opt.textContent = d.name;
          addSelect.appendChild(opt);
        });
        addBtn.disabled = addSelect.options.length === 0;
      }

      function classForSource(src) {
        if (/^'sha(256|384|512)-/.test(src)) return 'is-hash';
        if (/^'nonce-/.test(src)) return 'is-nonce';
        if (/^'[^']+'$/.test(src)) return 'is-keyword';
        return '';
      }

      function escapeHtml(s) {
        return String(s).replace(/[&<>"]/g, function (c) {
          return c === '&' ? '&amp;' : c === '<' ? '&lt;' : c === '>' ? '&gt;' : '&quot;';
        });
      }

      function renderDirectives() {
        directivesEl.innerHTML = '';
        var names = Object.keys(state.directives);
        names.forEach(function (name) {
          var def = DIRECTIVE_INDEX[name] || { name: name, kind: 'fetch' };
          var card = document.createElement('div');
          card.className = 'csp-directive';
          card.dataset.directive = name;

          var head = document.createElement('div');
          head.className = 'csp-directive-head';
          var nameEl = document.createElement('span');
          nameEl.className = 'csp-directive-name';
          nameEl.textContent = name;
          var removeBtn = document.createElement('button');
          removeBtn.type = 'button';
          removeBtn.className = 'csp-directive-remove';
          removeBtn.setAttribute('aria-label', T.removeDirective);
          removeBtn.textContent = '×';
          removeBtn.addEventListener('click', function () {
            delete state.directives[name];
            renderAll();
            update();
          });
          head.appendChild(nameEl);
          head.appendChild(removeBtn);
          card.appendChild(head);

          // Selected sources
          var sourceList = document.createElement('div');
          sourceList.className = 'csp-source-list';
          (state.directives[name] || []).forEach(function (src, idx) {
            var tag = document.createElement('span');
            tag.className = 'csp-source-tag ' + classForSource(src);
            var text = document.createElement('span');
            text.className = 'csp-source-tag-text';
            text.textContent = src;
            var rm = document.createElement('button');
            rm.type = 'button';
            rm.className = 'csp-source-remove';
            rm.setAttribute('aria-label', T.removeSource);
            rm.textContent = '×';
            rm.addEventListener('click', function () {
              state.directives[name].splice(idx, 1);
              renderAll();
              update();
            });
            tag.appendChild(text);
            tag.appendChild(rm);
            sourceList.appendChild(tag);
          });
          card.appendChild(sourceList);

          // Keyword pool
          var keywords = KEYWORDS_BY_KIND[def.kind] || [];
          if (keywords.length > 0) {
            var kwRow = document.createElement('div');
            kwRow.className = 'csp-pool-row';
            var kwLabel = document.createElement('span');
            kwLabel.className = 'csp-pool-label';
            kwLabel.textContent = def.kind === 'sandbox' ? 'sandbox tokens' : T.poolKeywords;
            kwRow.appendChild(kwLabel);
            var kwPool = document.createElement('div');
            kwPool.className = 'csp-keyword-pool';
            keywords.forEach(function (kw) {
              var chip = document.createElement('button');
              chip.type = 'button';
              chip.className = 'csp-keyword-chip';
              chip.textContent = kw;
              if ((state.directives[name] || []).indexOf(kw) >= 0) chip.disabled = true;
              chip.addEventListener('click', function () {
                addSource(name, kw);
              });
              kwPool.appendChild(chip);
            });
            kwRow.appendChild(kwPool);
            card.appendChild(kwRow);
          }

          // Scheme pool (only fetch directives)
          if (def.kind === 'fetch') {
            var schRow = document.createElement('div');
            schRow.className = 'csp-pool-row';
            var schLabel = document.createElement('span');
            schLabel.className = 'csp-pool-label';
            schLabel.textContent = T.poolSchemes;
            schRow.appendChild(schLabel);
            var schPool = document.createElement('div');
            schPool.className = 'csp-keyword-pool';
            SCHEMES.forEach(function (s) {
              var chip = document.createElement('button');
              chip.type = 'button';
              chip.className = 'csp-keyword-chip';
              chip.textContent = s;
              if ((state.directives[name] || []).indexOf(s) >= 0) chip.disabled = true;
              chip.addEventListener('click', function () {
                addSource(name, s);
              });
              schPool.appendChild(chip);
            });
            schRow.appendChild(schPool);
            card.appendChild(schRow);
          }

          // Custom host / nonce input (skip pure tt directives)
          if (def.kind !== 'tt') {
            var hostRow = document.createElement('div');
            hostRow.className = 'csp-pool-row';
            var hostLabel = document.createElement('span');
            hostLabel.className = 'csp-pool-label';
            hostLabel.textContent = def.kind === 'report' ? 'URLs / group' : T.poolHosts;
            hostRow.appendChild(hostLabel);

            var addRow = document.createElement('div');
            addRow.className = 'csp-source-add-row';
            var input = document.createElement('input');
            input.type = 'text';
            input.className = 'csp-source-input';
            input.placeholder = def.kind === 'report' ? '/csp-reports' : T.inputPlaceholder;
            input.spellcheck = false;

            var addHostBtn = document.createElement('button');
            addHostBtn.type = 'button';
            addHostBtn.className = 'csp-source-add-btn';
            addHostBtn.textContent = T.addBtn;
            addHostBtn.addEventListener('click', function () {
              if (!input.value.trim()) return;
              addSource(name, input.value.trim());
              input.value = '';
              input.focus();
            });
            input.addEventListener('keydown', function (ev) {
              if (ev.key === 'Enter') {
                ev.preventDefault();
                addHostBtn.click();
              }
            });
            addRow.appendChild(input);
            addRow.appendChild(addHostBtn);

            if (def.kind === 'fetch') {
              var nonceBtn = document.createElement('button');
              nonceBtn.type = 'button';
              nonceBtn.className = 'csp-source-add-btn';
              nonceBtn.textContent = T.addNonceBtn;
              nonceBtn.addEventListener('click', function () {
                addSource(name, "'nonce-" + randomNonce() + "'");
              });
              addRow.appendChild(nonceBtn);
            }

            hostRow.appendChild(addRow);
            card.appendChild(hostRow);
          }

          directivesEl.appendChild(card);
        });
      }

      function addSource(name, value) {
        var raw = String(value).trim();
        if (!raw) return;
        if (raw.indexOf(';') >= 0) {
          showStatus(T.warnEmpty, 'error');
          return;
        }
        state.directives[name] = state.directives[name] || [];
        if (state.directives[name].indexOf(raw) >= 0) return;
        state.directives[name].push(raw);
        renderDirectives();
        renderAddSelect();
        update();
      }

      function randomNonce() {
        var bytes = new Uint8Array(16);
        (window.crypto || window.msCrypto).getRandomValues(bytes);
        var bin = '';
        for (var i = 0; i < bytes.length; i++) bin += String.fromCharCode(bytes[i]);
        return btoa(bin).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
      }

      function buildPolicy(forMeta) {
        var entries = [];
        Object.keys(state.directives).forEach(function (name) {
          var def = DIRECTIVE_INDEX[name];
          if (forMeta && def && (name === 'frame-ancestors' || name === 'sandbox' || name === 'report-uri' || name === 'report-to')) {
            return;
          }
          var sources = state.directives[name] || [];
          if (sources.length === 0 && name !== 'sandbox') return;
          entries.push(name + (sources.length ? ' ' + sources.join(' ') : ''));
        });
        if (state.upgrade) entries.push('upgrade-insecure-requests');
        if (state.block) entries.push('block-all-mixed-content');
        return entries.join('; ');
      }

      function buildOutput(format) {
        var policyHeader = buildPolicy(false);
        var policyMeta = buildPolicy(true);
        if (!policyHeader) return T.warnEmpty;
        var headerName = state.mode === 'report-only' ? 'Content-Security-Policy-Report-Only' : 'Content-Security-Policy';

        if (format === 'header') {
          return headerName + ': ' + policyHeader;
        }
        if (format === 'meta') {
          if (state.mode === 'report-only') {
            return '<!-- Report-Only mode is not available in <meta>. Send as HTTP header instead. -->\n' +
              '<meta http-equiv="Content-Security-Policy" content="' + escapeAttr(policyMeta) + '">';
          }
          return '<meta http-equiv="Content-Security-Policy" content="' + escapeAttr(policyMeta) + '">';
        }
        if (format === 'express') {
          var helmet = "// npm install helmet\n" +
            "const helmet = require('helmet');\n\n" +
            "app.use(helmet.contentSecurityPolicy({\n" +
            "  useDefaults: false,\n" +
            "  reportOnly: " + (state.mode === 'report-only' ? 'true' : 'false') + ",\n" +
            "  directives: " + JSON.stringify(buildHelmetDirectives(), null, 2).replace(/\n/g, '\n    ') + "\n" +
            "}));";
          return helmet;
        }
        if (format === 'nginx') {
          return 'add_header ' + headerName + ' "' + policyHeader.replace(/"/g, '\\"') + '" always;';
        }
        return '';
      }

      function buildHelmetDirectives() {
        var out = {};
        Object.keys(state.directives).forEach(function (name) {
          var sources = state.directives[name] || [];
          out[name] = sources.length ? sources : [];
        });
        if (state.upgrade) out['upgrade-insecure-requests'] = [];
        if (state.block) out['block-all-mixed-content'] = [];
        return out;
      }

      function escapeAttr(s) {
        return String(s).replace(/"/g, '&quot;');
      }

      function renderTabs() {
        tabBtns.forEach(function (btn) {
          var active = btn.getAttribute('data-format') === state.format;
          btn.classList.toggle('is-active', active);
          btn.setAttribute('aria-selected', active ? 'true' : 'false');
        });
      }

      function renderOutput() {
        var text = buildOutput(state.format);
        outputEl.textContent = text;
        copyBtn.disabled = !text || text === T.warnEmpty;
      }

      function renderValidation() {
        validationEl.innerHTML = '';
        var warns = [];
        var names = Object.keys(state.directives);
        if (names.length === 0) {
          warns.push({ level: 'info', text: T.warnEmpty });
        }
        if (!state.directives['default-src']) {
          warns.push({ level: 'info', text: T.warnNoDefault });
        }
        names.forEach(function (n) {
          var sources = state.directives[n] || [];
          if (sources.indexOf("'none'") >= 0 && sources.length > 1) {
            warns.push({ level: 'warn', text: n + ': ' + T.warnNoneAlone });
          }
          var hasHash = sources.some(function (s) { return /^'(sha256|sha384|sha512)-/.test(s); });
          var hasNonce = sources.some(function (s) { return /^'nonce-/.test(s); });
          if (sources.indexOf("'unsafe-inline'") >= 0 && (hasHash || hasNonce)) {
            warns.push({ level: 'info', text: n + ': ' + T.warnInlineHash });
          }
          if (n === 'script-src' && sources.indexOf("'unsafe-inline'") >= 0 && !hasHash && !hasNonce) {
            warns.push({ level: 'warn', text: T.warnUnsafeInlineScript });
          }
          if (sources.indexOf("'unsafe-eval'") >= 0) {
            warns.push({ level: 'info', text: n + ': ' + T.warnUnsafeEval });
          }
          if (sources.indexOf('http:') >= 0) {
            warns.push({ level: 'info', text: n + ': ' + T.warnHttpScheme });
          }
        });
        if (state.format === 'meta') {
          if (state.directives['frame-ancestors']) warns.push({ level: 'warn', text: T.warnFrameAncestorsMeta });
          if (state.directives['report-uri'] || state.directives['report-to']) warns.push({ level: 'warn', text: T.warnReportMeta });
          if (state.directives['sandbox']) warns.push({ level: 'warn', text: T.warnSandboxMeta });
        }
        warns.forEach(function (w) {
          var item = document.createElement('li');
          item.className = 'csp-validation-item ' + (w.level === 'warn' ? 'is-warn' : 'is-info');
          item.textContent = (w.level === 'warn' ? '⚠ ' : 'ℹ ') + w.text;
          validationEl.appendChild(item);
        });
      }

      function renderAll() {
        presetSel.value = state.preset;
        modeBtns.forEach(function (btn) {
          var active = btn.getAttribute('data-mode') === state.mode;
          btn.classList.toggle('is-active', active);
          btn.setAttribute('aria-checked', active ? 'true' : 'false');
        });
        flagUpgrade.checked = !!state.upgrade;
        flagBlock.checked = !!state.block;
        renderDirectives();
        renderAddSelect();
        renderTabs();
      }

      function update() {
        renderOutput();
        renderValidation();
        persist();
        if (window.trackTool) window.trackTool('csp-header-generator', 'generate');
      }

      function showStatus(msg, level) {
        var el = document.getElementById('csp-status');
        if (!el) return;
        el.textContent = msg || '';
        el.className = 'tool-status ' + (level || 'none');
        if (msg) {
          window.setTimeout(function () { el.textContent = ''; el.className = 'tool-status none'; }, 3000);
        }
      }

      // ── Hash calculator ──────────────────────────────────────────────
      var lastHash = '';
      hashInput.addEventListener('input', function () {
        if (lastHash) {
          lastHash = '';
          hashValueEl.textContent = T.hashEmpty;
          hashCopyBtn.disabled = true;
        }
        hashAddBtn.disabled = !hashInput.value;
      });

      async function computeHash() {
        var algo = hashAlgo.value;
        var content = hashInput.value;
        if (!content) return;
        var encoder = new TextEncoder();
        var data = encoder.encode(content);
        var digest = await window.crypto.subtle.digest(algo, data);
        var bytes = new Uint8Array(digest);
        var bin = '';
        for (var i = 0; i < bytes.length; i++) bin += String.fromCharCode(bytes[i]);
        var b64 = btoa(bin);
        var prefix = algo.toLowerCase().replace('-', '');
        return "'" + prefix + '-' + b64 + "'";
      }

      hashAddBtn.addEventListener('click', async function () {
        try {
          var value = await computeHash();
          if (!value) return;
          lastHash = value;
          hashValueEl.textContent = value;
          hashCopyBtn.disabled = false;
          var target = hashTarget.value;
          if (!state.directives[target]) state.directives[target] = ["'self'"];
          addSource(target, value);
        } catch (e) {
          showStatus('Hash failed: ' + e.message, 'error');
        }
      });

      function attachCopy(btn, getter) {
        btn.addEventListener('click', async function () {
          var value = getter();
          if (!value) return;
          try {
            await navigator.clipboard.writeText(value);
            var original = btn.textContent;
            btn.classList.add('copied');
            btn.textContent = T.copied;
            window.setTimeout(function () {
              btn.classList.remove('copied');
              btn.textContent = original;
            }, 1500);
          } catch (e) {
            showStatus('Copy failed.', 'error');
          }
        });
      }

      attachCopy(copyBtn, function () { return outputEl.textContent || ''; });
      attachCopy(hashCopyBtn, function () { return lastHash; });

      // ── Wiring ───────────────────────────────────────────────────────
      presetSel.addEventListener('change', function () {
        applyPreset(presetSel.value);
        renderAll();
        update();
      });

      modeBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          state.mode = btn.getAttribute('data-mode');
          renderAll();
          update();
        });
      });

      resetBtn.addEventListener('click', function () {
        applyPreset(state.preset);
        renderAll();
        update();
      });

      addBtn.addEventListener('click', function () {
        var name = addSelect.value;
        if (!name || state.directives[name]) return;
        state.directives[name] = name === 'sandbox' ? [] : ["'self'"];
        renderAll();
        update();
      });

      flagUpgrade.addEventListener('change', function () {
        state.upgrade = flagUpgrade.checked;
        update();
      });
      flagBlock.addEventListener('change', function () {
        state.block = flagBlock.checked;
        update();
      });

      tabBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          state.format = btn.getAttribute('data-format');
          renderTabs();
          renderOutput();
          renderValidation();
        });
      });

      // ── Boot ─────────────────────────────────────────────────────────
      loadPersisted();
      if (Object.keys(state.directives).length === 0) {
        applyPreset('strict');
      }
      renderAll();
      update();
    })();
  </script>
</div>
