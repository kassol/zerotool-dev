---
// CspHeaderGeneratorTool — interactive Content-Security-Policy builder
// Output: HTTP header, HTML <meta>, Express (helmet), Nginx add_header.
// Pure DOM + Web Crypto API for hash calculation. No npm runtime deps.
---
<div>
  <div class="csp-wrap">

    <div class="csp-toolbar">
      <div class="csp-toolbar-row">
        <label class="csp-toolbar-field">
          <span class="tool-label" data-i18n="presetLabel">Preset</span>
          <select id="csp-preset" class="csp-select">
            <option value="strict" data-i18n="presetStrict">Strict (recommended)</option>
            <option value="moderate" data-i18n="presetModerate">Moderate</option>
            <option value="basic" data-i18n="presetBasic">Basic</option>
            <option value="empty" data-i18n="presetEmpty">Empty (start blank)</option>
          </select>
        </label>

        <div class="csp-toolbar-field">
          <span class="tool-label" data-i18n="modeLabel">Mode</span>
          <div class="csp-mode-toggle" role="radiogroup" aria-label="CSP mode">
            <button type="button" class="csp-mode-btn is-active" data-mode="enforce" role="radio" aria-checked="true" data-i18n="modeEnforce">Enforce</button>
            <button type="button" class="csp-mode-btn" data-mode="report-only" role="radio" aria-checked="false" data-i18n="modeReport">Report-Only</button>
          </div>
        </div>

        <div class="csp-toolbar-actions">
          <button type="button" id="csp-reset" class="btn-secondary" data-i18n="resetBtn">Reset to preset</button>
        </div>
      </div>
    </div>

    <div id="csp-directives" class="csp-directive-grid" aria-live="polite"></div>

    <div class="csp-add-row">
      <label class="csp-toolbar-field csp-add-field">
        <span class="tool-label" data-i18n="addDirectiveLabel">Add directive</span>
        <select id="csp-add-select" class="csp-select"></select>
      </label>
      <button type="button" id="csp-add-btn" class="btn-secondary" data-i18n="addDirectiveBtn">+ Add</button>
    </div>

    <div class="csp-flag-row">
      <label class="csp-flag">
        <input type="checkbox" id="csp-flag-upgrade" />
        <span data-i18n="upgradeInsecure">upgrade-insecure-requests</span>
      </label>
      <label class="csp-flag">
        <input type="checkbox" id="csp-flag-block" />
        <span data-i18n="blockAllMixed">block-all-mixed-content</span>
      </label>
    </div>

    <details class="csp-section">
      <summary class="csp-section-summary">
        <span data-i18n="hashCalcTitle">Inline script &amp; style hash calculator</span>
      </summary>
      <div class="csp-section-body">
        <textarea
          id="csp-hash-input"
          class="tool-textarea"
          rows="3"
          data-i18n-ph="hashInputPh"
          placeholder="Paste the exact contents between &lt;script&gt;...&lt;/script&gt; or &lt;style&gt;...&lt;/style&gt;"
          spellcheck="false"
        ></textarea>
        <div class="csp-hash-controls">
          <label class="csp-toolbar-field">
            <span class="tool-label" data-i18n="hashAlgoLabel">Algorithm</span>
            <select id="csp-hash-algo" class="csp-select">
              <option value="SHA-256">sha256</option>
              <option value="SHA-384">sha384</option>
              <option value="SHA-512">sha512</option>
            </select>
          </label>
          <label class="csp-toolbar-field">
            <span class="tool-label" data-i18n="hashTargetLabel">Add to</span>
            <select id="csp-hash-target" class="csp-select">
              <option value="script-src">script-src</option>
              <option value="style-src">style-src</option>
            </select>
          </label>
          <div class="csp-hash-actions">
            <button type="button" id="csp-hash-add" class="btn-primary" disabled data-i18n="hashAddBtn">Compute &amp; add</button>
          </div>
        </div>
        <div class="csp-hash-output">
          <code id="csp-hash-value" class="csp-hash-value" data-i18n="hashEmpty">Hash will appear here</code>
          <button type="button" id="csp-hash-copy" class="btn-copy" disabled data-i18n="copy">Copy</button>
        </div>
      </div>
    </details>

    <div class="csp-output">
      <div class="csp-tab-row" role="tablist">
        <button type="button" class="csp-tab is-active" data-format="header" role="tab" aria-selected="true" data-i18n="formatHeader">HTTP header</button>
        <button type="button" class="csp-tab" data-format="meta" role="tab" aria-selected="false" data-i18n="formatMeta">HTML &lt;meta&gt;</button>
        <button type="button" class="csp-tab" data-format="express" role="tab" aria-selected="false" data-i18n="formatExpress">Express (helmet)</button>
        <button type="button" class="csp-tab" data-format="nginx" role="tab" aria-selected="false" data-i18n="formatNginx">Nginx</button>
      </div>
      <div class="csp-output-panel">
        <pre id="csp-output" class="csp-output-pre" tabindex="0"></pre>
        <button type="button" id="csp-copy" class="btn-copy" disabled data-i18n="copy">Copy</button>
      </div>
    </div>

    <div id="csp-validation" class="csp-validation" aria-live="polite"></div>
    <div id="csp-status" class="tool-status" aria-live="polite"></div>
  </div>

  <style is:global>
    .csp-wrap {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .csp-toolbar,
    .csp-section,
    .csp-output {
      background: var(--color-bg-secondary);
      border-radius: var(--radius-md);
      padding: 0.95rem 1rem;
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
    }

    .csp-toolbar-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: flex-end;
    }
    .csp-toolbar-field {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      min-width: 0;
    }
    .csp-toolbar-actions {
      margin-left: auto;
    }
    .csp-add-field { flex: 1 1 220px; }

    .csp-select {
      min-height: 40px;
      padding: 0.5rem 0.75rem;
      border-radius: var(--radius-md);
      border: 0;
      background: var(--color-surface);
      color: var(--color-text);
      font-family: var(--font-sans);
      font-size: 0.9rem;
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
      transition: background-color var(--transition-fast), box-shadow var(--transition-fast);
    }
    .csp-select:focus {
      outline: none;
      box-shadow: inset 0 0 0 1px var(--color-primary), 0 0 0 4px var(--color-primary-light);
    }

    .csp-mode-toggle {
      display: inline-flex;
      gap: 0.25rem;
      padding: 0.25rem;
      border-radius: var(--radius-pill);
      background: var(--color-surface-muted);
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
    }
    .csp-mode-btn {
      min-height: 32px;
      padding: 0.3rem 0.95rem;
      border: 0;
      background: transparent;
      color: var(--color-text-secondary);
      border-radius: var(--radius-pill);
      cursor: pointer;
      font-weight: 700;
      font-size: 0.82rem;
      transition: background-color var(--transition-fast), color var(--transition-fast);
    }
    .csp-mode-btn.is-active {
      background: var(--color-surface);
      color: var(--color-primary);
      box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--color-primary) 45%, transparent);
    }
    @media (hover: hover) {
      .csp-mode-btn:hover:not(.is-active) { color: var(--color-text); }
    }

    .csp-directive-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
      gap: 0.85rem;
    }
    .csp-directive {
      background: var(--color-surface);
      border-radius: var(--radius-md);
      padding: 0.85rem 0.9rem;
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }
    .csp-directive-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }
    .csp-directive-name {
      font-family: var(--font-mono);
      font-size: 0.92rem;
      font-weight: 700;
      color: var(--color-primary);
      word-break: break-all;
    }
    .csp-directive-remove {
      background: transparent;
      border: 0;
      color: var(--color-text-muted);
      cursor: pointer;
      padding: 0.2rem 0.45rem;
      border-radius: var(--radius-sm);
      font-size: 0.85rem;
      transition: color var(--transition-fast), background-color var(--transition-fast);
    }
    @media (hover: hover) {
      .csp-directive-remove:hover {
        color: var(--color-danger);
        background: var(--color-surface-muted);
      }
    }
    .csp-source-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .csp-source-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.3rem 0.55rem;
      border-radius: var(--radius-pill);
      background: var(--color-surface-muted);
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--color-text);
      max-width: 100%;
    }
    .csp-source-tag-text {
      overflow-wrap: anywhere;
    }
    .csp-source-tag.is-keyword {
      color: var(--color-primary);
      box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--color-primary) 45%, transparent);
      background: var(--color-primary-light);
    }
    .csp-source-tag.is-hash,    .csp-source-tag.is-nonce {
      color: var(--color-accent);
      box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--color-accent) 45%, transparent);
    }
    .csp-source-remove {
      background: transparent;
      border: 0;
      color: inherit;
      cursor: pointer;
      font-size: 0.85rem;
      padding: 0;
      line-height: 1;
      opacity: 0.65;
    }
    @media (hover: hover) {
      .csp-source-remove:hover { opacity: 1; }
    }
    .csp-source-add-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      align-items: center;
    }
    .csp-source-input {
      flex: 1 1 140px;
      min-width: 0;
      min-height: 32px;
      padding: 0.32rem 0.6rem;
      border: 0;
      border-radius: var(--radius-md);
      background: var(--color-bg-secondary);
      color: var(--color-text);
      font-family: var(--font-mono);
      font-size: 0.8rem;
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
    }
    .csp-source-input:focus {
      outline: none;
      background: var(--color-surface);
      box-shadow: inset 0 0 0 1px var(--color-primary), 0 0 0 4px var(--color-primary-light);
    }
    .csp-source-add-btn {
      min-height: 32px;
      padding: 0.25rem 0.7rem;
      font-size: 0.78rem;
      border: 0;
      background: var(--color-surface-muted);
      color: var(--color-text-secondary);
      border-radius: var(--radius-pill);
      cursor: pointer;
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
      font-weight: 700;
      white-space: nowrap;
      transition: background-color var(--transition-fast), color var(--transition-fast);
    }
    @media (hover: hover) {
      .csp-source-add-btn:hover {
        color: var(--color-primary);
        box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--color-primary) 45%, transparent);
      }
    }
    .csp-keyword-pool {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
    }
    .csp-keyword-chip {
      background: transparent;
      border: 0;
      padding: 0.2rem 0.55rem;
      font-family: var(--font-mono);
      font-size: 0.74rem;
      color: var(--color-text-muted);
      border-radius: var(--radius-pill);
      cursor: pointer;
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
      transition: color var(--transition-fast), box-shadow var(--transition-fast), background-color var(--transition-fast);
    }
    @media (hover: hover) {
      .csp-keyword-chip:hover:not(:disabled) {
        color: var(--color-primary);
        background: var(--color-primary-light);
        box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--color-primary) 45%, transparent);
      }
    }
    .csp-keyword-chip:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }
    .csp-pool-row {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .csp-pool-label {
      font-size: 0.72rem;
      color: var(--color-text-muted);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-weight: 700;
    }

    .csp-add-row {
      display: flex;
      gap: 0.6rem;
      align-items: flex-end;
      flex-wrap: wrap;
    }

    .csp-flag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem 1.4rem;
      padding: 0.4rem 0.2rem 0;
      font-size: 0.85rem;
    }
    .csp-flag {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      cursor: pointer;
      color: var(--color-text-secondary);
      font-family: var(--font-mono);
    }

    .csp-section-summary {
      cursor: pointer;
      list-style: none;
      font-weight: 700;
      color: var(--color-text);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .csp-section-summary::-webkit-details-marker { display: none; }
    .csp-section-summary::after {
      content: '';
      width: 8px;
      height: 8px;
      border-right: 2px solid currentColor;
      border-bottom: 2px solid currentColor;
      transform: rotate(-45deg);
      transition: transform var(--transition-fast);
    }
    details[open] > .csp-section-summary::after {
      transform: rotate(45deg);
    }
    .csp-section-body {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      padding-top: 0.7rem;
    }
    .csp-hash-controls {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: flex-end;
    }
    .csp-hash-actions { margin-left: auto; }
    .csp-hash-output {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.5rem 0.6rem;
      background: var(--color-bg-secondary);
      border-radius: var(--radius-md);
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
      flex-wrap: wrap;
    }
    .csp-hash-value {
      flex: 1;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--color-text);
      word-break: break-all;
      min-width: 0;
    }

    .csp-tab-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-bottom: 0.6rem;
    }
    .csp-tab {
      min-height: 32px;
      padding: 0.3rem 0.85rem;
      border: 0;
      border-radius: var(--radius-pill);
      background: transparent;
      color: var(--color-text-secondary);
      font-weight: 700;
      font-size: 0.8rem;
      cursor: pointer;
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
      transition: background-color var(--transition-fast), color var(--transition-fast), box-shadow var(--transition-fast);
    }
    @media (hover: hover) {
      .csp-tab:hover:not(.is-active) { color: var(--color-text); }
    }
    .csp-tab.is-active {
      background: var(--color-primary-light);
      color: var(--color-primary);
      box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--color-primary) 45%, transparent);
    }

    .csp-output-panel {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .csp-output-pre {
      margin: 0;
      padding: 0.85rem 0.95rem;
      background: var(--color-surface);
      color: var(--color-text);
      font-family: var(--font-mono);
      font-size: 0.85rem;
      line-height: 1.55;
      border-radius: var(--radius-md);
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      max-width: 100%;
    }

    .csp-validation {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .csp-validation-item {
      padding: 0.5rem 0.7rem;
      border-radius: var(--radius-md);
      font-size: 0.85rem;
      box-shadow: inset 0 0 0 1px var(--color-border-soft);
      background: var(--color-bg-secondary);
    }
    .csp-validation-item.is-warn {
      color: var(--color-danger);
      box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--color-danger) 45%, transparent);
      background: color-mix(in oklch, var(--color-danger) 8%, var(--color-bg-secondary));
    }
    .csp-validation-item.is-info {
      color: var(--color-text-secondary);
    }

    @media (max-width: 540px) {
      .csp-toolbar-row { gap: 0.7rem; }
      .csp-toolbar-actions { margin-left: 0; width: 100%; }
      .csp-toolbar-actions .btn-secondary { width: 100%; }
      .csp-mode-toggle { width: 100%; justify-content: stretch; }
      .csp-mode-btn { flex: 1; }
      .csp-hash-actions { margin-left: 0; width: 100%; }
      .csp-hash-actions .btn-primary { width: 100%; }
    }
  </style>

