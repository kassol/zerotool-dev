---
// No props needed — tool widget is language-independent
---

<div>
  <div class="cj-wrap">
    <div class="cj-panels">
      <div class="cj-panel">
        <label for="cj-csv">
          <span>CSV</span>
          <button id="cj-copy-csv" class="btn-copy" type="button" data-i18n="copy">Copy</button>
        </label>
        <textarea
          id="cj-csv"
          placeholder="name,age,city&#10;Alice,30,&quot;New York&quot;&#10;Bob,25,London"
          spellcheck="false"
        ></textarea>
      </div>
      <div class="cj-panel">
        <label for="cj-json">
          <span>JSON</span>
          <button id="cj-copy-json" class="btn-copy" type="button" data-i18n="copy">Copy</button>
        </label>
        <textarea
          id="cj-json"
          placeholder='[{"name":"Alice","age":"30","city":"New York"}]'
          spellcheck="false"
        ></textarea>
      </div>
    </div>

    <div class="cj-actions">
      <button id="cj-to-json" class="btn-primary" data-i18n="csvToJson">CSV → JSON</button>
      <button id="cj-to-csv" class="btn-primary" data-i18n="jsonToCsv">JSON → CSV</button>
      <button id="cj-clear" class="btn-ghost" data-i18n="clear">Clear</button>
    </div>

    <div class="cj-options">
      <label class="cj-checkbox-label">
        <input type="checkbox" id="cj-parse-types" checked />
        <span data-i18n="parseTypes">Parse numbers &amp; booleans</span>
      </label>
      <label class="cj-checkbox-label">
        <input type="checkbox" id="cj-empty-null" />
        <span data-i18n="emptyNull">Empty → null</span>
      </label>
    </div>

    <div id="cj-status" class="cj-status" aria-live="polite"></div>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: { copy: 'Copy', copied: 'Copied!', clear: 'Clear', csvToJson: 'CSV \u2192 JSON', jsonToCsv: 'JSON \u2192 CSV', convertedToJson: 'Converted {n} row{s} to JSON.', convertedToCsv: 'Converted {n} row{s} to CSV.', errorPrefix: 'Error: ', parseTypes: 'Parse numbers & booleans', emptyNull: 'Empty \u2192 null' },
        zh: { copy: '复制', copied: '已复制！', clear: '清除', csvToJson: 'CSV \u2192 JSON', jsonToCsv: 'JSON \u2192 CSV', convertedToJson: '已将 {n} 行转换为 JSON。', convertedToCsv: '已将 {n} 行转换为 CSV。', errorPrefix: '错误：', parseTypes: '推断数字和布尔值', emptyNull: '空字段 \u2192 null' },
        ja: { copy: 'コピー', copied: 'コピー済み！', clear: 'クリア', csvToJson: 'CSV \u2192 JSON', jsonToCsv: 'JSON \u2192 CSV', convertedToJson: '{n} 行を JSON に変換しました。', convertedToCsv: '{n} 行を CSV に変換しました。', errorPrefix: 'エラー：', parseTypes: '数値・真偽値を自動変換', emptyNull: '空フィールド \u2192 null' },
        ko: { copy: '복사', copied: '복사됨!', clear: '지우기', csvToJson: 'CSV \u2192 JSON', jsonToCsv: 'JSON \u2192 CSV', convertedToJson: '{n}행을 JSON으로 변환했습니다.', convertedToCsv: '{n}행을 CSV로 변환했습니다.', errorPrefix: '오류: ', parseTypes: '숫자 및 불리언 추론', emptyNull: '빈 필드 \u2192 null' }
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;

      document.querySelectorAll('.cj-wrap [data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n'); if (t[key]) el.textContent = t[key];
      });

      function rowMsg(tmpl, n) {
        return tmpl.replace('{n}', n).replace('{s}', n === 1 ? '' : 's');
      }

      var csvEl = document.getElementById('cj-csv');
      var jsonEl = document.getElementById('cj-json');
      var statusEl = document.getElementById('cj-status');
      var copyCsvBtn = document.getElementById('cj-copy-csv');
      var copyJsonBtn = document.getElementById('cj-copy-json');
      var parseTypesEl = document.getElementById('cj-parse-types');
      var emptyNullEl = document.getElementById('cj-empty-null');
      var lastValidJsonOutput = '';
      var lastValidCsvOutput = '';

      function escapeCsvField(val) {
        if (val.indexOf(',') !== -1 || val.indexOf('"') !== -1 || val.indexOf('\n') !== -1) {
          return '"' + val.replace(/"/g, '""') + '"';
        }
        return val;
      }

      function setStatus(msg, isError) {
        statusEl.textContent = msg;
        statusEl.className = 'cj-status ' + (isError ? 'error' : 'success');
      }

      function clearStatus() {
        statusEl.textContent = '';
        statusEl.className = 'cj-status';
      }

      /* ── Type inference for a single CSV field value ── */
      function inferValue(raw, quoted, parseTypes, emptyNull) {
        if (quoted) return raw;
        if (raw === '') return emptyNull ? null : raw;
        if (!parseTypes) return raw;
        var lo = raw.toLowerCase();
        if (lo === 'null') return null;
        if (lo === 'true') return true;
        if (lo === 'false') return false;
        /* number: reject leading-zero strings (e.g. "007", "0123") */
        if (raw.length > 1 && raw[0] === '0' && raw[1] !== '.' && raw[1] !== 'e' && raw[1] !== 'E') return raw;
        var n = Number(raw);
        if (!isNaN(n) && isFinite(n) && raw.trim() !== '') {
          /* reject integers that exceed safe range to avoid precision loss */
          if (Number.isInteger(n) && !Number.isSafeInteger(n)) return raw;
          return n;
        }
        return raw;
      }

      /* ── CSV parser: handles quoted fields; tracks per-field quoted status ── */
      function parseCsv(text) {
        var rows = [];
        var quotedFlags = []; /* parallel array: quotedFlags[r][c] === true when field was quoted */
        var row = [];
        var rowQ = [];
        var field = '';
        var wasQuoted = false;
        var inQuote = false;
        var i = 0;
        var len = text.length;

        while (i < len) {
          var ch = text[i];
          if (inQuote) {
            if (ch === '"') {
              if (i + 1 < len && text[i + 1] === '"') {
                field += '"';
                i += 2;
              } else {
                inQuote = false;
                i++;
              }
            } else {
              field += ch;
              i++;
            }
          } else {
            if (ch === '"') {
              inQuote = true;
              wasQuoted = true;
              i++;
            } else if (ch === ',') {
              row.push(field);
              rowQ.push(wasQuoted);
              field = '';
              wasQuoted = false;
              i++;
            } else if (ch === '\r') {
              row.push(field);
              rowQ.push(wasQuoted);
              field = '';
              wasQuoted = false;
              rows.push(row);
              quotedFlags.push(rowQ);
              row = [];
              rowQ = [];
              i++;
              if (i < len && text[i] === '\n') i++;
            } else if (ch === '\n') {
              row.push(field);
              rowQ.push(wasQuoted);
              field = '';
              wasQuoted = false;
              rows.push(row);
              quotedFlags.push(rowQ);
              row = [];
              rowQ = [];
              i++;
            } else {
              field += ch;
              i++;
            }
          }
        }

        /* last field / row */
        if (field || row.length > 0) {
          row.push(field);
          rowQ.push(wasQuoted);
          rows.push(row);
          quotedFlags.push(rowQ);
        }

        /* drop trailing empty row */
        if (rows.length > 0) {
          var last = rows[rows.length - 1];
          if (last.length === 1 && last[0] === '') {
            rows.pop();
            quotedFlags.pop();
          }
        }

        return { rows: rows, quotedFlags: quotedFlags };
      }

      function buildJsonFromCsv(raw) {
        var parsed = parseCsv(raw);
        var rows = parsed.rows;
        var quotedFlags = parsed.quotedFlags;
        if (rows.length < 2) throw new Error('CSV must have at least a header row and one data row.');
        var headers = rows[0];
        var parseTypes = parseTypesEl.checked;
        var emptyNull = emptyNullEl.checked;
        var result = [];
        for (var r = 1; r < rows.length; r++) {
          var obj = {};
          for (var c = 0; c < headers.length; c++) {
            var rawVal = rows[r][c] !== undefined ? rows[r][c] : '';
            var isQuoted = quotedFlags[r] ? !!quotedFlags[r][c] : false;
            obj[headers[c]] = inferValue(rawVal, isQuoted, parseTypes, emptyNull);
          }
          result.push(obj);
        }
        return result;
      }

      /* ── Real-time CSV → JSON (debounced 300ms) ── */
      var _csvLiveTimer = null;
      csvEl.addEventListener('input', function () {
        clearTimeout(_csvLiveTimer);
        _csvLiveTimer = setTimeout(function () {
          var raw = csvEl.value.trim();
          if (!raw) { clearStatus(); return; }
          try {
            var result = buildJsonFromCsv(raw);
            jsonEl.value = JSON.stringify(result, null, 2);
            lastValidJsonOutput = jsonEl.value;
            setStatus(rowMsg(t.convertedToJson, result.length), false);
          } catch (e) {
            setStatus(t.errorPrefix + e.message, true);
          }
        }, 300);
      });

      /* re-run live conversion when options change */
      parseTypesEl.addEventListener('change', function () {
        if (csvEl.value.trim()) csvEl.dispatchEvent(new Event('input'));
      });
      emptyNullEl.addEventListener('change', function () {
        if (csvEl.value.trim()) csvEl.dispatchEvent(new Event('input'));
      });

      /* ── Real-time JSON → CSV (debounced 300ms) ── */
      var _jsonLiveTimer = null;
      jsonEl.addEventListener('input', function () {
        clearTimeout(_jsonLiveTimer);
        _jsonLiveTimer = setTimeout(function () {
          var raw = jsonEl.value.trim();
          if (!raw) { clearStatus(); return; }
          try {
            var data = JSON.parse(raw);
            if (!Array.isArray(data)) throw new Error('JSON must be an array of objects.');
            if (data.length === 0) throw new Error('JSON array is empty.');
            if (typeof data[0] !== 'object' || data[0] === null || Array.isArray(data[0])) {
              throw new Error('Each item must be a plain object.');
            }
            var headers = Object.keys(data[0]);
            var lines = [];
            lines.push(headers.map(escapeCsvField).join(','));
            for (var i = 0; i < data.length; i++) {
              var row = [];
              for (var h = 0; h < headers.length; h++) {
                var val = data[i][headers[h]];
                row.push(escapeCsvField(val == null ? '' : String(val)));
              }
              lines.push(row.join(','));
            }
            csvEl.value = lines.join('\n');
            lastValidCsvOutput = csvEl.value;
            setStatus(rowMsg(t.convertedToCsv, data.length), false);
          } catch (e) {
            setStatus(t.errorPrefix + e.message, true);
          }
        }, 300);
      });

      /* ── CSV → JSON button ── */
      document.getElementById('cj-to-json').addEventListener('click', function () {
        var raw = csvEl.value.trim();
        if (!raw) { clearStatus(); return; }
        try {
          var result = buildJsonFromCsv(raw);
          jsonEl.value = JSON.stringify(result, null, 2);
          lastValidJsonOutput = jsonEl.value;
          setStatus(rowMsg(t.convertedToJson, result.length), false);
          window.trackTool && window.trackTool('csv_json', 'csv_to_json');
        } catch (e) {
          setStatus(t.errorPrefix + e.message, true);
        }
      });

      /* ── JSON → CSV button ── */
      document.getElementById('cj-to-csv').addEventListener('click', function () {
        var raw = jsonEl.value.trim();
        if (!raw) { clearStatus(); return; }

        try {
          var data = JSON.parse(raw);
          if (!Array.isArray(data)) throw new Error('JSON must be an array of objects.');
          if (data.length === 0) throw new Error('JSON array is empty.');
          if (typeof data[0] !== 'object' || data[0] === null || Array.isArray(data[0])) {
            throw new Error('Each item must be a plain object.');
          }

          var headers = Object.keys(data[0]);
          var lines = [];

          lines.push(headers.map(escapeCsvField).join(','));

          for (var i = 0; i < data.length; i++) {
            var row = [];
            for (var h = 0; h < headers.length; h++) {
              var val = data[i][headers[h]];
              row.push(escapeCsvField(val == null ? '' : String(val)));
            }
            lines.push(row.join(','));
          }

          csvEl.value = lines.join('\n');
          lastValidCsvOutput = csvEl.value;
          setStatus(rowMsg(t.convertedToCsv, data.length), false);
          window.trackTool && window.trackTool('csv_json', 'json_to_csv');
        } catch (e) {
          setStatus(t.errorPrefix + e.message, true);
        }
      });

      /* ── Clear ── */
      document.getElementById('cj-clear').addEventListener('click', function () {
        csvEl.value = '';
        jsonEl.value = '';
        clearStatus();
      });

      /* ── Copy buttons ── */
      copyCsvBtn.addEventListener('click', function () {
        if (!csvEl.value) return;
        navigator.clipboard.writeText(csvEl.value).then(function () {
          copyCsvBtn.textContent = t.copied;
          setTimeout(function () { copyCsvBtn.textContent = t.copy; }, 1500);
        });
      });

      copyJsonBtn.addEventListener('click', function () {
        if (!jsonEl.value) return;
        navigator.clipboard.writeText(jsonEl.value).then(function () {
          copyJsonBtn.textContent = t.copied;
          setTimeout(function () { copyJsonBtn.textContent = t.copy; }, 1500);
        });
      });
    })();
  </script>
</div>

<style>
  .cj-wrap { display: flex; flex-direction: column; gap: 0.75rem; }

  .cj-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  @media (max-width: 600px) {
    .cj-panels { grid-template-columns: 1fr; }
  }

  .cj-panel { display: flex; flex-direction: column; gap: 0.4rem; }

  .cj-panel label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cj-panel textarea {
    width: 100%;
    min-height: 200px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: vertical;
    background: var(--color-bg-secondary);
    color: var(--color-text);
    line-height: 1.5;
  }

  .cj-panel textarea:focus { outline: none; border-color: var(--color-primary); background: var(--color-bg); }

  .cj-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .cj-options {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .cj-checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    cursor: pointer;
    user-select: none;
  }

  .cj-checkbox-label input[type="checkbox"] {
    accent-color: var(--color-primary);
    width: 0.9rem;
    height: 0.9rem;
    cursor: pointer;
  }

  .cj-status { font-size: 0.85rem; min-height: 1.2rem; }
  .cj-status.success { color: #057a55; }
  .cj-status.error { color: #c0392b; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .cj-status.success { color: #34d399; }
    :root:not([data-theme="light"]) .cj-status.error { color: #f87171; }
  }
  [data-theme="dark"] .cj-status.success { color: #34d399; }
  [data-theme="dark"] .cj-status.error { color: #f87171; }
</style>
