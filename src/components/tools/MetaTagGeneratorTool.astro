---
// MetaTagGeneratorTool — composes a complete <head> meta tag block (basic SEO + Open Graph + Twitter Card + Schema.org JSON-LD)
// with live previews for Google SERP, Facebook, Twitter, and Discord. Pure DOM + string templating, no dependencies.
---
<div>
  <div class="mtg-wrap">
    <!-- LEFT: form -->
    <div class="mtg-form">
      <details class="mtg-group" open>
        <summary class="mtg-summary">
          <span class="mtg-summary-label" data-i18n="basicSection">Basic SEO</span>
          <span class="mtg-summary-chevron" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </span>
        </summary>
        <div class="mtg-fields">
          <div class="mtg-field mtg-field-full">
            <label for="mtg-title" class="tool-label">
              <span data-i18n="title">Title</span>
              <span class="mtg-counter" id="mtg-title-counter">0 / 60</span>
            </label>
            <input id="mtg-title" class="tool-input" type="text" data-i18n-ph="titlePh" placeholder="My Page Title" autocomplete="off" />
          </div>

          <div class="mtg-field mtg-field-full">
            <label for="mtg-description" class="tool-label">
              <span data-i18n="description">Description</span>
              <span class="mtg-counter" id="mtg-description-counter">0 / 160</span>
            </label>
            <textarea id="mtg-description" class="tool-textarea" rows="2" data-i18n-ph="descriptionPh" placeholder="Concise summary, ideally 120–160 chars."></textarea>
          </div>

          <div class="mtg-field mtg-field-full">
            <label for="mtg-canonical" class="tool-label" data-i18n="canonical">Canonical URL</label>
            <input id="mtg-canonical" class="tool-input" type="url" placeholder="https://example.com/page/" autocomplete="off" />
          </div>

          <div class="mtg-field">
            <label for="mtg-site-name" class="tool-label" data-i18n="siteName">Site Name</label>
            <input id="mtg-site-name" class="tool-input" type="text" placeholder="My Site" autocomplete="off" />
          </div>

          <div class="mtg-field">
            <label for="mtg-author" class="tool-label" data-i18n="author">Author</label>
            <input id="mtg-author" class="tool-input" type="text" placeholder="Jane Doe" autocomplete="off" />
          </div>

          <div class="mtg-field mtg-field-full">
            <label for="mtg-keywords" class="tool-label" data-i18n="keywords">Keywords (comma-separated)</label>
            <input id="mtg-keywords" class="tool-input" type="text" placeholder="seo, meta tags, open graph" autocomplete="off" />
          </div>

          <div class="mtg-field">
            <label for="mtg-language" class="tool-label" data-i18n="language">Language</label>
            <select id="mtg-language" class="mtg-select">
              <option value="en">en (English)</option>
              <option value="en-US">en-US</option>
              <option value="en-GB">en-GB</option>
              <option value="zh-CN">zh-CN</option>
              <option value="zh-TW">zh-TW</option>
              <option value="ja">ja</option>
              <option value="ko">ko</option>
              <option value="fr">fr</option>
              <option value="de">de</option>
              <option value="es">es</option>
            </select>
          </div>

          <div class="mtg-field">
            <label for="mtg-theme-color" class="tool-label" data-i18n="themeColor">Theme Color</label>
            <div class="mtg-color-row">
              <input id="mtg-theme-color" class="mtg-color-picker" type="color" value="#5b3d20" />
              <input id="mtg-theme-color-text" class="tool-input mtg-color-text" type="text" value="#5b3d20" autocomplete="off" spellcheck="false" />
            </div>
          </div>

          <div class="mtg-field">
            <label for="mtg-robots-index" class="tool-label" data-i18n="robotsIndex">Robots: Indexing</label>
            <select id="mtg-robots-index" class="mtg-select">
              <option value="index">index</option>
              <option value="noindex">noindex</option>
            </select>
          </div>

          <div class="mtg-field">
            <label for="mtg-robots-follow" class="tool-label" data-i18n="robotsFollow">Robots: Following</label>
            <select id="mtg-robots-follow" class="mtg-select">
              <option value="follow">follow</option>
              <option value="nofollow">nofollow</option>
            </select>
          </div>

          <div class="mtg-field mtg-field-full">
            <label class="mtg-checkbox-label">
              <input id="mtg-viewport" type="checkbox" checked />
              <span data-i18n="includeViewport">Include responsive viewport meta</span>
            </label>
          </div>
        </div>
      </details>

      <details class="mtg-group" open>
        <summary class="mtg-summary">
          <span class="mtg-summary-label" data-i18n="ogSection">Open Graph</span>
          <span class="mtg-summary-chevron" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </span>
        </summary>
        <div class="mtg-fields">
          <div class="mtg-field">
            <label for="mtg-og-type" class="tool-label" data-i18n="ogType">og:type</label>
            <select id="mtg-og-type" class="mtg-select">
              <option value="website">website</option>
              <option value="article">article</option>
              <option value="product">product</option>
              <option value="video.other">video.other</option>
              <option value="music.song">music.song</option>
              <option value="profile">profile</option>
              <option value="book">book</option>
            </select>
          </div>

          <div class="mtg-field">
            <label for="mtg-og-locale" class="tool-label" data-i18n="ogLocale">og:locale</label>
            <input id="mtg-og-locale" class="tool-input" type="text" placeholder="en_US" autocomplete="off" />
          </div>

          <div class="mtg-field mtg-field-full">
            <label for="mtg-og-image" class="tool-label" data-i18n="ogImage">og:image URL</label>
            <input id="mtg-og-image" class="tool-input" type="url" placeholder="https://example.com/cover.png" autocomplete="off" />
          </div>

          <div class="mtg-field">
            <label for="mtg-og-image-width" class="tool-label" data-i18n="ogImageWidth">Image Width</label>
            <input id="mtg-og-image-width" class="tool-input" type="number" min="1" placeholder="1200" autocomplete="off" />
          </div>

          <div class="mtg-field">
            <label for="mtg-og-image-height" class="tool-label" data-i18n="ogImageHeight">Image Height</label>
            <input id="mtg-og-image-height" class="tool-input" type="number" min="1" placeholder="630" autocomplete="off" />
          </div>

          <div class="mtg-field mtg-field-full">
            <label for="mtg-og-image-alt" class="tool-label" data-i18n="ogImageAlt">Image Alt</label>
            <input id="mtg-og-image-alt" class="tool-input" type="text" placeholder="Cover image alt text" autocomplete="off" />
          </div>
        </div>
      </details>

      <details class="mtg-group">
        <summary class="mtg-summary">
          <span class="mtg-summary-label" data-i18n="twitterSection">Twitter Card</span>
          <span class="mtg-summary-chevron" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </span>
        </summary>
        <div class="mtg-fields">
          <div class="mtg-field">
            <label for="mtg-tw-card" class="tool-label" data-i18n="twCard">Card Type</label>
            <select id="mtg-tw-card" class="mtg-select">
              <option value="summary_large_image">summary_large_image</option>
              <option value="summary">summary</option>
              <option value="app">app</option>
              <option value="player">player</option>
            </select>
          </div>

          <div class="mtg-field">
            <label for="mtg-tw-site" class="tool-label" data-i18n="twSite">Site (@user)</label>
            <input id="mtg-tw-site" class="tool-input" type="text" placeholder="@mysite" autocomplete="off" />
          </div>

          <div class="mtg-field">
            <label for="mtg-tw-creator" class="tool-label" data-i18n="twCreator">Creator (@user)</label>
            <input id="mtg-tw-creator" class="tool-input" type="text" placeholder="@author" autocomplete="off" />
          </div>

          <div class="mtg-field mtg-field-full">
            <label for="mtg-tw-image" class="tool-label" data-i18n="twImage">Twitter Image (defaults to og:image)</label>
            <input id="mtg-tw-image" class="tool-input" type="url" placeholder="https://example.com/twitter-card.png" autocomplete="off" />
          </div>
        </div>
      </details>

      <details class="mtg-group">
        <summary class="mtg-summary">
          <span class="mtg-summary-label" data-i18n="schemaSection">Schema.org JSON-LD</span>
          <span class="mtg-summary-chevron" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </span>
        </summary>
        <div class="mtg-fields">
          <div class="mtg-field mtg-field-full">
            <label for="mtg-schema-type" class="tool-label" data-i18n="schemaType">@type</label>
            <select id="mtg-schema-type" class="mtg-select">
              <option value="">— None —</option>
              <option value="WebPage">WebPage</option>
              <option value="Article">Article</option>
              <option value="Product">Product</option>
              <option value="Organization">Organization</option>
            </select>
            <p class="mtg-hint" data-i18n="schemaHint">Outputs a minimal JSON-LD with name / description / url / image fields.</p>
          </div>
        </div>
      </details>
    </div>

    <!-- RIGHT: preview -->
    <div class="mtg-preview-pane">
      <div class="mtg-preview-tabs" role="tablist" aria-label="Preview platform">
        <button class="mtg-preview-tab is-active" data-platform="google" role="tab" aria-selected="true" data-i18n="tabGoogle">Google</button>
        <button class="mtg-preview-tab" data-platform="facebook" role="tab" aria-selected="false" data-i18n="tabFacebook">Facebook</button>
        <button class="mtg-preview-tab" data-platform="twitter" role="tab" aria-selected="false" data-i18n="tabTwitter">Twitter</button>
        <button class="mtg-preview-tab" data-platform="discord" role="tab" aria-selected="false" data-i18n="tabDiscord">Discord</button>
      </div>
      <div id="mtg-preview" class="mtg-preview" role="tabpanel" aria-live="polite"></div>
    </div>
  </div>

  <div class="mtg-output-section">
    <div class="mtg-output-header">
      <span class="mtg-output-label" data-i18n="generatedHead">Generated &lt;head&gt; meta</span>
      <button id="mtg-copy" class="btn-copy" data-i18n="copy">Copy</button>
    </div>
    <pre id="mtg-output" class="mtg-output"></pre>
  </div>

  <script is:inline>
    (function () {
      var STRINGS = {
        en: {
          basicSection: 'Basic SEO',
          ogSection: 'Open Graph',
          twitterSection: 'Twitter Card',
          schemaSection: 'Schema.org JSON-LD',
          title: 'Title', description: 'Description', canonical: 'Canonical URL',
          siteName: 'Site Name', author: 'Author', keywords: 'Keywords (comma-separated)',
          language: 'Language', themeColor: 'Theme Color',
          robotsIndex: 'Robots: Indexing', robotsFollow: 'Robots: Following',
          includeViewport: 'Include responsive viewport meta',
          ogType: 'og:type', ogLocale: 'og:locale', ogImage: 'og:image URL',
          ogImageWidth: 'Image Width', ogImageHeight: 'Image Height', ogImageAlt: 'Image Alt',
          twCard: 'Card Type', twSite: 'Site (@user)', twCreator: 'Creator (@user)', twImage: 'Twitter Image (defaults to og:image)',
          schemaType: '@type', schemaHint: 'Outputs a minimal JSON-LD with name / description / url / image fields.',
          tabGoogle: 'Google', tabFacebook: 'Facebook', tabTwitter: 'Twitter', tabDiscord: 'Discord',
          generatedHead: 'Generated <head> meta', copy: 'Copy', copied: 'Copied!',
          titlePh: 'My Page Title', descriptionPh: 'Concise summary, ideally 120–160 chars.',
          fillToPreview: 'Fill in fields above to see the preview.',
        },
        zh: {
          basicSection: '基础 SEO', ogSection: 'Open Graph', twitterSection: 'Twitter 卡片', schemaSection: 'Schema.org JSON-LD',
          title: '标题', description: '描述', canonical: '规范 URL',
          siteName: '站点名称', author: '作者', keywords: '关键词（逗号分隔）',
          language: '语言', themeColor: '主题色',
          robotsIndex: '索引规则', robotsFollow: '跟踪规则',
          includeViewport: '包含响应式 viewport meta',
          ogType: 'og:type', ogLocale: 'og:locale', ogImage: 'og:image URL',
          ogImageWidth: '图片宽度', ogImageHeight: '图片高度', ogImageAlt: '图片 Alt',
          twCard: '卡片类型', twSite: '站点 (@user)', twCreator: '作者 (@user)', twImage: 'Twitter 图（默认沿用 og:image）',
          schemaType: '@type', schemaHint: '输出仅含 name / description / url / image 的最小 JSON-LD。',
          tabGoogle: 'Google', tabFacebook: 'Facebook', tabTwitter: 'Twitter', tabDiscord: 'Discord',
          generatedHead: '生成的 <head> meta', copy: '复制', copied: '已复制！',
          titlePh: '我的页面标题', descriptionPh: '简洁摘要，建议 120–160 字符。',
          fillToPreview: '填入上方字段查看预览。',
        },
        ja: {
          basicSection: '基本 SEO', ogSection: 'Open Graph', twitterSection: 'Twitter カード', schemaSection: 'Schema.org JSON-LD',
          title: 'タイトル', description: '説明文', canonical: '正規 URL',
          siteName: 'サイト名', author: '著者', keywords: 'キーワード（カンマ区切り）',
          language: '言語', themeColor: 'テーマカラー',
          robotsIndex: 'ロボット：インデックス', robotsFollow: 'ロボット：フォロー',
          includeViewport: 'レスポンシブ viewport メタを含める',
          ogType: 'og:type', ogLocale: 'og:locale', ogImage: 'og:image URL',
          ogImageWidth: '画像の幅', ogImageHeight: '画像の高さ', ogImageAlt: '画像 Alt',
          twCard: 'カード形式', twSite: 'サイト (@user)', twCreator: '作成者 (@user)', twImage: 'Twitter 画像（既定は og:image）',
          schemaType: '@type', schemaHint: 'name / description / url / image を含む最小 JSON-LD を出力します。',
          tabGoogle: 'Google', tabFacebook: 'Facebook', tabTwitter: 'Twitter', tabDiscord: 'Discord',
          generatedHead: '生成された <head> メタ', copy: 'コピー', copied: 'コピー済み！',
          titlePh: 'ページタイトル', descriptionPh: '簡潔な要約。120〜160 文字推奨。',
          fillToPreview: '上のフィールドに入力するとプレビューが表示されます。',
        },
        ko: {
          basicSection: '기본 SEO', ogSection: 'Open Graph', twitterSection: 'Twitter 카드', schemaSection: 'Schema.org JSON-LD',
          title: '제목', description: '설명', canonical: '대표 URL',
          siteName: '사이트 이름', author: '작성자', keywords: '키워드(쉼표 구분)',
          language: '언어', themeColor: '테마 색상',
          robotsIndex: '로봇: 색인', robotsFollow: '로봇: 추적',
          includeViewport: '반응형 viewport 메타 포함',
          ogType: 'og:type', ogLocale: 'og:locale', ogImage: 'og:image URL',
          ogImageWidth: '이미지 너비', ogImageHeight: '이미지 높이', ogImageAlt: '이미지 Alt',
          twCard: '카드 유형', twSite: '사이트 (@user)', twCreator: '작성자 (@user)', twImage: 'Twitter 이미지(기본값 og:image)',
          schemaType: '@type', schemaHint: 'name / description / url / image 만 포함한 최소 JSON-LD를 출력합니다.',
          tabGoogle: 'Google', tabFacebook: 'Facebook', tabTwitter: 'Twitter', tabDiscord: 'Discord',
          generatedHead: '생성된 <head> 메타', copy: '복사', copied: '복사됨!',
          titlePh: '페이지 제목', descriptionPh: '간결한 요약. 120–160자 권장.',
          fillToPreview: '위 입력란을 채우면 미리보기가 표시됩니다.',
        },
      };

      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;
      document.querySelectorAll('[data-i18n]').forEach(function (el) {
        var k = el.getAttribute('data-i18n');
        if (t[k]) el.textContent = t[k];
      });
      document.querySelectorAll('[data-i18n-ph]').forEach(function (el) {
        var k = el.getAttribute('data-i18n-ph');
        if (t[k]) el.placeholder = t[k];
      });

      // Special-case: the "Generated <head> meta" label uses literal angle brackets
      // and survives the textContent replacement, but innerHTML rewrites would
      // double-encode. textContent is the safe path.
      var headLabel = document.querySelector('[data-i18n="generatedHead"]');
      if (headLabel) headLabel.textContent = t.generatedHead;

      var fields = {
        title: document.getElementById('mtg-title'),
        description: document.getElementById('mtg-description'),
        canonical: document.getElementById('mtg-canonical'),
        siteName: document.getElementById('mtg-site-name'),
        author: document.getElementById('mtg-author'),
        keywords: document.getElementById('mtg-keywords'),
        language: document.getElementById('mtg-language'),
        themeColor: document.getElementById('mtg-theme-color'),
        themeColorText: document.getElementById('mtg-theme-color-text'),
        robotsIndex: document.getElementById('mtg-robots-index'),
        robotsFollow: document.getElementById('mtg-robots-follow'),
        viewport: document.getElementById('mtg-viewport'),
        ogType: document.getElementById('mtg-og-type'),
        ogLocale: document.getElementById('mtg-og-locale'),
        ogImage: document.getElementById('mtg-og-image'),
        ogImageWidth: document.getElementById('mtg-og-image-width'),
        ogImageHeight: document.getElementById('mtg-og-image-height'),
        ogImageAlt: document.getElementById('mtg-og-image-alt'),
        twCard: document.getElementById('mtg-tw-card'),
        twSite: document.getElementById('mtg-tw-site'),
        twCreator: document.getElementById('mtg-tw-creator'),
        twImage: document.getElementById('mtg-tw-image'),
        schemaType: document.getElementById('mtg-schema-type'),
      };

      var titleCounter = document.getElementById('mtg-title-counter');
      var descCounter = document.getElementById('mtg-description-counter');
      var outputEl = document.getElementById('mtg-output');
      var previewEl = document.getElementById('mtg-preview');
      var copyBtn = document.getElementById('mtg-copy');
      var tabs = document.querySelectorAll('.mtg-preview-tab');
      var currentPlatform = 'google';

      function escapeAttr(s) {
        return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }
      function escapeHtml(s) {
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }
      function getValues() {
        return {
          title: fields.title.value.trim(),
          description: fields.description.value.trim(),
          canonical: fields.canonical.value.trim(),
          siteName: fields.siteName.value.trim(),
          author: fields.author.value.trim(),
          keywords: fields.keywords.value.trim(),
          language: fields.language.value,
          themeColor: fields.themeColorText.value.trim(),
          robotsIndex: fields.robotsIndex.value,
          robotsFollow: fields.robotsFollow.value,
          viewport: fields.viewport.checked,
          ogType: fields.ogType.value,
          ogLocale: fields.ogLocale.value.trim(),
          ogImage: fields.ogImage.value.trim(),
          ogImageWidth: fields.ogImageWidth.value.trim(),
          ogImageHeight: fields.ogImageHeight.value.trim(),
          ogImageAlt: fields.ogImageAlt.value.trim(),
          twCard: fields.twCard.value,
          twSite: fields.twSite.value.trim(),
          twCreator: fields.twCreator.value.trim(),
          twImage: fields.twImage.value.trim(),
          schemaType: fields.schemaType.value,
        };
      }

      function getDomain(url) {
        if (!url) return '';
        try {
          var u = new URL(url);
          return u.host;
        } catch (e) {
          return url.replace(/^https?:\/\//, '').split('/')[0];
        }
      }

      function getBreadcrumb(url) {
        if (!url) return '';
        try {
          var u = new URL(url);
          var path = u.pathname.replace(/^\/|\/$/g, '');
          if (!path) return u.host;
          return u.host + ' › ' + path.split('/').join(' › ');
        } catch (e) {
          return url;
        }
      }

      function buildHead(v) {
        var lines = [];
        if (v.viewport) lines.push('<meta name="viewport" content="width=device-width, initial-scale=1">');
        if (v.title) lines.push('<title>' + escapeHtml(v.title) + '</title>');
        if (v.description) lines.push('<meta name="description" content="' + escapeAttr(v.description) + '">');
        if (v.canonical) lines.push('<link rel="canonical" href="' + escapeAttr(v.canonical) + '">');
        if (v.author) lines.push('<meta name="author" content="' + escapeAttr(v.author) + '">');
        if (v.keywords) lines.push('<meta name="keywords" content="' + escapeAttr(v.keywords) + '">');
        if (v.themeColor) lines.push('<meta name="theme-color" content="' + escapeAttr(v.themeColor) + '">');
        lines.push('<meta name="robots" content="' + v.robotsIndex + ', ' + v.robotsFollow + '">');

        // Open Graph
        var hasOg = v.title || v.description || v.canonical || v.siteName || v.ogImage;
        if (hasOg) {
          lines.push('');
          lines.push('<!-- Open Graph / Facebook -->');
          lines.push('<meta property="og:type" content="' + v.ogType + '">');
          if (v.title) lines.push('<meta property="og:title" content="' + escapeAttr(v.title) + '">');
          if (v.description) lines.push('<meta property="og:description" content="' + escapeAttr(v.description) + '">');
          if (v.canonical) lines.push('<meta property="og:url" content="' + escapeAttr(v.canonical) + '">');
          if (v.siteName) lines.push('<meta property="og:site_name" content="' + escapeAttr(v.siteName) + '">');
          if (v.ogImage) lines.push('<meta property="og:image" content="' + escapeAttr(v.ogImage) + '">');
          if (v.ogImage && v.ogImageWidth) lines.push('<meta property="og:image:width" content="' + escapeAttr(v.ogImageWidth) + '">');
          if (v.ogImage && v.ogImageHeight) lines.push('<meta property="og:image:height" content="' + escapeAttr(v.ogImageHeight) + '">');
          if (v.ogImage && v.ogImageAlt) lines.push('<meta property="og:image:alt" content="' + escapeAttr(v.ogImageAlt) + '">');
          if (v.ogLocale) lines.push('<meta property="og:locale" content="' + escapeAttr(v.ogLocale) + '">');
        }

        // Twitter
        var hasTw = v.title || v.description || v.ogImage || v.twImage || v.twSite || v.twCreator;
        if (hasTw) {
          lines.push('');
          lines.push('<!-- Twitter Card -->');
          lines.push('<meta name="twitter:card" content="' + v.twCard + '">');
          if (v.twSite) lines.push('<meta name="twitter:site" content="' + escapeAttr(v.twSite) + '">');
          if (v.twCreator) lines.push('<meta name="twitter:creator" content="' + escapeAttr(v.twCreator) + '">');
