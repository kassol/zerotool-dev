---
// OpenapiValidatorTool — pure client-side OpenAPI 3.x validator
---
<div>
  <div class="ov-wrap">
    <div class="ov-field">
      <label for="ov-input" data-i18n="inputLabel">OpenAPI Spec (YAML or JSON)</label>
      <textarea
        id="ov-input"
        rows="16"
        spellcheck="false"
        autocomplete="off"
        placeholder="openapi: &quot;3.0.3&quot;
info:
  title: My API
  version: &quot;1.0.0&quot;
paths:
  /users:
    get:
      summary: List users
      responses:
        &quot;200&quot;:
          description: OK"
      ></textarea>
    </div>

    <div class="ov-actions">
      <button id="ov-validate" type="button" data-i18n="validate">Validate</button>
      <button id="ov-clear" type="button" data-i18n="clear">Clear</button>
    </div>

    <div id="ov-result" class="ov-result" aria-live="polite"></div>
  </div>

  <script is:inline>
    /* Apply i18n synchronously to prevent FOUC */
    (function () {
      var STRINGS = {
        en: { inputLabel: 'OpenAPI Spec (YAML or JSON)', clear: 'Clear', validate: 'Validate' },
        zh: { inputLabel: 'OpenAPI 规范（YAML 或 JSON）', clear: '清空', validate: '验证' },
        ja: { inputLabel: 'OpenAPI 仕様（YAML または JSON）', clear: 'クリア', validate: '検証' },
        ko: { inputLabel: 'OpenAPI 스펙 (YAML 또는 JSON)', clear: '지우기', validate: '검증' }
      };
      var pageLang = (document.documentElement.lang || 'en').slice(0, 2);
      var t = STRINGS[pageLang] || STRINGS.en;
      document.querySelectorAll('.ov-wrap [data-i18n]').forEach(function (el) {
        var key = el.getAttribute('data-i18n');
        if (t[key]) el.textContent = t[key];
      });
    })();
  </script>

  <script>
    import jsyaml from 'js-yaml';

    const STRINGS = {
      en: {
        msgEmpty: 'Paste an OpenAPI spec above and click Validate.',
        msgValid: 'Valid OpenAPI spec',
        msgInvalid: 'Invalid OpenAPI spec',
        specTitle: 'API Title',
        specVersion: 'Version',
        specOas: 'OpenAPI Version',
        specPaths: 'Paths',
        specOps: 'Operations',
        specServers: 'Servers',
        errorsFound: 'error(s) found',
        errPath: 'Path',
        errMessage: 'Message'
      },
      zh: {
        msgEmpty: '请在上方粘贴 OpenAPI 规范，然后点击验证。',
        msgValid: 'OpenAPI 规范有效',
        msgInvalid: 'OpenAPI 规范无效',
        specTitle: 'API 名称',
        specVersion: '版本',
        specOas: 'OpenAPI 版本',
        specPaths: '路径数',
        specOps: '接口数',
        specServers: '服务器',
        errorsFound: '个错误',
        errPath: '路径',
        errMessage: '信息'
      },
      ja: {
        msgEmpty: '上にOpenAPI仕様を貼り付けて検証をクリックしてください。',
        msgValid: '有効なOpenAPI仕様',
        msgInvalid: '無効なOpenAPI仕様',
        specTitle: 'API タイトル',
        specVersion: 'バージョン',
        specOas: 'OpenAPI バージョン',
        specPaths: 'パス数',
        specOps: 'オペレーション数',
        specServers: 'サーバー',
        errorsFound: '件のエラー',
        errPath: 'パス',
        errMessage: 'メッセージ'
      },
      ko: {
        msgEmpty: '위에 OpenAPI 스펙을 붙여넣고 검증을 클릭하세요.',
        msgValid: '유효한 OpenAPI 스펙',
        msgInvalid: '유효하지 않은 OpenAPI 스펙',
        specTitle: 'API 제목',
        specVersion: '버전',
        specOas: 'OpenAPI 버전',
        specPaths: '경로',
        specOps: '오퍼레이션',
        specServers: '서버',
        errorsFound: '개 오류 발견',
        errPath: '경로',
        errMessage: '메시지'
      }
    };

    const pageLang = (document.documentElement.lang || 'en').slice(0, 2);
    const t = (STRINGS as any)[pageLang] || STRINGS.en;

    const inputEl    = document.getElementById('ov-input') as HTMLTextAreaElement;
    const resultEl   = document.getElementById('ov-result')!;
    const validateBtn = document.getElementById('ov-validate')!;
    const clearBtn   = document.getElementById('ov-clear')!;

    const HTTP_METHODS = ['get', 'put', 'post', 'delete', 'options', 'head', 'patch', 'trace'];

    function escHtml(s: string): string {
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function validateSpec(doc: any): { path: string; message: string }[] {
      const errors: { path: string; message: string }[] = [];

      if (!doc.openapi && !doc.swagger) {
        errors.push({ path: 'openapi', message: 'Missing required field "openapi".' });
      } else if (doc.swagger) {
        errors.push({ path: 'swagger', message: 'Swagger 2.x detected. Migrate to OpenAPI 3.x: replace "swagger: \\"2.0\\"" with "openapi: \\"3.0.3\\"" and update "definitions" to "components/schemas".' });
        return errors;
      } else if (!/^3\.\d+\.\d+$/.test(String(doc.openapi))) {
        errors.push({ path: 'openapi', message: 'Field "openapi" must be a 3.x.y version string (e.g. "3.0.3" or "3.1.0"). Got: ' + doc.openapi });
      }

      if (!doc.info || typeof doc.info !== 'object') {
        errors.push({ path: 'info', message: 'Missing required object "info".' });
      } else {
        if (!doc.info.title) errors.push({ path: 'info.title', message: 'Missing required field "info.title".' });
        if (!doc.info.version) errors.push({ path: 'info.version', message: 'Missing required field "info.version".' });
      }

      if (!doc.paths || typeof doc.paths !== 'object') {
        errors.push({ path: 'paths', message: 'Missing required object "paths".' });
      } else {
        Object.keys(doc.paths).forEach(function (p) {
          if (!p.startsWith('/')) {
            errors.push({ path: 'paths.' + p, message: 'Path key "' + p + '" must start with "/".' });
          }
          const pathItem = doc.paths[p];
          if (pathItem && typeof pathItem === 'object') {
            HTTP_METHODS.forEach(function (method) {
              const op = pathItem[method];
              if (op && typeof op === 'object') {
                if (!op.responses || typeof op.responses !== 'object' || Object.keys(op.responses).length === 0) {
                  errors.push({ path: 'paths.' + p + '.' + method + '.responses', message: 'Operation "' + method.toUpperCase() + ' ' + p + '" must have a non-empty "responses" object.' });
                }
              }
            });
          }
        });
      }

      return errors;
    }

    function countOps(paths: any): number {
      let count = 0;
      if (!paths || typeof paths !== 'object') return 0;
      Object.values(paths).forEach(function (pathItem: any) {
        if (pathItem && typeof pathItem === 'object') {
          HTTP_METHODS.forEach(function (m) { if (pathItem[m]) count++; });
        }
      });
      return count;
    }

    function renderValid(doc: any): void {
      const title = (doc.info && doc.info.title) || '—';
      const version = (doc.info && doc.info.version) || '—';
      const oasVersion = doc.openapi || '—';
      const pathCount = doc.paths ? Object.keys(doc.paths).length : 0;
      const opCount = countOps(doc.paths);
      const servers = doc.servers;

      let html = '<div class="ov-valid-header">';
      html += '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>';
      html += '<span>' + escHtml(t.msgValid) + '</span>';
      html += '</div>';

      html += '<div class="ov-info-grid">';
      html += '<div class="ov-info-row"><span class="ov-info-key">' + escHtml(t.specTitle) + '</span><span class="ov-info-val">' + escHtml(title) + '</span></div>';
      html += '<div class="ov-info-row"><span class="ov-info-key">' + escHtml(t.specVersion) + '</span><span class="ov-info-val">' + escHtml(String(version)) + '</span></div>';
      html += '<div class="ov-info-row"><span class="ov-info-key">' + escHtml(t.specOas) + '</span><span class="ov-info-val">' + escHtml(String(oasVersion)) + '</span></div>';
      html += '<div class="ov-info-row"><span class="ov-info-key">' + escHtml(t.specPaths) + '</span><span class="ov-info-val">' + pathCount + '</span></div>';
      html += '<div class="ov-info-row"><span class="ov-info-key">' + escHtml(t.specOps) + '</span><span class="ov-info-val">' + opCount + '</span></div>';

      if (servers && Array.isArray(servers) && servers.length > 0) {
        const serverUrls = servers.map((s: any) => s.url || '').filter(Boolean).join(', ');
        if (serverUrls) {
          html += '<div class="ov-info-row"><span class="ov-info-key">' + escHtml(t.specServers) + '</span><span class="ov-info-val">' + escHtml(serverUrls) + '</span></div>';
        }
      }

      html += '</div>';
      resultEl.innerHTML = html;
      resultEl.className = 'ov-result ov-result--valid';
    }

    function renderErrors(errors: { path: string; message: string }[]): void {
      let html = '<div class="ov-invalid-header">';
      html += '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';
      html += '<span>' + escHtml(t.msgInvalid) + ' — ' + errors.length + ' ' + escHtml(t.errorsFound) + '</span>';
      html += '</div>';

      html += '<table class="ov-err-table">';
      html += '<thead><tr><th>' + escHtml(t.errPath) + '</th><th>' + escHtml(t.errMessage) + '</th></tr></thead>';
      html += '<tbody>';
      errors.forEach(function (e) {
        html += '<tr>';
        html += '<td><code class="ov-err-path">' + escHtml(e.path) + '</code></td>';
        html += '<td>' + escHtml(e.message) + '</td>';
        html += '</tr>';
      });
      html += '</tbody></table>';

      resultEl.innerHTML = html;
      resultEl.className = 'ov-result ov-result--invalid';
    }

    function renderEmpty(): void {
      resultEl.innerHTML = '<p class="ov-empty">' + escHtml(t.msgEmpty) + '</p>';
      resultEl.className = 'ov-result';
    }

    function doValidate(): void {
      const raw = inputEl.value.trim();
      if (!raw) {
        renderEmpty();
        return;
      }

      let doc: any;
      try {
        doc = jsyaml.load(raw);
      } catch (e: any) {
        renderErrors([{ path: '(parse)', message: 'Parse error: ' + e.message }]);
        (window as any).trackTool?.('openapi-validator', 'validate_error');
        return;
      }

      if (!doc || typeof doc !== 'object') {
        renderErrors([{ path: '(root)', message: 'Document must be a YAML/JSON object.' }]);
        (window as any).trackTool?.('openapi-validator', 'validate_error');
        return;
      }

      const errors = validateSpec(doc);
      if (errors.length === 0) {
        renderValid(doc);
        (window as any).trackTool?.('openapi-validator', 'validate_success');
      } else {
        renderErrors(errors);
        (window as any).trackTool?.('openapi-validator', 'validate_error');
      }
    }

    /* Prevent textarea blur before click fires (eliminates first-click race) */
    validateBtn.addEventListener('mousedown', (e) => e.preventDefault());
    validateBtn.addEventListener('click', doValidate);

    clearBtn.addEventListener('mousedown', (e) => e.preventDefault());
    clearBtn.addEventListener('click', () => {
      inputEl.value = '';
      renderEmpty();
    });

    inputEl.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
        e.preventDefault();
        doValidate();
      }
    });

    renderEmpty();
  </script>
</div>

<style>
  .ov-wrap { display: flex; flex-direction: column; gap: 1rem; }

  .ov-field { display: flex; flex-direction: column; gap: 0.3rem; }

  .ov-field label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ov-field textarea {
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.87rem;
    line-height: 1.55;
    background: var(--color-bg-secondary);
    color: var(--color-text);
    width: 100%;
    resize: vertical;
    min-height: 240px;
  }

  .ov-field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background: var(--color-bg);
  }

  .ov-actions {
    display: flex;
    gap: 0.5rem;
  }

  .ov-actions button {
    padding: 0.45rem 1.1rem;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  #ov-validate {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  #ov-validate:hover { opacity: 0.88; }

  #ov-clear {
    background: var(--color-bg);
    color: var(--color-text-secondary);
  }

  #ov-clear:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .ov-result { min-height: 2rem; }

  .ov-empty {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .ov-err-msg { color: var(--color-danger, #dc2626); }

  /* Valid panel */
  .ov-result--valid {
    border: 1px solid #22c55e;
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    background: var(--color-bg-secondary);
  }

  .ov-valid-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: #16a34a;
    margin-bottom: 0.75rem;
    font-size: 0.95rem;
  }

  .ov-info-grid { display: flex; flex-direction: column; gap: 0.35rem; }

  .ov-info-row {
    display: flex;
    gap: 0.75rem;
    font-size: 0.9rem;
    flex-wrap: wrap;
  }

  .ov-info-key {
    color: var(--color-text-secondary);
    font-weight: 600;
    min-width: 9rem;
    flex-shrink: 0;
  }

  .ov-info-val {
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.87rem;
    word-break: break-all;
  }

  /* Invalid panel */
  .ov-result--invalid {
    border: 1px solid #ef4444;
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    background: var(--color-bg-secondary);
  }

  .ov-invalid-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: #dc2626;
    margin-bottom: 0.75rem;
    font-size: 0.95rem;
  }

  .ov-err-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.87rem;
  }

  .ov-err-table th {
    text-align: left;
    padding: 0.3rem 0.5rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid var(--color-border);
  }

  .ov-err-table td {
    padding: 0.4rem 0.5rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
    color: var(--color-text);
  }

  .ov-err-table tr:last-child td { border-bottom: none; }

  .ov-err-path {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: #dc2626;
    background: var(--color-bg-icon);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    white-space: nowrap;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .ov-result--valid { border-color: #16a34a; }
    :root:not([data-theme="light"]) .ov-result--invalid { border-color: #b91c1c; }
    :root:not([data-theme="light"]) .ov-err-path { color: #f87171; }
    :root:not([data-theme="light"]) .ov-invalid-header { color: #f87171; }
  }

  [data-theme="dark"] .ov-result--valid { border-color: #16a34a; }
  [data-theme="dark"] .ov-result--invalid { border-color: #b91c1c; }
  [data-theme="dark"] .ov-err-path { color: #f87171; }
  [data-theme="dark"] .ov-invalid-header { color: #f87171; }
</style>
