---
// AdUnit.astro — wraps AdSense <ins> tags
// Set ADSENSE_PUBLISHER_ID in env or astro.config.mjs publicEnv
// Usage: <AdUnit slot="1234567890" format="auto" />

interface Props {
  slot: string;
  format?: 'auto' | 'rectangle' | 'horizontal' | 'vertical';
  responsive?: boolean;
  class?: string;
}

const {
  slot,
  format = 'auto',
  responsive = true,
  class: className = '',
} = Astro.props;

// Publisher ID from env — never hard-code
const publisherId = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID ?? '';
---

{publisherId && (
  <div class={`ad-unit ${className}`}>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={publisherId}
      data-ad-slot={slot}
      data-ad-format={format}
      data-full-width-responsive={responsive ? 'true' : 'false'}
    ></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
)}

<style>
  .ad-unit {
    margin: 1.5rem 0;
    text-align: center;
  }
</style>
