---
import { t } from '../i18n/utils';

interface Props {
  lang: 'en' | 'zh' | 'ja' | 'ko';
}
const { lang } = Astro.props;

const categories = ['all', 'data', 'color', 'encoding', 'text', 'security', 'dev', 'api'] as const;
const labels = Object.fromEntries(
  categories.map(c => [c, t(lang, `category.${c}`)])
);
const recentLabel = t(lang, 'category.recent');
---

<div class="category-filter" role="group" aria-label={t(lang, 'category.filterLabel')}>
  <!-- Recently Used chip: hidden until localStorage has entries (JS unhides it) -->
  <button
    id="chip-recent"
    class="chip chip--recent"
    data-cat="recent"
    type="button"
    aria-pressed="false"
    hidden
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align:-1px"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    {recentLabel}
  </button>
  {categories.map(cat => (
    <button
      class={`chip${cat === 'all' ? ' chip--active' : ''}`}
      data-cat={cat}
      type="button"
      aria-pressed={cat === 'all' ? 'true' : 'false'}
    >
      {labels[cat]}
    </button>
  ))}
</div>

<script is:inline>
  (function () {
    // Shared filter state — written by both CategoryFilter and ToolSearchBar
    window.__ztSearch = window.__ztSearch || '';
    window.__ztCat = window.__ztCat || 'all';

    // Read recently-used list from localStorage
    function getRecent() {
      try {
        return JSON.parse(localStorage.getItem('zt-recent') || '[]');
      } catch (e) {
        return [];
      }
    }

    // Cache original card order on first call so we can restore it later
    var _ztOriginalOrder = null;
    function ensureOriginalOrder() {
      if (_ztOriginalOrder) return;
      var cards = document.querySelectorAll('.tool-card');
      _ztOriginalOrder = Array.prototype.slice.call(cards);
    }

    // Shared apply function — called by both components
    window.__ztApply = function () {
      var q = window.__ztSearch || '';
      var cat = window.__ztCat || 'all';
      var recent = cat === 'recent' ? getRecent() : null;

      ensureOriginalOrder();
      var grid = _ztOriginalOrder && _ztOriginalOrder.length > 0 ? _ztOriginalOrder[0].parentNode : null;

      if (grid) {
        if (cat === 'recent' && !q) {
          // Reorder cards by recency (most recent first)
          var sorted = _ztOriginalOrder.slice().sort(function(a, b) {
            var aIdx = recent.indexOf(a.getAttribute('data-slug') || '');
            var bIdx = recent.indexOf(b.getAttribute('data-slug') || '');
            if (aIdx === -1) aIdx = 9999;
            if (bIdx === -1) bIdx = 9999;
            return aIdx - bIdx;
          });
          sorted.forEach(function(card) { grid.appendChild(card); });
        } else {
          // Restore original DOM order
          _ztOriginalOrder.forEach(function(card) { grid.appendChild(card); });
        }
      }

      var cards = document.querySelectorAll('.tool-card');
      var visible = 0;
      for (var i = 0; i < cards.length; i++) {
        var kw = cards[i].getAttribute('data-keywords') || '';
        var cardCat = cards[i].getAttribute('data-category') || '';
        var cardSlug = cards[i].getAttribute('data-slug') || '';
        var matchSearch = !q || kw.indexOf(q) !== -1;
        var matchCat;
        if (cat === 'recent') {
          matchCat = recent.indexOf(cardSlug) !== -1;
        } else {
          matchCat = cat === 'all' || cardCat === cat;
        }
        if (matchSearch && matchCat) {
          cards[i].style.display = '';
          visible++;
        } else {
          cards[i].style.display = 'none';
        }
      }
      var noResults = document.getElementById('no-results');
      if (noResults) noResults.hidden = visible > 0;
    };

    // Show Recently Used chip if localStorage has entries
    var recentChip = document.getElementById('chip-recent');
    if (recentChip) {
      var recentList = getRecent();
      if (recentList.length > 0) {
        recentChip.hidden = false;
      }
    }

    // Category chip click handler
    var filter = document.querySelector('.category-filter');
    if (!filter) return;
    filter.addEventListener('click', function (e) {
      var btn = e.target.closest('button[data-cat]');
      if (!btn) return;
      var cat = btn.getAttribute('data-cat');
      if (!cat) return;
      window.__ztCat = cat;
      // Update active chip and aria-pressed
      var chips = filter.querySelectorAll('.chip');
      for (var i = 0; i < chips.length; i++) {
        var isActive = chips[i].getAttribute('data-cat') === cat;
        chips[i].classList.toggle('chip--active', isActive);
        chips[i].setAttribute('aria-pressed', isActive ? 'true' : 'false');
      }
      window.__ztApply();
    });
  })();
</script>

<style>
  .category-filter {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
    margin-bottom: 1.25rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .category-filter::-webkit-scrollbar {
    display: none;
  }

  .chip {
    flex-shrink: 0;
    padding: 0.35rem 0.85rem;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: border-color var(--transition-fast), background var(--transition-fast), color var(--transition-fast);
    white-space: nowrap;
  }

  .chip:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .chip--active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  .chip--active:hover {
    color: #fff;
  }
</style>
